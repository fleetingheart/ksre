# game/mods/pxt/pxt.rpy:18
translate ru pxt_real_start_095ce138:

    # phi "A play there is, my lord, some ten words long, which is as brief as I have known a play;" id pxt_real_start_095ce138
    phi "Вся эта пьеса – в десять слов длиной."
    phi "Короче пьесы нет, насколько помню."

# game/mods/pxt/pxt.rpy:19
translate ru pxt_real_start_e04c546b:

    # phi "But by ten words, my lord, it is too long, which makes it tedious:" id pxt_real_start_e04c546b
    phi "Но лишние все эти десять слов"
    phi "Вот чем она длинна. Ни слова в ней..."

# game/mods/pxt/pxt.rpy:20
translate ru pxt_real_start_008ebd5b:

    # phi "For in all the play there is not one word apt, one player fitted:" id pxt_real_start_008ebd5b
    phi "...нет путного, ни путного актера."

# game/mods/pxt/pxt.rpy:21
translate ru pxt_real_start_d6023aa0:

    # phi "And tragical, my noble lord, it is;" id pxt_real_start_d6023aa0
    phi "Трагедия она лишь потому,"

# game/mods/pxt/pxt.rpy:22
translate ru pxt_real_start_ade4d3ad:

    # phi "For Pyramus therein doth kill himself: which when I saw rehears'd, I must confess, made mine eyes water;" id pxt_real_start_ade4d3ad
    phi "Что в ней герой Пирам с собой кончает."
    phi "На репетиции до слез дошел я..."

# game/mods/pxt/pxt.rpy:23
translate ru pxt_real_start_63f5f2a0:

    # phi "But more merry tears the passion of loud laughter never shed." id pxt_real_start_63f5f2a0
    phi "...но признаюсь, что никогда еще так весело не плакал я от смеха."

# game/mods/pxt/pxt.rpy:25
translate ru pxt_real_start_309f0434:

    # the "What are they that do play it?" id pxt_real_start_309f0434
    the "А кто актеры?"

# game/mods/pxt/pxt.rpy:27
translate ru pxt_real_start_23a12c75:

    # phi "Hard-handed men that work in Athens here, which never labour'd in their minds till now;" id pxt_real_start_23a12c75
    phi "Все простые люди, ремесленники из Афин. Привыкли не головой работать, а руками..."

# game/mods/pxt/pxt.rpy:28
translate ru pxt_real_start_d95f84ac:

    # phi "And now have toil'd their unbreath'd memories with this same play against your nuptial." id pxt_real_start_d95f84ac
    phi "И вдруг свою неразвитую память обременили пьесой в вашу честь."

# game/mods/pxt/pxt.rpy:30
translate ru pxt_real_start_ab46f115:

    # the "And we will hear it." id pxt_real_start_ab46f115
    the "И мы ее посмотрим."

# game/mods/pxt/pxt.rpy:32
translate ru pxt_real_start_40b6ad56:

    # phi "No, my noble lord, it is not for you:" id pxt_real_start_40b6ad56
    phi "Нет, мой герцог, нет, это не для вас."

# game/mods/pxt/pxt.rpy:33
translate ru pxt_real_start_3b38d021:

    # phi "I have heard it over, and it is nothing, nothing in the world;" id pxt_real_start_3b38d021
    phi "Я слушал пьесу: В ней ничего нет, ровно ничего!"

# game/mods/pxt/pxt.rpy:34
translate ru pxt_real_start_eaae6af0:

    # phi "Unless you can find sport in their intents, extremely stretch'd and conn'd with cruel pain, to do you service." id pxt_real_start_eaae6af0
    phi "Но, может быть, вас все же позабавят их тяжкие усилья вас развлечь."

# game/mods/pxt/pxt.rpy:36
translate ru pxt_real_start_0bbb43ef:

    # the "I will hear that play; For never anything can be amiss when simpleness and duty tender it." id pxt_real_start_0bbb43ef
    the "Да, эту пьесу будем мы смотреть! Не может никогда быть слишком плохо, что преданность смиренно предлагает."

# game/mods/pxt/pxt.rpy:37
translate ru pxt_real_start_c0915367:

    # the "Go, bring them in: and take your places, ladies. " id pxt_real_start_c0915367
    the "Зови их! Дам прошу занять места."

# game/mods/pxt/pxt.rpy:44
translate ru pxt_real_start_bb37de17:

    # hip "I love not to see wretchedness o'er-charged, and duty in his service perishing." id pxt_real_start_bb37de17
    hip "Я не люблю над нищетой смеяться и видеть, как усердье гибнет даром."

# game/mods/pxt/pxt.rpy:46
translate ru pxt_real_start_f5054b95:

    # the "Why, gentle sweet, you shall see no such thing." id pxt_real_start_f5054b95
    the "Нет, милая, здесь этого не будет."

# game/mods/pxt/pxt.rpy:48
translate ru pxt_real_start_f29713a7:

    # hip "He says they can do nothing in this kind." id pxt_real_start_f29713a7
    hip "Сказал он: ничего они не стоят."

# game/mods/pxt/pxt.rpy:50
translate ru pxt_real_start_4fbc1934:

    # the "The kinder we, to give them thanks for nothing." id pxt_real_start_4fbc1934
    the "Тем будем мы добрей, благодаря их за ничто."

# game/mods/pxt/pxt.rpy:51
translate ru pxt_real_start_2970bcd2:

    # the "Our sport shall be to take what they mistake:" id pxt_real_start_2970bcd2
    the "Мы примем добродушно ошибки их."

# game/mods/pxt/pxt.rpy:52
translate ru pxt_real_start_1f60207a:

    # the "And what poor duty cannot do, noble respect takes it in might, not merit." id pxt_real_start_1f60207a
    the "Где преданность бессильна, она усердьем искупает все."

# game/mods/pxt/pxt.rpy:53
translate ru pxt_real_start_ddec796a:

    # the "Where I have come, great clerks have purposed to greet me with premeditated welcomes;" id pxt_real_start_ddec796a
    the "Меня в моих поездках иногда ученые встречать хотели речью..."

# game/mods/pxt/pxt.rpy:54
translate ru pxt_real_start_6ea2f945:

    # the "Where I have seen them shiver and look pale, make periods in the midst of sentences," id pxt_real_start_6ea2f945
    the "...заране приготовленной, и вдруг — теряли нить:"

# game/mods/pxt/pxt.rpy:55
translate ru pxt_real_start_e16aaeec:

    # the "Throttle their practis'd accent in their fears, " id pxt_real_start_e16aaeec
    the "Бледнели, забывали готовые слова"

# game/mods/pxt/pxt.rpy:56
translate ru pxt_real_start_203e1077:

    # the "And, in conclusion, dumbly have broke off, not paying me a welcome." id pxt_real_start_203e1077
    the "И в заключенье, не кончив, обрывали речь свою."

# game/mods/pxt/pxt.rpy:57
translate ru pxt_real_start_03773a61:

    # the "Trust me, sweet, out of this silence yet I pick'd a welcome;" id pxt_real_start_03773a61
    the "И, веришь ли, любимая моя, в молчанье их я находил привет"

# game/mods/pxt/pxt.rpy:58
translate ru pxt_real_start_17bdea96:

    # the "And in the modesty of fearful duty I read as much as from the rattling tongue of saucy and audacious eloquence." id pxt_real_start_17bdea96
    the "И в скромности смущенного почтенья читал я большее, чем в болтовне напыщенных и смелых краснобаев."

# game/mods/pxt/pxt.rpy:59
translate ru pxt_real_start_c532570e:

    # the "Love, therefore, and tongue-tied simplicity in least speak most to my capacity." id pxt_real_start_c532570e
    the "Мне кажется, что у любви правдивой чем меньше слов, тем больше будет чувства."

# game/mods/pxt/pxt.rpy:66
translate ru pxt_real_start_6f7c7882:

    # phi "So please your grace, the prologue is address'd." id pxt_real_start_6f7c7882
    phi "Итак, коль вашей светлости угодно, Пролог готов."

# game/mods/pxt/pxt.rpy:68
translate ru pxt_real_start_d780c962:

    # the "Let him approach." id pxt_real_start_d780c962
    the "Пускай войдет сюда!"

# game/mods/pxt/pxt.rpy:72
translate ru pxt_real_start_80d2604a:

    # nvl clear
    # pr "If we offend, it is with our good will." id pxt_real_start_80d2604a
    nvl clear
    pr "Не думайте. Коль мы не угодим,"

# game/mods/pxt/pxt.rpy:75
translate ru pxt_real_start_2c943844:

    # pr "That you should think, we come not to offend," id pxt_real_start_2c943844
    pr "Что может быть. У нас желанья мало"

# game/mods/pxt/pxt.rpy:76
translate ru pxt_real_start_08e7f69a:

    # pr "But with good will. To show our simple skill," id pxt_real_start_08e7f69a
    pr "Искусством скромным вас занять своим."

# game/mods/pxt/pxt.rpy:77
translate ru pxt_real_start_8540aeec:

    # pr "That is the true beginning of our end." id pxt_real_start_8540aeec
    pr "Вот нашего конца сейчас начало."

# game/mods/pxt/pxt.rpy:78
translate ru pxt_real_start_832f1657:

    # pr "Consider then, we come but in despite." id pxt_real_start_832f1657
    pr "Мы не жалеем своего труда"

# game/mods/pxt/pxt.rpy:79
translate ru pxt_real_start_d25895c2:

    # pr "We do not come, as minding to content you," id pxt_real_start_d25895c2
    pr "Вас оскорбить. Не входит в наши цели"

# game/mods/pxt/pxt.rpy:80
translate ru pxt_real_start_703fa695:

    # pr "Our true intent is. All for your delight" id pxt_real_start_703fa695
    pr "Вас развлекать. Явились мы сюда"

# game/mods/pxt/pxt.rpy:81
translate ru pxt_real_start_6891aebf:

    # pr "We are not here. That you should here repent you," id pxt_real_start_6891aebf
    pr "Не с тем. Чтоб вы об этом пожалели,"

# game/mods/pxt/pxt.rpy:82
translate ru pxt_real_start_6c3a663b:

    # pr "The actors are at hand: and, by their show," id pxt_real_start_6c3a663b
    pr "Актеры здесь. Их стоит показать,"

# game/mods/pxt/pxt.rpy:83
translate ru pxt_real_start_e0db690d:

    # pr "You shall know all that you are like to know," id pxt_real_start_e0db690d
    pr "Чтоб вы узнали все, что надо знать."

# game/mods/pxt/pxt.rpy:85
translate ru pxt_real_start_pxt_a5s1_d41d8cd9:

    # nvl clear
    nvl clear

# game/mods/pxt/pxt.rpy:88
translate ru pxt_real_start_5a1ade2d:

    # the "This fellow doth not stand upon points." id pxt_real_start_5a1ade2d
    the "Этот молодец не очень-то считается со знаками препинания."

# game/mods/pxt/pxt.rpy:89
translate ru pxt_real_start_f2a94332:

    # lys "He hath rid his prologue like a rough colt; he knows not the stop. A good moral, my lord: it is not enough to speak, but to speak true." id pxt_real_start_f2a94332
    lys "Он пустил свой пролог, как необъезженного жеребца: он не знает, где ему остановиться. Отсюда мораль, государь: недостаточно говорить, надо еще говорить правильно."

# game/mods/pxt/pxt.rpy:90
translate ru pxt_real_start_6f1ede59:

    # hip "Indeed he hath played on this prologue like a child on a recorder; a sound, but not in government." id pxt_real_start_6f1ede59
    hip "Действительно, он сыграл свой пролог, как ребенок играет на флейте: звук есть, но управлять им он не умеет."

# game/mods/pxt/pxt.rpy:91
translate ru pxt_real_start_b474a34b:

    # the "His speech was like a tangled chain; nothing impaired, but all disordered. Who is next?" id pxt_real_start_b474a34b
    the "Его речь похожа на спутанную цепь: все звенья целы, но в беспорядке. А теперь что будет?"

# game/mods/pxt/pxt.rpy:111
translate ru pxt_real_start_pxt_a5s1_d41d8cd9_1:

    # nvl clear
    nvl clear

# game/mods/pxt/pxt.rpy:114
translate ru pxt_real_start_4e400b97:

    # pr "Gentles, perchance you wonder at this show;" id pxt_real_start_4e400b97
    pr "Почтенные, сей вид не ясен вам?"

# game/mods/pxt/pxt.rpy:115
translate ru pxt_real_start_87d2e6da:

    # pr "But wonder on, till truth make all things plain." id pxt_real_start_87d2e6da
    pr "Дивитесь: скоро все вам станет ясно."

# game/mods/pxt/pxt.rpy:120
translate ru pxt_real_start_0661528f:

    # pr "This man is Pyramus, if you would know;" id pxt_real_start_0661528f
    pr "Сей человек, известно будь, Пирам."

# game/mods/pxt/pxt.rpy:126
translate ru pxt_real_start_0b2a6b2e:

    # pr "This beauteous lady Thisby is certain." id pxt_real_start_0b2a6b2e
    pr "Девицу же звать Фисбою прекрасной."

# game/mods/pxt/pxt.rpy:132
translate ru pxt_real_start_d1deebed:

    # pr "This man, with lime and rough-cast, doth present" id pxt_real_start_d1deebed
    pr "В известке с глиной человек – Стена,"

# game/mods/pxt/pxt.rpy:133
translate ru pxt_real_start_eb1da2c8:

    # pr "Wall, that vile Wall which did these lovers sunder;" id pxt_real_start_eb1da2c8
    pr "Любовников жестокая преграда:"

# game/mods/pxt/pxt.rpy:134
translate ru pxt_real_start_05a00b6d:

    # pr "And through Wall's chink, poor souls, they are content" id pxt_real_start_05a00b6d
    pr "Сквозь щель ее шептаться (вот она!)"

# game/mods/pxt/pxt.rpy:135
translate ru pxt_real_start_17394a96:

    # pr "To whisper, at the which let no man wonder." id pxt_real_start_17394a96
    pr "Бедняжечкам – и то уже отрада."

# game/mods/pxt/pxt.rpy:141
translate ru pxt_real_start_7ebc322f:

    # pr "This man, with lanthorn, dog, and bush of thorn," id pxt_real_start_7ebc322f
    pr "Вот этот малый – Лунный Свет; при нем –"

# game/mods/pxt/pxt.rpy:142
translate ru pxt_real_start_6fff23db:

    # pr "Presenteth Moonshine: for, if you will know," id pxt_real_start_6fff23db
    pr "Терновый куст, фонарик и собака,"

# game/mods/pxt/pxt.rpy:143
translate ru pxt_real_start_5ac892c2:

    # pr "By moonshine did these lovers think no scorn" id pxt_real_start_5ac892c2
    pr "Чета влюбленных виделась тайком"

# game/mods/pxt/pxt.rpy:144
translate ru pxt_real_start_6656f287:

    # pr "To meet at Ninus' tomb, there, there to woo." id pxt_real_start_6656f287
    pr "В лучах луны, сияющей средь мрака."

# game/mods/pxt/pxt.rpy:146
translate ru pxt_real_start_pxt_a5s1_d41d8cd9_2:

    # nvl clear
    nvl clear

# game/mods/pxt/pxt.rpy:152
translate ru pxt_real_start_bfd151f7:

    # pr "This grisly beast, which by name Lion hight," id pxt_real_start_bfd151f7
    pr "Зверь, Львом рекомый, что наводит страх,"

# game/mods/pxt/pxt.rpy:153
translate ru pxt_real_start_49331b1d:

    # pr "The trusty Thisby, coming first by night," id pxt_real_start_49331b1d
    pr "Завидел Фисбу, что спешила к другу."

# game/mods/pxt/pxt.rpy:154
translate ru pxt_real_start_d796fb05:

    # pr "Did scare away, or rather did affright;" id pxt_real_start_d796fb05
    pr "Он напугал ее – и вот с испугу"

# game/mods/pxt/pxt.rpy:155
translate ru pxt_real_start_fcf2805b:

    # pr "And as she fled, her mantle she did fall;" id pxt_real_start_fcf2805b
    pr "Красавица бежала впопыхах,"
    pr "Свой плащ при этом уронив, к несчастью."

# game/mods/pxt/pxt.rpy:156
translate ru pxt_real_start_11046a56:

    # pr "Which Lion vile with bloody mouth did stain:" id pxt_real_start_11046a56
    pr "Лев вмиг его порвал кровавой пастью."


# game/mods/pxt/pxt.rpy:157
translate ru pxt_real_start_50de0093:

    # pr "Anon comes Pyramus, sweet youth, and tall," id pxt_real_start_50de0093
    pr "Тут появился, строен и высок,"

# game/mods/pxt/pxt.rpy:158
translate ru pxt_real_start_3e4b7758:

    # pr "And finds his trusty Thisby's mantle slain;" id pxt_real_start_3e4b7758
    pr "Пирам. Узрел в крови он плащ девицы"

# game/mods/pxt/pxt.rpy:159
translate ru pxt_real_start_437f3af2:

    # pr "Whereat with blade, with bloody blameful blade," id pxt_real_start_437f3af2
    pr "И сразу острый в грудь вонзил клинок."

# game/mods/pxt/pxt.rpy:160
translate ru pxt_real_start_c27a0c38:

    # pr "He bravely broach'd his boiling bloody breast;" id pxt_real_start_c27a0c38
    pr "Тем временем, под сенью шелковицы,"

# game/mods/pxt/pxt.rpy:161
translate ru pxt_real_start_2cbe0837:

    # pr "And Thisby, tarrying in mulberry shade," id pxt_real_start_2cbe0837
    pr "Узрев, что мертвый друг ее лежал,"

# game/mods/pxt/pxt.rpy:162
translate ru pxt_real_start_2f5a875a:

    # pr "His dagger drew, and died. For all the rest," id pxt_real_start_2f5a875a
    pr "Вонзила Фисба в грудь свою кинжал."

# game/mods/pxt/pxt.rpy:163
translate ru pxt_real_start_599b1e6f:

    # pr "Let Lion, Moonshine, Wall, and lovers twain," id pxt_real_start_599b1e6f
    pr "Подробно вам доскажут остальное"

# game/mods/pxt/pxt.rpy:164
translate ru pxt_real_start_d57e1f32:

    # pr "At large discourse while here they do remain." id pxt_real_start_d57e1f32
    pr "Луна, Стена, Лев и влюбленных двое."

# game/mods/pxt/pxt.rpy:166
translate ru pxt_real_start_pxt_a5s1_d41d8cd9_3:

    # nvl clear
    nvl clear

# game/mods/pxt/pxt.rpy:183
translate ru pxt_real_start_3c977328:

    # the "I wonder if the lion be to speak." id pxt_real_start_3c977328
    the "Интересно, заговорит ли и Лев?"

# game/mods/pxt/pxt.rpy:184
translate ru pxt_real_start_145bf7a1:

    # dem "No wonder, my lord: one lion may, when many asses do." id pxt_real_start_145bf7a1
    dem "В этом ничего не будет удивительного: отчего бы и не поговорить Льву, когда столько ослов разговаривают?"

# game/mods/pxt/pxt.rpy:191
translate ru pxt_real_start_21bd4d84:

    # wa "In this same interlude it doth befall" id pxt_real_start_21bd4d84
    wa "В сей интермедье решено так было,"

# game/mods/pxt/pxt.rpy:192
translate ru pxt_real_start_f4ac6534:

    # wa "That I, one Snout by name, present a wall:" id pxt_real_start_f4ac6534
    wa "Что Стену я представлю, медник Рыло."

# game/mods/pxt/pxt.rpy:197
translate ru pxt_real_start_3d40b0f3:

    # wa "And such a wall as I would have you think" id pxt_real_start_3d40b0f3
    wa "Стена такая я, что есть во мне"

# game/mods/pxt/pxt.rpy:198
translate ru pxt_real_start_0fa64bc6:

    # wa "That had in it a crannied hole or chink," id pxt_real_start_0fa64bc6
    wa "Дыра, иль щель, иль трещина в стене."

# game/mods/pxt/pxt.rpy:199
translate ru pxt_real_start_482df7f8:

    # wa "Through which the lovers, Pyramus and Thisby," id pxt_real_start_482df7f8
    wa "Влюбленные не раз сквозь эту щелку"

# game/mods/pxt/pxt.rpy:200
translate ru pxt_real_start_835caaf6:

    # wa "Did whisper often very secretly." id pxt_real_start_835caaf6
    wa "Все про любовь шептались втихомолку."

# game/mods/pxt/pxt.rpy:205
translate ru pxt_real_start_ce807810:

    # wa "This loam, this rough-cast, and this stone, doth show" id pxt_real_start_ce807810
    wa "Известка с глиной, с камешком должна"

# game/mods/pxt/pxt.rpy:206
translate ru pxt_real_start_b399ba1c:

    # wa "That I am that same wall; the truth is so:" id pxt_real_start_b399ba1c
    wa "Вам показать, что я и есть Стена."

# game/mods/pxt/pxt.rpy:207
translate ru pxt_real_start_c186c8e7:

    # wa "And this the cranny is, right and sinister," id pxt_real_start_c186c8e7
    wa "А вот и щель – направо и налево:"

# game/mods/pxt/pxt.rpy:208
translate ru pxt_real_start_13ae23bd:

    # wa "Through which the fearful lovers are to whisper." id pxt_real_start_13ae23bd
    wa "Шептаться будут здесь Пирам и дева»."

# game/mods/pxt/pxt.rpy:211
translate ru pxt_real_start_7d0cd8b7:

    # the "Would you desire lime and hair to speak better?" id pxt_real_start_7d0cd8b7
    the "Можно ли требовать, чтобы известь и глина говорили лучше?"

# game/mods/pxt/pxt.rpy:212
translate ru pxt_real_start_50c76026:

    # dem "It is the wittiest partition that ever I heard discourse, my lord." id pxt_real_start_50c76026
    dem "Государь, это положительно самая остроумная стена, какую мне приходилось слышать."

# game/mods/pxt/pxt.rpy:213
translate ru pxt_real_start_55826298:

    # the "Pyramus draws near the wall; silence." id pxt_real_start_55826298
    the "Тише! Пирам подходит к стене."

# game/mods/pxt/pxt.rpy:228
translate ru pxt_real_start_903f0283:

    # py "O grim-look'd night! O night with hue so black!" id pxt_real_start_903f0283
    py "О ночи тьма! Ночь, что как мрак черна!"

# game/mods/pxt/pxt.rpy:229
translate ru pxt_real_start_4c8bfbcd:

    # py "O night, which ever art when day is not!" id pxt_real_start_4c8bfbcd
    py "Ночь, что везде, где дня уж больше нет!"

# game/mods/pxt/pxt.rpy:230
translate ru pxt_real_start_5e058bf1:

    # py "O night, O night, alack, alack, alack," id pxt_real_start_5e058bf1
    py "О ночь, о ночь! Увы, увы, увы!"

# game/mods/pxt/pxt.rpy:231
translate ru pxt_real_start_7951691b:

    # py "I fear my Thisby's promise is forgot!—" id pxt_real_start_7951691b
    py "Боюсь, забыла Фисба свой обет!"

# game/mods/pxt/pxt.rpy:236
translate ru pxt_real_start_eb79e35d:

    # py "And thou, O wall, O sweet, O lovely wall," id pxt_real_start_eb79e35d
    py "А ты, Стена, любезная Стена,"

# game/mods/pxt/pxt.rpy:237
translate ru pxt_real_start_5600eeb9:

    # py "That stand'st between her father's ground and mine;" id pxt_real_start_5600eeb9
    py "Отцов-врагов делящая владенья,"

# game/mods/pxt/pxt.rpy:238
translate ru pxt_real_start_caf920e9:

    # py "Thou wall, O wall, O sweet and lovely wall," id pxt_real_start_caf920e9
    py "Пусть станет мне хоть щель в тебе видна"

# game/mods/pxt/pxt.rpy:239
translate ru pxt_real_start_7e98485e:

    # py "Show me thy chink, to blink through with mine eyne." id pxt_real_start_7e98485e
    py "Для моего предмета лицезренья."

# game/mods/pxt/pxt.rpy:249
translate ru pxt_real_start_5bcc31ab:

    # py "Thanks, courteous wall: Jove shield thee well for this!" id pxt_real_start_5bcc31ab
    py "Пошли тебе Юпитер благодать!"

# game/mods/pxt/pxt.rpy:250
translate ru pxt_real_start_8072e404:

    # py "But what see what see I? No Thisby do I see." id pxt_real_start_8072e404
    py "Но ах, увы! – что вижу я сквозь Стену?"

# game/mods/pxt/pxt.rpy:255
translate ru pxt_real_start_cb2557be:

    # py "O wicked wall, through whom I see no bliss," id pxt_real_start_cb2557be
    py "Стена-злодейка, девы не видать!"

# game/mods/pxt/pxt.rpy:256
translate ru pxt_real_start_f0815809:

    # py "Curs'd be thy stones for thus deceiving me!" id pxt_real_start_f0815809
    py "Будь проклята, Стена, ты за измену!"

# game/mods/pxt/pxt.rpy:259
translate ru pxt_real_start_d3708050:

    # the "The wall, methinks, being sensible, should curse again." id pxt_real_start_d3708050
    the "По-моему, Стена тоже должна напугаться, раз она обладает всеми чувствами."

# game/mods/pxt/pxt.rpy:264
translate ru pxt_real_start_5f7d91dd:

    # py "No, in truth, sir, he should not. 'Deceiving me' is Thisby's cue: she is to enter now, and I am to spy her through the wall." id pxt_real_start_5f7d91dd
    py "Никак это невозможно, ваша светлость: «за измену» – это реплика для Фисбы: она теперь должна войти, а мне надо ее заметить сквозь стену."

# game/mods/pxt/pxt.rpy:265
translate ru pxt_real_start_83cdb28b:

    # py "You shall see it will fall pat as I told you." id pxt_real_start_83cdb28b
    py "Вы увидите, что все будет точка в точку, как я сказал." 

# game/mods/pxt/pxt.rpy:270
translate ru pxt_real_start_d3fdfbc8:

    # py "—Yonder she comes." id pxt_real_start_d3fdfbc8
    py "А вот и она идет."

# game/mods/pxt/pxt.rpy:282
translate ru pxt_real_start_6cf14183:

    # th "O wall, full often hast thou heard my moans," id pxt_real_start_6cf14183
    th "Не ты ль, Стена, внимала вопль печали,"

# game/mods/pxt/pxt.rpy:283
translate ru pxt_real_start_4e4fc9d4:

    # th "For parting my fair Pyramus and me:" id pxt_real_start_4e4fc9d4
    th "Что от меня отторжен мой Пирам?"

# game/mods/pxt/pxt.rpy:284
translate ru pxt_real_start_f377aa8f:

    # th "My cherry lips have often kiss'd thy stones:" id pxt_real_start_f377aa8f
    th "Вишневые уста мои лобзали"

# game/mods/pxt/pxt.rpy:285
translate ru pxt_real_start_9f32fcbb:

    # th "Thy stones with lime and hair knit up in thee." id pxt_real_start_9f32fcbb
    th "Твою известку с глиной пополам"

# game/mods/pxt/pxt.rpy:292
translate ru pxt_real_start_b68f18a4:

    # py "I see a voice; now will I to the chink," id pxt_real_start_b68f18a4
    py "Я вижу голос; дай взгляну я в щелку."

# game/mods/pxt/pxt.rpy:293
translate ru pxt_real_start_cee1c0ec:

    # py "To spy an I can hear my Thisby's face." id pxt_real_start_cee1c0ec
    py "Услышу ль Фисбы я прекрасный лик?"

# game/mods/pxt/pxt.rpy:298
translate ru pxt_real_start_022aca68:

    # py "Thisby!" id pxt_real_start_022aca68
    py "О Фисба!"

# game/mods/pxt/pxt.rpy:305
translate ru pxt_real_start_af3a51b6:

    # th "My love! thou art my love, I think." id pxt_real_start_af3a51b6
    th "Ты ли к щелке там приник? Я думаю…"

# game/mods/pxt/pxt.rpy:312
translate ru pxt_real_start_b26e6417:

    # py "Think what thou wilt, I am thy lover's grace;" id pxt_real_start_b26e6417
    py "Что думаешь без толку?"

# game/mods/pxt/pxt.rpy:313
translate ru pxt_real_start_71a4df81:

    # py "And like Limander am I trusty still." id pxt_real_start_71a4df81
    py "Я, как Лимандр, не ведаю измены"

# game/mods/pxt/pxt.rpy:320
translate ru pxt_real_start_55953807:

    # th "And I like Helen, till the fates me kill." id pxt_real_start_55953807
    th "И я, пока жива, верней Елены"

# game/mods/pxt/pxt.rpy:327
translate ru pxt_real_start_691a6127:

    # py "Not Shafalus to Procrus was so true." id pxt_real_start_691a6127
    py "Шафал Прокрусу так не обожал"

# game/mods/pxt/pxt.rpy:334
translate ru pxt_real_start_6c32255b:

    # th "As Shafalus to Procrus, I to you." id pxt_real_start_6c32255b
    th "И я верна не меньше, чем Шафал"

# game/mods/pxt/pxt.rpy:341
translate ru pxt_real_start_d521d018:

    # py "O, kiss me through the hole of this vile wall." id pxt_real_start_d521d018
    py "Целуй сквозь щель: уста твои так сладки"

# game/mods/pxt/pxt.rpy:348
translate ru pxt_real_start_73c5188b:

    # th "I kiss the wall's hole, not your lips at all." id pxt_real_start_73c5188b
    th "Целую не уста – дыру в стене!"

# game/mods/pxt/pxt.rpy:355
translate ru pxt_real_start_918a0210:

    # py "Wilt thou at Ninny's tomb meet me straightway?" id pxt_real_start_918a0210
    py "К гробнице Ниньевой придешь ко мне?"

# game/mods/pxt/pxt.rpy:362
translate ru pxt_real_start_be157703:

    # th "'Tide life, 'tide death, I come without delay." id pxt_real_start_be157703
    th "'Tide life, 'tide death, I come without delay." id pxt_real_start_be157703

# game/mods/pxt/pxt.rpy:367
translate ru pxt_real_start_363bc04f:

    # wa "Thus have I, wall, my part discharged so;" id pxt_real_start_363bc04f
    wa "Хоть умереть, приду, и без оглядки!"

# game/mods/pxt/pxt.rpy:368
translate ru pxt_real_start_016f702c:

    # wa "And, being done, thus Wall away doth go." id pxt_real_start_016f702c
    wa "Тут роль свою закончила Стена, и может хоть совсем уйти она."

# game/mods/pxt/pxt.rpy:382
translate ru pxt_real_start_304c5e38:

    # the "Now is the mural down between the two neighbours." id pxt_real_start_304c5e38
    the "Вот и нет больше преграды между соседями."

# game/mods/pxt/pxt.rpy:383
translate ru pxt_real_start_eda32202:

    # dem "No remedy, my lord, when walls are so wilful to hear without warning." id pxt_real_start_eda32202
    dem "Это неизбежно, государь, если стены имеют уши и подслушивают без разрешения."

# game/mods/pxt/pxt.rpy:384
translate ru pxt_real_start_2deeefac:

    # hip "This is the silliest stuff that ever I heard." id pxt_real_start_2deeefac
    hip "Я никогда ничего глупее не слыхала!"

# game/mods/pxt/pxt.rpy:385
translate ru pxt_real_start_0515a6ba:

    # the "The best in this kind are but shadows; and the worst are no worse, if imagination amend them." id pxt_real_start_0515a6ba
    the "Лучшие пьесы такого рода – и то только тени; а худшие не будут слишком плохи, если воображение поможет им."

# game/mods/pxt/pxt.rpy:386
translate ru pxt_real_start_db720890:

    # hip "It must be your imagination then, and not theirs." id pxt_real_start_db720890
    hip "Но это должно сделать наше воображение, а не их."

# game/mods/pxt/pxt.rpy:387
translate ru pxt_real_start_b284b0f5:

    # the "If we imagine no worse of them than they of themselves, they may pass for excellent men. Here come two noble beasts in, a moon and a lion." id pxt_real_start_b284b0f5
    the "Если мы будем воображать о них не меньше того, что они сами о себе воображают, они могут представиться отличными людьми. А вот идут два благородных зверя: Луна и Лев."

# game/mods/pxt/pxt.rpy:398
translate ru pxt_real_start_cbe2296c:

    # lio "You, ladies, you, whose gentle hearts do fear" id pxt_real_start_cbe2296c
    lio "Сударыни, в ком нежных чувств излишек"

# game/mods/pxt/pxt.rpy:399
translate ru pxt_real_start_b7b8c81e:

    # lio "The smallest monstrous mouse that creeps on floor," id pxt_real_start_b7b8c81e
    lio "Пугается при виде малых мышек,"

# game/mods/pxt/pxt.rpy:400
translate ru pxt_real_start_414d5fa6:

    # lio "May now, perchance, both quake and tremble here," id pxt_real_start_414d5fa6
    lio "Боюсь, чтоб вы не начали кричать,"

# game/mods/pxt/pxt.rpy:401
translate ru pxt_real_start_00b3925e:

    # lio "When lion rough in wildest rage doth roar." id pxt_real_start_00b3925e
    lio "Коль будет грозный лев при вас рычать."

# game/mods/pxt/pxt.rpy:406
translate ru pxt_real_start_a53c624a:

    # lio "Then know that I, one Snug the joiner, am" id pxt_real_start_a53c624a
    lio "Но я не лев и не его подруга;"

# game/mods/pxt/pxt.rpy:407
translate ru pxt_real_start_7f4c78ac:

    # lio "A lion fell, nor else no lion's dam:" id pxt_real_start_7f4c78ac
    lio "Я лишь столяр; не надобно испуга."

# game/mods/pxt/pxt.rpy:412
translate ru pxt_real_start_3699d9dd:

    # lio "For, if I should as lion come in strife" id pxt_real_start_3699d9dd
    lio "Когда б, как лев, забрался я сюда,"

# game/mods/pxt/pxt.rpy:413
translate ru pxt_real_start_65785132:

    # lio "Into this place, 'twere pity on my life." id pxt_real_start_65785132
    lio "Ведь мне была бы самому беда."

# game/mods/pxt/pxt.rpy:416
translate ru pxt_real_start_27b9e599:

    # the "A very gentle beast, and of a good conscience." id pxt_real_start_27b9e599
    the "Какое кроткое животное и какое рассудительное!"

# game/mods/pxt/pxt.rpy:417
translate ru pxt_real_start_1d393753:

    # dem "The very best at a beast, my lord, that e'er I saw." id pxt_real_start_1d393753
    dem "Самое милое животное, государь, какое я видел."

# game/mods/pxt/pxt.rpy:418
translate ru pxt_real_start_992e5227:

    # lys "This lion is a very fox for his valour." id pxt_real_start_992e5227
    lys "Этот лев по храбрости – настоящая лисица."

# game/mods/pxt/pxt.rpy:419
translate ru pxt_real_start_5a4b8447:

    # the "True; and a goose for his discretion." id pxt_real_start_5a4b8447
    the "Верно, а по благоразумию – настоящий гусь."

# game/mods/pxt/pxt.rpy:420
translate ru pxt_real_start_bc025004:

    # dem "Not so, my lord; for his valour cannot carry his discretion, and the fox carries the goose." id pxt_real_start_bc025004
    dem "Не совсем так, государь, потому что его храбрость не пересиливает его благоразумия, а лисица всегда пересилит гуся."

# game/mods/pxt/pxt.rpy:421
translate ru pxt_real_start_10a2d717:

    # the "His discretion, I am sure, cannot carry his valour; for the goose carries not the fox. It is well; leave it to his discretion, and let us listen to the moon." id pxt_real_start_10a2d717
    the "Во всяком случае, его благоразумие не пересилит его храбрости, потому что гусь никогда не пересилит лисицы. Однако предоставим его собственному его благоразумию и послушаем, что скажет Луна."

# game/mods/pxt/pxt.rpy:429
translate ru pxt_real_start_d12f3204:

    # mo "This lanthorn doth the horned moon present:" id pxt_real_start_d12f3204
    mo "Двурогую луну фонарь являет сей, а я – тот человек, что обитает в ней"

# game/mods/pxt/pxt.rpy:432
translate ru pxt_real_start_73f74815:

    # dem "He should have worn the horns on his head." id pxt_real_start_73f74815
    dem "Ему стоило бы носить рога на голове."

# game/mods/pxt/pxt.rpy:433
translate ru pxt_real_start_59317d5a:

    # the "He is no crescent, and his horns are invisible within the circumference." id pxt_real_start_59317d5a
    the "Он — не растущая Луна, и его рога уже спрятаны за пределами окружности."

# game/mods/pxt/pxt.rpy:438
translate ru pxt_real_start_773dfb10:

    # mo "This lanthorn doth the horned moon present;" id pxt_real_start_773dfb10
    mo "Двурогую луну фонарь являет сей,"

# game/mods/pxt/pxt.rpy:443
translate ru pxt_real_start_ba1e935a:

    # mo "Myself the man i' the moon do seem to be." id pxt_real_start_ba1e935a
    mo "А я – тот человек, что обитает в ней."

# game/mods/pxt/pxt.rpy:446
translate ru pxt_real_start_2aa3b772:

    # the "This is the greatest error of all the rest: the man should be put into the lantern. How is it else the man i' the moon?" id pxt_real_start_2aa3b772
    the "Вот тут самая большая ошибка: человека надо было поместить в фонаре; какой же он иначе человек на луне?"

# game/mods/pxt/pxt.rpy:447
translate ru pxt_real_start_30ffd954:

    # dem "He dares not come there for the candle: for, you see, it is already in snuff." id pxt_real_start_30ffd954
    dem "Он не решился туда влезть из-за свечки: смотрите, как она нагорела."

# game/mods/pxt/pxt.rpy:448
translate ru pxt_real_start_77c63cea:

    # hip "I am aweary of this moon: would he would change!" id pxt_real_start_77c63cea
    hip "Мне надоела эта луна; пора бы ей перемениться!"

# game/mods/pxt/pxt.rpy:449
translate ru pxt_real_start_ff9a80bb:

    # the "It appears, by his small light of discretion, that he is in the wane: but yet, in courtesy, in all reason, we must stay the time." id pxt_real_start_ff9a80bb
    the "Судя по слабому пламени ее разума, она уже на ущербе; но из любезности нам надо дождаться."

# game/mods/pxt/pxt.rpy:450
translate ru pxt_real_start_6eea599d:

    # lys "Proceed, moon." id pxt_real_start_6eea599d
    lys "Продолжай, Луна."

# game/mods/pxt/pxt.rpy:455
translate ru pxt_real_start_3c40ade8:

    # mo "All that I have to say, is to tell you that the lantern is the moon;" id pxt_real_start_3c40ade8
    mo "Все, что я должен сказать, это вот что: только объяснить вам, что фонарь – это луна;"

# game/mods/pxt/pxt.rpy:460
translate ru pxt_real_start_94f7fce3:

    # mo "I, the man i' the moon;" id pxt_real_start_94f7fce3
    mo "А я – человек в луне;"

# game/mods/pxt/pxt.rpy:465
translate ru pxt_real_start_7919a907:

    # mo "This thorn-bush, my thorn-bush;" id pxt_real_start_7919a907
    mo "Этот терновый куст – мой терновый куст;"

# game/mods/pxt/pxt.rpy:466
translate ru pxt_real_start_de131351:

    # mo "And this dog, my dog." id pxt_real_start_de131351
    mo "А эта собака – моя собака."

# game/mods/pxt/pxt.rpy:469
translate ru pxt_real_start_5ef409a1:

    # dem "Why, all these should be in the lantern; for all these are in the moon. But silence; here comes Thisbe." id pxt_real_start_5ef409a1
    dem "Собственно, все это должно бы было находиться в фонаре: ведь это все на луне. Но тише: вот идет Фисба."

# game/mods/pxt/pxt.rpy:482
translate ru pxt_real_start_858fc504:

    # th "This is old Ninny's tomb. Where is my love?" id pxt_real_start_858fc504
    th "Вот Нина старого гробница. Где ж мой милый?…"

# game/mods/pxt/pxt.rpy:487
translate ru pxt_real_start_698fc2af:

    # lio "Oh!" id pxt_real_start_698fc2af
    lio "У-у-у!…"

# game/mods/pxt/pxt.rpy:498
translate ru pxt_real_start_990d4601:

    # dem "Well roared, lion." id pxt_real_start_990d4601
    dem "Отлично рычишь, Лев!"

# game/mods/pxt/pxt.rpy:499
translate ru pxt_real_start_973ea59c:

    # the "Well run, Thisbe." id pxt_real_start_973ea59c
    the "Отлично бежишь, Фисбе."

# game/mods/pxt/pxt.rpy:500
translate ru pxt_real_start_e0cc5d24:

    # hip "Well shone, moon. —Truly, the moon shines with a good grace." id pxt_real_start_e0cc5d24
    hip "Отлично светишь, Луна! Право, Луна светит очень мило."

# game/mods/pxt/pxt.rpy:514
translate ru pxt_real_start_78b85f55:

    # the "Well moused, lion." id pxt_real_start_78b85f55
    the "Отлично разодрал, Лев!"

# game/mods/pxt/pxt.rpy:515
translate ru pxt_real_start_12febeb9:

    # dem "And so comes Pyramus." id pxt_real_start_12febeb9
    dem "Тут является Пирам…"

# game/mods/pxt/pxt.rpy:516
translate ru pxt_real_start_150c8b27:

    # lys "And then the lion vanishes." id pxt_real_start_150c8b27
    lys "И Лев исчезает."

# game/mods/pxt/pxt.rpy:529
translate ru pxt_real_start_3af75a6e:

    # py "Sweet moon, I thank thee for thy sunny beams;" id pxt_real_start_3af75a6e
    py "Благодарю, Луна, за солнечны лучи,"

# game/mods/pxt/pxt.rpy:530
translate ru pxt_real_start_5deb40d2:

    # py "I thank thee, moon, for shining now so bright:" id pxt_real_start_5deb40d2
    py "За то, что ярко так сияешь ты в ночи."

# game/mods/pxt/pxt.rpy:531
translate ru pxt_real_start_50ae1825:

    # py "For, by thy gracious golden, glittering streams," id pxt_real_start_50ae1825
    py "Твой свет мерцающий, златой, лазурно-ясный"

# game/mods/pxt/pxt.rpy:532
translate ru pxt_real_start_fe1392b9:

    # py "I trust to take of truest Thisby's sight." id pxt_real_start_fe1392b9
    py "Поможет Фисбы мне увидеть лик прекрасный."

# game/mods/pxt/pxt.rpy:537
translate ru pxt_real_start_23ed37e0:

    # py "But stay;—O spite!" id pxt_real_start_23ed37e0
    py "Но страх какой!"

# game/mods/pxt/pxt.rpy:538
translate ru pxt_real_start_9a0019dc:

    # py "But mark,—poor knight," id pxt_real_start_9a0019dc
    py "О рыцарь, стой!"

# game/mods/pxt/pxt.rpy:539
translate ru pxt_real_start_1ef8b033:

    # py "What dreadful dole is here!" id pxt_real_start_1ef8b033
    py "Разит судьбина злая."

# game/mods/pxt/pxt.rpy:540
translate ru pxt_real_start_085e8884:

    # py "Eyes, do you see?" id pxt_real_start_085e8884
    py "Темно в очах…"

# game/mods/pxt/pxt.rpy:545
translate ru pxt_real_start_48f229b1:

    # py "How can it be?" id pxt_real_start_48f229b1
    py "Возможно ль? Ах!"

# game/mods/pxt/pxt.rpy:546
translate ru pxt_real_start_a3fed112:

    # py "O dainty duck! O dear!" id pxt_real_start_a3fed112
    py "Друг, дева дорогая!"

# game/mods/pxt/pxt.rpy:547
translate ru pxt_real_start_14848e49:

    # py "Thy mantle good," id pxt_real_start_14848e49
    py "Твой плащ в крови! Беда!"

# game/mods/pxt/pxt.rpy:548
translate ru pxt_real_start_0dc44d52:

    # py "What! stained with blood?" id pxt_real_start_0dc44d52
    py "О фурии, сюда!"

# game/mods/pxt/pxt.rpy:549
translate ru pxt_real_start_df934b72:

    # py "Approach, ye furies fell!" id pxt_real_start_df934b72
    py "Вы, парки, приходите"

# game/mods/pxt/pxt.rpy:550
translate ru pxt_real_start_44fcc6c9:

    # py "O fates! come, come;" id pxt_real_start_44fcc6c9
    py "Разрезать жизни нити,"

# game/mods/pxt/pxt.rpy:555
translate ru pxt_real_start_1aaa6cd4:

    # py "Cut thread and thrum;" id pxt_real_start_1aaa6cd4
    py "Ты, злобный рок, спеши:"

# game/mods/pxt/pxt.rpy:556
translate ru pxt_real_start_d0a56a20:

    # py "Quail, rush, conclude, and quell!" id pxt_real_start_d0a56a20
    py "Рази, грози, убей, добей, кончай и сокруши!"

# game/mods/pxt/pxt.rpy:559
translate ru pxt_real_start_4ee18586:

    # the "This passion, and the death of a dear friend, would go near to make a man look sad." id pxt_real_start_4ee18586
    the "Такое отчаяние и смерть милого друга, право, могут опечалить."

# game/mods/pxt/pxt.rpy:560
translate ru pxt_real_start_6098cd59:

    # hip "Beshrew my heart, but I pity the man." id pxt_real_start_6098cd59
    hip "Клянусь душой, мне жаль этого человека."

# game/mods/pxt/pxt.rpy:565
translate ru pxt_real_start_0abdb4d0:

    # py "O wherefore, nature, didst thou lions frame?" id pxt_real_start_0abdb4d0
    py "Зачем, Природа, жизнь даруешь львам,"

# game/mods/pxt/pxt.rpy:566
translate ru pxt_real_start_b8caa1ee:

    # py "Since lion vile hath here deflower'd my dear;" id pxt_real_start_b8caa1ee
    py "Чтоб красоту твою они губили?"

# game/mods/pxt/pxt.rpy:567
translate ru pxt_real_start_c084fff3:

    # py "Which is—no, no—which was the fairest dame" id pxt_real_start_c084fff3
    py "Увы, она была милей всех дам,"

# game/mods/pxt/pxt.rpy:568
translate ru pxt_real_start_c7a61d0b:

    # py "That liv'd, that lov'd, that lik'd, that look'd with cheer." id pxt_real_start_c7a61d0b
    py "Что на земле росли, цвели, любили."

# game/mods/pxt/pxt.rpy:569
translate ru pxt_real_start_469b4631:

    # py "Come, tears, confound;" id pxt_real_start_469b4631
    py "О, лейтесь, токи слезны!"

# game/mods/pxt/pxt.rpy:570
translate ru pxt_real_start_6dc32f6d:

    # py "Out, sword, and wound" id pxt_real_start_6dc32f6d
    py "Сюда, мой меч любезный!"

# game/mods/pxt/pxt.rpy:571
translate ru pxt_real_start_d73cb223:

    # py "The pap of Pyramus:" id pxt_real_start_d73cb223
    py "Рази меня, клинок,"

# game/mods/pxt/pxt.rpy:576
translate ru pxt_real_start_3ab1d420:

    # py "Ay, that left pap," id pxt_real_start_3ab1d420
    py "В тот самый левый бок,"

# game/mods/pxt/pxt.rpy:577
translate ru pxt_real_start_1ca60a46:

    # py "Where heart doth hop:—" id pxt_real_start_1ca60a46
    py "Где слышен сердца стук,{w} стук,{w} стук."

# game/mods/pxt/pxt.rpy:578
translate ru pxt_real_start_38e29cec:

    # py "Thus die I,{w} thus,{w} thus,{w} thus." id pxt_real_start_38e29cec
    py "Избавь меня от мук!"

# game/mods/pxt/pxt.rpy:584
translate ru pxt_real_start_5198726e:

    # py "Now am I dead," id pxt_real_start_5198726e
    py "Now am I dead," id pxt_real_start_5198726e

# game/mods/pxt/pxt.rpy:585
translate ru pxt_real_start_9743c7c7:

    # py "Now am I fled;" id pxt_real_start_9743c7c7
    py "И вот я мертв, ах, ах!"

# game/mods/pxt/pxt.rpy:586
translate ru pxt_real_start_43f23b56:

    # py "My soul is in the sky:" id pxt_real_start_43f23b56
    py "Мой дух уж в небесах!"

# game/mods/pxt/pxt.rpy:587
translate ru pxt_real_start_ecf629dc:

    # py "Tongue, lose thy light!" id pxt_real_start_ecf629dc
    py "На небо улетаю, лишь кости здесь слагаю."

# game/mods/pxt/pxt.rpy:588
translate ru pxt_real_start_262dc6f5:

    # py "Moon, take thy flight!" id pxt_real_start_262dc6f5
    py "Язык, свой свет сокрой!… Луна, лети долой!"

# game/mods/pxt/pxt.rpy:589
translate ru pxt_real_start_f8fb85a4:

    # py "Now die,{w} die,{w} die,{w} die,{w} die." id pxt_real_start_f8fb85a4
    py "Несчастный, умирай!{w}-ай!{w}-ай!{w}-ай!{w}-ай!{w}-ай!"

# game/mods/pxt/pxt.rpy:600
translate ru pxt_real_start_f12b49f9:

    # dem "No die, but an ace, for him; for he is but one." id pxt_real_start_f12b49f9
    dem "Какие же он кости слагает? Всего одно очко: ведь он один"

# game/mods/pxt/pxt.rpy:601
translate ru pxt_real_start_623564a2:

    # lys "Less than an ace, man; for he is dead; he is nothing." id pxt_real_start_623564a2
    lys "Меньше, чем одно очко, приятель: он умер – значит он пустышка."

# game/mods/pxt/pxt.rpy:602
translate ru pxt_real_start_be275cfd:

    # the "With the help of a surgeon he might yet recover and prove an ass." id pxt_real_start_be275cfd
    the "С помощью хорошего хирурга он мог бы исцелиться и оказаться ослом."

# game/mods/pxt/pxt.rpy:603
translate ru pxt_real_start_a3daeceb:

    # hip "How chance moonshine is gone before Thisbe comes back and finds her lover?" id pxt_real_start_a3daeceb
    hip "Как же это Лунный Свет ушел раньше, чем Фисба вернулась? Ведь ей надо отыскать своего любовника."

# game/mods/pxt/pxt.rpy:604
translate ru pxt_real_start_588449ae:

    # the "She will find him by starlight.—Here she comes; and her passion ends the play." id pxt_real_start_588449ae
    the "Она его отыщет при свете звезд. Вот и она: ее отчаянием заканчивается пьеса."

# game/mods/pxt/pxt.rpy:612
translate ru pxt_real_start_90c44bb2:

    # hip "Methinks she should not use a long one for such a Pyramus: I hope she will be brief." id pxt_real_start_90c44bb2
    hip "По-моему, из-за такого Пирама отчаяние не может быть слишком продолжительным: надеюсь, она будет
краткой."

# game/mods/pxt/pxt.rpy:613
translate ru pxt_real_start_4d006551:

    # dem "A mote will turn the balance, which Pyramus, which Thisbe, is the better." id pxt_real_start_4d006551
    dem "Пылинка перетянет чашку весов, если начать взвешивать, кто из них лучше, Пирам или Фисба: он как мужчина (Боже нас упаси!) или она как женщина (сохрани нас боже!)."

# game/mods/pxt/pxt.rpy:614
translate ru pxt_real_start_961e5373:

    # lys "She hath spied him already with those sweet eyes." id pxt_real_start_961e5373
    lys "Вот она уже высмотрела его своими прелестными глазками."

# game/mods/pxt/pxt.rpy:615
translate ru pxt_real_start_550b2333:

    # dem "And thus she moans, videlicet.—" id pxt_real_start_550b2333
    dem "И начинает его оплакивать."

# game/mods/pxt/pxt.rpy:620
translate ru pxt_real_start_8c2e33fc:

    # th "Asleep, my love?" id pxt_real_start_8c2e33fc
    th "Ты спишь ли, голубок?"

# game/mods/pxt/pxt.rpy:621
translate ru pxt_real_start_e4d030ed:

    # th "What, dead, my dove?" id pxt_real_start_e4d030ed
    th "Как! Умер мой дружок?"

# game/mods/pxt/pxt.rpy:626
translate ru pxt_real_start_0e1baa2c:

    # th "O Pyramus, arise," id pxt_real_start_0e1baa2c
    th "Проснись! Ты нем иль мертв совсем,"

# game/mods/pxt/pxt.rpy:627
translate ru pxt_real_start_4a5e35f0:

    # th "Speak, speak. Quite dumb?" id pxt_real_start_4a5e35f0
    th "И очи тьмой покрыты?"

# game/mods/pxt/pxt.rpy:628
translate ru pxt_real_start_095fa3d3:

    # th "Dead, dead? A tomb" id pxt_real_start_095fa3d3
    th "Твоя исчезла красота –"

# game/mods/pxt/pxt.rpy:629
translate ru pxt_real_start_942d03be:

    # th "Must cover thy sweet eyes." id pxt_real_start_942d03be
    th "Вишневый нос алее роз,"

# game/mods/pxt/pxt.rpy:630
translate ru pxt_real_start_b7ff77cd:

    # th "These lily lips," id pxt_real_start_b7ff77cd
    th "Твои лилейные уста"

# game/mods/pxt/pxt.rpy:631
translate ru pxt_real_start_34858005:

    # th "This cherry nose," id pxt_real_start_34858005
    th "И желтые ланиты..."

# game/mods/pxt/pxt.rpy:632
translate ru pxt_real_start_72c5d56e:

    # th "These yellow cowslip cheeks," id pxt_real_start_72c5d56e
    th "Любовники, стенайте все:"

# game/mods/pxt/pxt.rpy:633
translate ru pxt_real_start_945c8bbe:

    # th "Are gone, are gone:" id pxt_real_start_945c8bbe
    th "Вот он лежит во всей красе!"

# game/mods/pxt/pxt.rpy:638
translate ru pxt_real_start_f0aca02b:

    # th "Lovers, make moan!" id pxt_real_start_f0aca02b
    th "Ах, чудный взор его очей"

# game/mods/pxt/pxt.rpy:639
translate ru pxt_real_start_18d267a7:

    # th "His eyes were green as leeks." id pxt_real_start_18d267a7
    th "Был зеленее, чем порей."

# game/mods/pxt/pxt.rpy:640
translate ru pxt_real_start_1b0c1044:

    # th "O Sisters Three," id pxt_real_start_1b0c1044
    th "Прощай, мой ненаглядный!"

# game/mods/pxt/pxt.rpy:641
translate ru pxt_real_start_79a29738:

    # th "Come, come to me," id pxt_real_start_79a29738
    th "Вы, три сестры, сюда скорей,"

# game/mods/pxt/pxt.rpy:642
translate ru pxt_real_start_2f93dc5d:

    # th "With hands as pale as milk;" id pxt_real_start_2f93dc5d
    th "С руками молока белей;"

# game/mods/pxt/pxt.rpy:643
translate ru pxt_real_start_7ed2a57a:

    # th "Lay them in gore," id pxt_real_start_7ed2a57a
    th "Теперь они у вас в крови:"

# game/mods/pxt/pxt.rpy:644
translate ru pxt_real_start_6230f218:

    # th "Since you have shore" id pxt_real_start_6230f218
    th "Вы нить шелковую любви"

# game/mods/pxt/pxt.rpy:645
translate ru pxt_real_start_e097e19c:

    # th "With shears his thread of silk." id pxt_real_start_e097e19c
    th "Порвали беспощадно."

# game/mods/pxt/pxt.rpy:650
translate ru pxt_real_start_d5cede04:

    # th "Tongue, not a word:—" id pxt_real_start_d5cede04
    th "Молчи, язык! К чему тут речь?"

# game/mods/pxt/pxt.rpy:651
translate ru pxt_real_start_a90ac956:

    # th "Come, trusty sword;" id pxt_real_start_a90ac956
    th "Приди сюда, мой верный меч!"

# game/mods/pxt/pxt.rpy:652
translate ru pxt_real_start_bedc94b8:

    # th "Come, blade, my breast imbrue;" id pxt_real_start_bedc94b8
    th "Рази скорей – вот грудь моя."

# game/mods/pxt/pxt.rpy:653
translate ru pxt_real_start_b581d9ad:

    # th "And farewell, friends:—" id pxt_real_start_b581d9ad
    th "Прощайте, все друзья:"

# game/mods/pxt/pxt.rpy:654
translate ru pxt_real_start_a7a8f30c:

    # th "Thus Thisby ends;" id pxt_real_start_a7a8f30c
    th "Кончает Фисба жизнь свою,"

# game/mods/pxt/pxt.rpy:655
translate ru pxt_real_start_6b8accfc:

    # th "Adieu,{w} adieu,{w} adieu." id pxt_real_start_6b8accfc
    th "Адью,{w} адью,{w} адью."

# game/mods/pxt/pxt.rpy:669
translate ru pxt_real_start_91aa8908:

    # the "Moonshine and lion are left to bury the dead." id pxt_real_start_91aa8908
    the "Лев и Луна остались в живых, чтобы схоронить мертвых."

# game/mods/pxt/pxt.rpy:670
translate ru pxt_real_start_cbab053d:

    # dem "Ay, and wall too." id pxt_real_start_cbab053d
    dem "Да, и Стена тоже."

# game/mods/pxt/pxt.rpy:676
translate ru pxt_real_start_accd657c:

    # bo "No, I assure you; the wall is down that parted their fathers. Will it please you to see the epilogue, or to hear a Bergomask dance between two of our company?" id pxt_real_start_accd657c
    bo "Нет, смею вас уверить, стена, которая разделила их отцов, больше не существует. Угодно вам посмотреть эпилог или прослушать бергамаский танец в исполнении двух наших актеров?"

# game/mods/pxt/pxt.rpy:678
translate ru pxt_real_start_f1176961:

    # the "No epilogue, I pray you; for your play needs no excuse. " id pxt_real_start_f1176961
    the "Не надо эпилога: ваша пьеса в извинении не нуждается."

# game/mods/pxt/pxt.rpy:679
translate ru pxt_real_start_fe7284d2:

    # the "Never excuse; for when the players are all dead there need none to be blamed." id pxt_real_start_fe7284d2
    the "Какие же извинения? Раз все актеры умерли, бранить некого."

# game/mods/pxt/pxt.rpy:680
translate ru pxt_real_start_6441b3a1:

    # the "Marry, if he that writ it had played Pyramus, and hang'd himself in Thisbe's garter, it would have been a fine tragedy: and so it is, truly; and very notably discharged. " id pxt_real_start_6441b3a1
    the "Если бы сочинитель этой пьесы сыграл Пирама и удавился подвязкой Фисбы, то это была бы отличная трагедия и прекрасно исполненная; но она и так хороша."

# game/mods/pxt/pxt.rpy:681
translate ru pxt_real_start_cb964824:

    # the "But come, your Bergomask; let your epilogue alone. " id pxt_real_start_cb964824
    the "Покажите нам ваш бергамаский танец, а эпилог не нужен."

