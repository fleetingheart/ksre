# game/mods/pxt/pxt.rpy:161
translate zh_hans pxt_real_start_2cbe0837:

    # pr "And Thisby, tarrying in mulberry shade," id pxt_real_start_2cbe0837
    pr "那时雪丝佩却躱在桑树的树荫里，"

# game/mods/pxt/pxt.rpy:162
translate zh_hans pxt_real_start_2f5a875a:

    # pr "His dagger drew, and died. For all the rest," id pxt_real_start_2f5a875a
    pr "等到她发现了这回事，便把他身上的剑拔出来，结果了她自己的性命。"

# game/mods/pxt/pxt.rpy:163
translate zh_hans pxt_real_start_599b1e6f:

    # pr "Let Lion, Moonshine, Wall, and lovers twain," id pxt_real_start_599b1e6f
    pr "至于其余的一切，可以让狮子，月光，墙头和两个情人详详细细地告诉你们，"

# game/mods/pxt/pxt.rpy:164
translate zh_hans pxt_real_start_d57e1f32:

    # pr "At large discourse while here they do remain." id pxt_real_start_d57e1f32
    pr "当他们上场的时候。"

# game/mods/pxt/pxt.rpy:166
translate zh_hans pxt_real_start_pxt_a5s1_d41d8cd9_3:

    # nvl clear
    nvl clear

# game/mods/pxt/pxt.rpy:183
translate zh_hans pxt_real_start_3c977328:

    # the "I wonder if the lion be to speak." id pxt_real_start_3c977328
    the "我不知道狮子要不要说话。"

# game/mods/pxt/pxt.rpy:184
translate zh_hans pxt_real_start_145bf7a1:

    # dem "No wonder, my lord: one lion may, when many asses do." id pxt_real_start_145bf7a1
    dem "殿下，这可不用怀疑，要是一班驴子都会讲人话，狮子当然也会说话啦。"

# game/mods/pxt/pxt.rpy:191
translate zh_hans pxt_real_start_21bd4d84:

    # wa "In this same interlude it doth befall" id pxt_real_start_21bd4d84
    wa "小子斯诺脱是也，"

# game/mods/pxt/pxt.rpy:192
translate zh_hans pxt_real_start_f4ac6534:

    # wa "That I, one Snout by name, present a wall:" id pxt_real_start_f4ac6534
    wa "在这本戏文里扮做墙头。"

# game/mods/pxt/pxt.rpy:197
translate zh_hans pxt_real_start_3d40b0f3:

    # wa "And such a wall as I would have you think" id pxt_real_start_3d40b0f3
    wa "须知此墙不是他墙，"

# game/mods/pxt/pxt.rpy:198
translate zh_hans pxt_real_start_0fa64bc6:

    # wa "That had in it a crannied hole or chink," id pxt_real_start_0fa64bc6
    wa "乃是一堵有裂缝的墙，"

# game/mods/pxt/pxt.rpy:199
translate zh_hans pxt_real_start_482df7f8:

    # wa "Through which the lovers, Pyramus and Thisby," id pxt_real_start_482df7f8
    wa "在那条裂缝里匹拉麦斯和雪丝佩两个情人"

# game/mods/pxt/pxt.rpy:200
translate zh_hans pxt_real_start_835caaf6:

    # wa "Did whisper often very secretly." id pxt_real_start_835caaf6
    wa "常常偷偷地低声谈话。"

# game/mods/pxt/pxt.rpy:205
translate zh_hans pxt_real_start_ce807810:

    # wa "This loam, this rough-cast, and this stone, doth show" id pxt_real_start_ce807810
    wa "这一把石灰，这一撮黏土，这一块砖头，表明"

# game/mods/pxt/pxt.rpy:206
translate zh_hans pxt_real_start_b399ba1c:

    # wa "That I am that same wall; the truth is so:" id pxt_real_start_b399ba1c
    wa "我是一堵真正的墙头，并非滑头冒牌之流。"

# game/mods/pxt/pxt.rpy:207
translate zh_hans pxt_real_start_c186c8e7:

    # wa "And this the cranny is, right and sinister," id pxt_real_start_c186c8e7
    wa "这便是那个鬼缝儿，"

# game/mods/pxt/pxt.rpy:208
translate zh_hans pxt_real_start_13ae23bd:

    # wa "Through which the fearful lovers are to whisper." id pxt_real_start_13ae23bd
    wa "这两个胆小的情人在那儿谈着知心话儿的。"

# game/mods/pxt/pxt.rpy:211
translate zh_hans pxt_real_start_7d0cd8b7:

    # the "Would you desire lime and hair to speak better?" id pxt_real_start_7d0cd8b7
    the "石灰和泥土筑成的东西，居然这样会说话，难得难得！"

# game/mods/pxt/pxt.rpy:212
translate zh_hans pxt_real_start_50c76026:

    # dem "It is the wittiest partition that ever I heard discourse, my lord." id pxt_real_start_50c76026
    dem "殿下，这是我所听到的中间最俏皮的一段。"

# game/mods/pxt/pxt.rpy:213
translate zh_hans pxt_real_start_55826298:

    # the "Pyramus draws near the wall; silence." id pxt_real_start_55826298
    the "匹拉麦斯走近墙边来了。静听！"

# game/mods/pxt/pxt.rpy:228
translate zh_hans pxt_real_start_903f0283:

    # py "O grim-look'd night! O night with hue so black!" id pxt_real_start_903f0283
    py "板着脸孔的夜啊！漆黑的夜啊！"

# game/mods/pxt/pxt.rpy:229
translate zh_hans pxt_real_start_4c8bfbcd:

    # py "O night, which ever art when day is not!" id pxt_real_start_4c8bfbcd
    py "夜啊，白天一去，你就来啦！"

# game/mods/pxt/pxt.rpy:230
translate zh_hans pxt_real_start_5e058bf1:

    # py "O night, O night, alack, alack, alack," id pxt_real_start_5e058bf1
    py "夜啊！夜啊！唉呀！唉呀！唉呀！"

# game/mods/pxt/pxt.rpy:231
translate zh_hans pxt_real_start_7951691b:

    # py "I fear my Thisby's promise is forgot!—" id pxt_real_start_7951691b
    py "我担心我的雪丝佩要失约啦！"

# game/mods/pxt/pxt.rpy:236
translate zh_hans pxt_real_start_eb79e35d:

    # py "And thou, O wall, O sweet, O lovely wall," id pxt_real_start_eb79e35d
    py "墙啊！亲爱的，可爱的墙啊！"

# game/mods/pxt/pxt.rpy:237
translate zh_hans pxt_real_start_5600eeb9:

    # py "That stand'st between her father's ground and mine;" id pxt_real_start_5600eeb9
    py "你硬生生地隔分了我们两人的家！"

# game/mods/pxt/pxt.rpy:238
translate zh_hans pxt_real_start_caf920e9:

    # py "Thou wall, O wall, O sweet and lovely wall," id pxt_real_start_caf920e9
    py "墙啊！亲爱的，可爱的墙啊！"

# game/mods/pxt/pxt.rpy:239
translate zh_hans pxt_real_start_7e98485e:

    # py "Show me thy chink, to blink through with mine eyne." id pxt_real_start_7e98485e
    py "露出你的裂缝，让我向里头瞧瞧吧！"

# game/mods/pxt/pxt.rpy:249
translate zh_hans pxt_real_start_5bcc31ab:

    # py "Thanks, courteous wall: Jove shield thee well for this!" id pxt_real_start_5bcc31ab
    py "谢谢你，殷勤的墙！上帝大大保佑你！"

# game/mods/pxt/pxt.rpy:250
translate zh_hans pxt_real_start_8072e404:

    # py "But what see what see I? No Thisby do I see." id pxt_real_start_8072e404
    py "但是我瞧见些什么呢？我瞧不见她。"

# game/mods/pxt/pxt.rpy:255
translate zh_hans pxt_real_start_cb2557be:

    # py "O wicked wall, through whom I see no bliss," id pxt_real_start_cb2557be
    py "刁恶的墙啊！不让我瞧见可爱的她，"

# game/mods/pxt/pxt.rpy:256
translate zh_hans pxt_real_start_f0815809:

    # py "Curs'd be thy stones for thus deceiving me!" id pxt_real_start_f0815809
    py "愿你倒霉吧，因为你竟这样把我欺！"

# game/mods/pxt/pxt.rpy:259
translate zh_hans pxt_real_start_d3708050:

    # the "The wall, methinks, being sensible, should curse again." id pxt_real_start_d3708050
    the "这墙并不是没有知觉的，我想他应当反骂一下。"

# game/mods/pxt/pxt.rpy:264
translate zh_hans pxt_real_start_5f7d91dd:

    # py "No, in truth, sir, he should not. 'Deceiving me' is Thisby's cue: she is to enter now, and I am to spy her through the wall." id pxt_real_start_5f7d91dd
    py "没有的事，殿下，真的，他不能。“把我欺”是该雪丝佩接下去的尾白；她现在就要上场啦，我就要在墙缝里看她。"

# game/mods/pxt/pxt.rpy:265
translate zh_hans pxt_real_start_83cdb28b:

    # py "You shall see it will fall pat as I told you." id pxt_real_start_83cdb28b
    py "你们瞧着吧，下面做下去正跟我告诉你们的完全一样。"

# game/mods/pxt/pxt.rpy:270
translate zh_hans pxt_real_start_d3fdfbc8:

    # py "—Yonder she comes." id pxt_real_start_d3fdfbc8
    py "那边她来啦。"

# game/mods/pxt/pxt.rpy:282
translate zh_hans pxt_real_start_6cf14183:

    # th "O wall, full often hast thou heard my moans," id pxt_real_start_6cf14183
    th "墙啊！你常常听得见我的呻吟，"

# game/mods/pxt/pxt.rpy:283
translate zh_hans pxt_real_start_4e4fc9d4:

    # th "For parting my fair Pyramus and me:" id pxt_real_start_4e4fc9d4
    th "怨你生生把我共他两两分拆！"

# game/mods/pxt/pxt.rpy:284
translate zh_hans pxt_real_start_f377aa8f:

    # th "My cherry lips have often kiss'd thy stones:" id pxt_real_start_f377aa8f
    th "我的樱唇常跟你的砖石亲吻，"

# game/mods/pxt/pxt.rpy:285
translate zh_hans pxt_real_start_9f32fcbb:

    # th "Thy stones with lime and hair knit up in thee." id pxt_real_start_9f32fcbb
    th "你那用水泥胶得紧紧的砖石。"

# game/mods/pxt/pxt.rpy:292
translate zh_hans pxt_real_start_b68f18a4:

    # py "I see a voice; now will I to the chink," id pxt_real_start_b68f18a4
    py "我瞧见一个声音；让我去望望，"

# game/mods/pxt/pxt.rpy:293
translate zh_hans pxt_real_start_cee1c0ec:

    # py "To spy an I can hear my Thisby's face." id pxt_real_start_cee1c0ec
    py "不知可能听见雪丝佩的脸庞。"

# game/mods/pxt/pxt.rpy:298
translate zh_hans pxt_real_start_022aca68:

    # py "Thisby!" id pxt_real_start_022aca68
    py "雪丝佩！"

# game/mods/pxt/pxt.rpy:305
translate zh_hans pxt_real_start_af3a51b6:

    # th "My love! thou art my love, I think." id pxt_real_start_af3a51b6
    th "那是我的好人儿，我想。"

# game/mods/pxt/pxt.rpy:312
translate zh_hans pxt_real_start_b26e6417:

    # py "Think what thou wilt, I am thy lover's grace;" id pxt_real_start_b26e6417
    py "尽你想吧，我是你风流的情郎。"

# game/mods/pxt/pxt.rpy:313
translate zh_hans pxt_real_start_71a4df81:

    # py "And like Limander am I trusty still." id pxt_real_start_71a4df81
    py "好像李芒特，我此心永无变更。"

# game/mods/pxt/pxt.rpy:320
translate zh_hans pxt_real_start_55953807:

    # th "And I like Helen, till the fates me kill." id pxt_real_start_55953807
    th "我就像海伦，到死也决不变心。"

# game/mods/pxt/pxt.rpy:327
translate zh_hans pxt_real_start_691a6127:

    # py "Not Shafalus to Procrus was so true." id pxt_real_start_691a6127
    py "沙发勒斯对待普洛克勒斯不过如此。"

# game/mods/pxt/pxt.rpy:334
translate zh_hans pxt_real_start_6c32255b:

    # th "As Shafalus to Procrus, I to you." id pxt_real_start_6c32255b
    th "你就是普洛克勒斯，我就是沙发勒斯。"

# game/mods/pxt/pxt.rpy:341
translate zh_hans pxt_real_start_d521d018:

    # py "O, kiss me through the hole of this vile wall." id pxt_real_start_d521d018
    py "啊，在这堵万恶的墙缝中请给我一吻！"

# game/mods/pxt/pxt.rpy:348
translate zh_hans pxt_real_start_73c5188b:

    # th "I kiss the wall's hole, not your lips at all." id pxt_real_start_73c5188b
    th "我吻着墙缝，可全然吻不到你的嘴唇。"

# game/mods/pxt/pxt.rpy:355
translate zh_hans pxt_real_start_918a0210:

    # py "Wilt thou at Ninny's tomb meet me straightway?" id pxt_real_start_918a0210
    py "你肯不肯到尼内的坟头去跟我相聚？"

# game/mods/pxt/pxt.rpy:362
translate zh_hans pxt_real_start_be157703:

    # th "'Tide life, 'tide death, I come without delay." id pxt_real_start_be157703
    th "活也好，死也好，我一准立刻动身前去。"

# game/mods/pxt/pxt.rpy:367
translate zh_hans pxt_real_start_363bc04f:

    # wa "Thus have I, wall, my part discharged so;" id pxt_real_start_363bc04f
    wa "现在我已把墙头扮好，"

# game/mods/pxt/pxt.rpy:368
translate zh_hans pxt_real_start_016f702c:

    # wa "And, being done, thus Wall away doth go." id pxt_real_start_016f702c
    wa "因此我便要拔脚去了。"

# game/mods/pxt/pxt.rpy:382
translate zh_hans pxt_real_start_304c5e38:

    # the "Now is the mural down between the two neighbours." id pxt_real_start_304c5e38
    the "现在隔在这两份人家之间的墙头已经倒下了。"

# game/mods/pxt/pxt.rpy:383
translate zh_hans pxt_real_start_eda32202:

    # dem "No remedy, my lord, when walls are so wilful to hear without warning." id pxt_real_start_eda32202
    dem "殿下，墙头要是都像这样随随便便偷听人家的谈话起来，可真没法好想。"

# game/mods/pxt/pxt.rpy:384
translate zh_hans pxt_real_start_2deeefac:

    # hip "This is the silliest stuff that ever I heard." id pxt_real_start_2deeefac
    hip "我从来没有听到过比这再蠢的东西。"

# game/mods/pxt/pxt.rpy:385
translate zh_hans pxt_real_start_0515a6ba:

    # the "The best in this kind are but shadows; and the worst are no worse, if imagination amend them." id pxt_real_start_0515a6ba
    the "最好的戏剧也不过是人生的一个缩影；最坏的只要用想像补足一下，也就不会坏到甚么地方去。"

# game/mods/pxt/pxt.rpy:386
translate zh_hans pxt_real_start_db720890:

    # hip "It must be your imagination then, and not theirs." id pxt_real_start_db720890
    hip "那该是你的想像，而不是他们的想像。"

# game/mods/pxt/pxt.rpy:387
translate zh_hans pxt_real_start_b284b0f5:

    # the "If we imagine no worse of them than they of themselves, they may pass for excellent men. Here come two noble beasts in, a moon and a lion." id pxt_real_start_b284b0f5
    the "要是我们对于他们的想像并不比他们对于自己的想像更坏，那么他们也可以算得顶好的人。两只好东西登场了，一只是人，一只是狮子。"

# game/mods/pxt/pxt.rpy:398
translate zh_hans pxt_real_start_cbe2296c:

    # lio "You, ladies, you, whose gentle hearts do fear" id pxt_real_start_cbe2296c
    lio "各位太太小姐们，"

# game/mods/pxt/pxt.rpy:399
translate zh_hans pxt_real_start_b7b8c81e:

    # lio "The smallest monstrous mouse that creeps on floor," id pxt_real_start_b7b8c81e
    lio "你们那柔弱的心一见了地板上爬着的一头顶小的老鼠就会害怕，"

# game/mods/pxt/pxt.rpy:400
translate zh_hans pxt_real_start_414d5fa6:

    # lio "May now, perchance, both quake and tremble here," id pxt_real_start_414d5fa6
    lio "现在看见一头凶暴的狮子发狂地怒吼，"

# game/mods/pxt/pxt.rpy:401
translate zh_hans pxt_real_start_00b3925e:

    # lio "When lion rough in wildest rage doth roar." id pxt_real_start_00b3925e
    lio "多分要发起抖来的吧？"

# game/mods/pxt/pxt.rpy:406
translate zh_hans pxt_real_start_a53c624a:

    # lio "Then know that I, one Snug the joiner, am" id pxt_real_start_a53c624a
    lio "但是请你们放心，我实在是细木工匠史纳格，"

# game/mods/pxt/pxt.rpy:407
translate zh_hans pxt_real_start_7f4c78ac:

    # lio "A lion fell, nor else no lion's dam:" id pxt_real_start_7f4c78ac
    lio "既不是凶猛的公狮，也不是一头母狮；"

# game/mods/pxt/pxt.rpy:412
translate zh_hans pxt_real_start_3699d9dd:

    # lio "For, if I should as lion come in strife" id pxt_real_start_3699d9dd
    lio "要是我真的是一头狮子而冲到这儿来，"

# game/mods/pxt/pxt.rpy:413
translate zh_hans pxt_real_start_65785132:

    # lio "Into this place, 'twere pity on my life." id pxt_real_start_65785132
    lio "那我才大倒其霉！"

# game/mods/pxt/pxt.rpy:416
translate zh_hans pxt_real_start_27b9e599:

    # the "A very gentle beast, and of a good conscience." id pxt_real_start_27b9e599
    the "一头非常善良的野兽，有一颗好良心。"

# game/mods/pxt/pxt.rpy:417
translate zh_hans pxt_real_start_1d393753:

    # dem "The very best at a beast, my lord, that e'er I saw." id pxt_real_start_1d393753
    dem "殿下，这是我所看见过的最好的野兽了。"

# game/mods/pxt/pxt.rpy:418
translate zh_hans pxt_real_start_992e5227:

    # lys "This lion is a very fox for his valour." id pxt_real_start_992e5227
    lys "这头狮子按勇气说只好算是一只狐狸。"

# game/mods/pxt/pxt.rpy:419
translate zh_hans pxt_real_start_5a4b8447:

    # the "True; and a goose for his discretion." id pxt_real_start_5a4b8447
    the "对了，而且按它那小心翼翼的样子说起来倒像是一头鹅。"

# game/mods/pxt/pxt.rpy:420
translate zh_hans pxt_real_start_bc025004:

    # dem "Not so, my lord; for his valour cannot carry his discretion, and the fox carries the goose." id pxt_real_start_bc025004
    dem "那倒不，殿下，因为它的勇敢并不带着思虑，而狐狸却能叼走鹅。"

# game/mods/pxt/pxt.rpy:421
translate zh_hans pxt_real_start_10a2d717:

    # the "His discretion, I am sure, cannot carry his valour; for the goose carries not the fox. It is well; leave it to his discretion, and let us listen to the moon." id pxt_real_start_10a2d717
    the "我觉得它的思虑也并不带着勇敢，因为鹅可叼不走狐狸。好，别管他吧，让我们听月亮说话。"

# game/mods/pxt/pxt.rpy:429
translate zh_hans pxt_real_start_d12f3204:

    # mo "This lanthorn doth the horned moon present:" id pxt_real_start_d12f3204
    mo "这盏灯笼代表着角儿弯弯的新月；"

# game/mods/pxt/pxt.rpy:432
translate zh_hans pxt_real_start_73f74815:

    # dem "He should have worn the horns on his head." id pxt_real_start_73f74815
    dem "他应当把角装在头上"

# game/mods/pxt/pxt.rpy:433
translate zh_hans pxt_real_start_59317d5a:

    # the "He is no crescent, and his horns are invisible within the circumference." id pxt_real_start_59317d5a
    the "他并不是新月，圆圆的那里有个角儿？"

# game/mods/pxt/pxt.rpy:438
translate zh_hans pxt_real_start_773dfb10:

    # mo "This lanthorn doth the horned moon present;" id pxt_real_start_773dfb10
    mo "这盏灯笼代表着角儿弯弯的新月；"

# game/mods/pxt/pxt.rpy:443
translate zh_hans pxt_real_start_ba1e935a:

    # mo "Myself the man i' the moon do seem to be." id pxt_real_start_ba1e935a
    mo "我好像就是月亮里的仙人。"

# game/mods/pxt/pxt.rpy:446
translate zh_hans pxt_real_start_2aa3b772:

    # the "This is the greatest error of all the rest: the man should be put into the lantern. How is it else the man i' the moon?" id pxt_real_start_2aa3b772
    the "这该是最大的错误了。应该把这个人放进灯笼里去；否则他怎么会是月亮里的仙人呢？"

# game/mods/pxt/pxt.rpy:447
translate zh_hans pxt_real_start_30ffd954:

    # dem "He dares not come there for the candle: for, you see, it is already in snuff." id pxt_real_start_30ffd954
    dem "他因为怕蜡烛不敢进去。瞧，他恼了。"

# game/mods/pxt/pxt.rpy:448
translate zh_hans pxt_real_start_77c63cea:

    # hip "I am aweary of this moon: would he would change!" id pxt_real_start_77c63cea
    hip "这月亮真使我厌倦；他应该变化变化才好！"

# game/mods/pxt/pxt.rpy:449
translate zh_hans pxt_real_start_ff9a80bb:

    # the "It appears, by his small light of discretion, that he is in the wane: but yet, in courtesy, in all reason, we must stay the time." id pxt_real_start_ff9a80bb
    the "照他那知觉欠缺的样子看起来，他大概是一个缺月；但是为着礼貌和一切的理由，我们得忍耐一下。"

# game/mods/pxt/pxt.rpy:450
translate zh_hans pxt_real_start_6eea599d:

    # lys "Proceed, moon." id pxt_real_start_6eea599d
    lys "说下去，月亮。"

# game/mods/pxt/pxt.rpy:455
translate zh_hans pxt_real_start_3c40ade8:

    # mo "All that I have to say, is to tell you that the lantern is the moon;" id pxt_real_start_3c40ade8
    mo "总而言之，我要告诉你们的是，这灯笼便是月亮；"

# game/mods/pxt/pxt.rpy:460
translate zh_hans pxt_real_start_94f7fce3:

    # mo "I, the man i' the moon;" id pxt_real_start_94f7fce3
    mo "我便是月亮里的仙人；"

# game/mods/pxt/pxt.rpy:465
translate zh_hans pxt_real_start_7919a907:

    # mo "This thorn-bush, my thorn-bush;" id pxt_real_start_7919a907
    mo "这柴枝是我的柴枝；"

# game/mods/pxt/pxt.rpy:466
translate zh_hans pxt_real_start_de131351:

    # mo "And this dog, my dog." id pxt_real_start_de131351
    mo "这狗是我的狗。"

# game/mods/pxt/pxt.rpy:469
translate zh_hans pxt_real_start_5ef409a1:

    # dem "Why, all these should be in the lantern; for all these are in the moon. But silence; here comes Thisbe." id pxt_real_start_5ef409a1
    dem "嗨，这些都应该放进灯笼里去才对，因为它们都是在月亮里的。但是静些，雪丝佩来了。"

# game/mods/pxt/pxt.rpy:482
translate zh_hans pxt_real_start_858fc504:

    # th "This is old Ninny's tomb. Where is my love?" id pxt_real_start_858fc504
    th "这是尼内老人的坟。我的爱人呢？"

# game/mods/pxt/pxt.rpy:487
translate zh_hans pxt_real_start_698fc2af:

    # lio "Oh!" id pxt_real_start_698fc2af
    lio "呜……！"

# game/mods/pxt/pxt.rpy:498
translate zh_hans pxt_real_start_990d4601:

    # dem "Well roared, lion." id pxt_real_start_990d4601
    dem "吼得好，狮子。"

# game/mods/pxt/pxt.rpy:499
translate zh_hans pxt_real_start_973ea59c:

    # the "Well run, Thisbe." id pxt_real_start_973ea59c
    the "跑得好，雪丝佩！"

# game/mods/pxt/pxt.rpy:500
translate zh_hans pxt_real_start_e0cc5d24:

    # hip "Well shone, moon. —Truly, the moon shines with a good grace." id pxt_real_start_e0cc5d24
    hip "照得好，月亮！真的，月亮照得姿势很好。"

# game/mods/pxt/pxt.rpy:514
translate zh_hans pxt_real_start_78b85f55:

    # the "Well moused, lion." id pxt_real_start_78b85f55
    the "撕得好，狮子！"

# game/mods/pxt/pxt.rpy:515
translate zh_hans pxt_real_start_12febeb9:

    # dem "And so comes Pyramus." id pxt_real_start_12febeb9
    dem "于是匹拉麦斯来了。"

# game/mods/pxt/pxt.rpy:516
translate zh_hans pxt_real_start_150c8b27:

    # lys "And then the lion vanishes." id pxt_real_start_150c8b27
    lys "于是狮子不见了。"

# game/mods/pxt/pxt.rpy:529
translate zh_hans pxt_real_start_3af75a6e:

    # py "Sweet moon, I thank thee for thy sunny beams;" id pxt_real_start_3af75a6e
    py "可爱的月亮，我多谢你的阳光；"

# game/mods/pxt/pxt.rpy:530
translate zh_hans pxt_real_start_5deb40d2:

    # py "I thank thee, moon, for shining now so bright:" id pxt_real_start_5deb40d2
    py "谢谢你，因为你照得这么皎洁！"

# game/mods/pxt/pxt.rpy:531
translate zh_hans pxt_real_start_50ae1825:

    # py "For, by thy gracious golden, glittering streams," id pxt_real_start_50ae1825
    py "靠着你那慈和的闪烁的金光，"

# game/mods/pxt/pxt.rpy:532
translate zh_hans pxt_real_start_fe1392b9:

    # py "I trust to take of truest Thisby's sight." id pxt_real_start_fe1392b9
    py "我将要饱餐着雪丝佩的秀色。"

# game/mods/pxt/pxt.rpy:537
translate zh_hans pxt_real_start_23ed37e0:

    # py "But stay;—O spite!" id pxt_real_start_23ed37e0
    py "但是且住，啊该死！"

# game/mods/pxt/pxt.rpy:538
translate zh_hans pxt_real_start_9a0019dc:

    # py "But mark,—poor knight," id pxt_real_start_9a0019dc
    py "瞧哪，可怜的武士，"

# game/mods/pxt/pxt.rpy:539
translate zh_hans pxt_real_start_1ef8b033:

    # py "What dreadful dole is here!" id pxt_real_start_1ef8b033
    py "这是一场什么惨景！"

# game/mods/pxt/pxt.rpy:540
translate zh_hans pxt_real_start_085e8884:

    # py "Eyes, do you see?" id pxt_real_start_085e8884
    py "眼睛，你看不看见？"

# game/mods/pxt/pxt.rpy:545
translate zh_hans pxt_real_start_48f229b1:

    # py "How can it be?" id pxt_real_start_48f229b1
    py "这种事怎会发生？"

# game/mods/pxt/pxt.rpy:546
translate zh_hans pxt_real_start_a3fed112:

    # py "O dainty duck! O dear!" id pxt_real_start_a3fed112
    py "可爱的宝贝啊，亲亲！"

# game/mods/pxt/pxt.rpy:547
translate zh_hans pxt_real_start_14848e49:

    # py "Thy mantle good," id pxt_real_start_14848e49
    py "你的好外套一件，"

# game/mods/pxt/pxt.rpy:548
translate zh_hans pxt_real_start_0dc44d52:

    # py "What! stained with blood?" id pxt_real_start_0dc44d52
    py "怎么全都是血点？"

# game/mods/pxt/pxt.rpy:549
translate zh_hans pxt_real_start_df934b72:

    # py "Approach, ye furies fell!" id pxt_real_start_df934b72
    py "过来吧，狰狞的凶神！"

# game/mods/pxt/pxt.rpy:550
translate zh_hans pxt_real_start_44fcc6c9:

    # py "O fates! come, come;" id pxt_real_start_44fcc6c9
    py "快把生命的枷锁；"

# game/mods/pxt/pxt.rpy:555
translate zh_hans pxt_real_start_1aaa6cd4:

    # py "Cut thread and thrum;" id pxt_real_start_1aaa6cd4
    py "从此后一刀割断；"

# game/mods/pxt/pxt.rpy:556
translate zh_hans pxt_real_start_d0a56a20:

    # py "Quail, rush, conclude, and quell!" id pxt_real_start_d0a56a20
    py "今朝我了结了残生！"

# game/mods/pxt/pxt.rpy:559
translate zh_hans pxt_real_start_4ee18586:

    # the "This passion, and the death of a dear friend, would go near to make a man look sad." id pxt_real_start_4ee18586
    the "这一种情感再加上一个好朋友的死，很可以使一个人脸带愁容。"

# game/mods/pxt/pxt.rpy:560
translate zh_hans pxt_real_start_6098cd59:

    # hip "Beshrew my heart, but I pity the man." id pxt_real_start_6098cd59
    hip "该死！我倒真有点可怜这个人。"

# game/mods/pxt/pxt.rpy:565
translate zh_hans pxt_real_start_0abdb4d0:

    # py "O wherefore, nature, didst thou lions frame?" id pxt_real_start_0abdb4d0
    py "苍天啊！你为什么要造下狮子，"

# game/mods/pxt/pxt.rpy:566
translate zh_hans pxt_real_start_b8caa1ee:

    # py "Since lion vile hath here deflower'd my dear;" id pxt_real_start_b8caa1ee
    py "让它在这里蹂躏了我的爱人？"

# game/mods/pxt/pxt.rpy:567
translate zh_hans pxt_real_start_c084fff3:

    # py "Which is—no, no—which was the fairest dame" id pxt_real_start_c084fff3
    py "她在一切活着爱着的人中，"

# game/mods/pxt/pxt.rpy:568
translate zh_hans pxt_real_start_c7a61d0b:

    # py "That liv'd, that lov'd, that lik'd, that look'd with cheer." id pxt_real_start_c7a61d0b
    py "是一个最美最美最最美的美人。"

# game/mods/pxt/pxt.rpy:569
translate zh_hans pxt_real_start_469b4631:

    # py "Come, tears, confound;" id pxt_real_start_469b4631
    py "淋漓地流吧，眼泪！"

# game/mods/pxt/pxt.rpy:570
translate zh_hans pxt_real_start_6dc32f6d:

    # py "Out, sword, and wound" id pxt_real_start_6dc32f6d
    py "我要把宝剑一挥，"

# game/mods/pxt/pxt.rpy:571
translate zh_hans pxt_real_start_d73cb223:

    # py "The pap of Pyramus:" id pxt_real_start_d73cb223
    py "当着我的胸头划破："

# game/mods/pxt/pxt.rpy:576
translate zh_hans pxt_real_start_3ab1d420:

    # py "Ay, that left pap," id pxt_real_start_3ab1d420
    py "一剑刺过了左胸，"

# game/mods/pxt/pxt.rpy:577
translate zh_hans pxt_real_start_1ca60a46:

    # py "Where heart doth hop:—" id pxt_real_start_1ca60a46
    py "叫心儿莫再跳动，"

# game/mods/pxt/pxt.rpy:578
translate zh_hans pxt_real_start_38e29cec:

    # py "Thus die I,{w} thus,{w} thus,{w} thus." id pxt_real_start_38e29cec
    py "这样我就死啰{w}死啰！"

# game/mods/pxt/pxt.rpy:584
translate zh_hans pxt_real_start_5198726e:

    # py "Now am I dead," id pxt_real_start_5198726e
    py "现在我已经身死，"

# game/mods/pxt/pxt.rpy:585
translate zh_hans pxt_real_start_9743c7c7:

    # py "Now am I fled;" id pxt_real_start_9743c7c7
    py "现在我已经消逝，"

# game/mods/pxt/pxt.rpy:586
translate zh_hans pxt_real_start_43f23b56:

    # py "My soul is in the sky:" id pxt_real_start_43f23b56
    py "我灵魂儿升到天堂；"

# game/mods/pxt/pxt.rpy:587
translate zh_hans pxt_real_start_ecf629dc:

    # py "Tongue, lose thy light!" id pxt_real_start_ecf629dc
    py "太阳，不要再照耀！"

# game/mods/pxt/pxt.rpy:588
translate zh_hans pxt_real_start_262dc6f5:

    # py "Moon, take thy flight!" id pxt_real_start_262dc6f5
    py "月亮，给我拔脚跑！"

# game/mods/pxt/pxt.rpy:589
translate zh_hans pxt_real_start_f8fb85a4:

    # py "Now die,{w} die,{w} die,{w} die,{w} die." id pxt_real_start_f8fb85a4
    py "我已一命，{w}一命丧亡。"

# game/mods/pxt/pxt.rpy:600
translate zh_hans pxt_real_start_f12b49f9:

    # dem "No die, but an ace, for him; for he is but one." id pxt_real_start_f12b49f9
    dem "不是双亡，是单亡，因为他是孤零零地死去。"

# game/mods/pxt/pxt.rpy:601
translate zh_hans pxt_real_start_623564a2:

    # lys "Less than an ace, man; for he is dead; he is nothing." id pxt_real_start_623564a2
    lys "他现在死去，不但成不了双，而且成不了单；他已经变成“没有”啦。"

# game/mods/pxt/pxt.rpy:602
translate zh_hans pxt_real_start_be275cfd:

    # the "With the help of a surgeon he might yet recover and prove an ass." id pxt_real_start_be275cfd
    the "要是就去请外科医生来，也许还可以把他医活转来，叫他做一头驴子。"

# game/mods/pxt/pxt.rpy:603
translate zh_hans pxt_real_start_a3daeceb:

    # hip "How chance moonshine is gone before Thisbe comes back and finds her lover?" id pxt_real_start_a3daeceb
    hip "雪丝佩还要回来看见她的爱人，月亮怎么这样性急便去了呢？"

# game/mods/pxt/pxt.rpy:604
translate zh_hans pxt_real_start_588449ae:

    # the "She will find him by starlight.—Here she comes; and her passion ends the play." id pxt_real_start_588449ae
    the "她可以在星光底下看见他的，现在她来了。她再痛哭流涕一下子，戏文也就完了。"

# game/mods/pxt/pxt.rpy:612
translate zh_hans pxt_real_start_90c44bb2:

    # hip "Methinks she should not use a long one for such a Pyramus: I hope she will be brief." id pxt_real_start_90c44bb2
    hip "我想对于这样一个宝货的匹拉麦斯，她可以不必浪费口舌；我希望她说得短一点儿。"

# game/mods/pxt/pxt.rpy:613
translate zh_hans pxt_real_start_4d006551:

    # dem "A mote will turn the balance, which Pyramus, which Thisbe, is the better." id pxt_real_start_4d006551
    dem "她跟匹拉麦斯较量起来真是半斤对八两。上帝保佑我们不要嫁到这种男人，也保佑我们不要娶着这种妻子！"

# game/mods/pxt/pxt.rpy:614
translate zh_hans pxt_real_start_961e5373:

    # lys "She hath spied him already with those sweet eyes." id pxt_real_start_961e5373
    lys "她那秋波已经看见他了。"

# game/mods/pxt/pxt.rpy:615
translate zh_hans pxt_real_start_550b2333:

    # dem "And thus she moans, videlicet.—" id pxt_real_start_550b2333
    dem "于是悲声而言曰：——"

# game/mods/pxt/pxt.rpy:620
translate zh_hans pxt_real_start_8c2e33fc:

    # th "Asleep, my love?" id pxt_real_start_8c2e33fc
    th "睡着了吗，我的爱人？"

# game/mods/pxt/pxt.rpy:621
translate zh_hans pxt_real_start_e4d030ed:

    # th "What, dead, my dove?" id pxt_real_start_e4d030ed
    th "啊！死了，我的爱人？"

# game/mods/pxt/pxt.rpy:626
translate zh_hans pxt_real_start_0e1baa2c:

    # th "O Pyramus, arise," id pxt_real_start_0e1baa2c
    th "匹拉麦斯啊，快醒醒！"

# game/mods/pxt/pxt.rpy:627
translate zh_hans pxt_real_start_4a5e35f0:

    # th "Speak, speak. Quite dumb?" id pxt_real_start_4a5e35f0
    th "说呀！说呀！哑了吗？"

# game/mods/pxt/pxt.rpy:628
translate zh_hans pxt_real_start_095fa3d3:

    # th "Dead, dead? A tomb" id pxt_real_start_095fa3d3
    th "唉，死了！一堆黄沙！"

# game/mods/pxt/pxt.rpy:629
translate zh_hans pxt_real_start_942d03be:

    # th "Must cover thy sweet eyes." id pxt_real_start_942d03be
    th "将要盖住你的美睛。"

# game/mods/pxt/pxt.rpy:630
translate zh_hans pxt_real_start_b7ff77cd:

    # th "These lily lips," id pxt_real_start_b7ff77cd
    th "嘴唇像百合花开，"

# game/mods/pxt/pxt.rpy:631
translate zh_hans pxt_real_start_34858005:

    # th "This cherry nose," id pxt_real_start_34858005
    th "鼻子像樱桃可爱，"

# game/mods/pxt/pxt.rpy:632
translate zh_hans pxt_real_start_72c5d56e:

    # th "These yellow cowslip cheeks," id pxt_real_start_72c5d56e
    th "黄花像是你的脸孔，"

# game/mods/pxt/pxt.rpy:633
translate zh_hans pxt_real_start_945c8bbe:

    # th "Are gone, are gone:" id pxt_real_start_945c8bbe
    th "一齐消失，消失了，"

# game/mods/pxt/pxt.rpy:638
translate zh_hans pxt_real_start_f0aca02b:

    # th "Lovers, make moan!" id pxt_real_start_f0aca02b
    th "有情人同声哀悼！"

# game/mods/pxt/pxt.rpy:639
translate zh_hans pxt_real_start_18d267a7:

    # th "His eyes were green as leeks." id pxt_real_start_18d267a7
    th "他眼睛绿得像青葱。"

# game/mods/pxt/pxt.rpy:640
translate zh_hans pxt_real_start_1b0c1044:

    # th "O Sisters Three," id pxt_real_start_1b0c1044
    th "啊，命运三女神，"

# game/mods/pxt/pxt.rpy:641
translate zh_hans pxt_real_start_79a29738:

    # th "Come, come to me," id pxt_real_start_79a29738
    th "来，来到我身边，"

# game/mods/pxt/pxt.rpy:642
translate zh_hans pxt_real_start_2f93dc5d:

    # th "With hands as pale as milk;" id pxt_real_start_2f93dc5d
    th "你们的手像奶一样白。"

# game/mods/pxt/pxt.rpy:643
translate zh_hans pxt_real_start_7ed2a57a:

    # th "Lay them in gore," id pxt_real_start_7ed2a57a
    th "请把它们泡在血里面，"

# game/mods/pxt/pxt.rpy:644
translate zh_hans pxt_real_start_6230f218:

    # th "Since you have shore" id pxt_real_start_6230f218
    th "因为你们用剪刀，"

# game/mods/pxt/pxt.rpy:645
translate zh_hans pxt_real_start_e097e19c:

    # th "With shears his thread of silk." id pxt_real_start_e097e19c
    th "剪断了他的生命线。"

# game/mods/pxt/pxt.rpy:650
translate zh_hans pxt_real_start_d5cede04:

    # th "Tongue, not a word:—" id pxt_real_start_d5cede04
    th "舌头，不许再多言！"

# game/mods/pxt/pxt.rpy:651
translate zh_hans pxt_real_start_a90ac956:

    # th "Come, trusty sword;" id pxt_real_start_a90ac956
    th "凭着这一柄好剑，"

# game/mods/pxt/pxt.rpy:652
translate zh_hans pxt_real_start_bedc94b8:

    # th "Come, blade, my breast imbrue;" id pxt_real_start_bedc94b8
    th "赶快把我的胸膛刺穿。"

# game/mods/pxt/pxt.rpy:653
translate zh_hans pxt_real_start_b581d9ad:

    # th "And farewell, friends:—" id pxt_real_start_b581d9ad
    th "再会，亲爱的朋友！"

# game/mods/pxt/pxt.rpy:654
translate zh_hans pxt_real_start_a7a8f30c:

    # th "Thus Thisby ends;" id pxt_real_start_a7a8f30c
    th "雪丝佩已经毙命；"

# game/mods/pxt/pxt.rpy:655
translate zh_hans pxt_real_start_6b8accfc:

    # th "Adieu,{w} adieu,{w} adieu." id pxt_real_start_6b8accfc
    th "再见吧，{w}再见吧，{w}再见！"

# game/mods/pxt/pxt.rpy:669
translate zh_hans pxt_real_start_91aa8908:

    # the "Moonshine and lion are left to bury the dead." id pxt_real_start_91aa8908
    the "他们的葬事要让月亮和狮子来料理了吧？"

# game/mods/pxt/pxt.rpy:670
translate zh_hans pxt_real_start_cbab053d:

    # dem "Ay, and wall too." id pxt_real_start_cbab053d
    dem "是啊，还有墙头。"

# game/mods/pxt/pxt.rpy:676
translate zh_hans pxt_real_start_accd657c:

    # bo "No, I assure you; the wall is down that parted their fathers. Will it please you to see the epilogue, or to hear a Bergomask dance between two of our company?" id pxt_real_start_accd657c
    bo "不，我对你们说，那堵隔开他们两家的墙早已经倒了。你们要不要瞧瞧收场诗，或者听一场我们两个伙计的贝戈舞？"

# game/mods/pxt/pxt.rpy:678
translate zh_hans pxt_real_start_f1176961:

    # the "No epilogue, I pray you; for your play needs no excuse. " id pxt_real_start_f1176961
    the "请把收场诗免了吧，因为你们的戏剧无须再有什么解释。"

# game/mods/pxt/pxt.rpy:679
translate zh_hans pxt_real_start_fe7284d2:

