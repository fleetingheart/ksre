translate zh_hans pxt_real_start_50de0093:

    # pr "Anon comes Pyramus, sweet youth, and tall," id pxt_real_start_50de0093
    pr "隔了不久，匹拉麦斯，那个高个儿的美少年，也来了"

# game/mods/pxt/pxt.rpy:158
