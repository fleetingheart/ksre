# game/mods/pxt/pxt.rpy:159
translate zh_hans pxt_real_start_437f3af2:

    # pr "Whereat with blade, with bloody blameful blade," id pxt_real_start_437f3af2
    pr "便赤楞楞的一声拔出一把血淋淋的剑来，"

# game/mods/pxt/pxt.rpy:160
translate zh_hans pxt_real_start_c27a0c38:

    # pr "He bravely broach'd his boiling bloody breast;" id pxt_real_start_c27a0c38
