    # the "This fellow doth not stand upon points." id pxt_real_start_5a1ade2d
    the "这家伙简直乱来。"

# game/mods/pxt/pxt.rpy:89
translate zh_hans pxt_real_start_f2a94332:

    # lys "He hath rid his prologue like a rough colt; he knows not the stop. A good moral, my lord: it is not enough to speak, but to speak true." id pxt_real_start_f2a94332
    lys "他念他的开场诗就像骑一头顽劣的小马一样，乱冲乱撞，该停的地方不停，不该停的地方偏偏停下。殿下，这是一个好教训：单是会讲话不能算数，要讲话总该讲得像个路数。"

# game/mods/pxt/pxt.rpy:90
translate zh_hans pxt_real_start_6f1ede59:

    # hip "Indeed he hath played on this prologue like a child on a recorder; a sound, but not in government." id pxt_real_start_6f1ede59
