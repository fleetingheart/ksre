translate pt_br a1_saturday_shanghaied_dc2e21cd:

    # hi "So the tea shop was a trap after all! You two-timing scoundrels!"
    hi "Assim, a loja de chá era uma armadilha depois de tudo! Suas trapaceiras!"

# game/script-a1-saturday.rpy:3017
