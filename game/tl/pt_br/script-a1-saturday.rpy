translate pt_br a1_saturday_shanghaied_4f078693:

    # mi "Hicchan, it's your duty to help us, anyway! As a member of the Student Council!"
    mi "Hisaozinho, é seu dever nos ajudar, de qualquer maneira! Como membro do Conselho Estudantil!"

# game/script-a1-saturday.rpy:3073
translate pt_br a1_saturday_shanghaied_68eb1831:

    # hi "All right, all right! How could I forget?"
    hi "Tudo bem, tudo bem! Como eu poderia esquecer?"

# game/script-a1-saturday.rpy:3075
translate pt_br a1_saturday_shanghaied_4906130e:

    # hi "But, seriously, aren't there other people who can help you?"
    hi "Mas, sério, não existem outras pessoas que possam ajudá-las?"

# game/script-a1-saturday.rpy:3080
translate pt_br a1_saturday_shanghaied_57e8daa2:

    # mi "Like who, Hicchan?"
    mi "Como quem, Hisaozinho?"

# game/script-a1-saturday.rpy:3082
translate pt_br a1_saturday_shanghaied_543a2ac3:

    # mi "You were fine with helping us yesterday…"
    mi "Você estava bem nos ajudando ontem…"

# game/script-a1-saturday.rpy:3084
translate pt_br a1_saturday_shanghaied_a2c615ef:

    # hi "Yesterday is not today!"
    hi "Ontem não é hoje!"

# game/script-a1-saturday.rpy:3086
translate pt_br a1_saturday_shanghaied_0d9cb7f4:

    # hi "And anyone who isn't me!"
    hi "E qualquer um que não seja eu!"

# game/script-a1-saturday.rpy:3088
translate pt_br a1_saturday_shanghaied_9767f6fd:

    # hi "Why don't you have anyone else in the council?"
    hi "Por que não tem mais ninguém no conselho?"

# game/script-a1-saturday.rpy:3093
translate pt_br a1_saturday_shanghaied_b33ba1f7_4:

    # shi "…!"
    shi "…!"

# game/script-a1-saturday.rpy:3098
translate pt_br a1_saturday_shanghaied_313e6ace:

    # mi "That's what we'd like to know! …Aha… Ahahahahaha!"
    mi "Isso é o que nós gostaríamos de saber! …Aha… Ahahahahaha!"

# game/script-a1-saturday.rpy:3100
translate pt_br a1_saturday_shanghaied_d9c879ec:

    # "Misha's laughter explodes through the hall. She doesn't notice the grimace on my face at all. That's right, it's just the two of them, isn't it?"
    "A risada de Misha explode pelo hall. Ela não percebe a careta em meu rosto. É isso mesmo, são só as duas, não é?"

# game/script-a1-saturday.rpy:3102
translate pt_br a1_saturday_shanghaied_ce1e6a3a:

    # hi "Oh, right. Okay, I'll help you."
    hi "Oh, certo. Ok, eu vou ajudá-la."

# game/script-a1-saturday.rpy:3107
translate pt_br a1_saturday_shanghaied_fff80d75:

    # "Misha runs her tongue over her teeth, looking quite pleased."
    "Misha corre a língua sobre os dentes, parecendo bastante satisfeita."

# game/script-a1-saturday.rpy:3109
translate pt_br a1_saturday_shanghaied_1d9b5f48:

    # mi "That's my Hicchan! I knew we could trust you~!"
    mi "Esse é o meu Hisaozinho! Eu sabia que podia confiar em você~!"

# game/script-a1-saturday.rpy:3114
translate pt_br a1_saturday_shanghaied_b33ba1f7_5:

    # shi "…!"
    shi "…!"

# game/script-a1-saturday.rpy:3116
translate pt_br a1_saturday_shanghaied_f9753e72:

    # mi "So predictable~."
    mi "Tão previsível~."

# game/script-a1-saturday.rpy:3123
translate pt_br a1_saturday_shanghaied_328710e1:

    # "When we get to the student council room, my jaw drops. The number of signs, backing boards, and signposts is insane."
    "Quando chegamos à sala do Conselho Estudantil, meu queixo caiu. O número de sinais, placas de apoio e placas de sinalização era insano."

# game/script-a1-saturday.rpy:3125
translate pt_br a1_saturday_shanghaied_d20d114b:

    # "They're stacked all over the place like building materials at a construction site, something I let Shizune and Misha know right off the bat."
    "Elas estão empilhadas em todo o lugar, como materiais de construção em um canteiro de obras, algo que eu deixei Shizune e Misha saberem logo de cara."

# game/script-a1-saturday.rpy:3127
translate pt_br a1_saturday_shanghaied_334e0310:

    # hi "There are so many signposts here you could probably build a second wall around the school with them!"
    hi "Há tantas placas de sinalização aqui você provavelmente poderia construir um segundo muro ao redor da escola com eles!"

# game/script-a1-saturday.rpy:3135
translate pt_br a1_saturday_shanghaied_39ccfd02:

    # mi "Hahaha~! Really? Well, there are a lot of them, so maybe…"
    mi "Hahaha~! Realmente? Bem, há muitas delas, talvez por isso…"

# game/script-a1-saturday.rpy:3140
translate pt_br a1_saturday_shanghaied_b33ba1f7_6:

    # shi "…!"
    shi "…!"

# game/script-a1-saturday.rpy:3145
translate pt_br a1_saturday_shanghaied_8ee40e92:

