    shi "…!"

# game/script-a1-saturday.rpy:3036
translate pt_br a1_saturday_shanghaied_c1a069d6:

    # mi "No buts! You're coming with us!"
    mi "Sem mas! Você vem com a gente!"

# game/script-a1-saturday.rpy:3046
translate pt_br a1_saturday_shanghaied_0b595f35:

    # "I don't even get to finish my sentence as they grab me by the arms and try to pull me towards their office."
    "Eu nem consegui terminar minha frase e elas agarraram meus braços e tentaram me puxar até o escritório."

# game/script-a1-saturday.rpy:3051
translate pt_br a1_saturday_shanghaied_2dafcd6a:

    # "Misha laughs giddily as she and Shizune exchange sly looks behind my back."
    "Misha ri extasiadamente enquanto Shizune astutamente olha as minhas costas."

# game/script-a1-saturday.rpy:3056
translate pt_br a1_saturday_shanghaied_b33ba1f7_2:

    # shi "…!"
    shi "…!"

# game/script-a1-saturday.rpy:3058
