    emi "Bom dia, Hisao."

# game/script-a4-emi.rpy:1528
translate pt_br a4_emi_clean_teeth_2ffa756c:

    # hi "Hi. Sleep well?"
    hi "Olá. Dormiu bem?"

# game/script-a4-emi.rpy:1530
translate pt_br a4_emi_clean_teeth_2a9ad93d:

    # emi "Yeah. Yeah, I did. Exhausting day yesterday, you know?"
    emi "É, dormi. Dia cansativo aquele de ontem, sabe?"

# game/script-a4-emi.rpy:1532
translate pt_br a4_emi_clean_teeth_81be3340:

    # "I think back over yesterday's trip to the graveyard."
    "Penso em nossa viagem de ontem ao cemitério."

# game/script-a4-emi.rpy:1534
translate pt_br a4_emi_clean_teeth_81b8fed6:

    # hi "Yeah. Glad to hear you slept well."
    hi "É. Fico feliz em saber que dormiu bem."

# game/script-a4-emi.rpy:1536
translate pt_br a4_emi_clean_teeth_ebcbe393:

