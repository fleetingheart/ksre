    # "Who's there?"
    "Quem é?"

# game/script-a3-emi.rpy:4871
translate pt_br a3_emi_afterschool_plans_36c7cc88_1:

    # "Knock knock."
    "Toc toc."

# game/script-a3-emi.rpy:4873
translate pt_br a3_emi_afterschool_plans_9be89841:

    # "That's not how the joke goes at all."
    "Não é assim que piada funciona."

# game/script-a3-emi.rpy:4877
translate pt_br a3_emi_afterschool_plans_36c7cc88_2:

    # "Knock knock."
    "Toc toc."

# game/script-a3-emi.rpy:4879
translate pt_br a3_emi_afterschool_plans_d7b9ac77:

    # "I already said who's there!"
    "Eu ja disse quem é!"

# game/script-a3-emi.rpy:4881
translate pt_br a3_emi_afterschool_plans_6a728f92:

    # "More importantly, what time is it?"
    "Mais importante, que horas são?"

# game/script-a3-emi.rpy:4883
translate pt_br a3_emi_afterschool_plans_4234adba:

    # "Even more importantly, what day…?"
    
    "Ainda mais importante, que dia é hoje…?"

# game/script-a3-emi.rpy:4888
translate pt_br a3_emi_afterschool_plans_ede673b2:

    # "I am suddenly catapulted into wakefulness by both the fact that the knocking still hasn't stopped and the fact that it's noon."
    "Eu sou de repente catapultado em estado vigília por ambos o fato da bateção não ter parado e o fato de que é meio dia."

# game/script-a3-emi.rpy:4890
translate pt_br a3_emi_afterschool_plans_d07f306f:

    # "On a school day."
    "Num dia de escola."

# game/script-a3-emi.rpy:4892
translate pt_br a3_emi_afterschool_plans_eccf38d0:

    # "Now fully awake, I can remember why I was napping."
    "Agora totalmente acordado, eu consigo me lembrar porquê eu estava cochilando."

# game/script-a3-emi.rpy:4894
translate pt_br a3_emi_afterschool_plans_d39389b3:

    # "Better not give that excuse to Mutou."
    "Melhor não dar essa desculpa para o Mutou."

# game/script-a3-emi.rpy:4896
translate pt_br a3_emi_afterschool_plans_88064df2:

    # "'Sorry I wasn't in class, I was experimenting sexually with my girlfriend and it tired me out.'"
    "“Me desculpe que eu não estava na aula, eu estava experimentando algumas coisas sexuais com a minha namorada e acabei me cansando.”"

# game/script-a3-emi.rpy:4898
translate pt_br a3_emi_afterschool_plans_fa3995a1:

    # "Yeah, that'll go over well."
    "É, isso vai dar muito certo."

# game/script-a3-emi.rpy:4902
translate pt_br a3_emi_afterschool_plans_aa237850:

    # "I wonder how long this knocking is going to continue."
    "Eu imagino por quanto tempo mais essa batida vai continuar."

# game/script-a3-emi.rpy:4904
translate pt_br a3_emi_afterschool_plans_cc01b477:

    # "Guess I ought to answer the door."
    "Acho que vou ter de atender a porta."

# game/script-a3-emi.rpy:4912
translate pt_br a3_emi_afterschool_plans_4cfef8a6:

    # "I'm strangely unsurprised to see Kenji on the other side."
    "Estou estranhamente não surpreso de ver o Kenji no outro lado."

# game/script-a3-emi.rpy:4914
translate pt_br a3_emi_afterschool_plans_ad894c14:

    # "Though it appears that Kenji is surprised to see me."
    "Embora pareça que ele está surpreso em me ver."

# game/script-a3-emi.rpy:4916
translate pt_br a3_emi_afterschool_plans_3ce83633:

    # ke "What the hell are you doing here, man?"
    ke "O que diabos você está fazendo aqui, cara?"

# game/script-a3-emi.rpy:4920
translate pt_br a3_emi_afterschool_plans_23b79223:

    # hi "Well, I was sleeping."
    hi "Bem, eu estava dormindo."
    

# game/script-a3-emi.rpy:4925
translate pt_br a3_emi_afterschool_plans_26b6cce6:

    # "Kenji nods in understanding."
    "Kenji acena em entendimento."

# game/script-a3-emi.rpy:4930
translate pt_br a3_emi_afterschool_plans_e7904e52:

    # ke "Knocked out. I see."
    ke "Nocauteado, entendo."

# game/script-a3-emi.rpy:4935
translate pt_br a3_emi_afterschool_plans_ce8aa452:

    # ke "I told you to be careful around that Ibarazaki chick, man."
    ke "Eu te disse para ter cuidado com aquela mina Ibarazaki, cara."

# game/script-a3-emi.rpy:4937
translate pt_br a3_emi_afterschool_plans_9c411c39:

    # ke "This is the sort of thing that happens when you aren't cautious."
    ke "Esse é o tipo de coisa que acontece quando você não é cauteloso."

# game/script-a3-emi.rpy:4939
translate pt_br a3_emi_afterschool_plans_cafdb3d1:

    # "He makes an attempt to look at the back of my head."
    "Ele faz uma tentativa de ver a parte de trás de minha cabeça."

# game/script-a3-emi.rpy:4944
translate pt_br a3_emi_afterschool_plans_61eee3ff:

    # ke "Did she hit you with something?"
    ke "Ela te bateu com alguma coisa?"

# game/script-a3-emi.rpy:4946
translate pt_br a3_emi_afterschool_plans_6a5f0793:

    # ke "Or was it a drug?"
    ke "Ou foi uma droga?"

# game/script-a3-emi.rpy:4948
translate pt_br a3_emi_afterschool_plans_b982ff7c:

    # hi "Stop trying to touch me."
    hi "Para de tentar me tocar."

# game/script-a3-emi.rpy:4952
translate pt_br a3_emi_afterschool_plans_a6824861:

    # "Kenji produces a flashlight and shines it in my eyes."
    "Kenji puxa uma lanterna e acende ela em meus olhos."

# game/script-a3-emi.rpy:4954
translate pt_br a3_emi_afterschool_plans_16bf989e:

    # ke "You got a concussion?"
    ke "Você tem uma concussão?"

# game/script-a3-emi.rpy:4956
translate pt_br a3_emi_afterschool_plans_6be5434a:

    # hi "I wasn't knocked out!"
    hi "Eu não estava nocauteado!"

# game/script-a3-emi.rpy:4961
translate pt_br a3_emi_afterschool_plans_b2f7bed3:

    # ke "Maybe you just don't remember."
    ke "Talvez você apenas não se lembre."

# game/script-a3-emi.rpy:4963
translate pt_br a3_emi_afterschool_plans_5bb0d2f0:

    # "This conversation isn't going anywhere."
    "Essa conversa não está indo a lugar algum."

# game/script-a3-emi.rpy:4965
translate pt_br a3_emi_afterschool_plans_75e88ba6:

    # hi "No, I just had a tiring morning and fell asleep."
    
    hi "Não, eu apenas tive uma manhã cansativa e acabei dormindo."

# game/script-a3-emi.rpy:4970
translate pt_br a3_emi_afterschool_plans_e5fdb6b1:

    # ke "Whatever, man."
    ke "Que seja, cara."

# game/script-a3-emi.rpy:4972
translate pt_br a3_emi_afterschool_plans_4f8a51f3:

    # ke "If you want to be in denial about this, I guess I can't stop you."
    ke "Se você quer negar tudo, acho que não posso te impedir."

# game/script-a3-emi.rpy:4974
translate pt_br a3_emi_afterschool_plans_1c9944e2:

    # ke "But you gotta watch out for that girl, man. She's not safe."
    ke "Mas você tem que ter cuidado com aquela garota, cara. Ela não é segura."

# game/script-a3-emi.rpy:4976
translate pt_br a3_emi_afterschool_plans_81d99227:

    # hi "What?"
    hi "O quê?"

# game/script-a3-emi.rpy:4981
translate pt_br a3_emi_afterschool_plans_a66b43d7:

    # ke "She's not safe to be around; she's one of their most sinister agents!"
    ke "Ela não é uma pessoa muito segura de se estar por perto; ela é uma das agentes mais sinistras!"

# game/script-a3-emi.rpy:4983
translate pt_br a3_emi_afterschool_plans_e433b7d6:

    # ke "If you're not careful, there's no telling what could happen!"
    ke "Se você não tomar cuidado, não há como descrever o que poderia acontecer!"

# game/script-a3-emi.rpy:4985
translate pt_br a3_emi_afterschool_plans_25e2e6a2:

    # ke "She's brought down stronger men than you, you know!"
    ke "Ela derrubou homens mais fortes que você, sabe!"

# game/script-a3-emi.rpy:4987
translate pt_br a3_emi_afterschool_plans_26c8c721:

    # hi "What the hell are you talking about?"
    hi "Que diabos você está falando?"

# game/script-a3-emi.rpy:4989
translate pt_br a3_emi_afterschool_plans_c787088b:

    # hi "She's not an agent of anything, and she didn't knock me out, okay?"
    hi "Ela não é uma agente, e ela não me nocauteou, tá bom?"

# game/script-a3-emi.rpy:4991
translate pt_br a3_emi_afterschool_plans_2a046ede:

    # hi "I also highly doubt that she's brought down anyone at all."
    hi "Eu também duvido muito que ela tenha derrubado qualquer um que seja."

# game/script-a3-emi.rpy:4996
translate pt_br a3_emi_afterschool_plans_1201f791:

    # "Kenji looks almost offended."
    "Kenji parece quase ofendido."

# game/script-a3-emi.rpy:4998
translate pt_br a3_emi_afterschool_plans_eeb65699:

    # "I have no idea why."
    "Não faço ideia do porquê."

# game/script-a3-emi.rpy:5000
translate pt_br a3_emi_afterschool_plans_7b58ace4:

    # ke "You don't believe me?"
    ke "Você não acredita em mim?"
    

# game/script-a3-emi.rpy:5002
translate pt_br a3_emi_afterschool_plans_6be38258:

    # ke "That's cold, man. Real cold."
    ke "Isso é frio, cara. Frio mesmo."

# game/script-a3-emi.rpy:5004
translate pt_br a3_emi_afterschool_plans_b6ad9978:

    # ke "I'm just trying to look out for you. That's what friends do, you know."
    ke "Eu só estou tentando tomar cuidado por você. É isso o que os amigos fazem, cê sabe."

# game/script-a3-emi.rpy:5006
translate pt_br a3_emi_afterschool_plans_283cb9db:

    # "We're friends? I had no idea."
    "Nós somos amigos? Eu não fazia ideia."

# game/script-a3-emi.rpy:5008
translate pt_br a3_emi_afterschool_plans_bbd88d33:

    # "Then again, I wonder if Kenji knows what being a friend even entails."
    "Então novamente, eu me pergunto se o Kenji sabe o que ser amigo implica mesmo em detalhes."

# game/script-a3-emi.rpy:5010
translate pt_br a3_emi_afterschool_plans_659590c7:

    # "I feel something like pity for him, standing there before me."
    "Eu sinto algum tipo pena por ele, parado ali na minha frente."

# game/script-a3-emi.rpy:5012
translate pt_br a3_emi_afterschool_plans_fe7d9328:

    # "Maybe he does think he's looking out for me."
    "Talvez ele realmente pense que está cuidando de mim."

# game/script-a3-emi.rpy:5014
translate pt_br a3_emi_afterschool_plans_ee322606:

    # hi "I know, I know."
    hi "Eu sei, eu sei."

# game/script-a3-emi.rpy:5016
translate pt_br a3_emi_afterschool_plans_deb9f489:

    # hi "I'm sorry about that. Thanks for the warning."
    hi "Desculpe por isso. Obrigado pelo aviso."

# game/script-a3-emi.rpy:5018
translate pt_br a3_emi_afterschool_plans_43f9c875:

    # "I hold out my hand as a sign of peace."
    "Eu estico minha mão como um sinal de paz."

# game/script-a3-emi.rpy:5023
translate pt_br a3_emi_afterschool_plans_e10ffa66:

    # "Kenji shakes it gingerly, like my hand could possibly be on fire."
    "Kenji aperta ela cuidadosamente, como se minha mão pudesse estar em chamas."

# game/script-a3-emi.rpy:5025
translate pt_br a3_emi_afterschool_plans_fba1f204:

    # "There's an awkward silence for a few seconds before Kenji remembers that he's still shaking my hand."
    "Há um silêncio esquisito por alguns segundos antes que Kenji se lembre que ele ainda está apertando minha mão."

# game/script-a3-emi.rpy:5030
translate pt_br a3_emi_afterschool_plans_92102e59:

    # ke "Anyway, I need a favor."
    ke "De qualquer forma, eu preciso de um favor."

# game/script-a3-emi.rpy:5032
translate pt_br a3_emi_afterschool_plans_35f070c9:

    # hi "What kind of favor? I'm out of money…"
    hi "Que tipo de favor? Eu estou sem dinheiro…"

# game/script-a3-emi.rpy:5034
translate pt_br a3_emi_afterschool_plans_e61017de:

    # ke "No you aren't. You've got money kept in your desk drawer under a black notebook. For emergencies."
    ke "Não você não está. Você tem dinheiro guardado na gaveta da sua escrivaninha embaixo de um caderno. Para emergências."

# game/script-a3-emi.rpy:5036
translate pt_br a3_emi_afterschool_plans_53261128:

    # hi "Did you ransack my room?"
    hi "Você revistou meu quarto?"
    

# game/script-a3-emi.rpy:5041
translate pt_br a3_emi_afterschool_plans_42f44f98:

    # ke "That's not important."
    ke "Isso não importa."

# game/script-a3-emi.rpy:5043
translate pt_br a3_emi_afterschool_plans_00d80355:

    # ke "I don't need money, anyway."
    ke "Eu não preciso de dinheiro, de qualquer modo."

# game/script-a3-emi.rpy:5045
translate pt_br a3_emi_afterschool_plans_acf8d06a:

    # "He adopts a very serious tone."
    "Ele adota um tom bem sério."

# game/script-a3-emi.rpy:5050
translate pt_br a3_emi_afterschool_plans_9459ec53:

    # ke "I'm about to undertake a major op."
    ke "Eu estou prestes a realizar uma grande operação."

# game/script-a3-emi.rpy:5052
translate pt_br a3_emi_afterschool_plans_ca66085d:

    # ke "It'll blow the whole conspiracy wide open if I'm right."
    ke "Isso irá explodir toda conspiração em aberto se eu estou correto."

# game/script-a3-emi.rpy:5054
translate pt_br a3_emi_afterschool_plans_e6838a23:

    # ke "But it's dangerous, so I need you to do something for me in case I don't come back."
    ke "Mas isso é perigoso, então eu preciso que você faça algo por mim caso eu não volte."

# game/script-a3-emi.rpy:5056
translate pt_br a3_emi_afterschool_plans_0bd44345:

    # hi "Uh, sure man. Anything."
    hi "Hãã, claro cara, qualquer coisa."

# game/script-a3-emi.rpy:5058
translate pt_br a3_emi_afterschool_plans_d32c5b53:

    # "What the hell is he planning on doing?"
    
    "O que diabos ele está planejando fazer?"
    

# game/script-a3-emi.rpy:5060
translate pt_br a3_emi_afterschool_plans_970e2f0e:

    # "Should I be telling someone about this?"
    
    "Devo falar sobre isso para alguém?"

# game/script-a3-emi.rpy:5065
translate pt_br a3_emi_afterschool_plans_f2cd404c:

    # ke "If I go missing, wait three days and then mail my journal off to the newspapers."
    ke "Se eu desaparecer, espere três dias e então envie pelo correio o meu diário para os jornais."

# game/script-a3-emi.rpy:5067
translate pt_br a3_emi_afterschool_plans_e5cdf549:

    # ke "It's hidden in my room under a false bottom in one of my desk drawers."
    ke "Está escondido no meu quarto embaixo de um fundo falso em uma das gavetas da minha escrivaninha."

# game/script-a3-emi.rpy:5069
translate pt_br a3_emi_afterschool_plans_2811e377:

    # hi "How do I get into your room? I don't have a key."
    
    hi "Como eu entro no seu quarto? Eu não tenho uma chave."

# game/script-a3-emi.rpy:5074
translate pt_br a3_emi_afterschool_plans_4ccd4ebb:

    # "Kenji looks at me like I'm crazy."
    "Kenji olha para mim como se eu fosse louco."

# game/script-a3-emi.rpy:5076
translate pt_br a3_emi_afterschool_plans_d91ba613:

    # ke "So pick the lock. You know how to do that, right?"
    ke "Arrombe a porta. Você sabe como fazer isso, certo?"

# game/script-a3-emi.rpy:5078
translate pt_br a3_emi_afterschool_plans_05a8d001:

    # ke "It's an important skill to learn at a young age!"
    ke "É uma habilidade importante para se aprender durante a juventude!"

# game/script-a3-emi.rpy:5080
translate pt_br a3_emi_afterschool_plans_6f64cd6b:

    # hi "Uh, yeah, of course I know how."
    hi "Uh, é, claro que eu sei como."

# game/script-a3-emi.rpy:5082
translate pt_br a3_emi_afterschool_plans_7849b4a2:

    # hi "I'll be sure to uh, do that for you. If you go missing."
    hi "Eu vou ter certeza de err, fazer isso por você. Se você desaparecer."

# game/script-a3-emi.rpy:5084
translate pt_br a3_emi_afterschool_plans_33f7a431:

    # "I don't think I want to read Kenji's journal."
    "Eu não acho que eu queira ler o diário do Kenji."

# game/script-a3-emi.rpy:5086
translate pt_br a3_emi_afterschool_plans_0c5fc582:

    # "Either way, Kenji seems pretty happy that I've agreed to do this thing for him."
    "De qualquer maneira, Kenji parece estar bem feliz que eu concordei em fazer isso por ele."

# game/script-a3-emi.rpy:5091
translate pt_br a3_emi_afterschool_plans_41c37203:

    # ke "Great, man. Great."
    ke "Ótimo, cara. Ótimo."

# game/script-a3-emi.rpy:5093
translate pt_br a3_emi_afterschool_plans_043e8c7d:

    # ke "I'll see you around, I got stuff to do."
    ke "Te vejo por aí, eu tenho umas coisas para fazer."

# game/script-a3-emi.rpy:5104
translate pt_br a3_emi_afterschool_plans_f5f58461:

    # "And he's gone, dashing down the hallway."
    "E ele se foi, correndo pelo corredor."

# game/script-a3-emi.rpy:5106
translate pt_br a3_emi_afterschool_plans_5129771b:

    # "He made it seem so final."
    
    "Ele fez isso parecer algo irrevogável."

# game/script-a3-emi.rpy:5108
translate pt_br a3_emi_afterschool_plans_a3ce0ca6:

    # "I hope I don't have to carry out his final wishes."
    "Eu espero que eu não precise carregar os seus últimos desejos."

# game/script-a3-emi.rpy:5115
translate pt_br a3_emi_afterschool_plans_a9bb434d:

    # "Shaking my head, I close my door and walk back to my bed."
    "Chacoalhando minha cabeça, eu fecho a porta e caminho de volta para a cama."

# game/script-a3-emi.rpy:5117
translate pt_br a3_emi_afterschool_plans_d6f6fa03:

    # "Guess I should go to class, if only to catch the last half of the day."
    "Acho que eu deveria ir para a aula, mesmo se for só para pegar a última metade do dia."

# game/script-a3-emi.rpy:5119
translate pt_br a3_emi_afterschool_plans_6ef2a43c:

    # "But I've come this far without going to class today…"
    "Mas eu já cheguei tão longe sem ir para a aula hoje."

# game/script-a3-emi.rpy:5121
translate pt_br a3_emi_afterschool_plans_ef13de15:

    # "And I did want to read more of that Hawking book Mutou lent me…"
    "E eu queria tanto ler mais daquele livro do Hawking que o Mutou me emprestou."

# game/script-a3-emi.rpy:5123
translate pt_br a3_emi_afterschool_plans_2fa20249:

    # "I'm sure he'll understand."
    "Estou certo de que ele entenderá."

# game/script-a3-emi.rpy:5129
translate pt_br a3_emi_afterschool_plans_36c7cc88_3:

    # "Knock knock."
    "Toc toc."

# game/script-a3-emi.rpy:5131
translate pt_br a3_emi_afterschool_plans_5954ec69:

    # "This time the noise jerks my attention away from my book."
    "Desta vez o barulho sacode minha atenção para longe do meu livro."

# game/script-a3-emi.rpy:5133
translate pt_br a3_emi_afterschool_plans_9b3d9f1c:

    # "An experience not unlike being woken up."
    "Uma experiência nada parecido com ser acordado."

# game/script-a3-emi.rpy:5135
translate pt_br a3_emi_afterschool_plans_02adfd54:

    # hi "Who's there?"
    hi "Quem está aí?"

# game/script-a3-emi.rpy:5137
translate pt_br a3_emi_afterschool_plans_3a1b4370:

    # emi "Me! Aren't you glad?"
    emi "Eu! Não está contente?"

# game/script-a3-emi.rpy:5141
translate pt_br a3_emi_afterschool_plans_fb28bbcd:

    # "The voice is muffled through the door, but unmistakably Emi's."
    "A voz é abafada pela porta, mas inequivocamente é a Emi."

# game/script-a3-emi.rpy:5149
translate pt_br a3_emi_afterschool_plans_c12af0b0:

    # "I hop up and open the door, smiling broadly."
    "Eu pulo para cima e abro a porta, com um grande sorriso."

# game/script-a3-emi.rpy:5151
translate pt_br a3_emi_afterschool_plans_2afd0b37:

    # hi "Hey! Nice to see you again!"
    hi "E aí! Que bom te ver de novo!"

# game/script-a3-emi.rpy:5156
translate pt_br a3_emi_afterschool_plans_5afc69b2:

    # "Emi grins back, staring up at me from her wheelchair."
    
    "Emi sorri de volta, olhando para cima em mim de sua cadeira de rodas."

# game/script-a3-emi.rpy:5161
translate pt_br a3_emi_afterschool_plans_52476555:

    # emi "Yeah, you would have seen me earlier, but the damned elevator wasn't working."
    emi "É, você teria me visto antes, mas a porcaria do elevador não estava funcionando."

# game/script-a3-emi.rpy:5166
translate pt_br a3_emi_afterschool_plans_3cb51e6b:

    # emi "Had to wait for them to fix it."
    
    emi "Eu tive que esperar que eles o consertassem."

# game/script-a3-emi.rpy:5171
translate pt_br a3_emi_afterschool_plans_762f0477:

    # emi "You'd think they could keep it in better order, but nooo…"
    emi "Você iria pensar que eles deveriam mantê-lo num estado melhor, mas nããão…"

# game/script-a3-emi.rpy:5173
translate pt_br a3_emi_afterschool_plans_765be802:

    # "I chuckle a bit at her vexed expression and invite her in."
    "Eu rio um pouco de sua expressão aborrecida e a convido para entrar."

# game/script-a3-emi.rpy:5178
translate pt_br a3_emi_afterschool_plans_ff046799:

    # "She wheels in easily, and with my help she hops onto my bed."
    "Ela se dirige com facilidade, e com minha ajuda ela pula em minha cama."

# game/script-a3-emi.rpy:5189
translate pt_br a3_emi_afterschool_plans_8ca22c00:

    # emi "There. Much more comfortable than that stupid chair."
    emi "Isto. Muito mais confortável do que essa cadeira estúpida."
    

# game/script-a3-emi.rpy:5194
translate pt_br a3_emi_afterschool_plans_2c2bba33:

    # "A sigh of contentment hangs in the air, and for a minute we both just stare at one another."
    "Um suspiro de contentamento fica no ar, e por um minuto nós dois apenas nos olhamos um para o outro."

# game/script-a3-emi.rpy:5196
translate pt_br a3_emi_afterschool_plans_143b7f78:

    # "It's at that point that I notice the circles under Emi's eyes."
    "É nesse ponto que eu percebo círculos abaixo dos olhos da Emi."

# game/script-a3-emi.rpy:5198
translate pt_br a3_emi_afterschool_plans_b3d6e3d1:

    # "They're not that dark, but they definitely weren't there before."
    "Eles não estão tão escuros, mas definitivamente não estavam lá antes."

# game/script-a3-emi.rpy:5200
translate pt_br a3_emi_afterschool_plans_e4824304:

    # "Before I can ask about them, Emi fixes me with a mischievous stare."
    "Antes que eu possa perguntar sobre eles, Emi fixa em mim um olhar travesso."

# game/script-a3-emi.rpy:5205
translate pt_br a3_emi_afterschool_plans_f31b9ee3:

    # emi "So, I couldn't help but notice you weren't at lunch today."
    emi "Então, eu não pude deixar de notar que você não estava no almoço hoje."

# game/script-a3-emi.rpy:5207
translate pt_br a3_emi_afterschool_plans_88c1e9e5:

    # emi "In fact, I don't think I saw you at all."
    emi "Na verdade, eu não acho que eu tenha visto você em qualquer momento."

# game/script-a3-emi.rpy:5212
translate pt_br a3_emi_afterschool_plans_d656a3c4:

    # emi "What happened, hmmm?"
    emi "O quê aconteceu, hmmm?"

# game/script-a3-emi.rpy:5214
translate pt_br a3_emi_afterschool_plans_c17f12a3:

    # hi "Fell asleep."
    hi "Eu dormi."

# game/script-a3-emi.rpy:5216
translate pt_br a3_emi_afterschool_plans_8cd2ec60:

    # hi "I actually didn't wake up until lunch, and only then because Kenji woke me up."
    hi "Na verdade, eu não acordei até o almoço, e só porque o Kenji me acordou."

# game/script-a3-emi.rpy:5221
translate pt_br a3_emi_afterschool_plans_61c4be7f:

    # emi "What had you so tired, hmm?"
    emi "O que te cansou tanto, hmm?"

# game/script-a3-emi.rpy:5223
translate pt_br a3_emi_afterschool_plans_9e892c89:

    # hi "Strenuous workout this morning. Slightly uncomfortable, too."
    hi "O treino árduo dessa manhã. Um pouco desconfortável, também."

# game/script-a3-emi.rpy:5228
translate pt_br a3_emi_afterschool_plans_62d822a9:

    # "Emi coughs, a half-laughing, half-embarrassed noise."
    "Emi tosse, meio rindo, meio envergonhada."

# game/script-a3-emi.rpy:5233
translate pt_br a3_emi_afterschool_plans_2eac2033:

    # emi "Remind me not to do that again."
    emi "Me lembre de nunca mais fazer isso de novo."

# game/script-a3-emi.rpy:5235
translate pt_br a3_emi_afterschool_plans_ddb2d867:

    # hi "No problem. It wasn't exactly great for me either, to be honest."
    hi "Sem problema. Não foi exatamente ótimo para mim também, para ser honesto."

# game/script-a3-emi.rpy:5237
translate pt_br a3_emi_afterschool_plans_8c7eefda:

    # hi "We'll just avoid that from now on."
    hi "Vamos apenas evitar isso daqui em diante."

# game/script-a3-emi.rpy:5239
translate pt_br a3_emi_afterschool_plans_d8d91260:

    # hi "Are you, er, still sore?"
    hi "Você ainda, er, está dolorida?"

# game/script-a3-emi.rpy:5244
translate pt_br a3_emi_afterschool_plans_66521350:

    # "Emi stares at me in disbelief."
    "Emi me encara, desacreditada."

# game/script-a3-emi.rpy:5246
translate pt_br a3_emi_afterschool_plans_d09bb0b6:

    # hi "What? It's a legitimate question!"
    hi "O quê? É uma pergunta legítima!"

# game/script-a3-emi.rpy:5251
translate pt_br a3_emi_afterschool_plans_0b980092:

    # emi "Of all the questions I never thought I'd be asked, that's one of them."
    emi "De todas as perguntas que eu nunca pensei que seria perguntada, essa é uma delas."

# game/script-a3-emi.rpy:5253
translate pt_br a3_emi_afterschool_plans_69b357c6:

    # hi "Well, I didn't ever expect to have to ask it, so we're even."
    
    hi "Bem, eu não estava esperando perguntar por ela, então nós estamos quites."

# game/script-a3-emi.rpy:5258
translate pt_br a3_emi_afterschool_plans_6365c18a:

    # "Emi laughs at this."
    "Emi ri disso."

# game/script-a3-emi.rpy:5260
translate pt_br a3_emi_afterschool_plans_535b2535:

    # emi "I guess so, huh?"
    emi "Acho que sim, né?"

# game/script-a3-emi.rpy:5267
translate pt_br a3_emi_afterschool_plans_372466a1:

    # emi "Well, since you asked, yes. I'm still a little sore."
    emi "Bem, já que você perguntou, sim. Eu ainda estou um pouco dolorida."

# game/script-a3-emi.rpy:5272
translate pt_br a3_emi_afterschool_plans_d01669d1:

    # emi "We're never doing that again."
    
    emi "Nós nunca iremos fazer isso de novo."

# game/script-a3-emi.rpy:5274
translate pt_br a3_emi_afterschool_plans_d6300218:

    # hi "No arguments from here."
    hi "Sem argumentos daqui."

# game/script-a3-emi.rpy:5276
translate pt_br a3_emi_afterschool_plans_b45e1213:

    # "A yawn escapes her, and I raise an eyebrow."
    "Um bocejo escapa dela, e eu levanto uma sobrancelha."

# game/script-a3-emi.rpy:5278
translate pt_br a3_emi_afterschool_plans_af2a3f6c:

    # hi "Tired?"
    hi "Cansada?"

# game/script-a3-emi.rpy:5283
translate pt_br a3_emi_afterschool_plans_d7c791f1:

    # "Emi nods sleepily."
    "Emi acena com a cabeça sonolenta."

# game/script-a3-emi.rpy:5290
translate pt_br a3_emi_afterschool_plans_3cc0a177:

    # emi "Haven't slept well."
    emi "Não dormi bem."

# game/script-a3-emi.rpy:5292
translate pt_br a3_emi_afterschool_plans_483a5bc0:

    # "Not sleeping well?"
    "Não dormindo bem?"

# game/script-a3-emi.rpy:5294
translate pt_br a3_emi_afterschool_plans_2912deeb:

    # "I can tell that she didn't mean to tell me this either, because she gives a little start like she's just been caught lying and hastens to add,"
    "Eu posso dizer que ela não queria me dizer isso também, porque ela dá a entender que acabou de ser pega mentindo e precisa adicionar algo."

# game/script-a3-emi.rpy:5299
translate pt_br a3_emi_afterschool_plans_4b858ba0:

    # emi "It's not a big deal, though."
    emi "Não é nada, no entanto."

# game/script-a3-emi.rpy:5301
translate pt_br a3_emi_afterschool_plans_4ce06568:

    # hi "What's the trouble?"
    hi "Qual o problema?"

# game/script-a3-emi.rpy:5306
translate pt_br a3_emi_afterschool_plans_9fae0703:

    # "Emi shrugs and refuses to elaborate."
    "Emi encolhe os ombros e se recusa a falar."

# game/script-a3-emi.rpy:5308
translate pt_br a3_emi_afterschool_plans_a2e9ae3c:

    # hi "Stressed over exams?"
    hi "Estressada com as provas?"

# game/script-a3-emi.rpy:5310
translate pt_br a3_emi_afterschool_plans_4a26b5b9:

    # "Another shrug, but after a pause, Emi nods hesitantly."
    "Outro dar de ombros, mas depois de uma pausa, Emi concorda hesitantemente."

# game/script-a3-emi.rpy:5315
translate pt_br a3_emi_afterschool_plans_61e60cb6:

    # emi "Er, yeah, I guess."
    emi "Er, é, eu acho."

# game/script-a3-emi.rpy:5317
translate pt_br a3_emi_afterschool_plans_ddb807b2:

    # emi "Actually, that's why I stopped by."
    emi "Na verdade, é por isso que eu passei por aqui."

# game/script-a3-emi.rpy:5319
translate pt_br a3_emi_afterschool_plans_81c42474:

    # "She begins to look more and more miserable."
    "Ela começa a parecer cada vez mais miserável."

# game/script-a3-emi.rpy:5321
translate pt_br a3_emi_afterschool_plans_63402bd2:

    # "Not so you'd notice, of course; but her eyes are on her lap, she's fidgeting and her voice is quiet."
    "Não de um modo que você pudesse perceber, é claro; mas os olhos dela estão no seu colo, ela está se remexendo e sua voz está quieta."

# game/script-a3-emi.rpy:5326
translate pt_br a3_emi_afterschool_plans_0fdd2087:

    # emi "We uh, we need to stop hanging out so much."
    emi "Nós uh, precisamos parar de sair tanto."

# game/script-a3-emi.rpy:5328
translate pt_br a3_emi_afterschool_plans_f423f75f:

    # hi "Huh? Why?"
    hi "Hã? Por quê?"

# game/script-a3-emi.rpy:5330
translate pt_br a3_emi_afterschool_plans_3ac317a1:

    # "Emi takes a deep breath, like she's been practicing this."
    "Emi respira fundo, como se estivesse praticando isso."
    

# game/script-a3-emi.rpy:5335
translate pt_br a3_emi_afterschool_plans_c04cf982:

    # emi "Because you're too much fun to be around."
    emi "Porque você é divertido demais para se estar por perto."

# game/script-a3-emi.rpy:5337
translate pt_br a3_emi_afterschool_plans_085fe9f4:

    # emi "And I can't concentrate when you're near me."
    emi "E eu não consigo me concentrar quando você está perto de mim."

# game/script-a3-emi.rpy:5339
translate pt_br a3_emi_afterschool_plans_2866f355:

    # emi "With exams coming up soon, I just… can't have that distraction."
    emi "Com as provas chegando em breve, eu só… não posso ter essa distração."

# game/script-a3-emi.rpy:5344
translate pt_br a3_emi_afterschool_plans_6acc5e78:

    # emi "Otherwise my grades will be pretty lousy, I'm afraid."
    emi "Caso contrário minhas notas serão muito ruins, eu temo."

# game/script-a3-emi.rpy:5346
translate pt_br a3_emi_afterschool_plans_d932e811:

    # hi "I could help you study…"
    hi "Eu poderia te ajudar a estudar…"

# game/script-a3-emi.rpy:5351
translate pt_br a3_emi_afterschool_plans_fe056e26:

    # "She smiles at me, clearly unhappy with the situation."
    "Ela sorri para mim, claramente infeliz com a situação."

# game/script-a3-emi.rpy:5353
translate pt_br a3_emi_afterschool_plans_200947a5:

    # emi "I'd love it if you could, but we wouldn't actually study, would we?"
    emi "Eu adoraria se você pudesse, mas nós não iriamos mesmo estudar, iríamos?"

# game/script-a3-emi.rpy:5358
translate pt_br a3_emi_afterschool_plans_c50afd93:

    # emi "I mean even now, I'm trying to have a conversation with you but I kinda just want to, uh…"
    emi "Quero dizer até mesmo agora, eu estou tentando ter uma conversa com você mas eu meio que só quero, uh…"

# game/script-a3-emi.rpy:5363
translate pt_br a3_emi_afterschool_plans_bc2aee1d:

    # emi "Not converse."
    emi "Não conversar."

# game/script-a3-emi.rpy:5365
translate pt_br a3_emi_afterschool_plans_9a287fc4:

    # hi "Ah."
    hi "Ah."

# game/script-a3-emi.rpy:5367
translate pt_br a3_emi_afterschool_plans_b9a0d704:

    # hi "Overwhelmed by my rugged manliness. I understand."
    hi "Oprimida pela minha masculinidade. Eu entendo."

# game/script-a3-emi.rpy:5372
translate pt_br a3_emi_afterschool_plans_d7e48670:

    # "That earns me a grin, at least."
    "Isso me ganha um sorriso, ao menos."

# game/script-a3-emi.rpy:5374
translate pt_br a3_emi_afterschool_plans_4a72a162:

    # "Emi shakes her head."
    "Emi sacode a sua cabeça."

# game/script-a3-emi.rpy:5379
translate pt_br a3_emi_afterschool_plans_1fde6504:

    # emi "Idiot. You're full of yourself."
    emi "Idiota. Você é todo cheio de sí."

# game/script-a3-emi.rpy:5381
translate pt_br a3_emi_afterschool_plans_09d262ec:

    # hi "Well, I am pretty irresistible."
    hi "Bem, eu sou bem irresistível."

# game/script-a3-emi.rpy:5386
translate pt_br a3_emi_afterschool_plans_65476528:

    # emi "Er, more or less. I guess."
    emi "Er, mais ou menos. Eu acho."

# game/script-a3-emi.rpy:5391
translate pt_br a3_emi_afterschool_plans_4b32e83a:

    # emi "So that's the situation, Hisao."
    emi "Então essa é a situação, Hisao."

# game/script-a3-emi.rpy:5393
translate pt_br a3_emi_afterschool_plans_e517647a:

    # emi "I have too much fun around you, and if I'm going to go into exams prepared, I need to be alone."
    emi "Eu me divirto demais perto de você, e se eu tiver que ir para as provas preparada, eu teria que estar sozinha."

# game/script-a3-emi.rpy:5395
translate pt_br a3_emi_afterschool_plans_0cfbb39a:

    # hi "Hey, that's okay."
    hi "Ei, está tudo bem."

# game/script-a3-emi.rpy:5397
translate pt_br a3_emi_afterschool_plans_f09927ca:

    # "It really seems to have been bothering her."
    "Isso realmente parece estar a incomodando."

# game/script-a3-emi.rpy:5399
translate pt_br a3_emi_afterschool_plans_f5e3fbdc:

    # "Besides, it's only a couple of weeks. And we'll still see each other in the mornings, and at lunch."
    "Além do mais, é só por algumas semanas. E nós ainda vamos nos ver todas as manhãs, e no almoço."

# game/script-a3-emi.rpy:5401
translate pt_br a3_emi_afterschool_plans_80c83375:

    # hi "We can just hang out at school, no problem."
    hi "Nós podemos sair apenas no colégio, sem problema."

# game/script-a3-emi.rpy:5403
translate pt_br a3_emi_afterschool_plans_cc43877f:

    # hi "And after exams, we'll go on a date to celebrate their being over, okay?"
    hi "E depois das provas, nós iremos num encontro para celebrar o fim delas, certo?"

# game/script-a3-emi.rpy:5408
translate pt_br a3_emi_afterschool_plans_b549c8bc:

    # "Emi grins, pleased by this proposal."
    "Emi sorri, contente com esta proposta."

# game/script-a3-emi.rpy:5413
translate pt_br a3_emi_afterschool_plans_aa4a78da:

    # emi "Yeah, sure! That sounds great!"
    emi "Siiim, claro! Isso parece ótimo!"

# game/script-a3-emi.rpy:5418
translate pt_br a3_emi_afterschool_plans_1bd82e76:

    # "As if to signal the end of the conversation, she leans in and kisses me."
    "Como se fosse sinalizar o fim de nossa conversa, ela se curva e me beija."

# game/script-a3-emi.rpy:5420
translate pt_br a3_emi_afterschool_plans_a82e9d35:

    # "The rest of the night is not spent worrying about exams."
    "O resto da noite não é gasto se preocupando com as provas."

# game/script-a3-emi.rpy:5439
translate pt_br a3_emi_detached_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5442
translate pt_br a3_emi_detached_f2a49980:

    # n "{vspace=60}It's weird how easily Emi and I can keep from seeing one another after class now."
    n "{vspace=60}É esquisito o quão fácil é para mim e Emi de nos deixar de se ver depois da aula agora."

# game/script-a3-emi.rpy:5444
translate pt_br a3_emi_detached_636fc52d:

    # n "Actually, I'd venture to say that it's vaguely disturbing."
    n "Na verdade, eu iria me arriscar e dizer que isso é vagamente perturbador."

# game/script-a3-emi.rpy:5446
translate pt_br a3_emi_detached_43ccfa9d:

    # n "As easily as we'd come together, we seem to have split apart without much trouble."
    n "Tão facilmente como ficamos juntos, nós parecemos nos ter separado sem muito problema."

# game/script-a3-emi.rpy:5448
translate pt_br a3_emi_detached_ca6eb49f:

    # n "Well, I guess that's not exactly true."
    n "Bem, eu acho que isso não é exatamente verdade."

# game/script-a3-emi.rpy:5450
translate pt_br a3_emi_detached_beb36f14:

    # n "We'd both been pretty bummed after that last night together."
    n "Nós dois ficamos bem chateados depois daquela última noite juntos."

# game/script-a3-emi.rpy:5452
translate pt_br a3_emi_detached_f3dd8d65:

    # n "And we get to see each other every morning for our runs (and just our runs, I might add)."
    n "E nós ainda conseguimos nos ver todas manhãs para nossas corridas (e só nossas corridas, devo adicionar)."

# game/script-a3-emi.rpy:5454
translate pt_br a3_emi_detached_44631619:

    # n "Lunch, too. I especially enjoy lunchtime with her."
    n "Almoço, também. Eu gosto especialmente da hora do almoço com ela."
    

# game/script-a3-emi.rpy:5456
translate pt_br a3_emi_detached_04175a13:

    # n "We have plenty of time to talk about everything outside of school, whereas the morning runs have become increasingly businesslike."
    n "Nós temos bastante tempo para conversar sobre tudo fora do colégio, considerando que as corridas matinais tornaram-se cada vez mais eficientes."

# game/script-a3-emi.rpy:5458
translate pt_br a3_emi_detached_8ff1eb06:

    # n "I think it's because Emi wants to make up for our foolery in the storage shed."
    n "Eu acho que é porque a Emi quer se desculpar por nossa bobagem no depósito."

# game/script-a3-emi.rpy:5460
translate pt_br a3_emi_detached_e43927dd:

    # n "But no matter how much we joke at lunch, I can't help feeling a little worried about her."
    n "Mas não interessa o quanto nós brincamos no almoço, eu não consigo evitar de me sentir um pouco preocupado com ela."

# game/script-a3-emi.rpy:5462
translate pt_br a3_emi_detached_7028754c:

    # nvl clear
    # n "{vspace=60}She seems distracted more often, and I've caught her fidgeting nervously more than once."
    nvl clear
    n "Ela parece estar se distraindo com mais frequência, e eu peguei ela se remexendo nervosamente mais de uma vez."

# game/script-a3-emi.rpy:5466
translate pt_br a3_emi_detached_21e57098:

    # n "Never figured her to be someone who cared that deeply about exams, but they certainly seem to be taking their toll."
    n "Nunca achei que ela fosse ser alguém que se importasse tanto com provas assim, mas elas certamente estão fazendo o seu trabalho."

# game/script-a3-emi.rpy:5468
translate pt_br a3_emi_detached_1ec8a8c5:

    # n "Even though they haven't even started."
    n "Mesmo que elas nem tenham começado ainda."

# game/script-a3-emi.rpy:5470
translate pt_br a3_emi_detached_88dd447d:

    # n "This is just the run up, the deep breath before the plunge."
    n "Isso é apenas o sprint, a respiração profunda antes do mergulho."

# game/script-a3-emi.rpy:5472
translate pt_br a3_emi_detached_2b8f23d5:

    # n "Tomorrow, the real trials begin."
    n "Amanhã, começa a verdadeira corrida."
    

# game/script-a3-emi.rpy:5474
translate pt_br a3_emi_detached_1e06ee1b:

    # n "Or the real exams, anyway."
    n "Ou as provas de verdade, de qualquer modo."

# game/script-a3-emi.rpy:5476
translate pt_br a3_emi_detached_2bc1484a:

    # n "As for me, I actually don't feel that worried about exams at all."
    n "Já para mim, eu realmente não tenho me preocupado nem um pouco com as provas."

# game/script-a3-emi.rpy:5478
translate pt_br a3_emi_detached_d470d14a:

    # n "I'm not sure why. I mean, they're pretty important; my scores here will determine my odds of getting into a good university."
    "Não estou certo do porquê. Quero dizer, elas são bem importantes; minhas notas aqui vão determinar minhas chances de entrar em uma boa universidade."

# game/script-a3-emi.rpy:5480
translate pt_br a3_emi_detached_da414c8e:

    # n "Hell, if I'm too cavalier now, it could spell doom for my academic career."
    n "Que inferno, se eu for muito arrogante agora, isso pode significar a ruína para minha carreira acadêmica."

# game/script-a3-emi.rpy:5482
translate pt_br a3_emi_detached_426d9b82:

    # n "But going into them, I feel confident that I'll come out the other side okay."
    n "Mas indo nelas, sinto-me confiante de que vou sair bem do outro lado."

# game/script-a3-emi.rpy:5484
translate pt_br a3_emi_detached_52ac224e:

    # nvl clear
    # n "{vspace=180}Mutou thinks I've got the science examination locked up, at any rate."
    nvl clear
    n "{vspace=180}Mutou pensa que eu tenho a prova de ciências na ponta da língua, de qualquer modo."

# game/script-a3-emi.rpy:5488
translate pt_br a3_emi_detached_28dba056:

    # n "Or as he says, 'The last thing that should give you trouble is my exam, Hisao. It's way beneath your talents.'"
    n "Ou como ele diz, “a última coisa que pode dar problema para você é minha prova, Hisao. Está muito abaixo de seus talentos.”"

# game/script-a3-emi.rpy:5490
translate pt_br a3_emi_detached_6e4f3a96:

    # n "Then again, it is Mutou who's telling me this."
    n "Então novamente, é o Mutou que está me dizendo isso."

# game/script-a3-emi.rpy:5492
translate pt_br a3_emi_detached_d241477e:

    # n "His praise of me carries the veiled implication that anything less than perfect from me would be a disappointment, which has actually caused me to fret more than I should about the exam."
    n "Seu louvor a mim carrega aquela velada implicação de que tudo menos que perfeito vindo de mim seria uma decepção, o que fez me preocupar muito mais com a prova do que eu devia."

# game/script-a3-emi.rpy:5496
translate pt_br a3_emi_detached_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5502
translate pt_br a3_emi_detached_a35437b4:

    # "It's for that reason that I find myself in the library after class, poring over the textbook."
    "É por esse motivo que eu me encontro na biblioteca depois da aula, debruçado sobre o livro."

# game/script-a3-emi.rpy:5504
translate pt_br a3_emi_detached_3a204e22:

    # "Pretty simple things to look over; some formulas of velocity, a few bits about friction…"
    "Coisas bem simples para se olhar por cima; algumas fórmulas de velocidade, algumas coisinhas sobre atrito…"

# game/script-a3-emi.rpy:5506
translate pt_br a3_emi_detached_3805f385:

    # "A walk in the park compared to my dreaded English exam. Never was good with languages…"
    "Um passeio no parque comparado a minha temida prova de inglês. Eu nunca fui bom com línguas."

# game/script-a3-emi.rpy:5508
translate pt_br a3_emi_detached_c0fd781b:

    # "As I flip through my notes one more time, my mind begins to wander."
    "Enquanto eu passo pelas minhas anotações mais uma vez, minha mente começa a vaguear."

# game/script-a3-emi.rpy:5512
translate pt_br a3_emi_detached_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5515
translate pt_br a3_emi_detached_df418b1a:

    # n "{vspace=90}After these exams are over, things should get easier."
    n "{vspace=90}Depois que essas provas acabarem, as coisas devem ficar mais fáceis."

# game/script-a3-emi.rpy:5517
translate pt_br a3_emi_detached_1be20381:

    # n "Soon we'll be graduated."
    n "Em breve nós estaremos nos formando."

# game/script-a3-emi.rpy:5519
translate pt_br a3_emi_detached_e8a77bfb:

    # n "Then off to college, hopefully."
    n "Em seguida para a faculdade, eu espero."

# game/script-a3-emi.rpy:5521
translate pt_br a3_emi_detached_d90a3788:

    # n "I remember my abortive attempt to find out what Emi plans to do after high school."
    n "Eu lembro da minha tentativa abortada de tentar descobrir o que a Emi planeja fazer depois que ela acabar o ensino médio."

# game/script-a3-emi.rpy:5523
translate pt_br a3_emi_detached_626806c8:

    # n "Hmm, she avoided the subject pretty deftly, as I recall."
    n "Hmm, ela evitou aquele assunto de uma maneira muito hábil, se bem me lembro."

# game/script-a3-emi.rpy:5525
translate pt_br a3_emi_detached_b4f0ef20:

    # n "Heck, it seems that just about every time I push too hard, she dances around the subject."
    n "Droga, parece que toda vez que eu me esforço demais, ela dança em torno do assunto."

# game/script-a3-emi.rpy:5527
translate pt_br a3_emi_detached_96e3b897:

    # n "Or distracts me through… other means."
    n "Ou me distrai… de outras maneiras."

# game/script-a3-emi.rpy:5529
translate pt_br a3_emi_detached_969369b7:

    # n "Like a few days ago at lunch, when Rin wasn't around…"
    n "Como há alguns dias atrás, quando a Rin não estava por perto…"

# game/script-a3-emi.rpy:5531
translate pt_br a3_emi_detached_ceccb846:

    # n "Heh."
    n "Heh."

# game/script-a3-emi.rpy:5535
translate pt_br a3_emi_detached_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5543
translate pt_br a3_emi_detached_7aee21ca:

    # yu "I've done it!"
    yu "Eu consegui!"

# game/script-a3-emi.rpy:5545
translate pt_br a3_emi_detached_0bb148b9:

    # "I'm startled from my reverie by Yuuko's triumphant shout."
    "Sou assustado do meu devaneio pelo grito triunfante da Yuuko."

# game/script-a3-emi.rpy:5547
translate pt_br a3_emi_detached_7f83092f:

    # hi "Gah!"
    hi "Gah!"

# game/script-a3-emi.rpy:5552
translate pt_br a3_emi_detached_7c7fb8cf:

    # "Yuuko seems mortified at my sudden starting."
    "Yuuko parece mortificada com o meu súbito grito."

# game/script-a3-emi.rpy:5556
translate pt_br a3_emi_detached_95b82f20:

    # yu "Oh my god!"
    yu "Oh meu deus!"

# game/script-a3-emi.rpy:5561
translate pt_br a3_emi_detached_8512ab5f:

    # yu "I'm so sorry! I just got - and I really wasn't - and it's just that—"
    yu "Me desculpa! Eu acabei de conseguir - e eu não estava - e é só isso—"

# game/script-a3-emi.rpy:5563
translate pt_br a3_emi_detached_1d403a84:

    # "As she stutters, I move to quickly calm her down before she gets too agitated."
    "Enquanto ela gagueja, eu me movo rapidamente para acalmá-la antes que ela fique muito agitada."

# game/script-a3-emi.rpy:5565
translate pt_br a3_emi_detached_fde50182:

    # hi "Woah, hey."
    hi "Wow, ei."

# game/script-a3-emi.rpy:5567
translate pt_br a3_emi_detached_ef6489dd:

    # "My words seem ineffective."
    "Minhas palavras parecem ser ineficientes."

# game/script-a3-emi.rpy:5569
translate pt_br a3_emi_detached_4fa4aa29:

    # "Yuuko continues to work herself into a complete frenzy."
    "Yuuko continua a entrar em um frenesi completo."

# game/script-a3-emi.rpy:5574
translate pt_br a3_emi_detached_000d9e95:

    # yu "And it's a library and I shouldn't be—"
    
    yu "E é uma biblioteca e eu não deveria estar—"
    

# game/script-a3-emi.rpy:5576
translate pt_br a3_emi_detached_54e8b8db:

    # hi "Easy there, just calm down."
    hi "Calma aí, apenas se acalme."

# game/script-a3-emi.rpy:5581
translate pt_br a3_emi_detached_7b5fe30f:

    # yu "And really I'm setting a bad example, and now I'll get fired because I can't do anything right—"
    yu "E eu estou sendo um mal exemplo, e agora eu serei despedida porque eu não consigo fazer nada certo—"

# game/script-a3-emi.rpy:5583
translate pt_br a3_emi_detached_5fa12704:

    # hi "YUUKO!" with vpunch
    hi "YUUKO!" with vpunch
    

# game/script-a3-emi.rpy:5588
translate pt_br a3_emi_detached_71063af3:

    # "Shouting seems to work, though I draw the ire of several other students studying in the library."
    "Gritar parece ter funcionado, embora eu tenha atraído a ira de vários outros alunos estudando na biblioteca."

# game/script-a3-emi.rpy:5590
translate pt_br a3_emi_detached_b1268190:

    # "Yuuko snaps to attention, like a soldier who's just heard the captain bark an order."
    "Yuuko entra em atenção, como um soldado que acabou de escutar o capitão latir uma ordem."

# game/script-a3-emi.rpy:5595
translate pt_br a3_emi_detached_e72bf16c:

    # yu "Sorry! Sorry!"
    yu "Desculpa! Desculpa!"

# game/script-a3-emi.rpy:5597
translate pt_br a3_emi_detached_114ecea2:

    # hi "Calm down, it's okay."
    hi "Se acalme, está tudo bem."

# game/script-a3-emi.rpy:5599
translate pt_br a3_emi_detached_3583b8af:

    # hi "You just startled me a little, and that's only because I was daydreaming instead of studying."
    hi "Você apenas me assustou um pouco, e isso foi só porque eu estava sonhando acordado ao invés de estudar."

# game/script-a3-emi.rpy:5601
translate pt_br a3_emi_detached_e3066a05:

    # hi "So really, you got me back on task."
    hi "Então na real, você me fez voltar à minha tarefa."
    

# game/script-a3-emi.rpy:5603
translate pt_br a3_emi_detached_dc7e7500:

    # "This is a complete lie. But it seems to work."
    "É uma mentira completa. Mas parece surtir efeito."

# game/script-a3-emi.rpy:5608
translate pt_br a3_emi_detached_aa68b654:

    # "Yuuko takes a deep breath and seems to calm down a little."
    "Yuuko respira fundo e parece ter se acalmado um pouco."

# game/script-a3-emi.rpy:5610
translate pt_br a3_emi_detached_2a58dd25:

    # "Though she keeps shifting around with a nervous energy that seems awfully familiar."
    "Embora ela fique perambulando por aí com essa energia nervosa que é estranhamente familiar."

# game/script-a3-emi.rpy:5612
translate pt_br a3_emi_detached_e278e49b:

    # hi "So, what's got you so excited anyway?"
    hi "De qualquer maneira, o que foi que te deixou tão excitada?"

# game/script-a3-emi.rpy:5617
translate pt_br a3_emi_detached_1139c67d:

    # yu "The Yamaku Cat Burglar!"
    
    yu "O Gatuno da Yamaku!"

# game/script-a3-emi.rpy:5619
translate pt_br a3_emi_detached_f7fb134a:

    # "To her credit, Yuuko manages to convey her intense excitement in a whisper."
    "Méritos à ela, Yuuko consegue gerenciar sua excitação intensa em um sussuro."

# game/script-a3-emi.rpy:5624
translate pt_br a3_emi_detached_64195ecb:

    # yu "I think I know who it is!"
    yu "Eu acho que eu sei quem é!"

# game/script-a3-emi.rpy:5629
translate pt_br a3_emi_detached_719a51ad:

    # yu "I got an anonymous tip as to their identity!"
    yu "Eu ganhei uma denúncia sobre a sua identidade!"

# game/script-a3-emi.rpy:5631
translate pt_br a3_emi_detached_0068f50b:

    # yu "So I did some spying, and I think the tipster was right!"
    yu "Então eu espionei um pouco, e acho que o acusador estava certo!"

# game/script-a3-emi.rpy:5633
translate pt_br a3_emi_detached_83f0759c:

    # hi "Oh really? And who was this er, burglar?"
    hi "Oh é mesmo? E quem é esse er, ladrão?"

# game/script-a3-emi.rpy:5638
translate pt_br a3_emi_detached_f04e2f41:

    # "Yuuko shuts her mouth, shaking her head decisively."
    "Yuuko fecha sua boca, chacoalhando sua cabeça decisivamente."

# game/script-a3-emi.rpy:5640
translate pt_br a3_emi_detached_b6edcf9f:

    # yu "Nope, I can't tell you that."
    yu "Não, eu não posso te contar isso."

# game/script-a3-emi.rpy:5642
translate pt_br a3_emi_detached_f5743db9:

    # hi "Why not?"
    hi "Por que não?"

# game/script-a3-emi.rpy:5647
translate pt_br a3_emi_detached_193bfe8a:

    # yu "It's between me and the burglar."
    yu "Isso é entre mim e o ladrão."

# game/script-a3-emi.rpy:5649
translate pt_br a3_emi_detached_6833e965:

    # yu "I can't risk you warning him that I'm on to his game."
    yu "Eu não posso arriscar você poder avisar a ele que eu estou nesse jogo."

# game/script-a3-emi.rpy:5651
translate pt_br a3_emi_detached_8b548f1c:

    # yu "He could tip his hand early and blow town."
    yu "Ele poderia abanar a mão e sumir da cidade."

# game/script-a3-emi.rpy:5653
translate pt_br a3_emi_detached_09bcf6ed:

    # yu "Then I'm left with no perp."
    yu "Dai eu sou deixada sem nenhuma preparação."

# game/script-a3-emi.rpy:5655
translate pt_br a3_emi_detached_494554ab:

    # "When did Yuuko start talking like a hard-boiled detective?"
    "Quando foi que a Yuuko começou a falar como um detetive bruto?"

# game/script-a3-emi.rpy:5657
translate pt_br a3_emi_detached_1606b007:

    # hi "I wouldn't warn them! Why would I care?"
    hi "Eu não iria avisá-los! Por que eu iria me importar?"

# game/script-a3-emi.rpy:5662
translate pt_br a3_emi_detached_9f0c3187:

    # yu "If you've got to ask that question, then you don't need to know."
    yu "Se você tem que fazer esta pergunta, então você não precisa saber."

# game/script-a3-emi.rpy:5664
translate pt_br a3_emi_detached_66b73137:

    # hi "That doesn't make any sense, but okay."
    
    hi "Isso não faz nenhum sentido, mas está bem."

# game/script-a3-emi.rpy:5666
translate pt_br a3_emi_detached_8fcd60ec:

    # hi "Congratulations, I guess?"
    hi "Parabéns, eu acho?"

# game/script-a3-emi.rpy:5671
translate pt_br a3_emi_detached_28f039b7:

    # yu "Thanks!"
    yu "Obrigada!"

# game/script-a3-emi.rpy:5676
translate pt_br a3_emi_detached_fd01a005:

    # yu "Uh, what for?"
    yu "Hum, pelo o quê?"

# game/script-a3-emi.rpy:5678
translate pt_br a3_emi_detached_b439eb57:

    # hi "The uh, cat burglar thing?"
    hi "A err, coisa do gatuno?"

# game/script-a3-emi.rpy:5683
translate pt_br a3_emi_detached_25fcd8d5:

    # "Yuuko nods and smiles appreciatively."
    "Yuuko acena e sorri apreciativamente."

# game/script-a3-emi.rpy:5685
translate pt_br a3_emi_detached_579f1941:

    # yu "So! Studying for exams?"
    yu "Então! Estudando para as provas?"

# game/script-a3-emi.rpy:5687
translate pt_br a3_emi_detached_e34a6e33:

    # hi "Well, that was the plan. I'm not having much luck, though."
    hi "Bem, era esse o plano. Porém, eu não estou tendo muita sorte."

# game/script-a3-emi.rpy:5692
translate pt_br a3_emi_detached_b37e3231:

    # yu "Really? Is it because you can't find a book?"
    
    yu "Sério? É porque você não consegue encontrar um livro?"

# game/script-a3-emi.rpy:5697
translate pt_br a3_emi_detached_efb6ad7c:

    # yu "I'm really sorry!"
    yu "Eu sinto muito!"

# game/script-a3-emi.rpy:5699
translate pt_br a3_emi_detached_cbd5d088:

    # yu "I've been meaning to clean the shelves up for weeks now, but I keep getting distracted!"
    yu "Eu estive querendo limpar as estantes há semanas, mas eu fico me distraindo!"

# game/script-a3-emi.rpy:5701
translate pt_br a3_emi_detached_29a28e99:

    # yu "I'm so sorry!"
    yu "Eu sinto muito mesmo!"

# game/script-a3-emi.rpy:5703
translate pt_br a3_emi_detached_3a888913:

    # hi "Woah, wait."
    hi "Opa, espera."
    

# game/script-a3-emi.rpy:5705
translate pt_br a3_emi_detached_753cbe5b:

    # hi "It's not that. I've got my book right here."
    
    hi "Não é isso. Eu tenho o meu livro bem aqui."

# game/script-a3-emi.rpy:5707
translate pt_br a3_emi_detached_ea3a6b6b:

    # "To illustrate the point and hopefully calm Yuuko down, I show her the textbook in front of me."
    "Para ilustrar o ponto e com sorte acalmar a Yuuko, eu mostro a ela o livro em minha frente."

# game/script-a3-emi.rpy:5709
translate pt_br a3_emi_detached_1a7f2ddc:

    # hi "My mind just keeps wandering, is all."
    hi "Minha mente só fica vagando por aí, só isso."

# game/script-a3-emi.rpy:5714
translate pt_br a3_emi_detached_54cf7126:

    # yu "Is it because of the noise in here?"
    yu "É por causa do barulho aqui?"

# game/script-a3-emi.rpy:5716
translate pt_br a3_emi_detached_0059ba82:

    # yu "I'm trying to be more strict about the noise levels, but I can't bring myself to yell at people…"
    yu "Eu estou tentando ser mais rigorosa em questão sobre o nível dos barulhos, mas eu não consigo me fazer gritar com as pessoas."

# game/script-a3-emi.rpy:5721
translate pt_br a3_emi_detached_a67aa252:

    # yu "I mean aren't their lives hard enough without me throwing my authority around?"
    yu "Quero dizer, a vida deles já não é difícil o suficiente sem eu ficar jogando a minha autoridade por aí?"

# game/script-a3-emi.rpy:5723
translate pt_br a3_emi_detached_ac1ee313:

    # hi "No, it's not the noise level either, I promise."
    hi "Não, não é o barulho também, eu prometo."

# game/script-a3-emi.rpy:5725
translate pt_br a3_emi_detached_4207cbca:

    # hi "I'm just…"
    hi "Eu só…"

# game/script-a3-emi.rpy:5727
translate pt_br a3_emi_detached_9bc8906a:

    # "Hell, I don't know."
    "Inferno, eu não sei."

# game/script-a3-emi.rpy:5729
translate pt_br a3_emi_detached_2ce4f7cf:

    # "Worried about Emi."
    "Preocupado com a Emi."

# game/script-a3-emi.rpy:5731
translate pt_br a3_emi_detached_2573b2f3:

    # "Worried about us."
    "Preocupado com nós."
    

# game/script-a3-emi.rpy:5733
translate pt_br a3_emi_detached_40d81964:

    # "Worried about what happens after we graduate."
    "Preocupado com o que acontece após nos formarmos."

# game/script-a3-emi.rpy:5735
translate pt_br a3_emi_detached_bf32ea38:

    # hi "Emi's been kind of weird, lately."
    hi "A Emi esteve meio esquisita, ultimamente."

# game/script-a3-emi.rpy:5740
translate pt_br a3_emi_detached_f5c41094:

    # yu "What do you mean?"
    yu "O que você quer dizer?"

# game/script-a3-emi.rpy:5742
translate pt_br a3_emi_detached_7cab714b:

    # hi "Well, you know how we're dating now?"
    hi "Bem, você sabe que nós estamos saindo agora?"

# game/script-a3-emi.rpy:5744
translate pt_br a3_emi_detached_601cbb40:

    # hi "I just don't know that we're actually, you know…"
    hi "Eu só não sei se nós estamos realmente, você sabe…"

# game/script-a3-emi.rpy:5746
translate pt_br a3_emi_detached_e4639368:

    # hi "A couple. Or at least I don't know that we're beyond friends."
    hi "Um casal. Ou ao menos eu não sei se somos além de amigos."

# game/script-a3-emi.rpy:5748
translate pt_br a3_emi_detached_bfb9a6e0:

    # "Though friends normally don't do the sort of things we do."
    
    "Embora amigos não fazem o tipo de coisas que nós fazemos."

# game/script-a3-emi.rpy:5750
translate pt_br a3_emi_detached_92404989:

    # "Physically we're a couple."
    "Fisicamente nós somos um casal."

# game/script-a3-emi.rpy:5752
translate pt_br a3_emi_detached_4295f12a:

    # "Coupling, at least."
    "Quando acoplamos, ao menos."

# game/script-a3-emi.rpy:5754
translate pt_br a3_emi_detached_9ef9c98a:

    # hi "It's like every time I try to find out more about her, or about what she wants to do with her life, she dodges the question."
    hi "É como se toda vez que eu fosse tentar descobrir mais sobre ela, ou sobre o que ela quer fazer da vida, ela foge da pergunta."

# game/script-a3-emi.rpy:5756
translate pt_br a3_emi_detached_8ca42a8b:

    # hi "Like the other day, I was talking to her at lunch about some schools I've been looking into."
    hi "Como no outro dia, eu estava conversando com ela no almoço sobre alguns colégios que eu estive olhando."

# game/script-a3-emi.rpy:5758
translate pt_br a3_emi_detached_e6e5ea0f:

    # hi "And I asked her, 'Have you looked into any schools lately?'"
    
    hi "E eu perguntei para ela, “você tem visto alguma universidade ultimamente?”"

# game/script-a3-emi.rpy:5760
translate pt_br a3_emi_detached_70ac39bc:

    # hi "She shrugs in response, says no, and when I ask why not, she says that she doesn't think that far ahead."
    hi "Ela responde de ombros, diz não, e quando eu pergunto por que não, ela diz que não quer pensar tão longe."

# game/script-a3-emi.rpy:5762
translate pt_br a3_emi_detached_d39a6706:

    # hi "I asked why she had that policy, and she…"
    hi "Eu perguntei porque ela tinha essa atitude, e ela…"

# game/script-a3-emi.rpy:5764
translate pt_br a3_emi_detached_0101a1b4:

    # "I suddenly realize what I'm about to start describing, and wisely decide to clam up."
    "Eu de repente percebo o que eu estou prestes a descrever, e sabiamente decido encerrar."

# game/script-a3-emi.rpy:5769
translate pt_br a3_emi_detached_0ba172a7:

    # yu "She what?"
    yu "Ela o quê?"

# game/script-a3-emi.rpy:5771
translate pt_br a3_emi_detached_e0aa7d41:

    # hi "Er, she changed the subject."
    hi "Er, ela muda de assunto."

# game/script-a3-emi.rpy:5773
translate pt_br a3_emi_detached_71698b49:

    # hi "Wouldn't talk about it."
    hi "Não iria falar sobre isso."

# game/script-a3-emi.rpy:5778
translate pt_br a3_emi_detached_bf79791b:

    # yu "Maybe it's an uncomfortable subject for her?"
    yu "Talvez seja um assunto desconfortável para ela?"

# game/script-a3-emi.rpy:5780
translate pt_br a3_emi_detached_fc5662f3:

    # yu "Or she just doesn't think it needs explaining."
    yu "Ou talvez ela pense que isso apenas não seja um assunto que precise explicação."

# game/script-a3-emi.rpy:5782
translate pt_br a3_emi_detached_bdce1d25:

    # hi "Yeah, but it's not just that."
    hi "Sim, mas não é só isso."

# game/script-a3-emi.rpy:5784
translate pt_br a3_emi_detached_31387a47:

    # hi "Every time I try to find out what's been bothering her, she changes the subject too."
    hi "Toda vez que eu tento descobrir o que anda a incomodando, ela muda de assunto também."

# game/script-a3-emi.rpy:5786
translate pt_br a3_emi_detached_976bf7c4:

    # hi "It's like she likes being with me, but not getting close to me."
    hi "É como se ela gostasse de ficar comigo, mas não quer ficar perto de mim."

# game/script-a3-emi.rpy:5788
translate pt_br a3_emi_detached_87f799df:

    # "Now that I've said it out loud, I feel worse."
    "Agora que eu disse isso em voz alta, eu me sinto pior."

# game/script-a3-emi.rpy:5790
translate pt_br a3_emi_detached_38413fb9:

    # "Yuuko digests this bit of information."
    
    "Yuuko digere um pouco da informação."

# game/script-a3-emi.rpy:5795
translate pt_br a3_emi_detached_6d919ae0:

    # yu "You know, it seems to me that you're more serious about this than she is."
    yu "Sabe, parece que você está mais sério sobre isso do que ela."

# game/script-a3-emi.rpy:5797
translate pt_br a3_emi_detached_b20819ef:

    # "I can almost feel my stomach twist into a knot."
    "Eu quase consigo sentir o meu estômago se torcendo num nó."

# game/script-a3-emi.rpy:5799
translate pt_br a3_emi_detached_7fe46979:

    # "She's right."
    "Ela está certa."

# game/script-a3-emi.rpy:5801
translate pt_br a3_emi_detached_99710323:

    # "That's exactly what it seems like."
    "Isso é exatamente o que parece."

# game/script-a3-emi.rpy:5803
translate pt_br a3_emi_detached_b6ae381e:

    # hi "But is that really what's going on? I mean…"
    hi "Mas será que é isso mesmo o que está acontecendo? Quero dizer…"

# game/script-a3-emi.rpy:5808
translate pt_br a3_emi_detached_d1f76d3a:

    # yu "Sorry! I'm just talking nonsense!"
    yu "Desculpa! Eu estou falando só absurdos!"

# game/script-a3-emi.rpy:5810
translate pt_br a3_emi_detached_ece7ebc6:

    # yu "You shouldn't take my advice, you barely know me!"
    yu "Você não deveria escutar meu conselho, você mal me conhece!"

# game/script-a3-emi.rpy:5815
translate pt_br a3_emi_detached_48cc8d6d:

    # yu "I'm just the librarian, and I'm single so you can imagine I can't know what I'm talking about!"
    yu "Sou só a bibliotecária, e sou solteira então você já deve imaginar que eu não sei do que eu estou falando!"

# game/script-a3-emi.rpy:5817
translate pt_br a3_emi_detached_7cac9890:

    # hi "No, I think…"
    hi "Não, eu acho…"

# game/script-a3-emi.rpy:5819
translate pt_br a3_emi_detached_6e5f3d72:

    # hi "I think you have a point."
    hi "Que você tem razão."

# game/script-a3-emi.rpy:5821
translate pt_br a3_emi_detached_29c34b9a:

    # "As much as it hurts to even consider it."
    "Mesmo que doa considerar isso."
    

# game/script-a3-emi.rpy:5823
translate pt_br a3_emi_detached_874d25c0:

    # "Yuuko seems to try desperately to find a way to soften the blow somewhat."
    "Yuuko parece estar desesperadamente tentando achar uma maneira de acalmar o problema de algum modo."

# game/script-a3-emi.rpy:5828
translate pt_br a3_emi_detached_de545e4c:

    # yu "Er, look."
    yu "Er, olha."

# game/script-a3-emi.rpy:5833
translate pt_br a3_emi_detached_1da49682:

    # yu "I'm probably wrong, but if you want to be sure of how obviously wrong I am, maybe you should just talk to her?"
    yu "Eu posso estar errada, mas se você quiser ter certeza de como eu estou errada, talvez você devesse apenas conversar com ela?"

# game/script-a3-emi.rpy:5835
translate pt_br a3_emi_detached_5fae837c:

    # yu "Get some time alone and just ask about it."
    yu "Tire um tempo sozinhos e apenas pergunte sobre isso."
    

# game/script-a3-emi.rpy:5840
translate pt_br a3_emi_detached_01876a59:

    # yu "And don't let her change the subject, either!"
    yu "E não a deixe mudar de assunto, também!"

# game/script-a3-emi.rpy:5842
translate pt_br a3_emi_detached_1b58ae30:

    # hi "Yeah, maybe I should do that."
    hi "Certo, talvez eu deva fazer isso."

# game/script-a3-emi.rpy:5846
translate pt_br a3_emi_detached_76b2fe88_4:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5849
translate pt_br a3_emi_detached_61469bf9:

    # n "{vspace=60}Or maybe I should just enjoy what I have."
    n "{vspace=60}Ou talvez eu deva apenas apreciar o que eu tenho."

# game/script-a3-emi.rpy:5851
translate pt_br a3_emi_detached_c92f6b15:

    # n "We have fun hanging out, after all."
    n "Afinal, nós nos divertimos saindo juntos."

# game/script-a3-emi.rpy:5853
translate pt_br a3_emi_detached_b7147e22:

    # n "And the runs are nice, and the other activities are nice, and talking to her is nice…"
    n "E as corridas são legais, e as outras atividades são legais, e falar com ela é legal…"

# game/script-a3-emi.rpy:5855
translate pt_br a3_emi_detached_9a6c2349:

    # n "Do I really need to get closer to her? What I've got right now is pretty good."
    n "Será que eu realmente preciso me aproximar dela? O que eu tenho agora é muito bom."

# game/script-a3-emi.rpy:5857
translate pt_br a3_emi_detached_670c1d33:

    # n "But that's silly."
    n "Mas isso é ridículo."

# game/script-a3-emi.rpy:5859
translate pt_br a3_emi_detached_3f0b68c5:

    # n "I want to get closer to her."
    n "Eu quero me aproximar dela."

# game/script-a3-emi.rpy:5861
translate pt_br a3_emi_detached_2e5c0678:

    # n "I want to be able to help her out with whatever is bothering her."
    n "Eu quero ser capaz de ajudá-la com qualquer problema que a esteja incomodando."

# game/script-a3-emi.rpy:5863
translate pt_br a3_emi_detached_b1a9147f:

    # n "But… maybe I should wait until after exams are over."
    n "Mas… talvez eu deva esperar pelo menos até depois das provas terem terminado."

# game/script-a3-emi.rpy:5865
translate pt_br a3_emi_detached_b1809124:

    # n "Maybe she'll brighten up once the stress has passed."
    n "Talvez ela vá esclarecer tudo depois que o estresse tenha passado."

# game/script-a3-emi.rpy:5867
translate pt_br a3_emi_detached_8df9807f:

    # n "If she does, then I don't need to worry about it any more."
    n "Se ela fizer, então eu não tenho mais com o que me preocupar."

# game/script-a3-emi.rpy:5869
translate pt_br a3_emi_detached_bfacfc7f:

    # n "But if she doesn't, well."
    n "Mas e se, bem."

# game/script-a3-emi.rpy:5871
translate pt_br a3_emi_detached_cff700c2:

    # n "I'll cross that bridge when I come to it."
    n "Eu irei cruzar essa ponte quando chegar."

# game/script-a3-emi.rpy:5876
translate pt_br a3_emi_detached_76b2fe88_5:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5880
translate pt_br a3_emi_detached_41c71065:

    # "I thank Yuuko for her advice and head back to my room."
    "Eu agradeço a Yuuko pelo conselho e volto para o meu quarto."

# game/script-a3-emi.rpy:5885
translate pt_br a3_emi_detached_f8db0e02:

    # "Maybe I'll be able to concentrate more on my studies in there."
    "Talvez eu consiga me concentrar mais nos meus estudos lá."

# game/script-a3-emi.rpy:5900
translate pt_br a3_emi_phantom_pain_91d73f2a:

    # "I leave the room after finishing my final exam and breathe a sigh of relief."
    
    "Eu deixo a sala após acabar minha prova final e respiro com um suspiro de alívio."

# game/script-a3-emi.rpy:5902
translate pt_br a3_emi_phantom_pain_a877c3f5:

    # "As I'd hoped, the exams weren't so bad. I managed to breeze through just about everything but the English final."
    "Como eu esperava, as provas não foram tão ruins. Eu consegui passar por tudo menos a prova final de inglês."

# game/script-a3-emi.rpy:5904
translate pt_br a3_emi_phantom_pain_0e34496b:

    # "And even that was acceptable."
    "E até aquilo foi aceitável."

# game/script-a3-emi.rpy:5906
translate pt_br a3_emi_phantom_pain_aeed5931:

    # "I wonder how Emi did."
    "Eu imagino como a Emi deve ter ido."

# game/script-a3-emi.rpy:5908
translate pt_br a3_emi_phantom_pain_c58840b4:

    # "Even more so, how she's doing; she looked terrible at lunch today."
    "Ainda mais agora, como ela está; ela parecia terrível no almoço hoje."

# game/script-a3-emi.rpy:5910
translate pt_br a3_emi_phantom_pain_ceb44181:

    # "I mean, she was pretty happy to be out of her wheelchair, but she was so exhausted."
    "Quero dizer, ela estava bem feliz por não estar em sua cadeira de rodas, mas ela estava tão exausta."

# game/script-a3-emi.rpy:5912
translate pt_br a3_emi_phantom_pain_3843f87d:

    # "Something's been wearing her down, and I'm starting to really doubt that it was just the exams."
    "Alguma coisa tem a deixado para baixo, e eu estou começando a duvidar que isso seja apenas as provas."

# game/script-a3-emi.rpy:5914
translate pt_br a3_emi_phantom_pain_5d59690a:

    # "Should I confront her about this, though?"
    "Porém, devo confrontá-la sobre isso?"

# game/script-a3-emi.rpy:5916
translate pt_br a3_emi_phantom_pain_0d1f7f0b:

    # "My musing is interrupted by a tap on the shoulder."
    "Minha reflexão é interrompida por um toque no ombro."
    

# game/script-a3-emi.rpy:5921
translate pt_br a3_emi_phantom_pain_d5244a83:

    # mu "Hey, Hisao."
    mu "Ei, Hisao."

# game/script-a3-emi.rpy:5925
translate pt_br a3_emi_phantom_pain_825276c1:

    # mu "Got a minute?" nointeract
    mu "Tem um minuto?" nointeract

# game/script-a3-emi.rpy:5940
translate pt_br a3_emi_phantom_pain_efbe6d0b:

    # "The question keeps spinning in my head even after I made my way back to my room."
    "A pergunta continua girando em minha cabeça até mesmo depois que eu tenha voltado para o meu quarto."

# game/script-a3-emi.rpy:5944
translate pt_br a3_emi_phantom_pain_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5947
translate pt_br a3_emi_phantom_pain_b21cdf59:

    # n "{vspace=60}What if she gets angry about it?"
    n "{vspace=60}E se ela ficar irritada com isso?"

# game/script-a3-emi.rpy:5949
translate pt_br a3_emi_phantom_pain_08e3627d:

    # n "Besides, what if it's nothing?"
    n "Além disso, e se não for nada?"

# game/script-a3-emi.rpy:5951
translate pt_br a3_emi_phantom_pain_c90f8151:

    # n "If I go in and refuse to leave until she tells me what's wrong or something, won't that come off as clingy?"
    n "Se eu for e recusar sair até que ela me diga o que está errado ou algo assim, isso não seria meio grudento?"

# game/script-a3-emi.rpy:5953
translate pt_br a3_emi_phantom_pain_ca5d3732:

    # n "I don't want to start a fight or anything over something like this."
    n "Eu não quero começar uma briga nem nada acima de algo como isso."

# game/script-a3-emi.rpy:5955
translate pt_br a3_emi_phantom_pain_5e0de14f:

    # n "Maybe I should just drop the matter and see how she is tomorrow before I do anything."
    n "Talvez eu deva apenas esquecer o assunto e ver como ela estará amanhã antes de eu fazer qualquer coisa."

# game/script-a3-emi.rpy:5957
translate pt_br a3_emi_phantom_pain_63e7a279:

    # n "Would it be so bad to just let it go?"
    n "Seria muito ruim se eu apenas esquecesse?"

# game/script-a3-emi.rpy:5959
translate pt_br a3_emi_phantom_pain_0fc4bb43:

    # n "It's not like we don't enjoy each other's company."
    n "Não é como se nós não gostassemos da companhia um do outro."

# game/script-a3-emi.rpy:5961
translate pt_br a3_emi_phantom_pain_4237b9fa:

    # n "But odd as it sounds, I really want to… help her."
    n "Por mais estranho que pareça, eu realmente quero… ajudá-la."

# game/script-a3-emi.rpy:5963
translate pt_br a3_emi_phantom_pain_0b384bef:

    # n "I don't even know what with or if there's anything at all she needs help for."
    n "Eu não sei nem o que é e nem sei se ela realmente precisa de ajuda com algo."

# game/script-a3-emi.rpy:5965
translate pt_br a3_emi_phantom_pain_7eb56115:

    # n "But I want to."
    n "Mas eu quero."

# game/script-a3-emi.rpy:5973
translate pt_br a3_emi_phantom_pain_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:5976
translate pt_br a3_emi_phantom_pain_a0726d67:

    # "Suddenly, a knock at my door rouses me."
    "De repente, uma batida na minha porta me desperta."

# game/script-a3-emi.rpy:5984
translate pt_br a3_emi_phantom_pain_1bfc4d53:

    # "I open it to see Kenji."
    "Eu a abro para ver o Kenji."

# game/script-a3-emi.rpy:5986
translate pt_br a3_emi_phantom_pain_50684ad3:

    # hi "Oh, it's you."
    hi "Oh, é você."

# game/script-a3-emi.rpy:5993
translate pt_br a3_emi_phantom_pain_9e51229e:

    # ke "It's me? That's it?"
    ke "Sou eu? É isso?"

# game/script-a3-emi.rpy:5995
translate pt_br a3_emi_phantom_pain_90026d11:

    # ke "If you had any idea what I'd been through, what I'd done, you'd be happier to see me, dude."
    ke "Se você tivesse alguma ideia do que eu passei, o que eu fiz, você estaria mais feliz de me ver, cara."

# game/script-a3-emi.rpy:5997
translate pt_br a3_emi_phantom_pain_7c6f5b18:

    # ke "I mean that was some epic, you-may-never-see-me-again shit."
    ke "Quero dizer que houve algo extraordinário, coisa-que-você-poderia-nunca-mais-me-ver-de-novo."

# game/script-a3-emi.rpy:5999
translate pt_br a3_emi_phantom_pain_db853ef5:

    # ke "And here you're just acting like I went down to the store for some milk."
    ke "E você está aqui agindo como se eu tivesse descido para a loja atrás de um pouco de leite."

# game/script-a3-emi.rpy:6004
translate pt_br a3_emi_phantom_pain_48397c65:

    # ke "You're a cold man, Hisao. I really respect that."
    ke "Você é frio cara, Hisao. Eu realmente respeito isso."

# game/script-a3-emi.rpy:6006
translate pt_br a3_emi_phantom_pain_583054b1:

    # hi "Uh, thanks, I guess."
    hi "Uh, obrigado, eu acho."

# game/script-a3-emi.rpy:6011
translate pt_br a3_emi_phantom_pain_c132f93e:

    # ke "It's smart to play it safe, you know. Don't show any emotion."
    ke "É inteligente agir de forma segura, sabe. Não mostrar nenhuma emoção."

# game/script-a3-emi.rpy:6013
translate pt_br a3_emi_phantom_pain_f33ccb69:

    # ke "Keep your cards close to your chest."
    ke "Manter suas cartas perto do seu peito."

# game/script-a3-emi.rpy:6015
translate pt_br a3_emi_phantom_pain_3f91078b:

    # ke "Unless it's time to show your cards, or you have bad cards."
    ke "A não ser que seja hora de mostrar suas cartas, ou você tem cartas ruins."

# game/script-a3-emi.rpy:6017
translate pt_br a3_emi_phantom_pain_a2e9f1f4:

    # ke "Then you should fold or collect your winnings."
    ke "Então você deve desistir ou coletar seus ganhos."

# game/script-a3-emi.rpy:6022
translate pt_br a3_emi_phantom_pain_8f27f6fb:

    # ke "Do you understand?"
    ke "Você entendeu?"

# game/script-a3-emi.rpy:6024
translate pt_br a3_emi_phantom_pain_244eb6f2:

    # hi "Yeah, that makes perfect sense."
    hi "Sim, isso faz total sentido."

# game/script-a3-emi.rpy:6026
translate pt_br a3_emi_phantom_pain_27ff780c:

    # hi "I take it the uh, mission went well?"
    hi "Eu acho… a missão ocorreu bem?"

# game/script-a3-emi.rpy:6031
translate pt_br a3_emi_phantom_pain_4e52ba6f:

    # ke "Woah, awfully nosy of you, isn't it?"
    ke "Wow, muito bom de você, não é?"

# game/script-a3-emi.rpy:6033
translate pt_br a3_emi_phantom_pain_3e0718d7:

    # ke "You can't just go saying things like that! Things are at a delicate stage!"
    ke "Você não pode simplesmente sair falando coisas assim! As coisas estão num estado delicado!"

# game/script-a3-emi.rpy:6035
translate pt_br a3_emi_phantom_pain_2d30bc05:

    # ke "One wrong move, and BAM! The invasion succeeds!"
    ke "Um movimento errado, e BAM! A invasão sucede!"

# game/script-a3-emi.rpy:6037
translate pt_br a3_emi_phantom_pain_362f278d:

    # hi "I thought you were going to blow the conspiracy wide open?"
    hi "Eu pensei que você iria expor a conspiração em aberto para todos?"

# game/script-a3-emi.rpy:6039
translate pt_br a3_emi_phantom_pain_2eef5f15:

    # ke "It's bigger than I thought; I need to update my charts."
    ke "É maior do que eu pensava; eu preciso atualizar meus gráficos."

# game/script-a3-emi.rpy:6041
translate pt_br a3_emi_phantom_pain_fc51f627:

    # ke "And probably change some of the puppets around."
    ke "E provavelmente trocar alguns bonecos de lugar."

# game/script-a3-emi.rpy:6046
translate pt_br a3_emi_phantom_pain_2835dbd7:

    # ke "You wanna help? I've got some whiskey from… somewhere."
    ke "Você quer ajuda? Eu tenho um pouco de uísque de… algum lugar."

# game/script-a3-emi.rpy:6048
translate pt_br a3_emi_phantom_pain_a164d139:

    # ke "You can fill me in on everything your investigation has turned up."
    ke "Você pode me contar sobre tudo o que aconteceu na sua investigação até agora."

# game/script-a3-emi.rpy:6050
translate pt_br a3_emi_phantom_pain_8c7a5d43:

    # hi "Er, better not. I'm uh… supposed to meet her today."
    hi "Er, melhor não. Eu uh… tenho que vê-la hoje."

# game/script-a3-emi.rpy:6052
translate pt_br a3_emi_phantom_pain_e406a14c:

    # hi "Gotta go do that. Can't raise suspicion."
    hi "Tenho que ir fazer isso. Não posso levantar suspeita."

# game/script-a3-emi.rpy:6057
translate pt_br a3_emi_phantom_pain_35b2da72:

    # "Kenji nods in approval."
    "Kenji acena com a cabeça em aprovação."

# game/script-a3-emi.rpy:6059
translate pt_br a3_emi_phantom_pain_2fd398fc:

    # ke "Still keeping it close to the chest, eh? Okay man, I respect that."
    ke "Ainda mantendo isso perto do seu peito, eh? Tudo bem cara, eu respeito isso."

# game/script-a3-emi.rpy:6061
translate pt_br a3_emi_phantom_pain_3cf1fe27:

    # ke "Good luck."
    ke "Boa sorte."

# game/script-a3-emi.rpy:6063
translate pt_br a3_emi_phantom_pain_e7cbd408:

    # hi "Er, thanks."
    hi "Er, obrigado."
    

# game/script-a3-emi.rpy:6070
translate pt_br a3_emi_phantom_pain_94ae6363:

    # "I'm just going to pretend, for the sake of my own sanity, that he's wishing me luck in talking to Emi."
    "Eu só vou fingir, pelo bem de minha própria sanidade, que ele está me desejando boa sorte em ir conversar com a Emi."

# game/script-a3-emi.rpy:6072
translate pt_br a3_emi_phantom_pain_1bea8b3b:

    # "And if I squint, that whole card analogy he was talking about works here."
    "E se eu forçar um pouco, toda essa analogia com cartas que ele estava falando funciona aqui."

# game/script-a3-emi.rpy:6074
translate pt_br a3_emi_phantom_pain_1d5ba85a:

    # "Time to lay it all on the table."
    "Hora de colocar tudo na mesa."

# game/script-a3-emi.rpy:6076
translate pt_br a3_emi_phantom_pain_e443c147:

    # "Or see if I can't get Emi to do so, rather."
    "Ou ver se eu não consigo fazer a Emi colocar, em vez disso."

# game/script-a3-emi.rpy:6078
translate pt_br a3_emi_phantom_pain_3a7b8281:

    # "With a sense of something approaching purpose, I head for Emi's room."
    "Com uma sensação de que algo se aproxima, eu vou para o quarto da Emi."

# game/script-a3-emi.rpy:6085
translate pt_br a3_emi_phantom_pain_21cdcb82:

    # "I hop up the stairs leading to her room and knock on her door."
    "Eu subo as escadas que levam para o seu quarto e bato na porta dela."

# game/script-a3-emi.rpy:6087
translate pt_br a3_emi_phantom_pain_1b2ea5c9:

    # emi "W-who's there?"
    emi "Q-quem está aí?"

# game/script-a3-emi.rpy:6091
translate pt_br a3_emi_phantom_pain_6674838b:

    # "Huh. That's odd. Her voice sounds a little choked."
    "Huh. Isso é esquisito. A voz dela parecia um pouco engasgada."

# game/script-a3-emi.rpy:6093
translate pt_br a3_emi_phantom_pain_7c5e53aa:

    # hi "Hey, it's me. Thought I'd stop by."
    hi "Ei, sou eu. Pensei em passar por aqui."

# game/script-a3-emi.rpy:6095
translate pt_br a3_emi_phantom_pain_a18df911:

    # emi "Hisao?"
    emi "Hisao?"

# game/script-a3-emi.rpy:6097
translate pt_br a3_emi_phantom_pain_30885fe1:

    # emi "Come on in!"
    emi "Pode entrar!"

# game/script-a3-emi.rpy:6099
translate pt_br a3_emi_phantom_pain_eb2b44a1:

    # "I reach down to open the door, only to find that it's locked."
    
    "Eu alcanço para abrir a porta, só para descobrir que ela está trancada."

# game/script-a3-emi.rpy:6101
translate pt_br a3_emi_phantom_pain_db01ceec:

    # "More and more curious."
    "Mais e mais curioso."

# game/script-a3-emi.rpy:6103
translate pt_br a3_emi_phantom_pain_87a016c7:

    # hi "Er, your door's locked."
    hi "Er, sua porta está trancada."

# game/script-a3-emi.rpy:6105
translate pt_br a3_emi_phantom_pain_cf923ff4:

    # emi "Oh yeah, sorry. Gimme a minute."
    emi "Ah é, desculpa. Me dá um minuto."

# game/script-a3-emi.rpy:6115
translate pt_br a3_emi_phantom_pain_6e6512f9:

    # "In a few minutes, Emi opens the door, grinning."
    "Em alguns minutos, Emi abre a porta, com um sorriso meio errado."

# game/script-a3-emi.rpy:6117
translate pt_br a3_emi_phantom_pain_fa6ee035:

    # emi "Sorry, I had to put my legs on. I was napping."
    emi "Desculpa, eu tive que colocar as minhas pernas. Eu estava dormindo."

# game/script-a3-emi.rpy:6119
translate pt_br a3_emi_phantom_pain_d4cb5a92:

    # "Despite her grin, there's something definitely off."
    "Além do sorriso dela, tem alguma coisa definitivamenta errada."

# game/script-a3-emi.rpy:6121
translate pt_br a3_emi_phantom_pain_f3b99e1c:

    # "Emi's eyes are slightly red, and it looks like she's been crying."
    "Os olhos da Emi estão um pouco avermelhados, e parece que ela estava chorando."

# game/script-a3-emi.rpy:6123
translate pt_br a3_emi_phantom_pain_b94eb406:

    # hi "Hey, no problem."
    hi "Ei, sem problema."

# game/script-a3-emi.rpy:6125
translate pt_br a3_emi_phantom_pain_4ec637ea:

    # hi "Er, are you okay?"
    hi "Er, você está bem?"

# game/script-a3-emi.rpy:6130
translate pt_br a3_emi_phantom_pain_6fcca0dd:

    # emi "Huh? Yeah, I'm fine!"
    emi "Hã? É, eu estou ótima!"

# game/script-a3-emi.rpy:6132
translate pt_br a3_emi_phantom_pain_37b54c1d:

    # hi "It's just that you look like you've been crying…"
    hi "É que parece que você estava chorando…"

# game/script-a3-emi.rpy:6134
translate pt_br a3_emi_phantom_pain_5001e1e8:

    # "Oh yeah, Hisao. You're off to a great start on this one."
    "Aí sim, Hisao, você começou muito bem com essa."

# game/script-a3-emi.rpy:6139
translate pt_br a3_emi_phantom_pain_6d60086f:

    # emi "What? Nah, I'm fine. I'm just happy to see you."
    emi "O que? Nah, eu estou bem. Só estou feliz de ver você."

# game/script-a3-emi.rpy:6144
translate pt_br a3_emi_phantom_pain_c07acf33:

    # "She punctuates this with a long kiss that continues as the door slams shut behind us."
    "Ela diz isso com um longo beijo que continua enquanto a porta atrás de nós é fechada."

# game/script-a3-emi.rpy:6146
translate pt_br a3_emi_phantom_pain_babf11c2:

    # "I know what she wants to do now, and I'm also painfully aware of how badly I want to do it too, but…"
    "Eu sei o que ela quer fazer agora, e eu estou dolorosamente ciente do quanto eu quero fazer isso também, mas…"

# game/script-a3-emi.rpy:6152
translate pt_br a3_emi_phantom_pain_fa5d8b9c:

    # "I break the kiss with a wrench of self control that nearly kills me."
    "Eu quebro o beijo com uma chave de auto-controle que quase me mata."

# game/script-a3-emi.rpy:6154
translate pt_br a3_emi_phantom_pain_7d88a5e6:

    # hi "Hey, wait."
    hi "Epa, espera."

# game/script-a3-emi.rpy:6159
translate pt_br a3_emi_phantom_pain_83f77a6c:

    # "Emi's eyes crinkle in confusion."
    
    "Os olhos da Emi se dobram em confusão."

# game/script-a3-emi.rpy:6161
translate pt_br a3_emi_phantom_pain_0460472f:

    # emi "Huh? Wait for what?"
    emi "Hã? Esperar pelo o que?"

# game/script-a3-emi.rpy:6163
translate pt_br a3_emi_phantom_pain_3215796f:

    # hi "We need to talk."
    hi "Nós precisamos conversar."

# game/script-a3-emi.rpy:6168
translate pt_br a3_emi_phantom_pain_1b987d43:

    # emi "Isn't that supposed to be my line?"
    emi "Essa não é pra ser a minha fala?"

# game/script-a3-emi.rpy:6173
translate pt_br a3_emi_phantom_pain_07e9c53f:

    # emi "And never a good thing to say?"
    emi "E nunca é uma coisa boa para dizer?"

# game/script-a3-emi.rpy:6175
translate pt_br a3_emi_phantom_pain_e3d0fbe3:

    # "She's got a point."
    "Ela tem razão."

# game/script-a3-emi.rpy:6177
translate pt_br a3_emi_phantom_pain_50a2844b:

    # "It's usually the lead-in to a breakup."
    
    "Geralmente é o que leva para um término."

# game/script-a3-emi.rpy:6179
translate pt_br a3_emi_phantom_pain_852a4040:

    # "Or the prelude to a fight."
    "Ou o prelúdio de uma briga."
    

# game/script-a3-emi.rpy:6181
translate pt_br a3_emi_phantom_pain_41b11874:

    # hi "Maybe it can be a good thing this time."
    hi "Talvez isso possa ser uma coisa boa dessa vez."

# game/script-a3-emi.rpy:6183
translate pt_br a3_emi_phantom_pain_2a023032:

    # hi "Er, that's the hope, anyway."
    hi "Er, essa é a esperança, de qualquer maneira."

# game/script-a3-emi.rpy:6188
translate pt_br a3_emi_phantom_pain_276006e5:

    # emi "Uh… huh."
    emi "A… ham."
    

# game/script-a3-emi.rpy:6193
translate pt_br a3_emi_phantom_pain_42f584dc:

    # emi "Can we at least get onto the bed? It's my first day back on these things, and I'm still readjusting."
    emi "Podemos pelo menos ir para a cama? É o meu primeiro dia de volta nessas coisas, e eu ainda estou me reajustando."

# game/script-a3-emi.rpy:6198
translate pt_br a3_emi_phantom_pain_b5bf4e88:

    # emi "Plus the nurse said I should try to be on them less often, since running puts such a strain on them."
    emi "Ainda mais que o enfermeiro disse que eu deveria usar menos elas, já que correr coloca muita pressão nelas."

# game/script-a3-emi.rpy:6200
translate pt_br a3_emi_phantom_pain_eb14c7e5:

    # hi "Can't argue with that."
    hi "Não posso discutir com isso."

# game/script-a3-emi.rpy:6202
translate pt_br a3_emi_phantom_pain_3680e7d4:

    # "It's a trap, we both know it, and we both don't care."
    "É uma armadilha, nós dois sabemos, e nós dois não nos importamos."

# game/script-a3-emi.rpy:6204
translate pt_br a3_emi_phantom_pain_45d61ce0:

    # "Then again, it's awfully hard to get angry while in bed with the object of your affections, so maybe there's that motivation too."
    "Então de novo, é horrivelmente difícil ficar irritado enquanto se está na cama com o objeto de suas afeições, então talvez tenha um pouco dessa motivação também."

# game/script-a3-emi.rpy:6221
translate pt_br a3_emi_phantom_pain_efa1a123:

    # "I set Emi's legs by the bedside and sit down next to her, throwing an arm around her shoulders."
    "Eu coloco as pernas da Emi ao lado da cama e me sento perto dela, colocando um braço ao redor dos ombros dela."

# game/script-a3-emi.rpy:6223
translate pt_br a3_emi_phantom_pain_1e659f38:

    # "In silence, we just enjoy being able to be in this position again for a few minutes."
    "Em silêncio, nós apenas apreciamos poder estar nessa posição de novo por alguns minutos."

# game/script-a3-emi.rpy:6225
translate pt_br a3_emi_phantom_pain_a3a07c07:

    # "Then, of course, I need to ruin it by opening my mouth."
    "E então, é claro, eu preciso arruinar isso abrindo a minha boca."

# game/script-a3-emi.rpy:6227
translate pt_br a3_emi_phantom_pain_e444771a:

    # hi "Look, I know that… that you've been having kind of a rough time of it lately."
    hi "Olha, eu sei que… você esteve tendo um momento meio difícil ultimamente."

# game/script-a3-emi.rpy:6229
translate pt_br a3_emi_phantom_pain_338352e6:

    # hi "And I want to help you out."
    hi "E eu quero te ajudar com isso."
    

# game/script-a3-emi.rpy:6231
translate pt_br a3_emi_phantom_pain_3b2c2fac:

    # hi "I thought it was just exams getting to you, but now I come to your room and you've been crying, and that kills me."
    hi "Eu pensei que eram apenas as provas te aflingindo, mas agora eu venho no seu quarto e você esta chorando, e isso me mata."

# game/script-a3-emi.rpy:6233
translate pt_br a3_emi_phantom_pain_bc057710:

    # hi "But I can't do anything if you won't talk to me about it."
    hi "Mas eu não consigo fazer nada se você não me fala nada sobre isso."

# game/script-a3-emi.rpy:6238
translate pt_br a3_emi_phantom_pain_a30dda66:

    # emi "I told you, I'm fine."
    emi "Eu te disse, eu estou bem."

# game/script-a3-emi.rpy:6240
translate pt_br a3_emi_phantom_pain_5a89b29d:

    # hi "No, you aren't. It's obvious something's eating at you."
    hi "Não, você não está. Está óbvio que tem algo te consumindo."

# game/script-a3-emi.rpy:6242
translate pt_br a3_emi_phantom_pain_0ca9089e:

    # hi "You can tell me, you know."
    hi "Você pode me contar, sabe."

# game/script-a3-emi.rpy:6244
translate pt_br a3_emi_phantom_pain_ac8ff505:

    # "There's the slightest increase in tension in Emi's voice."
    "Há um pequeno aumento da tensão na voz da Emi."

# game/script-a3-emi.rpy:6249
translate pt_br a3_emi_phantom_pain_c3f3ca2c:

    # emi "Why is my saying I'm fine not good enough?"
    emi "Por que o meu dizer que estou bem não é o suficiente?"
    

# game/script-a3-emi.rpy:6254
translate pt_br a3_emi_phantom_pain_bfc364a6:

    # emi "You're concerned, I get that. That's cool."
    emi "Você está preocupado, eu entendi. Isso é legal."

# game/script-a3-emi.rpy:6256
translate pt_br a3_emi_phantom_pain_1738645f:

    # emi "But I'm fine, and it's nothing that you need to worry about."
    
    emi "Mas eu estou bem, e não tem nada que você precise se preocupar."

# game/script-a3-emi.rpy:6258
translate pt_br a3_emi_phantom_pain_62cdef89:

    # hi "Not sleeping and spacing out more than Rin doesn't strike me as 'being fine.'"
    hi "Não dormindo e viajando mais que a Rin não me parece algo como “estar bem.”"

# game/script-a3-emi.rpy:6260
translate pt_br a3_emi_phantom_pain_daf90821:

    # hi "I just… I want to help."
    hi "Eu só… eu quero ajudar."

# game/script-a3-emi.rpy:6262
translate pt_br a3_emi_phantom_pain_ca7d08c9:

    # emi "Uh-huh."
    emi "A-ham."

# game/script-a3-emi.rpy:6264
translate pt_br a3_emi_phantom_pain_587e0aaf:

    # hi "Yeah, I don't like seeing you like this."
    hi "É, e eu não gosto de ver você assim."

# game/script-a3-emi.rpy:6266
translate pt_br a3_emi_phantom_pain_b258ffa4:

    # hi "I want you to be happy, you know?"
    hi "Eu quero que você seja feliz, sabia?"

# game/script-a3-emi.rpy:6271
translate pt_br a3_emi_phantom_pain_d1e6bc6d:

    # "I get the feeling that came out wrong, because Emi fixes me with an icy stare."
    "Eu tenho a sensação de que isso soou errado, porque Emi me fixa com um olhar gélido."

# game/script-a3-emi.rpy:6273
translate pt_br a3_emi_phantom_pain_bfc2937a:

    # emi "So you want to fix me, Hisao?"
    emi "Então você quer me consertar, Hisao?"

# game/script-a3-emi.rpy:6275
translate pt_br a3_emi_phantom_pain_b2fd68f2:

    # "She's definitely getting angry now."
    "Ela está definitivamente ficando irritada agora."

# game/script-a3-emi.rpy:6280
translate pt_br a3_emi_phantom_pain_35f2bc49:

    # emi "Wanna swoop in on your white charger and save the day?"
    emi "Quer subir no seu cavalo branco e salvar o dia?"

# game/script-a3-emi.rpy:6282
translate pt_br a3_emi_phantom_pain_a3f6fe3c:

    # emi "Stop the nightmares, the phantom limb pains?"
    emi "Parar os pesadelos, as dores dos membros fantasma?"

# game/script-a3-emi.rpy:6287
translate pt_br a3_emi_phantom_pain_2fd0ee5c:

    # emi "Restore what's lost?"
    emi "Restaurar o que foi perdido?"

# game/script-a3-emi.rpy:6292
translate pt_br a3_emi_phantom_pain_da1e47c9:

    # "Her voice catches in her throat, and the tears start to flow."
    "Sua voz pega em sua garganta, e as lágrimas começam a surgir."

# game/script-a3-emi.rpy:6294
translate pt_br a3_emi_phantom_pain_0be76db0:

    # emi "Well you {b}can't{/b}."
    emi "Bem você {b}não pode{/b}."

# game/script-a3-emi.rpy:6299
translate pt_br a3_emi_phantom_pain_f2ceaf19:

    # emi "Nobody can."
    emi "Ninguém pode."

# game/script-a3-emi.rpy:6301
translate pt_br a3_emi_phantom_pain_35ffa19c:

    # emi "Nobody will."
    emi "Ninguém vai."

# game/script-a3-emi.rpy:6303
translate pt_br a3_emi_phantom_pain_5fe78a0f:

    # "I'm so stunned by her sudden verbal assault that I remain quiet."
    "Fico tão chocado com o súbito ataque verbal dela que eu permaneço quieto."

# game/script-a3-emi.rpy:6305
translate pt_br a3_emi_phantom_pain_ab29cb41:

    # "Neither of us says anything for a while."
    "Nenhum de nós consegue dizer nada por um tempo."

# game/script-a3-emi.rpy:6307
translate pt_br a3_emi_phantom_pain_8550c3b7:

    # "I'm surprised that Emi tightens her grip on me rather than pushing me away."
    "Estou surpreso que a Emi ao invés de me empurrar para longe ela me aperta ainda mais forte."

# game/script-a3-emi.rpy:6309
translate pt_br a3_emi_phantom_pain_911c4cef:

    # "After a deep breath, she starts talking again."
    "Depois de respirar fundo, ela começa a falar de novo."

# game/script-a3-emi.rpy:6314
translate pt_br a3_emi_phantom_pain_14b95518:

    # emi "Look, I'm sorry."
    emi "Olha, me desculpa."

# game/script-a3-emi.rpy:6319
translate pt_br a3_emi_phantom_pain_ef915004:

    # emi "I just… there's these nightmares."
    emi "Eu apenas… tenho esses pesadelos."

# game/script-a3-emi.rpy:6321
translate pt_br a3_emi_phantom_pain_db193b68:

    # emi "About the accident."
    emi "Sobre o acidente."

# game/script-a3-emi.rpy:6323
translate pt_br a3_emi_phantom_pain_9679ab82:

    # "Ah. The accident. I should've known."
    "Ah. O acidente. Eu já devia saber."

# game/script-a3-emi.rpy:6325
translate pt_br a3_emi_phantom_pain_6e9231ab:

    # "It took her legs, after all, but it never comes up, of course."
    "Isso levou as pernas dela, depois de tudo, mas isso nunca veio à tona, é claro."

# game/script-a3-emi.rpy:6330
translate pt_br a3_emi_phantom_pain_47fbb747:

    # emi "And I usually deal with them fine, because I can run."
    emi "E eu geralmente consigo lidar bem com isso, porque eu consigo correr."
    

# game/script-a3-emi.rpy:6332
translate pt_br a3_emi_phantom_pain_5d5bee32:

    # emi "Running clears my head like nothing else."
    emi "Correr limpa a minha cabeça como nada mais."

# game/script-a3-emi.rpy:6334
translate pt_br a3_emi_phantom_pain_d155a896:

    # emi "I don't have to worry about anything while I'm running."
    emi "Eu não preciso me preocupar com nada quando eu estou correndo."

# game/script-a3-emi.rpy:6336
translate pt_br a3_emi_phantom_pain_5ede7011:

    # emi "I just concentrate on breathing, on the rhythm of things."
    emi "Eu só me concentro em respirar, no ritmo das coisas."

# game/script-a3-emi.rpy:6338
translate pt_br a3_emi_phantom_pain_5a508f33:

    # emi "It's easier that way. Life's easier that way."
    emi "É mais fácil desse jeito. A vida é mais fácil desse jeito."

# game/script-a3-emi.rpy:6343
translate pt_br a3_emi_phantom_pain_2136b01f:

    # emi "Just keep moving forwards, you know? Nothing else matters, just getting around the next curve."
    emi "Apenas seguir em frente, sabe? Nada mais importa, apenas chegar na próxima curva."

# game/script-a3-emi.rpy:6345
translate pt_br a3_emi_phantom_pain_7d99e273:

    # emi "And then it's the next curve, and the next, and the next, until I can't go any more, or think any more, or do anything but slow down and walk until I catch my breath again."
    emi "E então é a próxima curva, e a próxima, e a próxima, até que eu não consiga mais ir, ou pensar mais, ou fazer qualquer coisa mas parar e caminhar até que eu recupere meu fôlego de novo."

# game/script-a3-emi.rpy:6347
translate pt_br a3_emi_phantom_pain_5ddeddc8:

    # emi "After something like that, nothing else matters."
    emi "Depois de alguma coisa desse tipo, nada mais importa."

# game/script-a3-emi.rpy:6352
translate pt_br a3_emi_phantom_pain_16cafc96:

    # emi "But I've been stuck in that goddamned wheelchair for too long. So, no outlet."
    emi "Eu fiquei presa nessa porcaria de cadeira de rodas por tempo demais. Então, não há escapatória."

# game/script-a3-emi.rpy:6357
translate pt_br a3_emi_phantom_pain_5fa5cf56:

    # emi "Today it just kinda boiled over a little."
    emi "Hoje a coisa meio que fugiu um pouco do controle."

# game/script-a3-emi.rpy:6359
translate pt_br a3_emi_phantom_pain_a433bca5:

    # hi "You could have talked to me about it, you know."
    hi "Você podia falar comigo sobre isso, sabia?"

# game/script-a3-emi.rpy:6361
translate pt_br a3_emi_phantom_pain_bb2db1af:

    # hi "You didn't have to go it alone."
    hi "Você não precisaria passar por isso sozinha."

# game/script-a3-emi.rpy:6366
translate pt_br a3_emi_phantom_pain_489e3dd7:

    # "Emi smiles sadly, like she's trying to explain to a child that all fire burns."
    "Emi sorri tristemente, como se estivesse tentando explicar para uma criança que todo fogo queima."

# game/script-a3-emi.rpy:6368
translate pt_br a3_emi_phantom_pain_d964f6e0:

    # emi "Yeah, I did. And I do."
    emi "É, eu sabia. Mas mesmo assim."

# game/script-a3-emi.rpy:6370
translate pt_br a3_emi_phantom_pain_6cd78fe5:

    # hi "But why?"
    hi "Mas por quê?"

# game/script-a3-emi.rpy:6372
translate pt_br a3_emi_phantom_pain_56eee97c:

    # hi "Why do you have to keep going through this alone?"
    hi "Por que você tem que continuar passando por isso sozinha?"

# game/script-a3-emi.rpy:6374
translate pt_br a3_emi_phantom_pain_b9be715d:

    # hi "Why can't you just trust me enough to let me help you?"
    hi "Por que você não pode confiar em mim o suficiente para eu te ajudar?"

# game/script-a3-emi.rpy:6376
translate pt_br a3_emi_phantom_pain_2eae27be:

    # "That smile again."
    "Aquele sorriso de novo."

# game/script-a3-emi.rpy:6384
translate pt_br a3_emi_phantom_pain_91d2efa2:

    # "Emi leans in and kisses me on my cheek, an almost motherly gesture."
    "Emi se curva e me beija na bochecha, quase como um gesto maternal."

# game/script-a3-emi.rpy:6386
translate pt_br a3_emi_phantom_pain_b3c2080b:

    # "She leaves her mouth close to my ear, as she confesses this one thing to me."
    "Ela deixa a sua boca perto do meu ouvido, enquanto ela confessa uma coisa para mim."

# game/script-a3-emi.rpy:6391
translate pt_br a3_emi_phantom_pain_f9b5557a:

    # emi "Because, Hisao."
    emi "Porque, Hisao."

# game/script-a3-emi.rpy:6393
translate pt_br a3_emi_phantom_pain_019f2170:

    # emi "I've already had everything I knew ripped away from me once."
    emi "Eu já tive tudo que eu conhecia arrancado de mim uma vez."

# game/script-a3-emi.rpy:6398
translate pt_br a3_emi_phantom_pain_48aa3e70:

    # emi "I don't know what I'd do if it happened again."
    emi "Eu não sei o que faria se isso acontecesse de novo."

# game/script-a3-emi.rpy:6400
translate pt_br a3_emi_phantom_pain_b26ab468:

    # "She pauses, as if uncertain as to whether or not she should continue."
    "Ela pausa, como se estivesse incerta se deveria ou não continuar."

# game/script-a3-emi.rpy:6402
translate pt_br a3_emi_phantom_pain_d23ce8fc:

    # "I can feel a violent churning in my gut."
    "Eu consigo sentir uma agitação violenta no meu intestino."

# game/script-a3-emi.rpy:6404
translate pt_br a3_emi_phantom_pain_f9359455:

    # "She continues."
    "Ela continua."

# game/script-a3-emi.rpy:6409
translate pt_br a3_emi_phantom_pain_8e9ff78d:

    # emi "So I can't rely on you."
    emi "Então eu não posso confiar em você."

# game/script-a3-emi.rpy:6411
translate pt_br a3_emi_phantom_pain_ae72a59b:

    # emi "Or the nurse."
    emi "Ou no enfermeiro."

# game/script-a3-emi.rpy:6413
translate pt_br a3_emi_phantom_pain_86804948:

    # emi "Or anyone else."
    emi "Ou em ninguém."

# game/script-a3-emi.rpy:6418
translate pt_br a3_emi_phantom_pain_0f4b7d0c:

    # emi "Just me."
    emi "Apenas em mim."

# game/script-a3-emi.rpy:6420
translate pt_br a3_emi_phantom_pain_483a95f1:

    # emi "That's how it's got to be."
    emi "É assim que isso deve ser."

# game/script-a3-emi.rpy:6422
translate pt_br a3_emi_phantom_pain_66eecf9f:

    # "Having delivered this short speech, she looks down and covers her mouth with the back of her hand."
    "Tendo entregue este pequeno discurso, ela olha para baixo e cobre sua boca com as costas da mão."

# game/script-a3-emi.rpy:6424
translate pt_br a3_emi_phantom_pain_acd0adf6:

    # "The conversation is clearly over. I search for something to say, but can't think of anything."
    "A conversa está claramente acabada. Eu procuro dizer alguma coisa, mas não consigo pensar em nada."

# game/script-a3-emi.rpy:6426
translate pt_br a3_emi_phantom_pain_d77f5a13:

    # hi "I…"
    hi "Eu…"

# game/script-a3-emi.rpy:6428
translate pt_br a3_emi_phantom_pain_c57b6772:

    # hi "Maybe I should go, for now."
    hi "Talvez eu devesse ir, por agora."

# game/script-a3-emi.rpy:6430
translate pt_br a3_emi_phantom_pain_7442de69:

    # hi "I've got… stuff."
    hi "Eu tenho… coisas."

# game/script-a3-emi.rpy:6432
translate pt_br a3_emi_phantom_pain_55bd749a:

    # "Emi doesn't even look up."
    "Emi nem olha para cima."

# game/script-a3-emi.rpy:6434
translate pt_br a3_emi_phantom_pain_eedea99d:

    # "She sounds tired, or relieved."
    "Ela parece cansada, ou aliviada."

# game/script-a3-emi.rpy:6436
translate pt_br a3_emi_phantom_pain_69d3937b:

    # "I can't tell which."
    "Não consigo diferenciar."

# game/script-a3-emi.rpy:6438
translate pt_br a3_emi_phantom_pain_741b568e:

    # emi "Okay, Hisao."
    emi "Ok, Hisao."

# game/script-a3-emi.rpy:6440
translate pt_br a3_emi_phantom_pain_526db814:

    # emi "Go take care of that stuff."
    emi "Vá cuidar dessas coisas."

# game/script-a3-emi.rpy:6442
translate pt_br a3_emi_phantom_pain_405c2c99:

    # emi "I'll see you tomorrow."
    emi "Te vejo amanhã."

# game/script-a3-emi.rpy:6452
translate pt_br a3_emi_phantom_pain_890765e3:

    # "I get off the bed and head for the door, pausing at the doorway."
    "Eu saio da cama e vou para a porta, parando na entrada."

# game/script-a3-emi.rpy:6454
translate pt_br a3_emi_phantom_pain_b95097d5:

    # hi "Hey, Emi…"
    hi "Ei, Emi…"

# game/script-a3-emi.rpy:6459
translate pt_br a3_emi_phantom_pain_95e3e68e:

    # emi "Yeah?"
    emi "Sim?"

# game/script-a3-emi.rpy:6463
translate pt_br a3_emi_phantom_pain_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6466
translate pt_br a3_emi_phantom_pain_43a34339:

    # n "{vspace=60}A thousand things I want to say."
    n "{vspace=60}Mil coisas que eu quero te dizer."

# game/script-a3-emi.rpy:6468
translate pt_br a3_emi_phantom_pain_9c4e8e4f:

    # n "I'm too mixed up to say any of them, though."
    n "Porém, estou muito confuso para dizer elas."

# game/script-a3-emi.rpy:6470
translate pt_br a3_emi_phantom_pain_d25195e7:

    # n "After her admitting that she'll never let me close, I feel like {b}my{/b} world's just been ripped out from me."
    n "Depois dela ter admitido que nunca me deixaria me aproximar, eu sinto que {b}meu{/b} mundo acabou de ser arrancado de mim."

# game/script-a3-emi.rpy:6472
translate pt_br a3_emi_phantom_pain_893fde02:

    # n "What happened in that accident?"
    n "O que aconteceu naquele acidente?"

# game/script-a3-emi.rpy:6474
translate pt_br a3_emi_phantom_pain_8640a555:

    # n "I know she lost her legs, but that's never seemed to bother her."
    n "Eu sei que ela perdeu as pernas, mas isso nunca pareceu incomodar ela."

# game/script-a3-emi.rpy:6476
translate pt_br a3_emi_phantom_pain_04297634:

    # n "What happened there?"
    n "O que aconteceu lá?"

# game/script-a3-emi.rpy:6478
translate pt_br a3_emi_phantom_pain_e90b49b6:

    # n "What scares a girl so badly that she won't accept help, even from someone she loves?"
    n "O que assusta tanto uma garota que ela não quer nem aceitar ajuda, mesmo de alguém que ela ama?"

# game/script-a3-emi.rpy:6480
translate pt_br a3_emi_phantom_pain_f5fd36c3:

    # n "I don't know."
    n "Eu não sei."

# game/script-a3-emi.rpy:6482
translate pt_br a3_emi_phantom_pain_64684785:

    # n "{vspace=30}But I want to know."
    n "{vspace=30}Mas eu quero saber."

# game/script-a3-emi.rpy:6484
translate pt_br a3_emi_phantom_pain_f9d74b66:

    # n "I want to know so badly that being denied that answer feels like a knife in my guts."
    n "Eu quero tanto saber isso que ter a resposta negada parece como uma facada na barriga."

# game/script-a3-emi.rpy:6488
translate pt_br a3_emi_phantom_pain_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6491
translate pt_br a3_emi_phantom_pain_a18df911_1:

    # emi "Hisao?"
    emi "Hisao?"

# game/script-a3-emi.rpy:6493
translate pt_br a3_emi_phantom_pain_4b768ac9:

    # emi "You were saying?"
    emi "Você estava dizendo?"

# game/script-a3-emi.rpy:6495
translate pt_br a3_emi_phantom_pain_dfd96335:

    # "I'm still standing in the doorway."
    "Eu ainda estou parado na entrada."

# game/script-a3-emi.rpy:6497
translate pt_br a3_emi_phantom_pain_2eec6a14:

    # hi "…Nothing."
    hi "…Nada."

# game/script-a3-emi.rpy:6499
translate pt_br a3_emi_phantom_pain_edc7b9f4:

    # hi "Never mind."
    hi "Deixa pra lá."

# game/script-a3-emi.rpy:6507
translate pt_br a3_emi_phantom_pain_5b9f5136:

    # "And I'm closing the door."
    "E eu estou fechando a porta."

# game/script-a3-emi.rpy:6509
translate pt_br a3_emi_phantom_pain_26e24540:

    # "And walking down the hallway."
    "E caminhando pelo corredor."

# game/script-a3-emi.rpy:6511
translate pt_br a3_emi_phantom_pain_3392e5f5:

    # "Down the stairs."
    "Descendo as escadas."

# game/script-a3-emi.rpy:6516
translate pt_br a3_emi_phantom_pain_3879f84f:

    # "Out the door."
    "Saindo pela porta."

# game/script-a3-emi.rpy:6518
translate pt_br a3_emi_phantom_pain_b9740685:

    # "Into the dark."
    "Na escuridão."

# game/script-a3-emi.rpy:6525
translate pt_br a3_emi_phantom_pain_52ae208b:

    # "Somehow I wander back to my own room. My brains are doing a mile a minute, going nowhere fast."
    "De algum modo eu consigo voltar para o meu quarto. Meu cérebro indo a mil por hora, indo para lugar nenhum."

# game/script-a3-emi.rpy:6527
translate pt_br a3_emi_phantom_pain_76b2fe88_4:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6530
translate pt_br a3_emi_phantom_pain_3e789cab:

    # n "{vspace=60}I can't figure out how to deal with this."
    n "{vspace=60}Eu não consigo achar um jeito de lidar com isso."

# game/script-a3-emi.rpy:6532
translate pt_br a3_emi_phantom_pain_01609bd7:

    # n "I thought that moving forward was a good thing."
    n "Eu achava que seguir em frente era uma boa coisa."

# game/script-a3-emi.rpy:6534
translate pt_br a3_emi_phantom_pain_4b5f51b1:

    # n "Dwelling less on a past that I can't change. Living in the present and looking at the future."
    n "Viver menos em um passado que não posso mudar. Viver no presente e olhando para o futuro."

# game/script-a3-emi.rpy:6536
translate pt_br a3_emi_phantom_pain_ca2f4ba8:

    # n "{vspace=60}After this… thing with Emi, I'm not sure any more."
    n "{vspace=60}Depois dessa… coisa com a Emi, eu não tenho mais certeza."

# game/script-a3-emi.rpy:6538
translate pt_br a3_emi_phantom_pain_f9856eb4:

    # n "She was saying the truth. It's simpler to look at the next curve, ignoring the path gone by."
    n "Ela estava falando a verdade. É mais simples olhar para a próxima curva, ignorando o caminho já percorrido."

# game/script-a3-emi.rpy:6540
translate pt_br a3_emi_phantom_pain_9b4c9c44:

    # n "No worry about the opponent left behind. No care for the spectators on the sidelines."
    n "Sem se preocupar com o oponente deixado para trás. Sem importância para os espectadores nas margens."

# game/script-a3-emi.rpy:6542
translate pt_br a3_emi_phantom_pain_942f56f4:

    # n "And unfortunately, no time to watch out for lagging teammates either."
    n "E infelizmente, sem tempo para cuidar de colegas lentos também."

# game/script-a3-emi.rpy:6544
translate pt_br a3_emi_phantom_pain_76b2fe88_5:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6547
translate pt_br a3_emi_phantom_pain_8684421a:

    # "I throw myself down on the bed, looking at one corner of my ceiling as if the answers I want were written there."
    "Eu me jogo na cama, olhando para o canto do meu teto como se as respostas que eu queria estivessem escritas ali."

# game/script-a3-emi.rpy:6549
translate pt_br a3_emi_phantom_pain_ffeb3ec8:

    # "No such luck, of course."
    "Sem sorte, é claro."

# game/script-a3-emi.rpy:6551
translate pt_br a3_emi_phantom_pain_76b2fe88_6:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6554
translate pt_br a3_emi_phantom_pain_0685fba6:

    # n "{vspace=150}She's literally running away from something - but have I not been doing the same thing, trying my best to forget about my hospitalization?"
    n "{vspace=150}Ela está literalmente fugindo de alguma coisa - mas eu não estive fazendo a mesma coisa, tentando o meu melhor em esquecer sobre a minha hospitalização?"

# game/script-a3-emi.rpy:6556
translate pt_br a3_emi_phantom_pain_5ca82997:

    # n "I am getting better, but my health isn't going to magically fix itself."
    n "Eu estou ficando melhor, mas a minha saúde não vai magicamente se consertar sozinha."

# game/script-a3-emi.rpy:6558
translate pt_br a3_emi_phantom_pain_bcae3277:

    # n "{vspace=30}Emi has two legs instead of a heart to deal with, but those aren't going to magically fix themselves either."
    n "{vspace=30}Emi tem duas pernas ao invés de um coração para lidar, mas elas também não vão magicamente se consertar."

# game/script-a3-emi.rpy:6560
translate pt_br a3_emi_phantom_pain_250e5b09:

    # n "{vspace=30}Maybe this is just as fixed as the both of us can get."
    n "{vspace=30}Talvez esse seja o tão fixo que nós conseguimos ter."

# game/script-a3-emi.rpy:6562
translate pt_br a3_emi_phantom_pain_76b2fe88_7:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6565
translate pt_br a3_emi_phantom_pain_f67d47cf:

    # "The room becomes darker and darker, until I can't really tell I'm looking at a corner any more."
    "O quarto fica cada vez mais escuro, até que eu não consiga mais dizer que estou olhando para o canto."

# game/script-a3-emi.rpy:6574
translate pt_br a3_emi_debate_expresses_doubt_0bbf31df:

    # "The morning comes too soon, on the heels of a sleepless night."
    "A manhã chega cedo demais, nos pés de uma noite não dormida."

# game/script-a3-emi.rpy:6576
translate pt_br a3_emi_debate_expresses_doubt_9b48d6ee:

    # "Is this how Emi's been spending her nights?"
    "É assim que a Emi tem passado suas noites?"

# game/script-a3-emi.rpy:6578
translate pt_br a3_emi_debate_expresses_doubt_f7dcb03a:

    # "Staring at the wall, or ceiling. Trying to stop thinking about whatever it is."
    "Olhando para a parede, ou teto. Tentando parar de pensar em qualquer coisa que seja."

# game/script-a3-emi.rpy:6580
translate pt_br a3_emi_debate_expresses_doubt_97e7b369:

    # "Her, in my case."
    "Ela, no meu caso."

# game/script-a3-emi.rpy:6582
translate pt_br a3_emi_debate_expresses_doubt_a1583b46:

    # "That clenched feeling in my gut is still there."
    "Essa sensação de aperto nas minhas entranhas ainda está ali."

# game/script-a3-emi.rpy:6584
translate pt_br a3_emi_debate_expresses_doubt_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6587
translate pt_br a3_emi_debate_expresses_doubt_524d2c66:

    # n "{vspace=60}'I can't rely on you.'"
    n "{vspace=60}Eu não posso confiar em você.”"

# game/script-a3-emi.rpy:6589
translate pt_br a3_emi_debate_expresses_doubt_84c7dd39:

    # n "{vspace=30}Words spoken so casually."
    n "{vspace=30}Palavras ditas de forma tão casual."

# game/script-a3-emi.rpy:6591
translate pt_br a3_emi_debate_expresses_doubt_84559103:

    # n "Almost like she were teasing me, or chastising me for suggesting that the Earth is flat."
    n "Quase como se ela estivesse brincando comigo, ou me castigando por sugerir que a Terra é plana."

# game/script-a3-emi.rpy:6593
translate pt_br a3_emi_debate_expresses_doubt_e52283df:

    # n "{vspace=30}'That's how it's got to be.'"
    n "{vspace=30}É assim que tem que ser.”"

# game/script-a3-emi.rpy:6595
translate pt_br a3_emi_debate_expresses_doubt_b9225692:

    # n "{vspace=30}The way it's got to be sucks."
    n "{vspace=30}O modo de como deve ser é uma droga."

# game/script-a3-emi.rpy:6597
translate pt_br a3_emi_debate_expresses_doubt_42cd0061:

    # n "I'm feeling so miserable that I very nearly decide to skip the run."
    n "Eu estou me sentindo tão miserável que eu quase decido pular a corrida."
    

# game/script-a3-emi.rpy:6599
translate pt_br a3_emi_debate_expresses_doubt_8912feb6:

    # n "That would be stupid, though. It's not something I should do just to see her."
    n "Embora, isso seja estúpido. Não é algo que eu deveria fazer apenas para vê-la."

# game/script-a3-emi.rpy:6601
translate pt_br a3_emi_debate_expresses_doubt_e3dd44fd:

    # n "Sure, that was the original reason, but it's something more now."
    n "Claro, esse foi o motivo original, mas é algo mais agora."

# game/script-a3-emi.rpy:6603
translate pt_br a3_emi_debate_expresses_doubt_73ab70cf:

    # nvl clear
    # n "{vspace=120}I've started to enjoy the running itself."
    nvl clear
    n "{vspace=120}Eu comecei a gostar de correr por mim."

# game/script-a3-emi.rpy:6607
translate pt_br a3_emi_debate_expresses_doubt_db48a36b:

    # n "There are worse ways to get the blood flowing, anyway."
    n "De qualquer maneira, há meios piores de manter o sangue fluindo."

# game/script-a3-emi.rpy:6609
translate pt_br a3_emi_debate_expresses_doubt_99f5e8a6:

    # n "Never thought I'd say it after that first week or so, but—"
    n "Nunca pensei que eu iria dizer isso aquela primeira semana ou algo assim, mas—"

# game/script-a3-emi.rpy:6611
translate pt_br a3_emi_debate_expresses_doubt_c35066c0:

    # n "{vspace=30}I feel a lot better after a run, like no matter what else I do today, I've at least done that one thing."
    n "Eu me sinto muito melhor depois de uma corrida, como se não importasse o que eu fosse fazer hoje, eu deveria apenas fazer essa uma coisa."

# game/script-a3-emi.rpy:6613
translate pt_br a3_emi_debate_expresses_doubt_b630c321:

    # n "It wakes me up, too, and Emi herself said that running always clears her mind. Maybe it'll help clear mine."
    n "Isso me acorda, também, e a Emi mesmo disse que correr sempre limpa a mente dela. Talvez isso possa ajudar a limpar a minha."

# game/script-a3-emi.rpy:6615
translate pt_br a3_emi_debate_expresses_doubt_4cca4b06:

    # n "{vspace=30}I hope so."
    n "{vspace=30}Eu espero."

# game/script-a3-emi.rpy:6617
translate pt_br a3_emi_debate_expresses_doubt_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6623
translate pt_br a3_emi_debate_expresses_doubt_0cadd00a:

    # "The morning is cool and clear, if a bit humid. Summer's making itself known, it seems."
    "A manhã é gélida e limpa, se talvez um pouco úmido. O verão está se fazendo ser reconhecido, aparentemente."

# game/script-a3-emi.rpy:6625
translate pt_br a3_emi_debate_expresses_doubt_7a177fca:

    # "Emi's already stretching out when I arrive, and greets me with a smile and a wave."
    "Emi já está se alongando quando eu chego, ela me cumprimenta com um sorriso e um aceno."

# game/script-a3-emi.rpy:6630
translate pt_br a3_emi_debate_expresses_doubt_41268bd2:

    # emi "Hey, Hisao!"
    emi "Ei, Hisao!"

# game/script-a3-emi.rpy:6632
translate pt_br a3_emi_debate_expresses_doubt_dfc4aac0:

    # "The sight of her so chipper is like a kick in the nuts."
    "A vista dela tão vívida se parece com um chute no saco."

# game/script-a3-emi.rpy:6634
translate pt_br a3_emi_debate_expresses_doubt_df08732d:

    # "How can she be so happy after yesterday?"
    "Como ela pode estar tão feliz depois de ontem?"

# game/script-a3-emi.rpy:6639
translate pt_br a3_emi_debate_expresses_doubt_632eefb0:

    # "I give a half wave and am surprised to receive a hug."
    "Eu dou um meio aceno e sou surpreendido por receber um abraço."

# game/script-a3-emi.rpy:6644
translate pt_br a3_emi_debate_expresses_doubt_6fd25320:

    # emi "Hey, about last night."
    emi "Ei, sobre a noite passada."

# game/script-a3-emi.rpy:6646
translate pt_br a3_emi_debate_expresses_doubt_4f30983b:

    # "Here it comes."
    "Lá vem."

# game/script-a3-emi.rpy:6653
translate pt_br a3_emi_debate_expresses_doubt_b4a1d3cb:

    # emi "I wanted to say thanks."
    emi "Eu queria te agradecer."

# game/script-a3-emi.rpy:6658
translate pt_br a3_emi_debate_expresses_doubt_af4d1d4f:

    # emi "I actually managed to get some sleep for the first time in a while, and I think it's because of our talk."
    emi "Eu realmente consegui dormir um pouco pela primeira vez em algum tempo já, e eu acho que foi por causa da nossa conversa."

# game/script-a3-emi.rpy:6663
translate pt_br a3_emi_debate_expresses_doubt_e8de6908:

    # emi "So, thanks."
    emi "Então, obrigada."

# game/script-a3-emi.rpy:6667
translate pt_br a3_emi_debate_expresses_doubt_cb45918e:

    # "How could she sleep better after our chat?"
    "Como você pode dormir melhor depois de nossa conversa?"

# game/script-a3-emi.rpy:6669
translate pt_br a3_emi_debate_expresses_doubt_7f6900a0:

    # "She basically told me that she wouldn't get any closer to me."
    "Ela basicamente me disse que não iria se aproximar mais nem um pouco de mim."

# game/script-a3-emi.rpy:6671
translate pt_br a3_emi_debate_expresses_doubt_0c5851e5:

    # "And that let her sleep well?"
    "E isso fez com que ela dormisse bem?"

# game/script-a3-emi.rpy:6673
translate pt_br a3_emi_debate_expresses_doubt_634fc438:

    # "Excuse me, but what the hell?"
    "Com licença, mas que porra é essa?"

# game/script-a3-emi.rpy:6675
translate pt_br a3_emi_debate_expresses_doubt_18ee496e:

    # "Emi either doesn't notice my bafflement or chooses not to notice."
    "Emi ou não percebe minha indignação ou escolhe não perceber."

# game/script-a3-emi.rpy:6677
translate pt_br a3_emi_debate_expresses_doubt_9da93fc2:

    # "No telling with her any more."
    "Sem contar mais com ela."

# game/script-a3-emi.rpy:6679
translate pt_br a3_emi_debate_expresses_doubt_54f64392:

    # hi "Oh, no problem. Glad it helped."
    hi "Oh, sem problema. Estou feliz em tê-la ajudado."

# game/script-a3-emi.rpy:6681
translate pt_br a3_emi_debate_expresses_doubt_15acf596:

    # "The venom that threatens to drip into my voice is controlled for now, but I think I'd better start running now, before I do anything stupid."
    "O veneno que ameaça invadir minha voz está controlado por ora, mas eu acho que melhor eu começar a correr agora, antes que eu faça qualquer coisa estúpida."

# game/script-a3-emi.rpy:6686
translate pt_br a3_emi_debate_expresses_doubt_a66bae7c:

    # "Emi seems equally willing to get started, and before long we're darting around the track."
    "Emi parece estar querendo começar também, e logo em seguida nós dois disparamos pela pista."

# game/script-a3-emi.rpy:6688
translate pt_br a3_emi_debate_expresses_doubt_08fe18e8:

    # "I can tell she feels more relaxed."
    "Posso dizer que ela se sente mais relaxada."

# game/script-a3-emi.rpy:6695
translate pt_br a3_emi_debate_expresses_doubt_7c05d675:

    # "Her running has gone back to the more graceful movements I remember from when I first watched her."
    "Sua corrida retornou com os movimentos graciosos que eu lembro quando a vi ela pela primeira vez."

# game/script-a3-emi.rpy:6697
translate pt_br a3_emi_debate_expresses_doubt_19995892:

    # "It's a stark contrast to the almost brutal way she's been hurling herself around the track these past few days."
    "É um forte contraste para o quase brutal modo de como ela vem se arrastando pela pista esses últimos dias."

# game/script-a3-emi.rpy:6699
translate pt_br a3_emi_debate_expresses_doubt_66dc28c9:

    # "Our talk really does seem to have helped her."
    "Nossa conversa realmente parece ter ajudado ela."

# game/script-a3-emi.rpy:6701
translate pt_br a3_emi_debate_expresses_doubt_34232a4e:

    # "A pity it couldn't help me."
    "Uma pena que não pode me ajudar."

# game/script-a3-emi.rpy:6703
translate pt_br a3_emi_debate_expresses_doubt_19658c4f:

    # "I get into the rhythm of the running, thinking back to when I couldn't afford thinking about anything else but keeping my breathing steady and legs moving."
    "Eu entro no ritmo da corrida, voltando a pensar eu não conseguia pensar em nada a não ser em manter minha respiração estável e minhas pernas se mexendo."

# game/script-a3-emi.rpy:6705
translate pt_br a3_emi_debate_expresses_doubt_499cb3b9:

    # "Guess those days are gone."
    "Acho que aqueles dias se foram."

# game/script-a3-emi.rpy:6707
translate pt_br a3_emi_debate_expresses_doubt_075babd0:

    # "At least for the first couple of laps."
    
    "Pelo menos pelas primeiras voltas."

# game/script-a3-emi.rpy:6712
translate pt_br a3_emi_debate_expresses_doubt_4d30bf68:

    # "Annoyed at the lack of success I'm having with clearing my head, I increase the pace."
    "Irritado com a falta de sucesso que eu estou tendo em limpar minha mente, eu aumento o passo."

# game/script-a3-emi.rpy:6714
translate pt_br a3_emi_debate_expresses_doubt_47013e7d:

    # "Ah, there's the burning sensation in my legs."
    "Ah, aqui está a sensação de queimação nas minhas pernas."

# game/script-a3-emi.rpy:6716
translate pt_br a3_emi_debate_expresses_doubt_0a9afe8c:

    # "The breaths coming ragged in my chest, the pounding of my heart. Which I still need to be careful about."
    "As respirações irregulares vindas do meu peito, o batimento do meu coração. O qual eu ainda deveria estar sendo cuidadoso."

# game/script-a3-emi.rpy:6718
translate pt_br a3_emi_debate_expresses_doubt_400816f7:

    # "But it does seem to have gotten stronger; I can feel it pumping blood through my veins."
    "Mas parece que ficou mais forte; eu posso sentir o sangue bombeando pelas minhas veias."

# game/script-a3-emi.rpy:6720
translate pt_br a3_emi_debate_expresses_doubt_0ab09e4b:

    # "The sound thrums in my ears, but instead of being panicked as I was that day in the snow, I'm instead filled with elation."
    "O som bate em meus ouvidos, mas ao invés de estar em pânico como foi aquele dia na neve, eu fico preenchido de alegria."

# game/script-a3-emi.rpy:6722
translate pt_br a3_emi_debate_expresses_doubt_86adaa66:

    # "Yes, it's working! My heart, that fatal flaw that landed me here, has improved."
    "Sim, está funcionando! Meu coração, a falha fatal que me deixou aqui, está melhorando."

# game/script-a3-emi.rpy:6724
translate pt_br a3_emi_debate_expresses_doubt_c25a8b8e:

    # "I'm able to keep going now, and maybe one day I'll be able to stop worrying as much."
    "Sou capaz de continuar agora, e talvez um dia eu serei capaz de parar de me preocupar tanto."

# game/script-a3-emi.rpy:6726
translate pt_br a3_emi_debate_expresses_doubt_9b049038:

    # "Right now, it doesn't matter that I have no idea what to do about Emi and me."
    "Agora mesmo, não interessa que eu não tenha ideia do que fazer sobre a Emi e eu."

# game/script-a3-emi.rpy:6728
translate pt_br a3_emi_debate_expresses_doubt_e63ea287:

    # "All that matters is that my arms and legs continue to pump in concert with one another."
    "Tudo que interessa é que meus braços e pernas continuem a bombear em conjunto um com o outro."

# game/script-a3-emi.rpy:6730
translate pt_br a3_emi_debate_expresses_doubt_d0c77d7b:

    # "Nothing else."
    "Nada mais."

# game/script-a3-emi.rpy:6735
translate pt_br a3_emi_debate_expresses_doubt_d8104f35:

    # "As I hit the final stretch, I remind myself that running really does help, though not as much as I'd hoped."
    "Quando eu atinjo a reta final, eu me recordo que correr realmente ajuda, embora não tanto quanto eu esperava."

# game/script-a3-emi.rpy:6737
translate pt_br a3_emi_debate_expresses_doubt_b7bb611a:

    # "I do feel better, and as I walk a few laps to cool down, I begin to remember last night in a slightly less emotional manner."
    "Eu realmente me sinto melhor, e enquanto eu começo a caminhar umas voltas para esfriar, eu começo a me lembrar da noite passada de uma maneira um pouco menos emocional."

# game/script-a3-emi.rpy:6739
translate pt_br a3_emi_debate_expresses_doubt_43d69fd2:

    # "Emi wants me to stay distant from her."
    "Emi quer que eu me mantenha distante dela."

# game/script-a3-emi.rpy:6741
translate pt_br a3_emi_debate_expresses_doubt_5ca0de6c:

    # "I can't bring myself to do so."
    "E eu não consigo me forçar a fazer isso."

# game/script-a3-emi.rpy:6743
translate pt_br a3_emi_debate_expresses_doubt_69d21548:

    # "There's got to be a way around this, some kind of middle ground I can reach."
    "Deve ter um modo de contornar isso, algum tipo de caminho que eu possa seguir."

# game/script-a3-emi.rpy:6745
translate pt_br a3_emi_debate_expresses_doubt_2d4f4583:

    # "Not sure what that middle ground is, though."
    "Embora, não tenha certeza de que caminho seja esse."

# game/script-a3-emi.rpy:6747
translate pt_br a3_emi_debate_expresses_doubt_3a350c70:

    # "Damn, I was almost feeling optimistic."
    "Droga, eu estava quase me sentindo otimista."

# game/script-a3-emi.rpy:6752
translate pt_br a3_emi_debate_expresses_doubt_161d8dff:

    # emi "Nice run, Hisao! You've really improved!"
    emi "Boa corrida, Hisao! Você realmente melhorou!"

# game/script-a3-emi.rpy:6754
translate pt_br a3_emi_debate_expresses_doubt_af555db9:

    # "Nice run. That's all I can hope for now, isn't it?"
    "Boa corrida. Isso é tudo que eu posso esperar por agora, não é?"

# game/script-a3-emi.rpy:6756
translate pt_br a3_emi_debate_expresses_doubt_efa38e87:

    # "Congratulations, Hisao. You're pathetic."
    "Parabéns, Hisao. Você é patético."

# game/script-a3-emi.rpy:6758
translate pt_br a3_emi_debate_expresses_doubt_ee201a60:

    # "I gotta change my attitude."
    "Eu preciso mudar minha atitude."

# game/script-a3-emi.rpy:6760
translate pt_br a3_emi_debate_expresses_doubt_019a99b9:

    # hi "Well, you know. I am pretty awesome."
    hi "Bem, você sabe. Eu sou demais."

# game/script-a3-emi.rpy:6762
translate pt_br a3_emi_debate_expresses_doubt_9b52b830:

    # "And yet I just keep saying things that I don't mean."
    "E ainda sim eu continuo a dizer coisas que eu não quero."

# game/script-a3-emi.rpy:6764
translate pt_br a3_emi_debate_expresses_doubt_48a7e73c:

    # "Any second now I'll be as good at hiding my problems as Emi is."
    "A qualquer segundo agora eu serei tão bom em esconder meus problemas como a Emi é."

# game/script-a3-emi.rpy:6769
translate pt_br a3_emi_debate_expresses_doubt_d424a7c5:

    # emi "I like to think so."
    emi "Eu gosto de pensar que sim."

# game/script-a3-emi.rpy:6771
translate pt_br a3_emi_debate_expresses_doubt_2c45da8d:

    # "Why does she do this to me? Say something like that with such real affection in her voice that it makes my heart leap?"
    "Por que ela faz isso comigo? Dizer alguma coisa assim com tanta afeição real na voz dela que faz com que meu coração palpite."

# game/script-a3-emi.rpy:6773
translate pt_br a3_emi_debate_expresses_doubt_a7cd818f:

    # "She doesn't mean it. She can't."
    
    "Ela não queria dizer isso. Ela não pode."

# game/script-a3-emi.rpy:6775
translate pt_br a3_emi_debate_expresses_doubt_d4d1ed76:

    # "I must be doing a worse job than I thought, because Emi peers closely at me."
    "Eu devo estar fazendo um trabalho pior do que eu pensava, porque a Emi para de perto para me ver."

# game/script-a3-emi.rpy:6780
translate pt_br a3_emi_debate_expresses_doubt_f189db56:

    # emi "Hey, you feeling okay?"
    emi "Ei, você está se sentindo bem?"

# game/script-a3-emi.rpy:6785
translate pt_br a3_emi_debate_expresses_doubt_0a3644b0:

    # emi "Maybe we should get to the nurse, huh?"
    
    emi "Talvez devêssemos ir ver o enfermeiro, não?"

# game/script-a3-emi.rpy:6787
translate pt_br a3_emi_debate_expresses_doubt_76eac390:

    # hi "Yeah, I'd hate to keel over on you."
    hi "É, eu odiaria desmaiar em você."

# game/script-a3-emi.rpy:6789
translate pt_br a3_emi_debate_expresses_doubt_7e5c4722:

    # "Emi looks a little shocked at my bitter tone."
    
    "Emi parece um pouco chocada com o meu tom amargo."

# game/script-a3-emi.rpy:6794
translate pt_br a3_emi_debate_expresses_doubt_6d68562d:

    # emi "Don't say things like that!"
    emi "Não diga coisas assim!"

# game/script-a3-emi.rpy:6799
translate pt_br a3_emi_debate_expresses_doubt_529b30e0:

    # emi "You've already done it once before, you know."
    emi "Você já fez isso uma vez, sabia?"

# game/script-a3-emi.rpy:6801
translate pt_br a3_emi_debate_expresses_doubt_978e8125:

    # "Why does she act so affectionate?"
    "Por que ela age tão afetuosa?"

# game/script-a3-emi.rpy:6803
translate pt_br a3_emi_debate_expresses_doubt_6deadfd8:

    # "She doesn't really care, I thought she made that clear."
    
    "Ela realmente não se importa, eu pensei que ela tinha deixado isso claro."

# game/script-a3-emi.rpy:6805
translate pt_br a3_emi_debate_expresses_doubt_81779e12:

    # "But despite all of that I find myself apologizing, even though I shouldn't have to. Even though she's probably just putting on an act."
    "Mas mesmo depois de tudo isso eu continuo me desculpando, mesmo quando eu não deveria. Mesmo que ela provavelmente esteja fingindo."

# game/script-a3-emi.rpy:6807
translate pt_br a3_emi_debate_expresses_doubt_8b65049b:

    # hi "Sorry, heh."
    hi "Desculpe, heh."

# game/script-a3-emi.rpy:6809
translate pt_br a3_emi_debate_expresses_doubt_21c623e9:

    # hi "Come on, let's see the nurse."
    hi "Vamos lá, vamos ver o enfermeiro."

# game/script-a3-emi.rpy:6811
translate pt_br a3_emi_debate_expresses_doubt_4c593746:

    # "I can't get myself to calm down the whole time."
    "Eu não consigo me acalmar o tempo todo."

# game/script-a3-emi.rpy:6815
translate pt_br a3_emi_debate_expresses_doubt_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6818
translate pt_br a3_emi_debate_expresses_doubt_05ccc61b:

    # n "{vspace=120}Every time it feels like I've gotten over what happened last night, Emi does something or says something that shows affection, and I'm back to the beginning."
    n "{vspace=120}Toda vez que sinto que superei o que aconteceu noite passada, Emi faz alguma coisa ou diz alguma coisa que demonstra afeição, e eu volto para a estaca zero."

# game/script-a3-emi.rpy:6820
translate pt_br a3_emi_debate_expresses_doubt_56f102a0:

    # n "The image of her ending that conversation haunts me."
    n "A imagem dela terminando aquela conversa me assombra."

# game/script-a3-emi.rpy:6822
translate pt_br a3_emi_debate_expresses_doubt_96dcec54:

    # n "It was like the final twist of the knife that left me feeling bereft of any hope that Emi and I could be more than what we are."
    n "Era como a torção final da faca que me deixou desprovido de qualquer esperança de que Emi e eu pudéssemos ser mais do que nós somos."

# game/script-a3-emi.rpy:6824
translate pt_br a3_emi_debate_expresses_doubt_244fb547:

    # n "And what are we at this point? Little more than friends who happen to fuck."
    n "E o quê nós somos neste ponto? Um pouco mais que amigos que por acaso transam?"

# game/script-a3-emi.rpy:6826
translate pt_br a3_emi_debate_expresses_doubt_e02f24b3:

    # n "And really, it's not like I don't enjoy the time I spend with her. Said so the other day myself."
    n "E realmente, não como se eu não gostasse do tempo que eu fico com ela. Disse o mesmo o outro eu do outro dia."

# game/script-a3-emi.rpy:6828
translate pt_br a3_emi_debate_expresses_doubt_a8302645:

    # n "I very nearly didn't even bring anything up with her, was just gonna hop on in there and let it ride, wasn't I?"
    n "Eu quase nem sequer falo mais nada com ela, ia só entrar na onda e deixar rolar, não ia?"

# game/script-a3-emi.rpy:6832
translate pt_br a3_emi_debate_expresses_doubt_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:6838
translate pt_br a3_emi_debate_expresses_doubt_25d5da16:

    # "With this running through my head, I find myself in front of the nurse's office, still brooding as he checks out Emi."
    "Com isso correndo pela minha cabeça, eu me encontro na frente da enfermaria, ainda me remoendo enquanto ele checa a Emi."

# game/script-a3-emi.rpy:6840
translate pt_br a3_emi_debate_expresses_doubt_8eef6f34:

    # "Emi comes bounding out of the door, gives me a kiss, and darts off to shower, I assume."
    "Emi sai pulando pela porta, me dá um beijo, e sai correndo para o banho, eu assumo."

# game/script-a3-emi.rpy:6842
translate pt_br a3_emi_debate_expresses_doubt_6f5c3372:

    # "Meanwhile, the nurse beckons me into his office to give me the ritual once-over."
    "Enquanto isso, o enfermeiro acena para mim de seu escritório e me faz o ritual mais uma vez."

# game/script-a3-emi.rpy:6851
translate pt_br a3_emi_debate_expresses_doubt_cdd0b28f:

    # nk "Any problems today?"
    nk "Algum problema hoje?"

# game/script-a3-emi.rpy:6853
translate pt_br a3_emi_debate_expresses_doubt_971b5fb6:

    # hi "Nah. I even pushed it a little harder today than I have in the past, and I seemed able to handle it."
    
    hi "Nah. Eu até me esforcei um pouco mais hoje do que antes, e eu parecia aguentar."

# game/script-a3-emi.rpy:6858
translate pt_br a3_emi_debate_expresses_doubt_265627ca:

    # nk "That's uncharacteristically risky coming from you, Hisao."
    nk "Isso é estranhamente arriscado vindo de você, Hisao."

# game/script-a3-emi.rpy:6860
translate pt_br a3_emi_debate_expresses_doubt_b4236130:

    # nk "You've been hanging out with Emi too much. She's rubbed off on you, and not necessarily in a good way."
    nk "Você está passando muito tempo com a Emi. Você está se parecendo com ela, e não necessariamente de uma boa maneira."

# game/script-a3-emi.rpy:6862
translate pt_br a3_emi_debate_expresses_doubt_23db58fd:

    # "At the mention of Emi's name, I can't help but frown unhappily in spite of my efforts at control."
    "Na menção do nome da Emi, não consigo fazer nada senão franzir a cara infeliz apesar dos meus esforços no controle."

# game/script-a3-emi.rpy:6867
translate pt_br a3_emi_debate_expresses_doubt_d34ee6d4:

    # nk "Well, now. This is new, don't you think?"
    nk "Bem, agora. Isso é novidade, não acha?"

# game/script-a3-emi.rpy:6872
translate pt_br a3_emi_debate_expresses_doubt_0dc74a74:

    # nk "Last I checked, your usual response to Emi's name was a grin, not a frown."
    nk "A última vez que chequei, sua resposta natural ao nome da Emi era um sorriso, não um franzido."

# game/script-a3-emi.rpy:6877
translate pt_br a3_emi_debate_expresses_doubt_4a074454:

    # nk "What exactly happened between you two? Because Emi doesn't seem to be in on it, whatever it is."
    nk "O que exatamente aconteceu entre vocês dois? Porque a Emi não parece afetada nisso, seja lá o que for."

# game/script-a3-emi.rpy:6882
translate pt_br a3_emi_debate_expresses_doubt_f89d7762:

    # nk "She looked more relaxed than I've seen her in weeks, which is unusual for this time of the year."
    nk "Ela pareceu mais relaxada do que eu a via em semanas, o que é incomum nessa época do ano."

# game/script-a3-emi.rpy:6884
translate pt_br a3_emi_debate_expresses_doubt_a09f8d61:

    # hi "What do you mean by that?"
    hi "O que você quer dizer com isso?"

# game/script-a3-emi.rpy:6889
translate pt_br a3_emi_debate_expresses_doubt_5c0032a1:

    # nk "By what?"
    nk "Com o quê?"

# game/script-a3-emi.rpy:6891
translate pt_br a3_emi_debate_expresses_doubt_d9bcd658:

    # hi "'For this time of year.' I keep trying to find out what's been bothering her, but she clams up as soon as I broach the subject."
    hi "”Nessa época do ano.” Eu continuo tentando encontrar o que está a incomodando, mas ela se fecha assim que eu toco no assunto."

# game/script-a3-emi.rpy:6893
translate pt_br a3_emi_debate_expresses_doubt_79d07ddc:

    # hi "Then last night, she said—"
    hi "Então noite passada, ela disse—"
    

# game/script-a3-emi.rpy:6898
translate pt_br a3_emi_debate_expresses_doubt_11dd6e74:

    # nk "Let me guess. She won't tell you, because she says she can't trust you?"
    nk "Deixe-me adivinhar. Ela não vai te dizer, porque ela diz que não pode confiar em você?"

# game/script-a3-emi.rpy:6900
translate pt_br a3_emi_debate_expresses_doubt_5ece713e:

    # nk "And now you're crushed, because you thought that the two of you were so much more than she seems to think, right?"
    nk "E agora você está arrasado, porque você pensou que vocês dois eram muito mais do que ela parece pensar, certo?"

# game/script-a3-emi.rpy:6902
translate pt_br a3_emi_debate_expresses_doubt_4b0fcd94:

    # hi "Er, more or less."
    hi "Er, mais ou menos."

# game/script-a3-emi.rpy:6904
translate pt_br a3_emi_debate_expresses_doubt_b75a3000:

    # hi "How the heck did you know?"
    hi "Como diabos você sabe?"

# game/script-a3-emi.rpy:6909
translate pt_br a3_emi_debate_expresses_doubt_d19658dc:

    # nk "Hisao, I'm the nurse. It's my job to know these things."
    nk "Hisao, eu sou o enfermeiro. É meu trabalho saber dessas coisas."

# game/script-a3-emi.rpy:6914
translate pt_br a3_emi_debate_expresses_doubt_62ec7fa4:

    # nk "Plus, I've known Emi for long enough to know that she'd try to do something like this; it's just like her."
    nk "Ainda mais, eu tenho conhecido a Emi por tempo suficiente para saber que ela iria tentar fazer algo desse tipo; é bem o tipo dela."

# game/script-a3-emi.rpy:6916
translate pt_br a3_emi_debate_expresses_doubt_0a679eb9:

    # "He says this in the sort of half-affectionate, half-frustrated tone that would seem more appropriate if he had a cigarette dangling from his lips."
    "Ele diz isso de um jeito, meio afeiçoado e meio frustrado que iria parecer mais apropriado se ele tivesse um cigarro balançando por entre os lábios."

# game/script-a3-emi.rpy:6918
translate pt_br a3_emi_debate_expresses_doubt_b5a02908:

    # "As it is, he seems willing to make do with a pen."
    "E como aparentava, ele parece querer fazer isso com uma caneta."

# game/script-a3-emi.rpy:6926
translate pt_br a3_emi_debate_expresses_doubt_4c4bc11c:

    # nk "Look, you mind if I give you some advice?" nointeract
    nk "Olha, você quer que eu te dê um conselho?" nointeract

# game/script-a3-emi.rpy:6940
translate pt_br a3_emi_debate_expresses_doubt_4425a0b8:

    # "I open my mouth to respond but a knocking sound at the door interrupts me."
    "Eu abro a minha boca para responder mas uma batida na porta me interrompe."

# game/script-a3-emi.rpy:6942
translate pt_br a3_emi_debate_expresses_doubt_8f502fa0:

    # emi "Hey, you guys still in there?"
    emi "Ei, vocês ainda estão aqui?"

# game/script-a3-emi.rpy:6947
translate pt_br a3_emi_debate_expresses_doubt_407949d2:

    # nk "Just a moment, Emi."
    nk "Só um momento, Emi."

# game/script-a3-emi.rpy:6949
translate pt_br a3_emi_debate_expresses_doubt_aadb7537:

    # nk "Give us a second to get our pants back on."
    nk "Nôs de um segundo para colocarmos de volta nossas calças."

# game/script-a3-emi.rpy:6965
translate pt_br a3_emi_debate_expresses_doubt_b22c8aee:

    # "The door bursts open and Emi glares knives at the nurse."
    "A porta se abre e a Emi encara o enfermeiro com um olhar afiado como o de uma faca."

# game/script-a3-emi.rpy:6967
translate pt_br a3_emi_debate_expresses_doubt_b50cdfbd:

    # emi "Asshole."
    emi "Cuzão."

# game/script-a3-emi.rpy:6972
translate pt_br a3_emi_debate_expresses_doubt_2dae0031:

    # nk "Didn't mean to get your hopes up."
    nk "Não quis levantar suas esperanças."
    

# game/script-a3-emi.rpy:6974
translate pt_br a3_emi_debate_expresses_doubt_391b5314:

    # hi "Hey, can we… leave me out of this?"
    hi "Ei, podemos… me deixar fora disso?"

# game/script-a3-emi.rpy:6976
translate pt_br a3_emi_debate_expresses_doubt_d166ef66:

    # hi "Anyway, what's up, Emi? Forget something?"
    hi "De qualquer modo, e aí Emi? Esqueceu alguma coisa?"

# game/script-a3-emi.rpy:6978
translate pt_br a3_emi_debate_expresses_doubt_899181f1:

    # "I try to take a more cheerful tone with her."
    "Eu tento fazer um tom mais animado com ela."
    

# game/script-a3-emi.rpy:6980
translate pt_br a3_emi_debate_expresses_doubt_e3e4cf73:

    # "No need to upset her. Two can play the 'everything's fine' game."
    "Sem necessidade de chateá-la. Dois podem jogar o jogo de “está tudo bem”."

# game/script-a3-emi.rpy:6985
translate pt_br a3_emi_debate_expresses_doubt_d810e149:

    # emi "Actually, I forgot to ask you something."
    emi "Na verdade, eu esqueci de te perguntar uma coisa."

# game/script-a3-emi.rpy:6987
translate pt_br a3_emi_debate_expresses_doubt_b241ddd2:

    # hi "Oh? What's that?"
    hi "Oh? Que seria?"

# game/script-a3-emi.rpy:6992
translate pt_br a3_emi_debate_expresses_doubt_a603ab2a:

    # emi "Do you wanna come with me on a trip to my house?"
    emi "Você quer vir comigo numa viagem para a minha casa?"

# game/script-a3-emi.rpy:6997
translate pt_br a3_emi_debate_expresses_doubt_a020c4a4:

    # emi "My mom's making dinner, and I thought you might want to join us."
    emi "A minha mãe está fazendo jantar, e eu pensei que você talvez quisesse se juntar a nós."

# game/script-a3-emi.rpy:7002
translate pt_br a3_emi_debate_expresses_doubt_99362257:

    # nk "Well, of course I accept."
    nk "Bem, é claro que eu aceito."

# game/script-a3-emi.rpy:7013
translate pt_br a3_emi_debate_expresses_doubt_2dd46cb5:

    # "Emi punches the nurse in the arm playfully."
    
    "Emi dá um soco no braço do enfermeiro de brincadeira."

# game/script-a3-emi.rpy:7015
translate pt_br a3_emi_debate_expresses_doubt_d0d1d321:

    # emi "Not you, idiot. You were over last week."
    emi "Não você, idiota. Você esteve lá semana passada."

# game/script-a3-emi.rpy:7020
translate pt_br a3_emi_debate_expresses_doubt_a1cd714f:

    # emi "I was talking to Hisao."
    emi "Eu estava falando com o Hisao."

# game/script-a3-emi.rpy:7025
translate pt_br a3_emi_debate_expresses_doubt_94013fc7:

    # nk "Oh? How interesting! Meeting the parent!"
    nk "Oh? Que interessante! Encontro com a mãe!"

# game/script-a3-emi.rpy:7027
translate pt_br a3_emi_debate_expresses_doubt_129b3992:

    # hi "I'd love to go, Emi. Thanks."
    hi "Eu adoraria ir, Emi. Obrigado."

# game/script-a3-emi.rpy:7032
translate pt_br a3_emi_debate_expresses_doubt_962de355:

    # "The nurse raises an eyebrow, but says nothing."
    "O enfermeiro levanta uma sobrancelha, mas não diz nada."

# game/script-a3-emi.rpy:7034
translate pt_br a3_emi_debate_expresses_doubt_82dbc18a:

    # emi "Great! I'll be in my room, swing by after you shower and change into something clean and we'll grab the bus!"
    emi "Ótimo! Eu estarei no meu quarto, vá lá depois que você tomar um banho e se arrumar para nós irmos pegar o ônibus!"

# game/script-a3-emi.rpy:7036
translate pt_br a3_emi_debate_expresses_doubt_ee372cef:

    # hi "Sounds good. I'll see you in a bit!"
    hi "Parece bom. Vejo você daqui a pouco!"

# game/script-a3-emi.rpy:7043
translate pt_br a3_emi_debate_expresses_doubt_93b15ea6:

    # "This time it's me who leans in for a quick kiss before darting off to my room."
    "Desta vez sou eu que me inclino para dar um beijinho antes de sair correndo para o meu quarto."

# game/script-a3-emi.rpy:7048
translate pt_br a3_emi_debate_expresses_doubt_becbe0a0:

    # "What an interesting development."
    "Mas que desenvolvimento interessante."

# game/script-a3-emi.rpy:7050
translate pt_br a3_emi_debate_expresses_doubt_993b4732:

    # "Maybe we're getting closer after all."
    "Talvez nós estejamos ficando mais próximos apesar de tudo."

# game/script-a3-emi.rpy:7052
translate pt_br a3_emi_debate_expresses_doubt_89805690:

    # "Maybe Emi's finally ready to open up a little."
    "Talvez a Emi finalmente está pronta para se abrir um pouco."

# game/script-a3-emi.rpy:7054
translate pt_br a3_emi_debate_expresses_doubt_e4921fc8:

    # "Or maybe she's just being polite, and a free meal seems like a good way to apologize for last night."
    "Ou talvez ela está apenas sendo educada, e uma refeição grátis parece um bom modo de se desculpar pela noite passada."

# game/script-a3-emi.rpy:7056
translate pt_br a3_emi_debate_expresses_doubt_e4be70b8:

    # "Great. Now I can't decide whether to be excited, nervous, or depressed."
    "Ótimo. Agora não consigo decidir se fico animado, nervoso ou deprimido."

# game/script-a3-emi.rpy:7058
translate pt_br a3_emi_debate_expresses_doubt_dcfe7be7:

    # "I settle for a combination of all three and hop in the shower."
    "Eu acabo numa combinação dos três e vou para o banho."

# game/script-a3-emi.rpy:7075
translate pt_br a3_emi_guess_whos_coming_never_mind_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:7078
translate pt_br a3_emi_guess_whos_coming_never_mind_8a7ed09f:

    # n "{vspace=90}I don't think I like riding on buses."
    n "{vspace=90}Eu não acho que eu goste de andar de ônibus."

# game/script-a3-emi.rpy:7080
translate pt_br a3_emi_guess_whos_coming_never_mind_ba9a9572:

    # n "Actually, I think I'm pretty comfortable saying that as a fact."
    n "Na verdade, eu acho que estou bem confortável em dizer que isso é um fato."

# game/script-a3-emi.rpy:7082
translate pt_br a3_emi_guess_whos_coming_never_mind_5be26d8f:

    # n "They sway a lot, and they smell funny, and you can feel every bump in the road."
    n "Eles balançam muito, e eles tem um cheiro engraçado, e você consegue sentir cada buraco na pista."

# game/script-a3-emi.rpy:7084
translate pt_br a3_emi_guess_whos_coming_never_mind_da63d109:

    # n "I'm really not looking forward to this."
    n "Eu realmente não estou ansioso para isso."

# game/script-a3-emi.rpy:7086
translate pt_br a3_emi_guess_whos_coming_never_mind_a6155558:

    # n "{vspace=30}Plus Emi's legs keep making a clanking noise that draws the attention of everyone else on the bus."
    n "{vspace=30}Ainda mais que as pernas da Emi ficam fazendo um barulho que pode chamar atenção de todo mundo do ônibus."

# game/script-a3-emi.rpy:7088
translate pt_br a3_emi_guess_whos_coming_never_mind_2d4e9ba3:

    # n "She's in shorts again, and she's got long socks drawn up on her prosthetics so they don't look so obviously false again."
    n "Ela está de shorts de novo, e agora ela está com meias longas esticadas até as suas próteses para que elas não pareçam obviamente falsas de novo."

# game/script-a3-emi.rpy:7090
translate pt_br a3_emi_guess_whos_coming_never_mind_d0864dda:

    # n "But that doesn't stop the odd look or two every time her legs bump together with an audible clunk."
    n "Mas isso não interrompe aquele ou aqueles olhares tortos toda vez que as pernas da Emi se batem fazendo um baque audível."

# game/script-a3-emi.rpy:7092
translate pt_br a3_emi_guess_whos_coming_never_mind_0bf8ef19:

    # nvl clear
    # n "{vspace=90}I shift nervously in my seat, and Emi raises an eyebrow questioningly."
    nvl clear
    n "{vspace=90}Eu me mexo nervoso no meu banco, e Emi levanta uma sobrancelha."

# game/script-a3-emi.rpy:7096
translate pt_br a3_emi_guess_whos_coming_never_mind_8fde870e:

    # n "She doesn't seem to mind the stares; either that or she doesn't even notice that people are staring."
    n "Ela não parece se importar com os olhares; ou isso ou ela nem mesmo percebe que as pessoas estão olhando."

# game/script-a3-emi.rpy:7098
translate pt_br a3_emi_guess_whos_coming_never_mind_fa4575d2:

    # n "I'm sure she's gotten her fill of odd looks before. After a certain amount of time, I doubt she'd notice any more."
    n "Tenho certeza que ela já se encheu com esses olhares. Depois de um certo tempo, eu duvido que ela perceba ainda."

# game/script-a3-emi.rpy:7100
translate pt_br a3_emi_guess_whos_coming_never_mind_3be2bf38:

    # n "{vspace=60}Not that she'd ever tell me if I asked."
    n "{vspace=60}Não que ela fosse me contar se eu perguntasse."

# game/script-a3-emi.rpy:7102
translate pt_br a3_emi_guess_whos_coming_never_mind_43c945cf:

    # n "Another fact is, I'm not just uncomfortable about the bus."
    n "Outro fato é, eu não estou desconfortável só por causa do ônibus."

# game/script-a3-emi.rpy:7104
translate pt_br a3_emi_guess_whos_coming_never_mind_c63a736f:

    # n "I can't seem to come to terms with the fact that Emi appears to be trying to bring me closer while at the same time pushing me away."
    n "Eu não consigo vir com termos à entender o fato de que a Emi parece estar tentando fazer eu me aproximar enquanto ao mesmo tempo me empurra para longe."

# game/script-a3-emi.rpy:7106
translate pt_br a3_emi_guess_whos_coming_never_mind_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:7109
translate pt_br a3_emi_guess_whos_coming_never_mind_d0e4abc5:

    # n "{vspace=90}The nurse said she trusts me, even if it doesn't look like it."
    n "{vspace=90}O enfermeiro disse que ela confia em mim, mesmo que não pareça."

# game/script-a3-emi.rpy:7111
translate pt_br a3_emi_guess_whos_coming_never_mind_108ee925:

    # n "But I'm not sure I can trust the nurse."
    n "Mas eu não tenho certeza se posso confiar no enfermeiro."

# game/script-a3-emi.rpy:7113
translate pt_br a3_emi_guess_whos_coming_never_mind_7ac49045:

    # n "He's protective of Emi, just like I'm protective of Emi, and I'd be likely to say something to make her look good if someone asked me about her."
    n "Ele é o protetor da Emi, assim como eu sou protetor dela, e eu provavelmente iria dizer algo para fazer ela ter uma imagem boa se alguém me perguntasse sobre ela."

# game/script-a3-emi.rpy:7115
translate pt_br a3_emi_guess_whos_coming_never_mind_d4350c68:

    # n "{vspace=30}So he might just be doing that."
    n "{vspace=30}Então ele talvez deva estar fazendo isso."

# game/script-a3-emi.rpy:7117
translate pt_br a3_emi_guess_whos_coming_never_mind_cb93adce:

    # n "{vspace=30}Still, there was something about the way he seemed genuinely surprised that Emi invited me along…"
    n "{vspace=30}Ainda assim, tinha uma coisa no modo de como ele parecia genuinamente surpreso em ver que a Emi me convidou para ir junto…"

# game/script-a3-emi.rpy:7119
translate pt_br a3_emi_guess_whos_coming_never_mind_58f11d2b:

    # n "Maybe last night's talk helped more than I think, but I'm still worried."
    n "Talvez a conversa de ontem ajudou mais do que eu pensava, mas ainda estou preocupado."

# game/script-a3-emi.rpy:7123
translate pt_br a3_emi_guess_whos_coming_never_mind_c8284ac4:

    # nvl clear
    # n "{vspace=90}Meeting the parents is a big deal, right?"
    nvl clear
    n "{vspace=90}Conhecer os pais é coisa séria, não é?"

# game/script-a3-emi.rpy:7127
translate pt_br a3_emi_guess_whos_coming_never_mind_151ac978:

    # n "Not that I haven't already met Emi's mother, but that was just as an acquaintance."
    n "Não que eu não já tenha conhecido a mãe da Emi, mas isso era quando eu era apenas um conhecido dela."

# game/script-a3-emi.rpy:7129
translate pt_br a3_emi_guess_whos_coming_never_mind_eb595e05:

    # n "Now it's going to be as Emi's boyfriend, with everything that implies."
    n "Agora será como o namorado da Emi, como tudo implica."

# game/script-a3-emi.rpy:7131
translate pt_br a3_emi_guess_whos_coming_never_mind_68d66c3f:

    # n "I can feel my heart pounding in my chest, an echo of that snow-covered afternoon that feels like it was so long ago that it might as well be another life entirely."
    n "Eu consigo sentir meu coração palpitando em meu peito, um eco daquela tarde coberta de neve que parece que faz tanto tempo como se tivesse ocorrido numa outra vida."

# game/script-a3-emi.rpy:7133
translate pt_br a3_emi_guess_whos_coming_never_mind_8951f940:

    # n "Except then, I didn't know what was going on; I also didn't have medication to help prevent things spiraling out of control."
    n "Exceto que, eu não sabia o que estava acontecendo; eu também não tinha os remédios para me ajudarem a prevenir quando as coisas ficassem fora de controle."

# game/script-a3-emi.rpy:7135
translate pt_br a3_emi_guess_whos_coming_never_mind_9d11fb7d:

    # n "I've come a long way in terms of my physical health, and for the second time today I feel like I'll be able to live normally now, or at least as normally as possible."
    n "Eu passei por muitas coisas em termos da minha saúde física, e pela segunda vez hoje eu sinto que poderei viver normalmente agora, ou pelo menos o mais normal possível."

# game/script-a3-emi.rpy:7137
translate pt_br a3_emi_guess_whos_coming_never_mind_b16aa4e1:

    # n "{vspace=30}Now if only I could manage my relationship as well as I've managed my heart, I'd be in great shape."
    n "Agora se apenas eu pudesse cuidar do meu relacionamento tão bem quanto eu cuido do meu coração, eu estaria numa ótima forma."

# game/script-a3-emi.rpy:7141
translate pt_br a3_emi_guess_whos_coming_never_mind_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:7151
translate pt_br a3_emi_guess_whos_coming_never_mind_3215f00b:

    # emi "Well, we're here."
    emi "Bem, aqui estamos."

# game/script-a3-emi.rpy:7155
translate pt_br a3_emi_guess_whos_coming_never_mind_19c6d106:

    # "Emi grabs my hand as soon as we've stepped off the bus. She starts heading down the street almost immediately."
    "Emi agarra a minha mão assim que saímos do ônibus. Ela começa a descer a rua quase imediatamente."

# game/script-a3-emi.rpy:7160
translate pt_br a3_emi_guess_whos_coming_never_mind_99a092e0:

    # emi "Come on, we've got a couple blocks until my place."
    emi "Vamos lá, nós temos algumas quadras até minha casa."

# game/script-a3-emi.rpy:7162
translate pt_br a3_emi_guess_whos_coming_never_mind_99973ebe:

    # hi "What? Oh, okay."
    hi "Quê? Oh, tudo bem."

# game/script-a3-emi.rpy:7169
translate pt_br a3_emi_guess_whos_coming_never_mind_36c9aab3:

    # "I follow Emi down the street, watching her confident stride."
    "Eu sigo a Emi pela rua, assistindo seu caminhar confiante."

# game/script-a3-emi.rpy:7171
translate pt_br a3_emi_guess_whos_coming_never_mind_5cf8b0b8:

    # "She's setting kind of a quick pace for just a walk."
    "Ela está meio que num passo rápido para apenas uma caminhada."

# game/script-a3-emi.rpy:7173
translate pt_br a3_emi_guess_whos_coming_never_mind_4932c634:

    # "I guess she's anxious to get there."
    "Acho que ela está ansiosa para chegar lá."

# game/script-a3-emi.rpy:7175
translate pt_br a3_emi_guess_whos_coming_never_mind_e8a2dbe4:

    # hi "So does your mom do this sort of thing often?"
    hi "Então a sua mãe faz esse tipo de coisa com freqüência?"

# game/script-a3-emi.rpy:7180
translate pt_br a3_emi_guess_whos_coming_never_mind_b00167cb:

    # emi "Nah, not too frequently. Mom's never been much for playing hostess."
    emi "Nah, não tão frequentemente. Minha mãe nunca ligou muito em ser uma anfitriã."

# game/script-a3-emi.rpy:7182
translate pt_br a3_emi_guess_whos_coming_never_mind_63754ef5:

    # hi "Oh yeah?"
    hi "Ah é?"

# game/script-a3-emi.rpy:7187
translate pt_br a3_emi_guess_whos_coming_never_mind_c281946f:

    # emi "Yeah, my dad was always the one pushing her to have people over."
    emi "É, meu pai era sempre quem ficava empurrando ela para ter convidados em casa."

# game/script-a3-emi.rpy:7189
translate pt_br a3_emi_guess_whos_coming_never_mind_3c2ba0b9:

    # "This sudden and unprompted reference to her father catches me off guard."
    "Essa súbita e espontânea referência ao pai dela me pega desprevenido."

# game/script-a3-emi.rpy:7191
translate pt_br a3_emi_guess_whos_coming_never_mind_271e212c:

    # "And from the look on Emi's face, I'm not sure she meant to mention him. I think I've only ever heard her talk about him once."
    "E pelo olhar da cara da Emi, eu não tenho certeza se ela quis mencionar ele. Eu acho que só ouvi ela falar dele uma vez."

# game/script-a3-emi.rpy:7193
translate pt_br a3_emi_guess_whos_coming_never_mind_ded34242:

    # "All I remember is that Emi's mom told me that he wasn't around any more."
    "Tudo que me lembro é que a mãe da Emi me disse que ele não estava mais por aí."

# game/script-a3-emi.rpy:7195
translate pt_br a3_emi_guess_whos_coming_never_mind_8f35b675:

    # hi "Oh? Your mom prefers solitude?"
    
    hi "Oh? Sua mãe prefere solidão?"

# game/script-a3-emi.rpy:7200
translate pt_br a3_emi_guess_whos_coming_never_mind_1aa54e29:

    # "Emi laughs, either from relief that I didn't ask about her father or from finding my statement actually funny."
    "Emi ri, ou por alívio de que eu não perguntei mais sobre o pai dela ou por achar minha afirmação realmente engraçada."

# game/script-a3-emi.rpy:7202
translate pt_br a3_emi_guess_whos_coming_never_mind_b0f69dca:

    # emi "Not at all! She's why I'm such an outgoing person, you know."
    emi "Não mesmo! Ela é o motivo de eu ser uma pessoa tão extrovertida, sabia."

# game/script-a3-emi.rpy:7207
translate pt_br a3_emi_guess_whos_coming_never_mind_a274fb6b:

    # emi "She just prefers to be a guest rather than a hostess; it's less stressful that way, or so she says."
    emi "Ela apenas prefere ser convidada a ser anfitriã; é menos estressante desse jeito, é o que ela diz."

# game/script-a3-emi.rpy:7209
translate pt_br a3_emi_guess_whos_coming_never_mind_49e21529:

    # hi "Clearly she's never had to meet her girlfriend's mother for dinner."
    hi "Claramente ela nunca precisou receber a mãe de sua namorada para o jantar."

# game/script-a3-emi.rpy:7211
translate pt_br a3_emi_guess_whos_coming_never_mind_773bc333:

    # "Emi giggles again and speaks in a teasing tone."
    "Emi ri novamente e fala num tom de provocação."

# game/script-a3-emi.rpy:7216
translate pt_br a3_emi_guess_whos_coming_never_mind_92c8676c:

    # emi "Nervous, Hisao?"
    emi "Nervoso, Hisao?"

# game/script-a3-emi.rpy:7221
translate pt_br a3_emi_guess_whos_coming_never_mind_ad037194:

    # emi "You shouldn't be, you know! It's not that big a deal! Just dinner at my house, that's all!"
    emi "Você não deveria, você sabe! Não é nada demais! É um jantar na minha casa, só isso!"

# game/script-a3-emi.rpy:7223
translate pt_br a3_emi_guess_whos_coming_never_mind_f3285db1:

    # hi "Yeah, but have you ever brought home a boyfriend before?"
    hi "É, mas você já trouxe um namorado para casa antes?"

# game/script-a3-emi.rpy:7225
translate pt_br a3_emi_guess_whos_coming_never_mind_bbda0e07:

    # "I confess that part of me dreads hearing the answer to this."
    "Eu confesso que parte de mim tem medo de ouvir a resposta disso."

# game/script-a3-emi.rpy:7227
translate pt_br a3_emi_guess_whos_coming_never_mind_b959ef4f:

    # "I know very little of Emi's past relationships - I don't even know if there were past relationships."
    "Eu sei muito pouco sobre os relacionamentos passados da Emi - eu nem sei se houveram relacionamentas passados."

# game/script-a3-emi.rpy:7232
translate pt_br a3_emi_guess_whos_coming_never_mind_00f58c71:

    # emi "No, I guess I haven't."
    emi "Não, eu acho que não."
    

# game/script-a3-emi.rpy:7237
translate pt_br a3_emi_guess_whos_coming_never_mind_d9c0cb35:

    # emi "Hey, maybe this really is kind of a big deal after all…"
    emi "É, talvez isso seja algo demais no fim… "

# game/script-a3-emi.rpy:7239
translate pt_br a3_emi_guess_whos_coming_never_mind_55c0a7cb:

    # hi "Oh good, now I feel twice as nervous."
    hi "Oh ótimo, agora eu estou duas vezes mais nervoso."

# game/script-a3-emi.rpy:7241
translate pt_br a3_emi_guess_whos_coming_never_mind_f1d5e40f:

    # "Though to tell the truth, I'm pretty happy to hear that I'm the first one."
    "Apesar de dizer a verdade, eu estou bem feliz de ouvir que sou o primeiro."

# game/script-a3-emi.rpy:7243
translate pt_br a3_emi_guess_whos_coming_never_mind_6b029773:

    # "Maybe we've got something special after all."
    "Talvez nós tenhamos algo especial apesar de tudo."

# game/script-a3-emi.rpy:7253
translate pt_br a3_emi_guess_whos_coming_never_mind_7f1af478:

    # "Bolstered by this new thought, I've managed to calm down considerably by the time Emi knocks on her front door."
    "Amparado por esse novo pensamento, eu consegui me acalmar consideravelmente até o momento em que Emi bate na sua porta."

# game/script-a3-emi.rpy:7258
translate pt_br a3_emi_guess_whos_coming_never_mind_20f845c9:

    # emi "Hey, mom, open up! We're here!"
    emi "Oiii, mãe, abre aí! Nós chegamos!"

# game/script-a3-emi.rpy:7267
translate pt_br a3_emi_guess_whos_coming_never_mind_843b5843:

    # "The door swings open, and Mrs. Ibarazaki stands grinning at her daughter. The grin is still surprisingly similar to Emi's."
    "A porta se abre, e a Sra. Ibarazaki para de pé sorrindo para sua filha. O sorriso é surpreendentemente similar ao da Emi."

# game/script-a3-emi.rpy:7269
translate pt_br a3_emi_guess_whos_coming_never_mind_634c6e39:

    # "I'm never going to get used to that."
    "Eu nunca vou me acostumar com isso."
    

# game/script-a3-emi.rpy:7274
translate pt_br a3_emi_guess_whos_coming_never_mind_03fe68ad:

    # emm "You know, people normally wait for a few minutes before they start shouting at the door."
    emm "Sabe, as pessoas normalmente esperam alguns minutos antes de começar a berrar contra a porta."

# game/script-a3-emi.rpy:7279
translate pt_br a3_emi_guess_whos_coming_never_mind_08839c54:

    # emi "And most mothers say hello to their daughters instead of scolding them right away."
    emi "E a maioria da mães dizem olá para suas filhas ao invés de passar um sermão logo de cara."

# game/script-a3-emi.rpy:7284
translate pt_br a3_emi_guess_whos_coming_never_mind_69cb3e1e:

    # emm "Ah, of course. Welcome home, dear. I've missed you."
    emm "Ah, é claro. Bem-vindo de volta, querida. Eu senti sua falta."

# game/script-a3-emi.rpy:7291
translate pt_br a3_emi_guess_whos_coming_never_mind_6fed2131:

    # "An affectionate hug later we're inside, and it is only then that Emi's mom seems to remember that I'm actually here."
    "Um abraço carinhoso depois de entrarmos, e é só aí que parece que a mãe da Emi se lembra de que eu estou aqui."

# game/script-a3-emi.rpy:7296
translate pt_br a3_emi_guess_whos_coming_never_mind_2429653d:

    # emm "And hello to you too, Hisao. How are you?"
    emm "E olá para você também, Hisao. Como você está?"

# game/script-a3-emi.rpy:7298
translate pt_br a3_emi_guess_whos_coming_never_mind_a9322a68:

    # hi "I'm quite well, thank you. Nice to not have school to worry about for a little bit."
    hi "Estou muito bem, obrigado. É bom não ter o colégio para se preocupar um pouco."

# game/script-a3-emi.rpy:7303
translate pt_br a3_emi_guess_whos_coming_never_mind_ec4b8631:

    # emm "Ah yes, you've finished up your exams, haven't you? That must be quite a relief for you both."
    emm "Ah sim, você acabou suas provas, não é? Isso deve ser um grande alívio para vocês dois."

# game/script-a3-emi.rpy:7305
translate pt_br a3_emi_guess_whos_coming_never_mind_af3f277a:

    # hi "It's certainly a weight off of my mind, that's for sure."
    
    hi "Certamente é um peso fora da minha consciência, pode ter certeza."

# game/script-a3-emi.rpy:7314
translate pt_br a3_emi_guess_whos_coming_never_mind_a2bfbb6e:

    # emi "Mine too! I think I slept well for the first time in weeks last night from relief alone."
    emi "Minha também! Eu acho que dormi aliviada pela primeira vez em semanas noite passada."

# game/script-a3-emi.rpy:7316
translate pt_br a3_emi_guess_whos_coming_never_mind_369701e0:

    # "If this news is a surprise to Emi's mother, she doesn't show it. Still, her response betrays a note of interest."
    "Se essa notícia é uma surpresa para a mãe de Emi, ela não demonstra. Ainda assim, sua resposta traz um tom de interesse."

# game/script-a3-emi.rpy:7321
translate pt_br a3_emi_guess_whos_coming_never_mind_7a768848:

    # emm "Is that so? I'm very glad to hear that, Emi. You know I get worried when you get all wound up about… well, exams."
    emm "É mesmo? Estou feliz em ouvir isso, Emi. Você sabe como eu fico preocupada quando você fica toda estressada por causa… bem, das provas."

# game/script-a3-emi.rpy:7323
translate pt_br a3_emi_guess_whos_coming_never_mind_c131bcd6:

    # "Certainly Emi's mother knows something I don't - or rather, she doesn't know that Emi's told me about the nightmares."
    "Certamente a mãe da Emi sabe de alguma coisa que eu não sei - ou, ela não sabe que a Emi me contou sobre os pesadelos."

# game/script-a3-emi.rpy:7325
translate pt_br a3_emi_guess_whos_coming_never_mind_a91750ad:

    # "It's interesting, being able to observe how Mrs. Ibarazaki covers for Emi. That protective instinct to make sure that I don't know any more than Emi's willing to tell me."
    "É interessante, ser capaz de ver como a Sra. Ibarazaki acoberta a Emi. Esse instinto protetor para ter certeza de que eu não saiba mais do que a Emi queira me contar."

# game/script-a3-emi.rpy:7328
translate pt_br a3_emi_guess_whos_coming_never_mind_7db11b24:

    # "I suppose Emi's got more in common with quarks than I ever realized."
    "Acredito que a Emi tem mais em comum com quarks do que eu havia imaginado."

# game/script-a3-emi.rpy:7330
translate pt_br a3_emi_guess_whos_coming_never_mind_b857a616:

    # "Moves around fast, impossible to understand through direct observation, yet she has an effect on everyone she encounters."
    "Se move por aí rápido, impossível de se entender observando a diretamente, e ainda assim ela afeta todo mundo com quem ela topa."

# game/script-a3-emi.rpy:7332
translate pt_br a3_emi_guess_whos_coming_never_mind_ebe4e0c6:

    # "I wonder if Mrs. Ibarazaki will figure out that I know about the nightmares, or is she just keeping everything secret from everybody?"
    "Eu imagino se a Sra. Ibarazaki irá descobrir que eu sei sobre os pesadelos, ou será que ela vai manter tudo em segredo de todo mundo?"

# game/script-a3-emi.rpy:7337
translate pt_br a3_emi_guess_whos_coming_never_mind_03a6cfda:

    # emi "Yeah, it's not been as bad this year as in the past; Hisao helped me to stay focused."
    emi "É, isso não tão ruim esse ano como no passado; Hisao me ajudou a ficar focada."

# game/script-a3-emi.rpy:7339
translate pt_br a3_emi_guess_whos_coming_never_mind_729f6cb0:

    # "Okay, I know that's not true. She even cut off contact outside of school hours during exam week!"
    "Tudo bem, eu sei que isso não é verdade. Ela até cortou o contato fora do horário de aula durante a semana de provas!"

# game/script-a3-emi.rpy:7341
translate pt_br a3_emi_guess_whos_coming_never_mind_4fecd3ad:

    # "But… she did see me during the day. And she told me more than once that the morning run was the only thing she looked forward to during exams, so maybe it's not that much of a lie."
    "Mas… ela realmente me via durante o dia. E ela me contou mais de uma vez que a corrida matinal era a única coisa que ela ansiava durante as provas, então talvez não seja tanto uma mentira."

# game/script-a3-emi.rpy:7343
translate pt_br a3_emi_guess_whos_coming_never_mind_11bf9e96:

    # "Either way, to hear that being around has helped even a little makes me feel a bit better."
    "De qualquer maneira, ouvir que estar por perto ajudou um pouco faz eu me sentir um pouco melhor."

# game/script-a3-emi.rpy:7345
translate pt_br a3_emi_guess_whos_coming_never_mind_aac3dd04:

    # "Emi's mother raises an eyebrow at this statement. Either she doesn't believe Emi, or she's as surprised as I am."
    "A mãe da Emi levanta uma sobrancelha nessa afirmativa. Ou ela não acredita na Emi, ou ela está tão surpresa quanto eu."

# game/script-a3-emi.rpy:7350
translate pt_br a3_emi_guess_whos_coming_never_mind_93c96af6:

    # emm "Well, then it appears that it's a good thing you two have become so close."
    emm "Bom, então parece que foi uma coisa boa que vocês dois tenham ficado tão próximos."

# game/script-a3-emi.rpy:7355
translate pt_br a3_emi_guess_whos_coming_never_mind_4f40d6af:

    # emm "I'd tell you to take good care of my daughter, Hisao, but it looks like you're already doing that."
    emm "Eu iria lhe dizer para cuidar da minha filha, Hisao, mas parece que você já está fazendo isso."

# game/script-a3-emi.rpy:7360
translate pt_br a3_emi_guess_whos_coming_never_mind_bc0ce105:

    # "Emi grins at this and seems to take pride in my having managed to ingratiate myself with her mother so easily."
    "Emi sorri nisso e parece ter orgulho de que eu tenha conseguido me engraçar com a sua mãe tão facilmente."

# game/script-a3-emi.rpy:7362
translate pt_br a3_emi_guess_whos_coming_never_mind_ecac9269:

    # hi "Actually, I'd say your daughter's been the one taking care of me. She's gotten me out and running."
    hi "Na verdade, eu diria que é a sua filha que tem cuidado de mim. Ela que me fez sair e correr."

# game/script-a3-emi.rpy:7364
translate pt_br a3_emi_guess_whos_coming_never_mind_8f2542a7:

    # hi "I've probably been more active since meeting her than I ever was, even before…"
    hi "Eu provavelmente estou mais ativo do que nunca desde que conheci ela, até mais que antes…"

# game/script-a3-emi.rpy:7366
translate pt_br a3_emi_guess_whos_coming_never_mind_ed798aa5:

    # "I'd actually never thought of it that much, nor had I ever appreciated the humor in it."
    "Eu nunca realmente pensei nisso tanto, ou nunca tinha apreciado o humor nisso."

# game/script-a3-emi.rpy:7368
translate pt_br a3_emi_guess_whos_coming_never_mind_572d399f:

    # "I wasn't too active before the heart attack. Pickup games of soccer don't really count since they weren't that common."
    "Eu não era tão ativo assim antes do ataque do coração. Jogos de futebol não contam já que eles não eram muito comuns."

# game/script-a3-emi.rpy:7370
translate pt_br a3_emi_guess_whos_coming_never_mind_b68c660e:

    # "So now that I know for sure that I have a weak heart, {b}now{/b} I run every day, pushing my luck with the help of my medication."
    "Então agora que eu sei que tenho um coração fraco, {b}agora{/b} eu corro todo dia, tentando minha sorte com a ajuda de minha medicação."

# game/script-a3-emi.rpy:7372
translate pt_br a3_emi_guess_whos_coming_never_mind_2bc2ad07:

    # "I chuckle quietly, then realize that I never finished my sentence."
    "Eu rio quietamente, e percebo que não terminei minha frase."

# game/script-a3-emi.rpy:7374
translate pt_br a3_emi_guess_whos_coming_never_mind_95169090:

    # hi "Well, before I had my heart attack and wound up at school here."
    hi "Bem, antes de eu ter meu ataque do coração e parar no colégio aqui."

# game/script-a3-emi.rpy:7376
translate pt_br a3_emi_guess_whos_coming_never_mind_eab47adf:

    # "It comes out so casually. There was a time that I would have thought twice about talking about what was wrong with me at all."
    "Isso sai tão casualmente. Houve uma época em que eu iria pensar duas vezes antes de dizer o que tinha de errado comigo."

# game/script-a3-emi.rpy:7378
translate pt_br a3_emi_guess_whos_coming_never_mind_ad4f9c4a:

    # "But now? Now it just seems silly to care, especially in the company of Emi and her mother."
    "Mas agora? Agora parece bobagem se preocupar, especialmente estando na companhia de Emi e sua mãe."

# game/script-a3-emi.rpy:7380
translate pt_br a3_emi_guess_whos_coming_never_mind_fb0cf212:

    # "If Emi can be cavalier about her disability, then so can I."
    "Se a Emi pode ser descuidada com sua deficiência, eu também posso."

# game/script-a3-emi.rpy:7382
translate pt_br a3_emi_guess_whos_coming_never_mind_e04bb472:

    # "I think back to the track meet, where Emi declared herself the fastest thing on no legs."
    "Eu me lembro da reunião da pista, onde Emi declarou ela mesma a coisa mais rápida sem pernas."

# game/script-a3-emi.rpy:7384
translate pt_br a3_emi_guess_whos_coming_never_mind_0a2dfed6:

    # "The fact of her obvious loss has never seemed to bother her, at least not in public."
    "O fato de sua perda óbvia parece nunca a ter incomodado, pelo menos não em público."

# game/script-a3-emi.rpy:7386
translate pt_br a3_emi_guess_whos_coming_never_mind_1c095f7d:

    # "Being stuck in the wheelchair frustrated her, I know. But even that was something she dealt with on her own, despite my efforts to the contrary."
    "Ficar preso numa cadeira de rodas a frustrou, eu sei. Mas mesmo aquilo foi uma coisa que ela lidou sozinha, apesar dos meus esforços do contrário."

# game/script-a3-emi.rpy:7391
translate pt_br a3_emi_guess_whos_coming_never_mind_f5d0922e:

    # emm "Emi has a way of bringing out the more active side in people. I've never quite figured out how she does it."
    emm "Emi tem um jeito de chamar o lado mais ativo das pessoas. Eu nunca entendi muito bem como ela faz isso."

# game/script-a3-emi.rpy:7393
translate pt_br a3_emi_guess_whos_coming_never_mind_228a06d9:

    # "Those puppy dog eyes she gets, for starters."
    "Esses olhos de cachorrinhos que ela tem, para iniciantes."

# game/script-a3-emi.rpy:7398
translate pt_br a3_emi_guess_whos_coming_never_mind_0dce7133:

    # emm "I'm not surprised that she managed to rope you into an exercise routine."
    emm "Eu não estou surpresa que ela conseguiu te enrolar numa rotina de exercícios."

# game/script-a3-emi.rpy:7400
translate pt_br a3_emi_guess_whos_coming_never_mind_d91ab5cf:

    # emm "If Rin weren't just as stubborn as she is, I'm sure that Emi would have gotten her out and running with you too."
    emm "Se a Rin não fosse tão teimosa como ela é, eu tenho certeza que a Emi iria fazer ela sair e correr com você também."

# game/script-a3-emi.rpy:7405
translate pt_br a3_emi_guess_whos_coming_never_mind_8844467e:

    # emi "Oh, that reminds me! Rin says hello."
    emi "Oh, isso me lembra! Rin mandou um oi."

# game/script-a3-emi.rpy:7410
translate pt_br a3_emi_guess_whos_coming_never_mind_54c5e239:

    # "I drift to the outer edges of the conversation again as we move into the dining room to eat."
    "Eu fico à deriva nas conversas enquanto nos movemos para a sala de jantar para comer."

# game/script-a3-emi.rpy:7412
translate pt_br a3_emi_guess_whos_coming_never_mind_46dd1e9b:

    # "It smells delicious in here, and the spread that Emi's mom has produced is impressive."
    "Tem um cheiro ótimo aqui, e a variedade que a mãe da Emi fez é impressionante."
    

# game/script-a3-emi.rpy:7418
translate pt_br a3_emi_guess_whos_coming_never_mind_166a5b7f:

    # emi "Woah, you've made enough to feed an army in here!"
    emi "Uau, você fez suficiente para alimentar um batalhão aqui!"

# game/script-a3-emi.rpy:7423
translate pt_br a3_emi_guess_whos_coming_never_mind_7bdb99ee:

    # emm "Is it too much? Well, you can always take some leftovers with you when you go."
    emm "É um pouco demais? Bem, você sempre pode levar as sobras com você quando partir."
    

# game/script-a3-emi.rpy:7425
translate pt_br a3_emi_guess_whos_coming_never_mind_c7bc167c:

    # hi "That sounds great! I can only handle cafeteria food for so long. Something home-cooked would be a welcome change of pace."
    hi "Isso parece ótimo! Eu estive comendo a comida do refeitório por tanto tempo. Algo caseiro seria uma mudança muito bem vinda."

# game/script-a3-emi.rpy:7430
translate pt_br a3_emi_guess_whos_coming_never_mind_e9653c2d:

    # emi "What he said. Thanks, mom."
    emi "Digo o mesmo. Obrigada, mãe."

# game/script-a3-emi.rpy:7432
translate pt_br a3_emi_guess_whos_coming_never_mind_953178c3:

    # "The food tastes as good as it smells, and there's a lull in the conversation while we all dig in."
    "A comida tem um gosto tão bom quanto seu cheiro, e há uma pausa na conversa enquanto comemos."

# game/script-a3-emi.rpy:7434
translate pt_br a3_emi_guess_whos_coming_never_mind_5ee05f86:

    # "Emi assaults her plate with the usual amount of gusto, and I will admit that I set a pretty fast pace myself."
    "Emi ataca o prato de seu modo usual, e eu tenho que admitir que eu mesmo estou num passo bem rápido."

# game/script-a3-emi.rpy:7439
translate pt_br a3_emi_guess_whos_coming_never_mind_c85ff4ae:

    # emm "So Hisao, I hear that you and my daughter here have gotten rather close, hmm?"
    emm "Então Hisao, eu ouvi que você e minha filha aqui ficaram um tanto próximos, hmm?"

# game/script-a3-emi.rpy:7441
translate pt_br a3_emi_guess_whos_coming_never_mind_e015eaec:

    # "The urge to say something like 'Not really' is so strong that I open my mouth to say it, but then reassert control."
    "A vontade de dizer algo como “não mesmo” é tão forte que eu até abro minha boca para dizer isso, mas em seguida eu retomo o controle."

# game/script-a3-emi.rpy:7443
translate pt_br a3_emi_guess_whos_coming_never_mind_01ca0ddd:

    # "We are close, there's no getting around it. I mean Emi's brought me here, hasn't she?"
    "Nós somos próximos, não tem como negar. Quero dizer, a Emi me trouxe aqui, não trouxe?"

# game/script-a3-emi.rpy:7445
translate pt_br a3_emi_guess_whos_coming_never_mind_dcbeeac8:

    # "Fortunately, both Emi and her mother seem to take my reaction as a sign that I'm caught off guard rather than considering saying something cruel."
    "Felizmente, ambas Emi e sua mãe parecem levar minha reação como um sinal de que fui pego desprevenido do que considerar dizer algo cruel."

# game/script-a3-emi.rpy:7447
translate pt_br a3_emi_guess_whos_coming_never_mind_d484047f:

    # hi "Heh, I suppose we have. I blame the morning runs, myself."
    hi "Heh, eu suponho que sim. Eu mesmo, culpo as corridas matinais."

# game/script-a3-emi.rpy:7452
translate pt_br a3_emi_guess_whos_coming_never_mind_28dc01e5:

    # emi "You make it sound like a bad thing, Hisao."
    emi "Você faz isso soar como se fosse uma coisa ruim, Hisao."

# game/script-a3-emi.rpy:7457
translate pt_br a3_emi_guess_whos_coming_never_mind_06bdd557:

    # emm "Well, I for one found it a relief."
    emm "Bem, eu por outro lado acho isso um alívio."

# game/script-a3-emi.rpy:7459
translate pt_br a3_emi_guess_whos_coming_never_mind_e2ba6edd:

    # hi "Why's that?"
    hi "Por que disso?"

# game/script-a3-emi.rpy:7464
translate pt_br a3_emi_guess_whos_coming_never_mind_463818ea:

    # emm "Emi's always been a popular girl, but never made many close friends."
    emm "Emi sempre foi uma garota popular, mas nunca teve muitos amigos próximos."

# game/script-a3-emi.rpy:7466
translate pt_br a3_emi_guess_whos_coming_never_mind_33dd3af8:

    # "This is a bit of news to me. I've always seen Emi chatting with her classmates in the hallways."
    "Isso é meio que novo para mim. Eu sempre via Emi conversando com seus colegas nos corredores."

# game/script-a3-emi.rpy:7468
translate pt_br a3_emi_guess_whos_coming_never_mind_c1df0fa8:

    # "And certainly the whole track team seems to love her, but it is true that she chooses to isolate herself during lunch with Rin and me."
    "E certamente todo o time da pista parece amar ela, mas é verdade que ela prefere se isolar durante o almoço comigo e a Rin."

# game/script-a3-emi.rpy:7470
translate pt_br a3_emi_guess_whos_coming_never_mind_4ae31f68:

    # "Not exactly the sort of behavior one expects from a popular girl, after all. Then again, I've experienced her unwillingness to get close firsthand, so I can't say I'm that surprised."
    "Não exatamente o tipo de comportamento que se espera de uma garota popular, apesar de tudo. Ainda assim, eu experienciei sua falta de vontade de se aproximar em primeira mão, então não posso dizer que estou surpreso."

# game/script-a3-emi.rpy:7475
translate pt_br a3_emi_guess_whos_coming_never_mind_90d1a678:

    # emm "I was beginning to have my doubts."
    emm "Eu estava começando a ter minhas dúvidas."

# game/script-a3-emi.rpy:7480
translate pt_br a3_emi_guess_whos_coming_never_mind_8043a524:

    # "Emi rolls her eyes to the ceiling and grumbles something I can't quite make out."
    "Emi revira os olhos para o teto e murmura algo que eu não consigo entender muito bem."

# game/script-a3-emi.rpy:7484
translate pt_br a3_emi_guess_whos_coming_never_mind_0f638bea:

    # hi "Huh?"
    hi "Hein?"

# game/script-a3-emi.rpy:7489
translate pt_br a3_emi_guess_whos_coming_never_mind_cf45f9a1:

    # emi "What?"
    emi "Quê?"

# game/script-a3-emi.rpy:7491
translate pt_br a3_emi_guess_whos_coming_never_mind_a13564ab:

    # hi "What's that you just said?"
    hi "O que foi que você acabou de dizer?"

# game/script-a3-emi.rpy:7496
translate pt_br a3_emi_guess_whos_coming_never_mind_9beded29:

    # emi "Nothing."
    emi "Nada."

# game/script-a3-emi.rpy:7501
translate pt_br a3_emi_guess_whos_coming_never_mind_fee27260:

    # "Mrs. Ibarazaki chokes on her drink with laughter."
    "A Sra. Ibarazaki se engasga com a sua bebida de tanto rir."

# game/script-a3-emi.rpy:7505
translate pt_br a3_emi_guess_whos_coming_never_mind_dbb9427c:

    # emm "You've been hanging out with the nurse too long, Emi."
    emm "Você tem andado demais com o enfermeiro, Emi."

# game/script-a3-emi.rpy:7507
translate pt_br a3_emi_guess_whos_coming_never_mind_7f9ca110:

    # emm "I'm going to have to talk to him about corrupting my daughter."
    emm "Eu vou ter de conversar com ele sobre corromper a minha filha."

# game/script-a3-emi.rpy:7509
translate pt_br a3_emi_guess_whos_coming_never_mind_ae5fa616:

    # hi "Somehow I don't think that would be very effective."
    hi "De alguma maneira eu não acho que isso seria muito eficaz."

# game/script-a3-emi.rpy:7514
translate pt_br a3_emi_guess_whos_coming_never_mind_8de4e42e:

    # emi "I learned most of it from you anyway. Not the nurse."
    emi "De qualquer jeito eu aprendi a maior parte disso de você. Não o enfermeiro."

# game/script-a3-emi.rpy:7519
translate pt_br a3_emi_guess_whos_coming_never_mind_374f8d01:

    # emm "Don't listen to her, Hisao. She's a born liar."
    emm "Não escute ela, Hisao. Ela é uma ótima mentirosa."
    

# game/script-a3-emi.rpy:7524
translate pt_br a3_emi_guess_whos_coming_never_mind_6a329f53:

    # emi "Hmph. Yeah right."
    emi "Hmph. É claro."

# game/script-a3-emi.rpy:7526
translate pt_br a3_emi_guess_whos_coming_never_mind_32ec23fc:

    # hi "Oh, I don't know, Emi. I think your mother has a point."
    hi "Ah, eu não sei, Emi. Eu acho que sua mãe possa estar certa."

# game/script-a3-emi.rpy:7531
translate pt_br a3_emi_guess_whos_coming_never_mind_e1a3b072:

    # emi "What? You traitor! You're supposed to take my side in this!"
    emi "O que? Seu traidor! Era para você ficar no meu lado nisso!"

# game/script-a3-emi.rpy:7533
translate pt_br a3_emi_guess_whos_coming_never_mind_5e736e57:

    # hi "Yeah, but you did lie about your leg after the meet—{w=0.3}{nw}"
    hi "É, mas você mentiu sobre sua perna depois do encont—{w=0.3}{nw}"

# game/script-a3-emi.rpy:7537
translate pt_br a3_emi_guess_whos_coming_never_mind_f8858abd:

    # extend " ow!"
    extend " ai!"

# game/script-a3-emi.rpy:7539
translate pt_br a3_emi_guess_whos_coming_never_mind_ca3a150a:

    # "A kick in the shins from an unmistakably plastic foot cuts me off, but not before Mrs. Ibarazaki's eyebrows shoot upwards."
    "Um chute nas canelas de um inconfundível pé de plástico me corta, mas não antes que a sobrancelha da Sra. Ibarazaki suba."

# game/script-a3-emi.rpy:7544
translate pt_br a3_emi_guess_whos_coming_never_mind_1f7021fb:

    # emm "What about your leg?"
    emm "O que tem a sua perna?"

# game/script-a3-emi.rpy:7549
translate pt_br a3_emi_guess_whos_coming_never_mind_5d05c03a:

    # emi "It wasn't a big deal, that's all… I just was, er, inawheelchairforabit."
    emi "Não era nada demais, isso é… eu só estava, er, nacadeiraderodasumpouco."

# game/script-a3-emi.rpy:7551
translate pt_br a3_emi_guess_whos_coming_never_mind_c5755eb4:

    # "The last few mumbled words are quickly deciphered by Emi's mother - I suspect she has experience with this sort of thing - and a worried frown appears on her face."
    "As últimas palavras murmuradas são rapidamente decifradas pela mãe da Emi - eu suspeito que ela tenha experiência com esse tipo de coisa - e uma expressão de preocupada aparece em sua cara."

# game/script-a3-emi.rpy:7556
translate pt_br a3_emi_guess_whos_coming_never_mind_10b003df:

    # emm "So that's why he kept dodging my calls…"
    emm "Então era por isso que você não atendia as minhas ligações…"

# game/script-a3-emi.rpy:7558
translate pt_br a3_emi_guess_whos_coming_never_mind_32a1ecf5:

    # emm "Oh Emi… I know how much you hate being in a wheelchair."
    emm "Ah Emi… eu sei o quanto você odeia estar em uma cadeira de rodas."

# game/script-a3-emi.rpy:7560
translate pt_br a3_emi_guess_whos_coming_never_mind_725c7ac6:

    # emm "No wonder you've been in such a mood lately!"
    emm "Não me admira que você esteve tão temperamental ultimamente!"

# game/script-a3-emi.rpy:7565
translate pt_br a3_emi_guess_whos_coming_never_mind_37020521:

    # hi "Yeah, she's much happier on her feet, so to speak."
    
    hi "É, ela é muito mais feliz com seus pés, por assim dizer."

# game/script-a3-emi.rpy:7571
translate pt_br a3_emi_guess_whos_coming_never_mind_8f036395:

    # emm "Well of course! She spent enough time in a chair just after the accident."
    emm "Bem é claro! Ela ficou tempo suficiente em uma cadeira logo depois do acidente."

# game/script-a3-emi.rpy:7576
translate pt_br a3_emi_guess_whos_coming_never_mind_e3585a21:

    # hi "She didn't get prosthetics immediately?"
    hi "Mas ela não conseguiu as próteses imediatamente?"

# game/script-a3-emi.rpy:7582
translate pt_br a3_emi_guess_whos_coming_never_mind_0466cd92:

    # emm "No, she had to finish healing up before they'd let her start the sort of therapy you've got to go through to adjust to those things."
    emm "Não, ela tinha que se curar um pouco antes que eles começassem o tipo de terapia que você precisa fazer para se acostumar com aquelas coisas."

# game/script-a3-emi.rpy:7584
translate pt_br a3_emi_guess_whos_coming_never_mind_b9ad829c:

    # emm "Especially since she wanted to run on them."
    emm "Especialmente já que ela queria correr com elas."

# game/script-a3-emi.rpy:7589
translate pt_br a3_emi_guess_whos_coming_never_mind_1d9bf979:

    # hi "I had no idea."
    hi "Eu não tinha ideia."

# game/script-a3-emi.rpy:7594
translate pt_br a3_emi_guess_whos_coming_never_mind_16ef8a97:

    # emi "Yeah, it sucked. Oh, did you see Rin's mural at the festival?"
    emi "É, foi uma droga. Oh, você viu o mural da Rin no festival?"

# game/script-a3-emi.rpy:7596
translate pt_br a3_emi_guess_whos_coming_never_mind_d99e95ec:

    # "Emi's sudden change of topic makes me realize belatedly that she's been fidgeting the whole time her mother and I have been talking."
    "A repentina mudança de assunto faz eu perceber tardiamente que ela ficou se mexendo o tempo todo enquanto eu e a mãe dela estávamos conversando."

# game/script-a3-emi.rpy:7598
translate pt_br a3_emi_guess_whos_coming_never_mind_03cc72b7:

    # "I should have figured on her being a little skittish when it comes to talking about the accident. Even around her mother."
    "Eu deveria ter imaginado que ela iria ficar um pouco arisca quando conversamos sobre o acidente. Mesmo do lado da sua mãe."

# game/script-a3-emi.rpy:7603
translate pt_br a3_emi_guess_whos_coming_never_mind_07bcaae4:

    # emm "No, I didn't make it out to the festival, remember?"
    emm "Não, eu não cheguei a tempo para o festival, lembra?"

# game/script-a3-emi.rpy:7608
translate pt_br a3_emi_guess_whos_coming_never_mind_290dece8:

    # emm "Although I caught a glimpse of it at your track meet. It seemed pretty weird to me."
    emm "Embora eu tenha visto bem de longe na reunião da pista. Pareceu bem esquisito para mim."

# game/script-a3-emi.rpy:7613
translate pt_br a3_emi_guess_whos_coming_never_mind_536e05f3:

    # emi "I think that's more or less what she was going for. She talked a lot about it being dreamlike. Or trying to make it dreamlike."
    emi "Acho que era isso mais ou menos o que ela queria. Ela falava bastante sobre aquilo ser como um sonho. Ou tentar fazer parecer um sonho."

# game/script-a3-emi.rpy:7618
translate pt_br a3_emi_guess_whos_coming_never_mind_a4f345bb:

    # emm "Rin's art is one of those things I don't think I'll ever understand."
    emm "A arte da Rin é uma daquelas coisas que eu nunca vou conseguir entender."

# game/script-a3-emi.rpy:7623
translate pt_br a3_emi_guess_whos_coming_never_mind_4b87f18e:

    # emi "That's not surprising. I don't think Rin expects to be understood."
    emi "Não é surpresa. Eu não acho que a Rin espera ser compreendida."

# game/script-a3-emi.rpy:7628
translate pt_br a3_emi_guess_whos_coming_never_mind_0ed9e21c:

    # emi "She told me once that art allows people to understand stuff they wouldn't understand otherwise, but all the same she doesn't think it actually works that way."
    emi "Ela me disse uma vez que a arte possibilita as pessoas a entender coisas que elas não conseguiriam de outra maneira, mas mesmo assim ela não acha que realmente funcione desse jeito."

# game/script-a3-emi.rpy:7630
translate pt_br a3_emi_guess_whos_coming_never_mind_40f1ec35:

    # "I'm surprised that Emi's talked about this with Rin extensively enough to actually have Rin's opinion, such as it is."
    "Estou surpreso que a Emi tenha conversado tanto com a Rin a ponto de ter uma opinião, como essa."

# game/script-a3-emi.rpy:7632
translate pt_br a3_emi_guess_whos_coming_never_mind_7f6b9020:

    # "Although I expect that Rin could not, if she were so inclined, say the same thing about Emi's."
    "Embora eu esperasse que a Rin não pudesse, se ela estivesse tão instigada, dizer a mesma coisa sobre a Emi."

# game/script-a3-emi.rpy:7634
translate pt_br a3_emi_guess_whos_coming_never_mind_9921e9cb:

    # "Unless, of course, Emi is purposely keeping me in the dark about everything; which is likely, but unpleasant to think about."
    "A não ser, é claro, a Emi está propositalmente me deixando no escuro aqui; o que é provável, mas desagradável de se pensar."

# game/script-a3-emi.rpy:7636
translate pt_br a3_emi_guess_whos_coming_never_mind_bfc4fe33:

    # "I drift down this unpleasant train of thought for a while, losing track of the conversation."
    "Eu me afundo nessa terrível linha de pensamento um pouco, perdendo noção da conversa."

# game/script-a3-emi.rpy:7641
translate pt_br a3_emi_guess_whos_coming_never_mind_b71f5676:

    # emm "Hey Emi, I've been meaning to ask…"
    emm "Ei Emi, eu estive querendo perguntar…"

# game/script-a3-emi.rpy:7646
translate pt_br a3_emi_guess_whos_coming_never_mind_d5e5048f:

    # emi "Huh?"
    emi "Hã?"

# game/script-a3-emi.rpy:7651
translate pt_br a3_emi_guess_whos_coming_never_mind_551b3be0:

    # emm "Are you going to visit your father this year?"
    emm "Você vai visitar seu pai esse ano?"

# game/script-a3-emi.rpy:7655
translate pt_br a3_emi_guess_whos_coming_never_mind_30b6cf65:

    # "From the way she says it, you'd think Emi's mother was talking about the weather. From the way Emi reacts, it's clearly not the weather they're talking about."
    "Do jeito que ela diz isso, você iria pensar que a mãe da Emi estava falando do clima. Do modo como Emi reage, claramente não é do clima que estamos falando."

# game/script-a3-emi.rpy:7660
translate pt_br a3_emi_guess_whos_coming_never_mind_8ab5bf74:

    # "She flinches, a slight jerk of the head backwards as if she's just been slapped in the face."
    "Ela recua, um pequeno solavanco para trás com a cabeça como se ela tivesse acabado de receber um tapa na cara."

# game/script-a3-emi.rpy:7665
translate pt_br a3_emi_guess_whos_coming_never_mind_f3776a60:

    # emi "Can we talk about this later?"
    emi "Podemos falar sobre isso depois?"

# game/script-a3-emi.rpy:7667
translate pt_br a3_emi_guess_whos_coming_never_mind_c0450383:

    # "Her voice sounds brittle, strained. It looks as if she's been severely shaken by the question."
    "Sua voz soa frágil, tensa. Como se ela tivesse ficado bem abalada com a pergunta."

# game/script-a3-emi.rpy:7669
translate pt_br a3_emi_guess_whos_coming_never_mind_7c05bc2f:

    # "It seems that Mrs. Ibarazaki misjudged just how close Emi and I are."
    "Parece que a Sra. Ibarazaki calculou mal o quanto eu e a Emi somos próximos."

# game/script-a3-emi.rpy:7671
translate pt_br a3_emi_guess_whos_coming_never_mind_a1059814:

    # "Some things, it seems, are best not conversed about with me around. Her father is one of these things."
    "Algumas coisas, aparentemente, são melhores não conversadas quando eu estou por perto. O pai dela é uma dessas coisas."

# game/script-a3-emi.rpy:7673
translate pt_br a3_emi_guess_whos_coming_never_mind_e2e1899a:

    # "The accident that took her legs is probably another one of those things, if her reaction to the earlier conversation between her mother and myself is any indication."
    "O acidente que levou as pernas dela é provavelmente outra dessas coisas, se a reação dela para a conversa anterior comigo e a mãe dela é qualquer indicação."

# game/script-a3-emi.rpy:7675
translate pt_br a3_emi_guess_whos_coming_never_mind_e0c9019c:

    # "It doesn't take Emi's mother long to realize she's screwed up."
    "Não leva muito tempo para a mãe da Emi perceber que ela estragou tudo."

# game/script-a3-emi.rpy:7680
translate pt_br a3_emi_guess_whos_coming_never_mind_fc616770:

    # emm "Of course we can, dear. I'm sorry to bring it up, I just wanted to ask so I could make plans—"
    emm "É claro que podemos, querida. Me desculpe por mencionar agora, eu só queria perguntar para que eu possa fazer os plan—"

# game/script-a3-emi.rpy:7685
translate pt_br a3_emi_guess_whos_coming_never_mind_14d83275:

    # emi "It's fine. Don't worry about it."
    emi "Está tudo bem. Não se preocupe."

# game/script-a3-emi.rpy:7687
translate pt_br a3_emi_guess_whos_coming_never_mind_98e1c6e8:

    # "Emi fidgets nervously, as if embarrassed by her own reaction. I confess that her reaction is confusing."
    "Emi se agita muito nervosa, como se estivesse envergonhada pela própria reação. Eu confesso que é confuso."

# game/script-a3-emi.rpy:7689
translate pt_br a3_emi_guess_whos_coming_never_mind_b4fcff75:

    # "She only just mentioned her father to me earlier today! Less than a few hours ago, even!"
    "Ela tinha mencionado sobre o pai dela para mim hoje ainda! Menos que algumas horas atrás, até!"

# game/script-a3-emi.rpy:7691
translate pt_br a3_emi_guess_whos_coming_never_mind_ad44ae1f:

    # "Why does a simple question about when she'll visit her father cause such a strong reaction?"
    "Por que uma pergunta tão simples sobre se ela vai visitar ou não o pai dela causa uma reação assim?"

# game/script-a3-emi.rpy:7693
translate pt_br a3_emi_guess_whos_coming_never_mind_f75b261e:

    # "Unless whatever serenity she claimed to have reached by means of our talk the previous evening has suddenly evaporated."
    "A não ser que qualquer serenidade que ela tenha alcançado por nossa conversa na noite anterior tenha evaporado."

# game/script-a3-emi.rpy:7695
translate pt_br a3_emi_guess_whos_coming_never_mind_8156789b:

    # "Or it didn't help as much as she thought. Or claimed."
    "Ou ela não ajudou tanto quanto eu pensava. Ou disse."

# game/script-a3-emi.rpy:7700
translate pt_br a3_emi_guess_whos_coming_never_mind_4d5d59ee:

    # emi "I'll uh, be right back. Gotta visit the little girl's room."
    
    emi "Eu, hã, já volto. Preciso ir ao cômodo das meninas aqui."

# game/script-a3-emi.rpy:7709
translate pt_br a3_emi_guess_whos_coming_never_mind_cb1cf1ef:

    # "Emi gets up suddenly and leaves the table, leaving me and Mrs. Ibarazaki alone."
    "Emi de repente se levanta e sai da mesa, deixando eu e a Sra. Ibarazaki sozinhos."

# game/script-a3-emi.rpy:7711
translate pt_br a3_emi_guess_whos_coming_never_mind_5a946000:

    # "I'm a little conflicted. Should I go after her, or should I stay here?"
    "Eu estou um pouco em conflito. Devo ir atrás dela, ou eu devo ficar aqui?"

# game/script-a3-emi.rpy:7713
translate pt_br a3_emi_guess_whos_coming_never_mind_9f687960:

    # "It's obvious that Emi's departure was not based on the call of nature. Something's bothering her, and I have to know what it is."
    "É óbvio que a partida de Emi não é por causa de um chamado da natureza. Algo está incomodando ela, e eu preciso saber o que é."

# game/script-a3-emi.rpy:7751
translate pt_br a3_emi_instant_replay_b680217d:

    # "The morning alarm sounds and I roll over, switching it off. My eyes open blearily to stare at the ceiling."
    "O alarme da manhã soa e eu me rolo, o desligando. Meus olhos se abrem pouco para olhar para o teto."

# game/script-a3-emi.rpy:7755
translate pt_br a3_emi_instant_replay_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:7758
translate pt_br a3_emi_instant_replay_6a3194b6:

    # n "{vspace=60}What am I going to do? Do I get out of bed, go down to the track, and pretend that nothing happened?"
    n "{vspace=60}O que será que eu vou fazer? Será que eu saio da cama, desço até a pista, e finjo que nada aconteceu?"

# game/script-a3-emi.rpy:7760
translate pt_br a3_emi_instant_replay_5ab072f7:

    # n "Will Emi even show up? After last evening's events, I doubt it."
    n "Será que Emi irá aparecer? Depois dos eventos da noite passada, eu duvido."

# game/script-a3-emi.rpy:7762
translate pt_br a3_emi_instant_replay_f722a445:

    # n "Even supposing that she did, what would I do then? Get over this fight just to dance the same routine the next time something's bothering her?"
    n "Mesmo supondo que ela aparecesse, o que eu iria fazer daí? Superar essa briga só pra dançar a mesma rotina a próxima vez que algo incomodar ela de novo?"

# game/script-a3-emi.rpy:7764
translate pt_br a3_emi_instant_replay_849db78f:

    # n "I know that I spoke hastily last evening, especially trying to use her father as leverage."
    n "Eu sei que falei apressadamente noite passada, especialmente tentanto usar o pai dela como alavanca."

# game/script-a3-emi.rpy:7766
translate pt_br a3_emi_instant_replay_7466e7f4:

    # n "But was anything I said really off the mark? She won't let me in, ever, and she'll be forced to suffer alone."
    n "Mas será que tudo que eu disse foi fora da marca? Ela não me deixa entrar, nunca, e ela será forçada a sofrer sozinha."

# game/script-a3-emi.rpy:7768
translate pt_br a3_emi_instant_replay_6c093fa7:

    # n "Nothing I do, nothing I say is going to change that. She won't change, and she's already decided to keep me at arm's length."
    n "Nada que eu faço, nada que eu digo vai mudar isso. Ela não muda, e ela parece já ter se decidido em me manter à um braço de distância."

# game/script-a3-emi.rpy:7770
translate pt_br a3_emi_instant_replay_59b1b5a2:

    # n "{vspace=30}Can I really bring myself to go down there and see her, knowing that I'm never going to get past where I am now?"
    n "{vspace=30}Será que eu realmente consigo me levar até lá embaixo e vê-la, sabendo que eu nunca irei conseguir passar por onde eu estou agora?"

# game/script-a3-emi.rpy:7772
translate pt_br a3_emi_instant_replay_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:7778
translate pt_br a3_emi_instant_replay_b558f347:

    # "No, I decide. I really can't. Not today. I roll over and go back to sleep."
    "Não, eu decido. Eu realmente não consigo. Não hoje. Eu rolo de volta e volto a dormir."

# game/script-a3-emi.rpy:7780
translate pt_br a3_emi_instant_replay_368a2055:

    # "She probably won't be there anyway."
    "Ela provavelmente não estará lá de qualquer jeito."

# game/script-a3-emi.rpy:7785
translate pt_br a3_emi_instant_replay_f2af4db5:

    # "A similar mental conversation repeats itself when it comes time to go to lunch, and I eat in the cafeteria, alone."
    "Uma conversa mental similar se repete quando chega a hora de ir para o almoço, eu como no refeitório, sozinho."

# game/script-a3-emi.rpy:7787
translate pt_br a3_emi_instant_replay_aef0cd7d:

    # "I don't want to see her; the very thought makes me feel ill."
    "Eu não quero vê-la; tal pensamento me deixa mal."

# game/script-a3-emi.rpy:7792
translate pt_br a3_emi_instant_replay_a513cf4d:

    # "That night, I go for a run; I'm solo for the first time since Emi got sick after the track meet."
    "Aquela noite, eu vou para uma corrida; estou solo pela primeira vez desde que a Emi tinha ficado doente depois da reunião da pista."

# game/script-a3-emi.rpy:7794
translate pt_br a3_emi_instant_replay_53fd5c7a:

    # "Skipped seeing the nurse, just in case he asked about Emi."
    "Não vi o enfermeiro também, só para não ouví-lo me perguntar sobre a Emi."

# game/script-a3-emi.rpy:7796
translate pt_br a3_emi_instant_replay_3c4c8b74:

    # "I don't want to talk about her, either."
    "Eu não quero falar sobre ela, também."

# game/script-a3-emi.rpy:7801
translate pt_br a3_emi_instant_replay_0462fc35:

    # "The next day, I do the same thing. Alarm, off. Stay in bed. Eat alone, run alone."
    "O próximo dia, eu faço a mesma coisa. Alarme, desligado. Fico na cama. Como sozinho, corro sozinho."

# game/script-a3-emi.rpy:7803
translate pt_br a3_emi_instant_replay_40f83df9:

    # "To fill the time that I would usually be spending with Emi, I start reading more."
    "Para preencher o tempo que eu normalmente iria gastar vendo a Emi, eu começo a ler mais."

# game/script-a3-emi.rpy:7805
translate pt_br a3_emi_instant_replay_68ae325d:

    # "It works surprisingly well, until I find myself ducking into a restroom because I see her walking down the hall in between classes."
    
    
    "Isso funciona surpreendentemente bem, até que eu me encontro me agachando num banheiro porque eu a vi andando pelo corredor entre as classes."
    

# game/script-a3-emi.rpy:7807
translate pt_br a3_emi_instant_replay_067980ec:

    # "If she noticed me, she didn't show it, even though I don't suppose she ever shows anything."
    "Se ela me percebesse, ela não demonstrou isso, mesmo que eu não ache que ela demonstre qualquer coisa."

# game/script-a3-emi.rpy:7809
translate pt_br a3_emi_instant_replay_763198c0:

    # "Certainly not to the girls from her class I see talking cheerfully to her."
    "Certamente não para as garotas da turma dela que eu vejo conversarem com ela alegremente."

# game/script-a3-emi.rpy:7811
translate pt_br a3_emi_instant_replay_cadf6a00:

    # "Or to her fellow track members."
    "Ou os companheiros de pista dela."

# game/script-a3-emi.rpy:7813
translate pt_br a3_emi_instant_replay_a4e3112d:

    # "Especially not to me."
    "Especialmente não para mim."

# game/script-a3-emi.rpy:7815
translate pt_br a3_emi_instant_replay_a08995ae:

    # "Alarm off. Stay in bed."
    "Alarme desligado. Ficar na cama."

# game/script-a3-emi.rpy:7821
translate pt_br a3_emi_instant_replay_d7d7db9f:

    # "Mutou and I have a lengthy talk about the possibility that string theory is plausible. I don't buy it, myself."
    "Mutou e eu temos uma enorme conversa sobre a possibilidade da teoria das cordas ser plausível. Eu mesmo, não engulo essa."

# game/script-a3-emi.rpy:7823
translate pt_br a3_emi_instant_replay_fc8c183a:

    # "More than four dimensions, I can buy. But a bunch of vibrating strings at the subatomic level? That's asking a bit much."
    "Mais do que quatro dimensões, eu até posso acreditar. Mas um bando de cordas vibrando à um nivel subatômico? Isso é pedir demais."

# game/script-a3-emi.rpy:7825
translate pt_br a3_emi_instant_replay_263ec96c:

    # "Looks like I'm not the only one to think this way, too. Apparently it's not really as strong a theory as it once was."
    "Parece que eu não sou o único que pensa dessa forma, também. Aparentemente não é uma teoria tão forte como já foi uma vez."

# game/script-a3-emi.rpy:7827
translate pt_br a3_emi_instant_replay_b12d92d3:

    # "Mutou says that's just because nobody has found the right way of looking at the data yet."
    "Mutou diz isso porque ninguém encontrou ainda o modo certo de analisar os dados."

# game/script-a3-emi.rpy:7835
translate pt_br a3_emi_instant_replay_8aeeb3af:

    # "Eat alone."
    "Comer sozinho."

# game/script-a3-emi.rpy:7837
translate pt_br a3_emi_instant_replay_3ca0d5ad:

    # "The rooftop is deserted today. I briefly wonder where Emi and Rin are, but shrug off the question. The important thing is that they aren't here, so I won't have to talk to them."
    "O terraço está deserto hoje. Eu brevemente pondero onde será que Emi e Rin estão, mas esqueço o assunto. O importante é que elas não estão aqui, então eu não preciso falar com elas."

# game/script-a3-emi.rpy:7839
translate pt_br a3_emi_instant_replay_8683142c:

    # "Since I have nobody to talk to, I bring a book with me to read."
    
    "Já que eu não tenho ninguém para conversar, eu trago um livro comigo para ler."

# game/script-a3-emi.rpy:7841
translate pt_br a3_emi_instant_replay_0822dd6b:

    # "The weather's nicer, if getting a little hot."
    "O clima está melhor, até ficando um pouco mais quente."

# game/script-a3-emi.rpy:7843
translate pt_br a3_emi_instant_replay_605fab63:

    # "Hopefully it will be cooler in the evening; a cool breeze seems to back up my theory."
    "Tomara que esteja mais frio à noite; uma brisa fria parece concordar com a minha teoria."

# game/script-a3-emi.rpy:7850
translate pt_br a3_emi_instant_replay_ffe6c4e7:

    # "Run alone."
    "Correr sozinho."

# game/script-a3-emi.rpy:7852
translate pt_br a3_emi_instant_replay_a70e82c7:

    # "It is, in fact, cooler at the track. No sign of Emi, which is exactly the sort of thing I'm going for."
    "É, na verdade, mais frio na pista. Nenhum sinal da Emi, o que é exatamente o que eu queria."

# game/script-a3-emi.rpy:7854
translate pt_br a3_emi_instant_replay_8624089c:

    # "I stretch out and start on my usual run, trying hard to ignore the lack of a running partner in front of me."
    "Eu me alongo para começar minha corrida usual, tentando ao máximo que posso ignorar a falta da minha parceira de corrida na minha frente."

# game/script-a3-emi.rpy:7856
translate pt_br a3_emi_instant_replay_14ba994a:

    # "Finding my thoughts drifting damnably to that girlish laugh, incorrigible grin, those wide and friendly eyes, her incredibly toned body—"
    "Encontrando meus pensamentos viajando sem escapatória daquela risada feminina, sorriso incorrigível, aqueles olhos enormes, corpo incrivelmente tonificado dela—"

# game/script-a3-emi.rpy:7861
translate pt_br a3_emi_instant_replay_749ec5cb:

    # "I increase the pace to clear my head. Chew up the distance between me and the turns, find the speed that makes me think only of my legs and how much they burn."
    "Eu aumento o passo para limpar minha cabeça. Diminuo a distância entre eu e as curvas, encontro a velocidade que faz eu pensar apenas nas minhas pernas e como elas queimam."

# game/script-a3-emi.rpy:7863
translate pt_br a3_emi_instant_replay_62d6141e:

    # "I glance at my watch as I round the final turn, noting that my time's gotten faster."
    "Eu olho para o meu relógio enquanto eu dou a minha última volta, percebendo que meu tempo ficou mais rápido."

# game/script-a3-emi.rpy:7868
translate pt_br a3_emi_instant_replay_c34435a9:

    # "My heart seems a little squirrelly tonight, so I give myself a few extra cool-down laps just to be safe."
    "Meu coração parece um pouco mais agitado nesta noite, então eu dou mais algumas voltas extras para esfriar, só por cautela."

# game/script-a3-emi.rpy:7870
translate pt_br a3_emi_instant_replay_30baaa09:

    # "No reason to bring this to the nurse's attention. I'll be fine. A rather Emi-ish thought to have, I'll admit."
    "Sem motivos para falar isso para o enfermeiro. Eu vou ficar bem. Um pensamento bem Emi, devo admitir."

# game/script-a3-emi.rpy:7872
translate pt_br a3_emi_instant_replay_aba6608c:

    # "I have to hope that eventually I'll stop thinking about her so much."
    "Eu preciso ter esperança de que eventualmente eu irei parar de pensar nela tanto assim."

# game/script-a3-emi.rpy:7877
translate pt_br a3_emi_instant_replay_6b61b823:

    # "I finish another book before going to bed that night. I'll have to stop by the library tomorrow."
    "Eu termino outro livro antes de ir para cama esta noite. Eu terei que passar na biblioteca amanhã."

# game/script-a3-emi.rpy:7898
translate pt_br a3_emi_instant_replay_4b326df0:

    # "I don't know why I keep the early alarm on any more, but it wakes me up the next morning just the same. I still turn it off and go back to sleep."
    "Eu não sei porque eu continuo deixando o alarme da manhã ligado, ele me acorda sempre. Ainda assim eu o desligo e volto a dormir."

# game/script-a3-emi.rpy:7906
translate pt_br a3_emi_instant_replay_d600b3ca:

    # "That afternoon, as I get ready to head to the cafeteria for another solo lunch (I've got a new book about a couple of con men in ancient Persia that I'm pretty excited about reading) I am suddenly cornered by Misha and…"
    "Esta tarde, eu me preparo para ir ao refeitório para outro almoço solo (eu tenho um novo livro sobre um par de vigaristas na antiga Pérsia o qual estou bem ansioso em ler) e de repente sou encurralado pela Misha e…"

# game/script-a3-emi.rpy:7908
translate pt_br a3_emi_instant_replay_4567b99b:

    # "Huh. I guess just Misha."
    "Hmm. Acho que só a Misha mesmo."

# game/script-a3-emi.rpy:7913
translate pt_br a3_emi_instant_replay_eff7d165:

    # mi "Off to eat alone again, Hicchan~?"
    mi "Comendo sozinho de novo, Hisaozinho~?"

# game/script-a3-emi.rpy:7918
translate pt_br a3_emi_instant_replay_125a6879:

    # mi "We've noticed, you know~!"
    mi "Nós percebemos, sabe~!"

# game/script-a3-emi.rpy:7920
translate pt_br a3_emi_instant_replay_be2d8009:

    # hi "We?"
    hi "Nós?"

# game/script-a3-emi.rpy:7925
translate pt_br a3_emi_instant_replay_ca9b28c0:

    # mi "Uh huh! Shicchan and I noticed that you've been spending more time alone!"
    mi "Aham! Shizunezinha e eu percebemos que você andou ficando sozinho com mais frequência!"

# game/script-a3-emi.rpy:7930
translate pt_br a3_emi_instant_replay_7f250962:

    # mi "She wanted me to find out why, so I told her I'd ask you!"
    mi "Ela queria que eu descobrisse o porquê, então eu disse para ela perguntar à você!"

# game/script-a3-emi.rpy:7932
translate pt_br a3_emi_instant_replay_dbcf5995:

    # hi "I'm surprised she didn't ask me herself."
    hi "Estou surpreso que ela não tenha me perguntado ela mesma."

# game/script-a3-emi.rpy:7937
translate pt_br a3_emi_instant_replay_7c0f0e12:

    # mi "She would have, but she wanted to get a head start on some paperwork. There's a lot of it since we're coming up on the end of the term, you know~!"
    mi "Ela teria, mas ela queria se adiantar em uma papelada. Tem muita já que estamos chegando no fim do ano letivo, sabe~!"

# game/script-a3-emi.rpy:7939
translate pt_br a3_emi_instant_replay_a9798800:

    # hi "Why the sudden interest in my well-being, anyway?"
    hi "Por que esse interesse repentino do meu bem-estar, de qualquer jeito?"

# game/script-a3-emi.rpy:7944
translate pt_br a3_emi_instant_replay_29a7f10e:

    # mi "Ah, Shicchan said 'It is the duty of the Student Council to keep track of the emotional health of its students! To allow a cons—constituent to spiral into depression unchecked would be an unforgivable failure in the council's duties!'"
    mi "Ah, a Shizunezinha disse “é dever do Conselho Estudantíl observar a saúde emocional de seus estudantes! Para deixar uma cons-constituinte espiral de depressão passar assim seria uma falha imperdoável dos afazeres do conselho!”"

# game/script-a3-emi.rpy:7946
translate pt_br a3_emi_instant_replay_3d6f7497:

    # hi "Well, that's easy, then. I'm not depressed."
    hi "Bem, isso é fácil, então. Eu não estou deprimido."
    

# game/script-a3-emi.rpy:7951
translate pt_br a3_emi_instant_replay_3a768537:

    # mi "But you're eating alone, and nobody's seen you and Emi together at all! Something happened, didn't it, Hicchan~?"
    mi "Mas você está comendo sozinho, além do mais que ninguém mais viu você e a Emi juntos! Alguma coisa aconteceu, não foi, Hisaozinho~?"

# game/script-a3-emi.rpy:7953
translate pt_br a3_emi_instant_replay_3525cbdd:

    # "Misha's voice takes on a slightly sterner tone, though somehow she keeps the familiar lilt at the end of her sentences."
    "A voz da Misha assume um tom ligeramente mais severo, embora de alguma maneira ela ainda mantenha aquela melodia cadenciada no fim de suas frases."

# game/script-a3-emi.rpy:7974
translate pt_br a3ec1o1_1e6ef2de:

    # hi "Are you absolutely sure?"
    hi "Tem certeza?"

# game/script-a3-emi.rpy:7976
translate pt_br a3ec1o1_2c5b5ed3:

    # hi "You don't want to go ahead and adjust it before heading up the stairs?"
    hi "Você não quer ajuda para ajustar antes de subir as escadas?"

# game/script-a3-emi.rpy:7978
translate pt_br a3ec1o1_631f6b45:

    # hi "You could get hurt if you don't, right?"
    hi "Você poderia se machucar, certo?"

# game/script-a3-emi.rpy:7983
translate pt_br a3ec1o1_2835b752:

    # emi "I said it was fine, Hisao."
    emi "Eu disse que está tudo certo Hisao."

# game/script-a3-emi.rpy:7988
translate pt_br a3ec1o1_d8ef0a60:

    # emi "Seriously, don't worry about it."
    emi "Eu disse que está tudo certo Hisao."

# game/script-a3-emi.rpy:7993
translate pt_br a3ec1o1_7abc511b:

    # emi "I've got some experience in these matters, after all."
    emi "Eu tenho experiência com isso afinal."

# game/script-a3-emi.rpy:7995
translate pt_br a3ec1o1_f47650ad:

    # hi "Yeah, I suppose so."
    hi "É, suponho que sim."

# game/script-a3-emi.rpy:7997
translate pt_br a3ec1o1_ffa75436:

    # "Emi grins reassuringly."
    "Emi dá uma risada reconfortante."

# game/script-a3-emi.rpy:8002
translate pt_br a3ec1o1_8556a6d0:

    # emi "Honestly, Hisao, I appreciate the concern but I really am okay."
    emi "Sério Hisao, eu agradeço a preocupação mas eu estou bem."

# game/script-a3-emi.rpy:8007
translate pt_br a3ec1o2_1304d62e:

    # "Well, she's probably fine."
    "Bom, ela provavelmente está bem."

# game/script-a3-emi.rpy:8009
translate pt_br a3ec1o2_6ae99f52:

    # "I imagine she'd say something if it was really a problem."
    "Eu imagino que ela diria algo se houvesse realmente um problema."

# game/script-a3-emi.rpy:8011
translate pt_br a3ec1o2_07d3e409:

    # "Heck, she'd probably get annoyed if I kept bringing it up."
    "Na verdade, ela provavelmente ficaria irritada se eu ficasse forçando o assunto."

# game/script-a3-emi.rpy:8016
translate pt_br a3ec2o1_49acf163:

    # hi "Yeah, I've got some time. Nowhere important to be or anything like that."
    hi "Sim, eu tenho um tempo. Nenhum lugar importante que eu deva estar ou algo assim."
    

# game/script-a3-emi.rpy:8021
translate pt_br a3ec2o1_f6ff709d:

    # "Mutou raises an eyebrow as if questioning my statement, then beckons me back into the classroom."
    "Mutou levanta uma sobrancelha como se estivesse questionando minha declaração, e então me chama de volta para a sala de aula."

# game/script-a3-emi.rpy:8032
translate pt_br a3ec2o1_c0fcded6:

    # mu "I wanted to get some feedback from you, if I could."
    mu "Eu queria ter um feedback seu, se possível."

# game/script-a3-emi.rpy:8034
translate pt_br a3ec2o1_2ae600e4:

    # mu "I know that this course wasn't quite up to your level…"
    mu "Eu sei que este curso não está muito no seu nível…"

# game/script-a3-emi.rpy:8036
translate pt_br a3ec2o1_b7d75319:

    # hi "Don't worry about it. The science club activities more than made up for it."
    hi "Não se preocupe com isso. As atividades do clube de ciências compensaram por isso."

# game/script-a3-emi.rpy:8041
translate pt_br a3ec2o1_ec1ed78c:

    # mu "Hmm, did they?"
    mu "Hmm, elas compensaram?"

# game/script-a3-emi.rpy:8046
translate pt_br a3ec2o1_6f109888:

    # mu "Well in fact, that's what I wanted to talk to you about."
    mu "Bem na real, era sobre isso que eu queria falar com você."

# game/script-a3-emi.rpy:8048
translate pt_br a3ec2o1_1eb5d0ab:

    # mu "Do you think that was a worthwhile activity? Just for my own reference."
    mu "Você acha que foi uma atividade que valesse a pena? Só para minha própria referência."

# game/script-a3-emi.rpy:8050
translate pt_br a3ec2o1_a058eb79:

    # hi "Well yeah, it was a great way to go further than we did in class. It was definitely worthwhile."
    hi "Ah claro, foi ótimo ir além do que vamos na aula. Definitivamente valeu a pena."

# game/script-a3-emi.rpy:8055
translate pt_br a3ec2o1_ab053ee6:

    # "Mutou seems delighted by my response."
    "Mutou parece encantado com a minha resposta."

# game/script-a3-emi.rpy:8057
translate pt_br a3ec2o1_b651e417:

    # mu "That's great! Exactly the sort of thing I was hoping for."
    mu "Isso é ótimo! Exatamente o tipo de coisa que eu estava esperando."

# game/script-a3-emi.rpy:8059
translate pt_br a3ec2o1_8b5f656b:

    # mu "You know, Hisao, I'm glad you came here. It's always good to have a student who really gets into the subject you teach."
    mu "Sabe Hisao, estou contente que você tenha vindo aqui. É sempre bom ter um estudante que realmente entenda o assunto que você ensina."

# game/script-a3-emi.rpy:8061
translate pt_br a3ec2o1_3a84ff1b:

    # mu "In a way, it makes dealing with the rest of the students more tolerable."
    mu "De certa maneira, faz com que lidar com o resto dos estudantes se torne mais tolerável."

# game/script-a3-emi.rpy:8063
translate pt_br a3ec2o1_f0d69a0c:

    # mu "You're a bright kid, too. You took to this stuff like a duck to water, or some other such simile."
    mu "Você é um garoto brilhante, também. Você olha para essas coisas como se fosse um pato na água, ou algo similar."

# game/script-a3-emi.rpy:8065
translate pt_br a3ec2o1_e7cbd408:

    # hi "Er, thanks."
    hi "Er, obrigado."

# game/script-a3-emi.rpy:8067
translate pt_br a3ec2o1_e1c8d28c:

    # hi "You were a great help. Especially with that college stuff."
    hi "Você foi de grande ajuda. Especialmente com aquelas coisas da universidade."

# game/script-a3-emi.rpy:8072
translate pt_br a3ec2o1_3d2fc31a:

    # mu "There's one more thing, Hisao."
    mu "Tem mais uma coisa, Hisao."

# game/script-a3-emi.rpy:8074
translate pt_br a3ec2o1_aadb7a11:

    # mu "A bit of advice, from one scientist to another."
    mu "Um pouco de aconselhamento, de um cientista para outro."

# game/script-a3-emi.rpy:8076
translate pt_br a3ec2o1_111a58e1:

    # hi "What's that?"
    hi "O que é isso?"

# game/script-a3-emi.rpy:8078
translate pt_br a3ec2o1_104f1141:

    # mu "What does a scientist do?"
    mu "O que um cientista faz?"

# game/script-a3-emi.rpy:8080
translate pt_br a3ec2o1_0ccb7eba:

    # hi "Observe the world around him."
    hi "Observa o mundo ao seu redor."

# game/script-a3-emi.rpy:8085
translate pt_br a3ec2o1_03d49752:

    # mu "Exactly. Good."
    mu "Exatamente. Bom."
    

# game/script-a3-emi.rpy:8090
translate pt_br a3ec2o1_551b9eff:

    # mu "A simple question, but one that most people can't seem to answer. That's the essence of a scientist, Hisao."
    mu "Uma pergunta simples, mas uma que a maioria das pessoas parecem não conseguir responder. Essa é a essência de um cientista, Hisao."

# game/script-a3-emi.rpy:8092
translate pt_br a3ec2o1_977d7c08:

    # mu "We observe what's there, and try to figure it out."
    mu "Nós observamos o que está ali, e tentamos descobrir isso."

# game/script-a3-emi.rpy:8094
translate pt_br a3ec2o1_c63ab9a8:

    # mu "But what if there's something you can't figure out?"
    mu "Mas e se tem algo que você não consiga descobrir?"

# game/script-a3-emi.rpy:8096
translate pt_br a3ec2o1_54e4e3d1:

    # mu "What's a scientist to do if he can't observe something?"
    mu "O que um cientista faz quando ele não consegue observar algo?"

# game/script-a3-emi.rpy:8098
translate pt_br a3ec2o1_18e46db2:

    # mu "How, for example, can we talk about quarks when nobody has ever actually seen one? Or black holes when observing them directly is impossible?"
    mu "Como, por exemplo, podemos falar de quarks quando ninguém conseguiu ver um na verdade? Ou buracos negros quando observá-los diretamente é impossível."

# game/script-a3-emi.rpy:8100
translate pt_br a3ec2o1_a3264b91:

    # hi "Well, scientific equipment's pretty advanced…"
    hi "Bem, equipamentos de cientistas são bem avançados…"

# game/script-a3-emi.rpy:8105
translate pt_br a3ec2o1_aa7ff39c:

    # "Mutou irritably waves away my response."
    "Mutou irritado empurra para longe minha resposta."

# game/script-a3-emi.rpy:8107
translate pt_br a3ec2o1_885e0fe7:

    # mu "No, that's not it at all."
    mu "Não, não é isso mesmo."

# game/script-a3-emi.rpy:8109
translate pt_br a3ec2o1_4a210c68:

    # mu "Those are tools, I'm trying to give you a philosophy."
    mu "Essas são as ferramentas, eu estou tentando te dar a filosofia."

# game/script-a3-emi.rpy:8114
translate pt_br a3ec2o1_3ef87056:

    # mu "Think. If you can't observe something directly, then how can you observe it?"
    mu "Pense. Se você não consegue ver algo diretamente, então como você vai observá-la?"

# game/script-a3-emi.rpy:8116
translate pt_br a3ec2o1_b9b5c963:

    # hi "Uh, guess?"
    hi "Uh, suposição?"
    

# game/script-a3-emi.rpy:8118
translate pt_br a3ec2o1_40c33409:

    # mu "How? How would you guess the movement of a quark? What is your guess based on?"
    mu "Como? Como você iria supor o movimento de um quark? No que sua suposição é baseada?"

# game/script-a3-emi.rpy:8120
translate pt_br a3ec2o1_e5f4a4e1:

    # "Of course."
    "É claro."

# game/script-a3-emi.rpy:8122
translate pt_br a3ec2o1_d2fd2fa5:

    # "I should have thought of it earlier."
    "Eu deveria ter pensado nisso antes."

# game/script-a3-emi.rpy:8124
translate pt_br a3ec2o1_40fa6360:

    # hi "The things it affects."
    hi "As coisas que isso afeta."

# game/script-a3-emi.rpy:8129
translate pt_br a3ec2o1_245db389:

    # "Mutou claps his hands together excitedly and whoops."
    "Mutou bate as mãos animadamente e comemora."

# game/script-a3-emi.rpy:8131
translate pt_br a3ec2o1_505d9c34:

    # mu "Yes, exactly. Good."
    mu "Isso, exatamente. Bom."

# game/script-a3-emi.rpy:8133
translate pt_br a3ec2o1_8a376fc3:

    # mu "Remember that, Hisao."
    mu "Lembre-se disso, Hisao."

# game/script-a3-emi.rpy:8138
translate pt_br a3ec2o1_2a7ca04b:

    # mu "If you can't examine something directly, it's because you're looking at it wrong."
    mu "Se você não consegue examinar algo diretamente, é porque você está olhando para isso de maneira errada."

# game/script-a3-emi.rpy:8140
translate pt_br a3ec2o1_2e2c8e2f:

    # mu "You have to look at it differently if you want to uncover the truth. And if it eludes you, then look at what it leaves behind."
    mu "Você precisa olhar para as coisas de um modo diferente se você quiser descobrir a verdade. E se você for iludido, então você olha para o que isso deixa para trás."

# game/script-a3-emi.rpy:8142
translate pt_br a3ec2o1_db89a8d6:

    # mu "That is the essence of being a scientist. We never stop looking for the answer. Never take anything for granted."
    mu "Essa é a essência de ser um cientista. Nós nunca paramos de procurar por respostas. Nunca tome nada como garantido."

# game/script-a3-emi.rpy:8144
translate pt_br a3ec2o1_5158fddd:

    # mu "Observe, experiment, and observe some more."
    mu "Observe, experimente, e observe um pouco mais."

# game/script-a3-emi.rpy:8146
translate pt_br a3ec2o1_c7b6fc13:

    # mu "There's a lot of stuff out there that makes no sense, Hisao. Your job is to get it to make sense."
    mu "Há muitas coisas por aí que não fazem sentido, Hisao. Seu trabalho e fazer com que elas façam sentido."

# game/script-a3-emi.rpy:8148
translate pt_br a3ec2o1_df338b28:

    # mu "If nothing else, I hope you've learned that here."
    mu "Se nada mais, eu espero que você tenha aprendido isso aqui."

# game/script-a3-emi.rpy:8150
translate pt_br a3ec2o1_ca060dfb:

    # hi "I think I can remember that."
    hi "Eu acho que consigo lembrar disso."

# game/script-a3-emi.rpy:8155
translate pt_br a3ec2o1_d448d0e1:

    # "Mutou smiles, satisfied."
    "Mutou sorri, satisfeito."

# game/script-a3-emi.rpy:8157
translate pt_br a3ec2o1_9170cc54:

    # mu "Good. Now go enjoy your time off. You've earned it."
    mu "Ótimo. Agora vá aproveitar o seu tempo livre. Você merece."

# game/script-a3-emi.rpy:8164
translate pt_br a3ec2o1_23c758ca:

    # "I leave the room feeling a little confused."
    "Eu deixo a sala me sentindo um pouco confuso."

# game/script-a3-emi.rpy:8166
translate pt_br a3ec2o1_2a7d631f:

    # "What brought that on?"
    "O que trouxe isso?"

# game/script-a3-emi.rpy:8168
translate pt_br a3ec2o1_8d26952d:

    # "Although…"
    "Embora…"

# game/script-a3-emi.rpy:8170
translate pt_br a3ec2o1_4772ef91:

    # "Am I going about this thing with Emi the wrong way?"
    "Será que eu estou levando essa coisa com a Emi por um caminho errado?"

# game/script-a3-emi.rpy:8172
translate pt_br a3ec2o1_d7ba5a40:

    # "If she won't tell me, then can I go about it some other way?"
    "Se ela não me conta, então eu devo ir por outro caminho?"

# game/script-a3-emi.rpy:8178
translate pt_br a3ec2o2_d55dd87c:

    # hi "Actually, I've got something I need to do…"
    hi "Na verdade, eu tenho uma coisa que eu preciso fazer…"

# game/script-a3-emi.rpy:8183
translate pt_br a3ec2o2_34fbbd33:

    # mu "Yeah? Oh well."
    mu "É? Oh certo."

# game/script-a3-emi.rpy:8185
translate pt_br a3ec2o2_8d007dd6:

    # mu "I wanted to get some feedback on the science club from you. But we can do that later, I guess."
    mu "Eu queria ter um feedback sobre o clube de ciências com você. Mas nós podemos fazer isso mais tarde, eu acho."

# game/script-a3-emi.rpy:8187
translate pt_br a3ec2o2_4ceaf043:

    # mu "Enjoy your break, you hear?"
    mu "Aproveite seu intervalo, ouviu?"

# game/script-a3-emi.rpy:8189
translate pt_br a3ec2o2_c488fa82:

    # hi "Thanks, I will."
    hi "Obrigado, eu vou."

# game/script-a3-emi.rpy:8191
translate pt_br a3ec2o2_784c5475:

    # "I'd really love to chat with Mutou, but I've got other things on my mind."
    "Eu adoraria conversar com o Mutou, mas eu tenho outras coisas em minha mente."

# game/script-a3-emi.rpy:8193
translate pt_br a3ec2o2_0a4a50c3:

    # "Specifically, what to do about Emi."
    "Especificamente, o que fazer sobre a Emi."

# game/script-a3-emi.rpy:8195
translate pt_br a3ec2o2_ef154516:

    # "Can I really just confront her?"
    "Posso realmente apenas confrontá-la?"

# game/script-a3-emi.rpy:8200
translate pt_br a3ec3o1_e71151dd:

    # "What was it Mutou said yesterday?"
    
    "O que foi que o Mutou disse ontem?"
    

# game/script-a3-emi.rpy:8202
translate pt_br a3ec3o1_8789c9de:

    # "If you can't observe the thing, then observe what's around it?"
    "Se você não pode observar a coisa, então enxergue o que está ao seu redor."

# game/script-a3-emi.rpy:8204
translate pt_br a3ec3o1_6b021aa1:

    # "Worth a shot."
    "Vale a pena."

# game/script-a3-emi.rpy:8206
translate pt_br a3ec3o1_166a0e2d:

    # "The nurse knows Emi better than I do, I'll wager."
    "O enfermeiro conhece a Emi melhor que eu, vou apostar."

# game/script-a3-emi.rpy:8208
translate pt_br a3ec3o1_6a455da5:

    # hi "Sure, I'm open to suggestions."
    hi "Claro, estou aberto a sugestões."

# game/script-a3-emi.rpy:8210
translate pt_br a3ec3o1_477bba36:

    # hi "Honestly, I'm kind of lost."
    hi "Honestamente, eu estou meio perdido."

# game/script-a3-emi.rpy:8212
translate pt_br a3ec3o1_78f76b0c:

    # hi "I've got no idea how to deal with this."
    hi "Não tenho ideia de como lidar com isso."

# game/script-a3-emi.rpy:8217
translate pt_br a3ec3o1_3811de36:

    # nk "I never would have guessed."
    nk "Eu nunca teria adivinhado."

# game/script-a3-emi.rpy:8219
translate pt_br a3ec3o1_cdbe098c:

    # "He grins while he says this. I think he's kidding."
    "Ele sorri enquanto diz isso. Eu acho que ele está brincando."

# game/script-a3-emi.rpy:8224
translate pt_br a3ec3o1_6b1de434:

    # nk "Look, here's the deal: Emi is… stubborn."
    nk "Olha, esse é o problema: a Emi é… teimosa."

# game/script-a3-emi.rpy:8229
translate pt_br a3ec3o1_a8943490:

    # nk "You should know that by now, and if you don't then you're pretty unobservant, but I'm giving you the benefit of the doubt here."
    nk "Você ja devia saber disso até agora, e se não sabe então você é bem desatento, mas eu estou dando para você o benefício da dúvida aqui."

# game/script-a3-emi.rpy:8231
translate pt_br a3ec3o1_a1eada82:

    # hi "I'm so grateful."
    hi "Estou muito grato."

# game/script-a3-emi.rpy:8236
translate pt_br a3ec3o1_16b77770:

    # nk "Anyway, if she's decided that she doesn't want to talk about what happened, then she's not going to talk about what's happened."
    nk "De qualquer maneira, se ela decidiu que não quer falar sobre o que aconteceu, então ela não irá falar sobre o que aconteceu."

# game/script-a3-emi.rpy:8238
translate pt_br a3ec3o1_bfc48be2:

    # nk "Has she said anything about what's been bothering her? Even a hint?"
    nk "Será que ela não disse nada sobre o que anda aborrecendo ela? Nem mesmo uma dica?"

# game/script-a3-emi.rpy:8240
translate pt_br a3ec3o1_0bc45ea7:

    # hi "Well, she did say she'd been having nightmares about the accident…"
    hi "Bem, ela disse que ela estava tendo esses pesadelos relacionados ao acidente…"

# game/script-a3-emi.rpy:8245
translate pt_br a3ec3o1_4a03fcd2:

    # nk "Really? You're making progress, then. That's good."
    nk "Sério? Então, você está fazendo progresso. Isso é bom."

# game/script-a3-emi.rpy:8250
translate pt_br a3ec3o1_ffabed58:

    # nk "Well, I guess I can fill you in on this without violating my strict non-interference policy when it comes to Emi making stupid decisions."
    nk "Bem, eu acho que eu posso te ajudar nessa sem violar a minha estrita política de não-interferência quando relacionada à Emi fazer decisões idiotas."

# game/script-a3-emi.rpy:8255
translate pt_br a3ec3o1_018c58a8:

    # nk "The anniversary of her accident is coming up soon."
    nk "O aniversário do acidente dela está chegando."

# game/script-a3-emi.rpy:8257
translate pt_br a3ec3o1_3308ccdc:

    # nk "She gets depressed around this time, because it was a pretty traumatic event, considering what she lost."
    nk "Ela fica deprimida nessa época, porque foi um evento muito traumático, considerando o que ela perdeu."

# game/script-a3-emi.rpy:8259
translate pt_br a3ec3o1_be2d9336:

    # hi "That's the other thing. She acted like she lost more than just her legs. What happened?"
    hi "Essa é a outra coisa. Ela agiu como se ela tivesse perdido mais do que as pernas. O que aconteceu?"

# game/script-a3-emi.rpy:8264
translate pt_br a3ec3o1_2829c4ee:

    # nk "Whoa! Nope, not going there. You'll have to ask someone else about that, because that's a whole can of worms I'm not about to open."
    nk "Opa! Não, não vou tocar nisso. Você terá que perguntar isso para outra pessoa, porque isso aí é uma lata de minhocas que não estou disposto a abrir."

# game/script-a3-emi.rpy:8269
translate pt_br a3ec3o1_a9d99ce6:

    # nk "If Emi wants you to know, she'll tell you in her own time."
    nk "Se a Emi quer que você saiba, ela lhe dirá no seu próprio ritmo."

# game/script-a3-emi.rpy:8271
translate pt_br a3ec3o1_129e0d70:

    # nk "You've just got to be patient, that's all."
    nk "Você só precisa ser paciente, isso é tudo."

# game/script-a3-emi.rpy:8273
translate pt_br a3ec3o1_9f28c1e1:

    # hi "Why are you even helping me with all this?"
    hi "Por que você está me ajudando com tudo isso?"

# game/script-a3-emi.rpy:8278
translate pt_br a3ec3o1_7c13bfdd:

    # nk "Because you're good for her. She trusts you, even if you don't think she does."
    nk "Porque você é bom para ela. Ela confia em você, mesmo que você não pense dessa forma."

# game/script-a3-emi.rpy:8280
translate pt_br a3ec3o1_457066f1:

    # nk "And you've got the best chance out of anyone at this school right now to help her through this time of year."
    nk "E você tem a melhor chance do que qualquer um dessa escola em ajudá-la nessa época do ano."

# game/script-a3-emi.rpy:8285
translate pt_br a3ec3o1_13ecab05:

    # nk "She won't accept my help, but she might accept yours if you don't screw it up."
    nk "Ela não aceita minha ajuda, mas ela talvez aceite a sua se não estragar tudo."

# game/script-a3-emi.rpy:8290
translate pt_br a3ec3o1_eae33d34:

    # nk "So don't screw it up, got it?"
    nk "Então não estrague tudo, entendeu?"

# game/script-a3-emi.rpy:8296
translate pt_br a3ec3o2_0ad0a7b4:

    # "Advice? About what? I don't think there's anything I can actually do about this."
    "Conselho? Sobre o que? eu não acho que eu realmente consiga fazer algo sobre isso."

# game/script-a3-emi.rpy:8298
translate pt_br a3ec3o2_6983fb7e:

    # hi "Not really. I don't think there's anything you can say that'll help."
    hi "Não precisa. Não acho que há algo que você possa dizer que irá ajudar."

# game/script-a3-emi.rpy:8303
translate pt_br a3ec3o2_8f596860:

    # nk "You never know, Hisao."
    
    nk "Nunca se sabe, Hisao."
    

# game/script-a3-emi.rpy:8305
translate pt_br a3ec3o2_e835aaf7:

    # hi "No, I think I've got a pretty good idea."
    hi "Não, eu acho que eu tenho uma boa ideia."

# game/script-a3-emi.rpy:8307
translate pt_br a3ec3o2_2267ef90:

    # hi "Emi's just being stubborn about some things, and it's bothering me, but I'll get over it."
    hi "A Emi só está sendo teimosa com algumas coisas, e isso está me incomodando, mas eu vou superar."

# game/script-a3-emi.rpy:8309
translate pt_br a3ec3o2_6f38490c:

    # hi "Don't worry about us."
    hi "Não se preocupe conosco."

# game/script-a3-emi.rpy:8314
translate pt_br a3ec3o2_f81ce9ca:

    # "The nurse doesn't seem to believe me, but shrugs."
    "O enfermeiro não parece acreditar em mim, mas encolhe os ombros."

# game/script-a3-emi.rpy:8316
translate pt_br a3ec3o2_70b7ddfe:

    # nk "Have it your way, kiddo."
    nk "Faça como quiser, garoto."

# game/script-a3-emi.rpy:8321
translate pt_br a3ec4o1_9c8e11d3:

    # "The only way to find out is to go to the source. And the source is currently pretending that she has to use the toilet."
    "O único jeito de descobrir o que se passa é indo à fonte. E a fonte está fingindo que ela precisa usar o banheiro."

# game/script-a3-emi.rpy:8326
translate pt_br a3ec4o1_bd114144:

    # "I excuse myself politely from the table and head that way, only to catch sight of Emi not in the bathroom, but in the kitchen just next to the living room."
    "Peço licença da mesa educadamente e sigo aquele caminho, apenas para avistar que a Emi não está no banheiro, mas sim na cozinha ao lado da sala de estar."

# game/script-a3-emi.rpy:8331
translate pt_br a3ec4o1_fd855342:

    # "Emi's left the door open, and as I approach I can see that she's holding on to the table in an attempt to compose herself, an effort that fails as soon as I open my mouth."
    "Emi deixou a porta aberta, e assim que me aproximo eu consigo ver que ela está se segurando na mesa em uma tentativa de se recompor, um esforço que se falha assim que eu abro a minha boca."

# game/script-a3-emi.rpy:8333
translate pt_br a3ec4o1_063abe3d:

    # hi "Doesn't look like nature's call was that urgent."
    hi "Não parece que o chamado da natureza foi tão urgente."

# game/script-a3-emi.rpy:8338
translate pt_br a3ec4o1_c23081e8:

    # "Emi jumps and glares at me."
    "Emi pula e olha para mim."

# game/script-a3-emi.rpy:8343
translate pt_br a3ec4o1_40cdd248:

    # emi "What are you doing here? I didn't come here to be with other people."
    emi "O que você está fazendo aqui? Eu não vim aqui para ficar com outras pessoas."

# game/script-a3-emi.rpy:8345
translate pt_br a3ec4o1_841169a6:

    # hi "I just wanted to help you. You looked pretty rattled."
    hi "Eu só queria te ajudar. Você parecia muito agitada."

# game/script-a3-emi.rpy:8350
translate pt_br a3ec4o1_a3712d14:

    # emi "I said it was nothing, didn't I? And besides, I thought we'd established that you can't help me."
    emi "Eu disse que não era nada, não disse? Ainda que, eu pensei que nós tinhamos estabelecido que você não pode me ajudar."

# game/script-a3-emi.rpy:8352
translate pt_br a3ec4o1_8059de66:

    # hi "No, we've established that you're stubborn."
    hi "Não, nós estabelecemos que você é teimosa."

# game/script-a3-emi.rpy:8357
translate pt_br a3ec4o1_d8295499:

    # emi "Look who's talking. The guy who followed me."
    emi "Olha quem fala. O cara que me seguiu."

# game/script-a3-emi.rpy:8359
translate pt_br a3ec4o1_e2bda517:

    # hi "This is different! I want to help you with… whatever this is."
    hi "Isso é diferente! Eu quero te ajudar com… qualquer coisa que seja."

# game/script-a3-emi.rpy:8364
translate pt_br a3ec4o1_8b313be2:

    # emi "Funny, because {b}I{/b} just want you to leave me alone."
    emi "Engraçado, porque {b}eu{/b} só quero que você me deixe em paz."

# game/script-a3-emi.rpy:8366
translate pt_br a3ec4o1_cd150340:

    # hi "But why? Why can't you just trust me?"
    hi "Mas por quê? Por que você não pode simplesmente confiar em mim?"

# game/script-a3-emi.rpy:8371
translate pt_br a3ec4o1_7bf3a941:

    # emi "We've been over this already, Hisao. I've got to deal with this stuff on my own."
    emi "Nós já falamos sobre isso, Hisao. Eu tenho que lidar com essas coisas sozinha."

# game/script-a3-emi.rpy:8373
translate pt_br a3ec4o1_a2825f8f:

    # hi "I won't accept that! You need my help, you just won't take it!"
    hi "Eu não aceito isso! Você precisa da minha ajuda, você só não aceita!"

# game/script-a3-emi.rpy:8375
translate pt_br a3ec4o1_141187e6:

    # "My wording seems to have been a little off."
    "Minhas palavras pareciam estar um pouco erradas."

# game/script-a3-emi.rpy:8380
translate pt_br a3ec4o1_f89785b9:

    # emi "Need? I {b}need{/b} your help?"
    emi "Preciso? Eu {b}preciso{/b} da sua ajuda?"

# game/script-a3-emi.rpy:8387
translate pt_br a3ec4o1_2a92923b:

    # emi "Well, it's a good thing we met, isn't it? Because otherwise I guess I'd just be a broken human being, wouldn't I?"
    emi "Bom, ainda bem que nos conhecemos, não é? Porque senão eu acho que eu seria apenas um ser humano quebrado, não seria?"

# game/script-a3-emi.rpy:8389
translate pt_br a3ec4o1_b821520c:

    # emi "No, it's a damn good thing that Hisao came along to save the day, isn't it? Because God knows I can't save myself, can I?"
    emi "Não, é ótimo que o Hisao veio para salvar o dia, não é? Porque Deus sabe que eu não posso me salvar, posso?"

# game/script-a3-emi.rpy:8391
translate pt_br a3ec4o1_064143eb:

    # emi "I'm just the poor, emotionally damaged girl with no legs, right?"
    emi "Eu sou apenas a pobre, garota traumatizada emocionalmente e sem pernas, não sou?"

# game/script-a3-emi.rpy:8393
translate pt_br a3ec4o1_643f4798:

    # hi "Emi, you know I don't think that—"
    hi "Emi, você sabe que eu não penso assim—"

# game/script-a3-emi.rpy:8398
translate pt_br a3ec4o1_5beb76b0:

    # emi "Really? Because if you thought differently then I don't think you'd be here, saying I need your help."
    emi "Sério? Porque se você não pensasse mesmo nisso então você não estaria aqui, dizendo que eu preciso da sua ajuda."

# game/script-a3-emi.rpy:8400
translate pt_br a3ec4o1_607b466f:

    # emi "I've gotten pretty far in life as a normal human being without you."
    emi "Eu consegui chegar bem longe na vida como um ser humano sem estar com você."

# game/script-a3-emi.rpy:8402
translate pt_br a3ec4o1_35f86601:

    # hi "So what, nothing we've shared was important? I'm just the guy who hangs out with you?"
    hi "E dai, nada que nós compartilhamos foi importante? Eu sou só o cara que sai com você?"

# game/script-a3-emi.rpy:8407
translate pt_br a3ec4o1_596a9d5e:

    # emi "You're my boyfriend, Hisao, not my savior."
    emi "Você é meu namorado, Hisao, não o meu salvador."

# game/script-a3-emi.rpy:8409
translate pt_br a3ec4o1_d33eb32b:

    # hi "Well no, that much is obvious. You won't even consider that I could be a help to you, will you?"
    hi "Bem não, isso é óbvio. Você não vai nem considerar que eu possa servir de ajuda para você, não vai?"

# game/script-a3-emi.rpy:8411
translate pt_br a3ec4o1_f51c5f34:

    # hi "You'll just bottle it all up and hope that a run will solve your problems, or you'll come visit me and we'll fool around until you feel better."
    hi "Você só vai segurar tudo consigo e esperar que uma corrida possa resolver seus problemas, ou você irá me visitar e nós vamos fazer umas bobagens por aí até você se sentir melhor."

# game/script-a3-emi.rpy:8413
translate pt_br a3ec4o1_a3639338:

    # hi "That's not being a healthy human being, Emi. That's not what a relationship means."
    hi "Isso não é ser um ser humano saudável, Emi. Não é isso o que um relacionamento significa."

# game/script-a3-emi.rpy:8418
translate pt_br a3ec4o1_2d24456b:

    # emi "Well it's what it means to me right now, Hisao."
    emi "Bem isso é o que significa para mim agora mesmo, Hisao."

# game/script-a3-emi.rpy:8423
translate pt_br a3ec4o1_703adbc5:

    # emi "I wish—"
    emi "Eu gostaria—"

# game/script-a3-emi.rpy:8425
translate pt_br a3ec4o1_7536b546:

    # "She seems to reconsider her words just then. A flicker of pain, of doubt on her face. For a moment I think she's about to cry."
    "Ela parecia reconsiderar suas palavras até que então. Um lampejo de dor, de dúvida na cara dela. Por um momento eu pensei que ela iria começar a chorar."

# game/script-a3-emi.rpy:8430
translate pt_br a3ec4o1_35bbac76:

    # "But the moment passes, and now she's composed herself again. Whatever that wish was will have to go unspoken."
    "Mas esse momento passa, e agora ela se recompôs de novo. O que quer que seja o que ela gostaria, agora passa sem ser mencionado."

# game/script-a3-emi.rpy:8432
translate pt_br a3ec4o1_3c511ab7:

    # emi "Look, I just… I can't do this right now."
    emi "Olha, eu só… eu não consigo fazer isso agora."

# game/script-a3-emi.rpy:8434
translate pt_br a3ec4o1_885fb58f:

    # hi "What, have a serious conversation? Be open? Be honest? Give a damn about anyone besides yourself and your problems?"
    hi "O quê, ter uma conversa séria? Ser aberta? Ser honesta? Dar a mínima pra qualquer um além de você e seus problemas?"

# game/script-a3-emi.rpy:8439
translate pt_br a3ec4o1_3682b830:

    # emi "What do you know about my problems? Nothing! You don't know what I've been through, so don't pretend that you do."
    emi "O que você sabe dos meus problemas? Nada! Você não sabe pelo o que eu passei, então não finja que saiba."

# game/script-a3-emi.rpy:8441
translate pt_br a3ec4o1_20eb2ac1:

    # hi "I know you have nightmares, and I know your father's gone. What happened to him?"
    hi "Eu sei dos seus pesadelos, e eu sei que seu pai se foi. O que aconteceu com ele?"

# game/script-a3-emi.rpy:8446
translate pt_br a3ec4o1_004c29b3:

    # "Emi's head jerks backwards as if I've just slapped her. That brittle quality has gotten back into her voice."
    "Emi inclina a cabeça para trás como se eu tivesse acabado de dar um tapa nela. Aquele tom frágil volta à sua voz."

# game/script-a3-emi.rpy:8451
translate pt_br a3ec4o1_5fe96675:

    # emi "That's enough."
    emi "Chega."

# game/script-a3-emi.rpy:8453
translate pt_br a3ec4o1_a5c070fe:

    # "This is stupid. This whole conversation has just been variations on Emi stonewalling me."
    "Isso é ridículo. Toda essa conversa não foi nada além da Emi me barrando de todas as formas possíveis."

# game/script-a3-emi.rpy:8455
translate pt_br a3ec4o1_45c759d0:

    # hi "What, you won't even answer that question? Fine, keep your secrets. They can lie in the grave as far as I'm concerned."
    hi "O que, você não vai nem responder essa pergunta? TÁ BOM, fique com seus segredos. Pode ir com eles para o túmulo se bem quiser."

# game/script-a3-emi.rpy:8460
translate pt_br a3ec4o1_0e1c2080:

    # "Emi's eyes widen in shock. When she speaks again, it's in a voice that is low, dangerous."
    "Os olhos da Emi se arregalam em choque. Quando ela fala de novo, é em uma voz que é baixa, perigosa."

# game/script-a3-emi.rpy:8465
translate pt_br a3ec4o1_ee2abcaf:

    # emi "Get out of my house, Hisao."
    emi "Saia da minha casa, Hisao."

# game/script-a3-emi.rpy:8467
translate pt_br a3ec4o1_3fceda3a:

    # "The sudden change in her tone snaps me out of my self-righteous anger and makes me realize with a dawning horror what I've just said."
    "A súbita mudança no tom dela me tira da minha raiva hipócrita e faz eu perceber com grande horror o que eu acabei de dizer."

# game/script-a3-emi.rpy:8469
translate pt_br a3ec4o1_e2c54dc9:

    # hi "Emi, I didn't mean—"
    hi "Emi, eu não quis dizer—"

# game/script-a3-emi.rpy:8476
translate pt_br a3ec4o1_f1dab570:

    # emi "I said {b}go{/b}, Hisao."
    emi "Eu disse {b}saia{/b}, Hisao."

# game/script-a3-emi.rpy:8478
translate pt_br a3ec4o1_014eb49f:

    # emi "Tell my mother that she cooked a wonderful meal but you've forgotten a prior engagement, and get out of my house."
    emi "Diga para minha mãe que ela preparou uma refeição maravilhosa mas você esqueceu que tinha um compromisso anterior, e saia da minha casa."

# game/script-a3-emi.rpy:8480
translate pt_br a3ec4o1_de7dd83b:

    # "She's trembling now, shaking with anger, or sadness, or determination. Her voice is still low, controlled. Almost a growl."
    
    "Ela está tremendo agora, tremendo de raiva, ou tristeza, ou determinação. Sua voz ainda está em baixo tom, controlada. Quase como um rosnado."

# game/script-a3-emi.rpy:8482
translate pt_br a3ec4o1_00b9d2d6:

    # "I reach out to put an arm on her shoulder, to apologize for going too far, but she jerks away from my touch."
    "Eu estico para tentar por um braço no ombro dela, para me desculpar por ter passado dos limites, mas ela se empurra para longe do meu toque."

# game/script-a3-emi.rpy:8487
translate pt_br a3ec4o1_fddca906:

    # emi "Get out."
    emi "Vá embora."

# game/script-a3-emi.rpy:8493
translate pt_br a3ec4o1_f4a4531a:

    # "What can I do? I walk out of the kitchen and go to the living room, make my apology to Mrs. Ibarazaki, and let myself out."
    "O que eu posso fazer? Eu saio da cozinha e vou até a sala de estar, peço desculpas para a Sra. Ibarazaki, e vou embora."

# game/script-a3-emi.rpy:8501
translate pt_br a3ec4o2_aee4b1dd:

    # "There's an awkward silence at the table for a while after Emi dashes off. I can't think of anything to say."
    "Há um silêncio incômodo na mesa por um tempo depois que a Emi sai correndo. Eu não consigo pensar em mais nada para dizer."

# game/script-a3-emi.rpy:8506
translate pt_br a3ec4o2_3daf3f05:

    # "Emi's mother sighs, breaking the silence."
    "A mãe da Emi boceja, quebrando o silêncio."

# game/script-a3-emi.rpy:8510
translate pt_br a3ec4o2_e99f1509:

    # emm "Sorry about that, Hisao. I sometimes forget that Emi's touchy about certain subjects."
    emm "Desculpe por isso, Hisao. Eu esqueço que às vezes a Emi é meio irritável com certos assuntos."

# game/script-a3-emi.rpy:8512
translate pt_br a3ec4o2_ec5ad9cd:

    # emm "And I was talking about the wheelchair thing, too…"
    emm "E eu estava falando da coisa da cadeira de rodas, também…"

# game/script-a3-emi.rpy:8514
translate pt_br a3ec4o2_a7505259:

    # hi "Should I go after her?"
    hi "Devo ir atrás dela?"

# game/script-a3-emi.rpy:8519
translate pt_br a3ec4o2_01c8973d:

    # emm "Heavens no! She didn't leave the table to continue the conversation, you know."
    emm "Céus, não! Ela não saiu da mesa para continuar a conversa, você sabe."

# game/script-a3-emi.rpy:8521
translate pt_br a3ec4o2_ee16b503:

    # hi "But if she's troubled, shouldn't someone help her?"
    hi "Mas se ela está com problemas, não deveria alguém ajudar ela?"

# game/script-a3-emi.rpy:8526
translate pt_br a3ec4o2_972cf9cc:

    # emm "If it were anyone else, I'd say yes. But my daughter is stubborn as a mule, and if she wants to be alone it's best to let her be alone."
    emm "Se fosse com qualquer outro, eu diria que sim. Mas a minha filha é teimosa como uma mula, e se ela quer ficar sozinha é melhor deixar ela ficar sozinha."

# game/script-a3-emi.rpy:8528
translate pt_br a3ec4o2_d50e7c78:

    # emm "Otherwise she'll probably say something she'd regret, which would cause you to say something you'd regret, and I would prefer that dinner doesn't end with one or the both of you storming out of the house."
    emm "Se não ela provavelmente iria dizer algo que ela fosse se arrepender, o que faria você dizer algo que fosse fazer você se arrepender, e eu iria preferir um jantar que não acabasse com um ou vocês dois saindo de casa."

# game/script-a3-emi.rpy:8533
translate pt_br a3ec4o2_43dce610:

    # emm "If that were to happen I'd be a terrible hostess, wouldn't I? I've already acted as a fool once today."
    emm "E se isso fosse acontecer eu iria ser uma terrível anfitriã, não seria? Eu já me fiz de idiota uma vez hoje."

# game/script-a3-emi.rpy:8535
translate pt_br a3ec4o2_62945f2b:

    # hi "That's okay, I shouldn't have brought up the wheelchair, apparently."
    hi "Está bem, eu não deveria ter falado da cadeira de rodas, aparentemente."

# game/script-a3-emi.rpy:8540
translate pt_br a3ec4o2_3fd4b53f:

    # "Mrs. Ibarazaki frowns, clearly more bothered by Emi's omission than she'd let on."
    "A Sra. Ibarazaki franze a testa, claramente mais incomodada do que a Emi transparecia."

# game/script-a3-emi.rpy:8542
translate pt_br a3ec4o2_7269a38c:

    # emm "I wish she wouldn't do that. It just makes me worry more, you know."
    emm "Eu desejaria que ela parasse de fazer isso. Só me faz me preocupar mais, sabe."

# game/script-a3-emi.rpy:8544
translate pt_br a3ec4o2_c345fa10:

    # hi "She does this often?"
    hi "Ela faz isso com frequência?"

# game/script-a3-emi.rpy:8549
translate pt_br a3ec4o2_cc665604:

    # emm "What, running off to the bathroom? No, I can't say she does. Keep injuries from her mother, though? Well, that's a little more common."
    emm "O que, correr para o banheiro? Não, não posso dizer que ela faz. Porém, esconder ferimentos da sua mãe? Bem, isso já é mais comum."

# game/script-a3-emi.rpy:8551
translate pt_br a3ec4o2_92c2e2ff:

    # emm "Every time I catch her lying like that, she assures me that the only reason she didn't tell me is because it wasn't a big deal."
    emm "Toda vez que eu a vejo deitada daquele jeito, ela me assegura que o único motivo pelo qual ela não me conta é porque não é nada."

# game/script-a3-emi.rpy:8553
translate pt_br a3ec4o2_40ec6131:

    # hi "If it's any consolation, I'm sure the only reason I knew about it at all was because I saw her every day."
    hi "Se serve de consolo, tenho certeza de que o único motivo de eu saber de tudo isso é porque eu a vejo todo dia."

# game/script-a3-emi.rpy:8558
translate pt_br a3ec4o2_52c85904:

    # "This elicits a dry chuckle from across the table. Mrs. Ibarazaki sighs, a little sadly."
    "Isso provoca uma risada seca do outro lado da mesa. A Sra. Ibarazaki ri, um pouco triste."

# game/script-a3-emi.rpy:8563
translate pt_br a3ec4o2_2ed81d0a:

    # emm "Still hesitant about getting close to people, huh? I keep hoping that she'll get over that."
    emm "Ainda hesitante em se aproximar das pessoas, hein? Eu continuo esperando que ela vá superar isso."

# game/script-a3-emi.rpy:8565
translate pt_br a3ec4o2_9133b5d6:

    # emm "It's funny, really. She's bounced back so well from the accident in so many ways…"
    emm "É engraçado, sério. Ela se recuperou do acidente tão bem de tantas maneiras…"

# game/script-a3-emi.rpy:8570
translate pt_br a3ec4o2_f50f0e74:

    # emm "I guess some things never really go away."
    emm "Acho que algumas coisas nunca vão mesmo embora."

# game/script-a3-emi.rpy:8572
translate pt_br a3ec4o2_af914936:

    # "From the looks of it, the whole thing still bothers her, too."
    "Do jeito que parece, a coisa toda ainda aborrece ela, também."

# game/script-a3-emi.rpy:8574
translate pt_br a3ec4o2_1581ba11:

    # "She seems to be a little more willing to talk about the accident without Emi around, though."
    "Porém, ela parece estar um pouco mais disposta a falar do acidente sem a Emi por perto."

# game/script-a3-emi.rpy:8576
translate pt_br a3ec4o2_a4fc3a64:

    # hi "Hey, I've got a question, if it's all right."
    hi "Ei, eu tenho uma pergunta, se isso está tudo bem."

# game/script-a3-emi.rpy:8581
translate pt_br a3ec4o2_dc0216ca:

    # emm "Oh?"
    emm "Oh?"

# game/script-a3-emi.rpy:8583
translate pt_br a3ec4o2_2325f9bd:

    # hi "What else did Emi lose in that accident? The nurse said that she gets this way near the anniversary, and she won't talk about it to me…"
    hi "O que mais a Emi perdeu no acidente? O enfermeiro disse que ela fica assim perto do aniversário, e ela não conversa comigo sobre isso…"

# game/script-a3-emi.rpy:8588
translate pt_br a3ec4o2_064e74d8:

    # emm "So you thought I'd fill you in, hmm?"
    emm "Então você pensou que eu poderia te explicar, hmm?"

# game/script-a3-emi.rpy:8590
translate pt_br a3ec4o2_d3f362db:

    # hi "Er, yeah. Hopefully."
    hi "Er, sim. Se possível."

# game/script-a3-emi.rpy:8595
translate pt_br a3ec4o2_94a84261:

    # emm "Well, there's a problem with that request, you know."
    emm "Bem, tem um problema com esse pedido, sabe."

# game/script-a3-emi.rpy:8597
translate pt_br a3ec4o2_b776a7b1:

    # hi "Let me guess: you promised Emi that you wouldn't tell anyone she didn't want to know, and you don't know if she wants me to know?"
    hi "Deixe-me adivinhar: você prometeu a Emi que não contaria para ninguém que ela não quer que saiba, e você não sabe se ela quer que eu saiba?"

# game/script-a3-emi.rpy:8599
translate pt_br a3ec4o2_c0546718:

    # emm "Something like that. I promised Emi that she'd be the one to tell people the full story."
    emm "Algo do tipo. Eu prometi à Emi que ela é quem deve contar toda a história."

# game/script-a3-emi.rpy:8601
translate pt_br a3ec4o2_74cd4844:

    # hi "But isn't that important? I mean, it's clearly had a huge effect on her if she's still like this so long after the accident happened."
    hi "Mas isso não é importante? Quero dizer, isso claramente teve uma enorme consequência nela se ela ainda é assim mesmo tanto tempo depois do acidente."

# game/script-a3-emi.rpy:8606
translate pt_br a3ec4o2_fbc04b16:

    # emm "That's true. It did have a long-lasting effect on her. There are a few things that she'll probably never really get over."
    emm "É verdade. Isso realmente teve um efeito duradouro sobre ela. Tem algumas coisas que ela provavelmente nunca irá superar."

# game/script-a3-emi.rpy:8608
translate pt_br a3ec4o2_18a090c5:

    # "For a moment Mrs. Ibarazaki looks incredibly saddened, as if an old wound is bothering her."
    "Por um momento a Sra. Ibarazaki parece incrivelmente entristecida, como se uma velha ferida estivesse a machucando."

# game/script-a3-emi.rpy:8610
translate pt_br a3ec4o2_ac46f44e:

    # emm "I suppose there are a few things I'll never really get over either…"
    emm "Eu acredito que há algumas coisas que eu nunca superei também…"

# game/script-a3-emi.rpy:8615
translate pt_br a3ec4o2_ec9f3444:

    # "Another dry chuckle, and with a shake of her head Emi's mother banishes the memory."
    "Outra risada seca, e com um sacudir de sua cabeça a mãe da Emi exila a memória."

# game/script-a3-emi.rpy:8620
translate pt_br a3ec4o2_1b682c1a:

    # emm "Look, there's something you absolutely must understand about the way Emi thinks about the accident."
    emm "Olha, tem uma coisa que você precisa absolutamente entender sobre o modo de como a Emi pensa sobre o acidente."

# game/script-a3-emi.rpy:8622
translate pt_br a3ec4o2_111a58e1:

    # hi "What's that?"
    hi "Que é?"

# game/script-a3-emi.rpy:8624
translate pt_br a3ec4o2_e48c0f85:

    # emm "It wasn't a big deal."
    emm "Não é nada demais."

# game/script-a3-emi.rpy:8628
translate pt_br a3ec4o2_a2c89b3d:

    # "Somehow I manage to keep my mouth from falling open in surprise, but it takes some effort."
    "De alguma maneira eu consigo evitar a minha boca de se abrir em surpresa, mas isso me custa um certo esforço."

# game/script-a3-emi.rpy:8630
translate pt_br a3ec4o2_52d1fd73:

    # "That has to be the most ridiculous thing I've ever heard."
    "Essa tem que ser a coisa mais ridícula que eu ja ouvi."

# game/script-a3-emi.rpy:8632
translate pt_br a3ec4o2_37f63bc4:

    # hi "I beg your pardon?"
    hi "É o quê!?"

# game/script-a3-emi.rpy:8639
translate pt_br a3ec4o2_a97675aa:

    # emm "Okay, maybe it's not that simple, but it's a pretty accurate summation. Emi believes that the accident did not define her, and that everything she lost that day didn't define her either."
    emm "Ok, talvez não seja tão simples assim, mas é um somatório bastante preciso. Emi acredita que o acidente não definiu ela, e tudo que ela perdeu aquele dia também não definiu."

# game/script-a3-emi.rpy:8641
translate pt_br a3ec4o2_1f6f00a2:

    # emm "She's not 'that girl who lost her legs,' she's 'The Fastest Thing on No Legs.' Her optimism and energy came out of that wreck without a scratch, as far as she's concerned."
    emm "Ela não é “aquela garota que perdeu as pernas,” ela é “a coisa mais rápida sem pernas.” O otimismo e energia dela sairam das ferragens sem nenhum arranhão, até onde ela sabe."

# game/script-a3-emi.rpy:8643
translate pt_br a3ec4o2_d19923cb:

    # hi "Yet it goes beyond that, doesn't it? I mean, last night she told me that she refused to rely on me because it would make losing me too painful."
    hi "No entanto vai além disso, não vai? Quero dizer, noite passada ela me disse que se recusou a confiar em mim porque isso iria tornar me perder algo muito doloroso."

# game/script-a3-emi.rpy:8648
translate pt_br a3ec4o2_cf578c14:

    # emm "Not really. You said she won't tell you about the accident, even though you've asked her about it before."
    emm "Não mesmo. Você disse que ela não te conta sobre o acidente, embora você já tenha perguntado para ela sobre isso antes."

# game/script-a3-emi.rpy:8650
translate pt_br a3ec4o2_7e01cfe0:

    # emm "The reason she won't talk about it when you ask is because to her it's not something you absolutely need to know. Even if she wasn't terrified of getting too close to anyone, she still wouldn't talk about it."
    emm "A razão pela qual ela não te conta sobre isso é porque para ela, isso é algo que você não precisa realmente saber. Mesmo se ela não tivesse pavor de se aproximar de alguém, ela ainda não iria falar sobre isso."

# game/script-a3-emi.rpy:8652
translate pt_br a3ec4o2_022419ee:

    # hi "She's afraid of being close to me?"
    hi "Ela tem pavor de se aproximar de mim?"

# game/script-a3-emi.rpy:8657
translate pt_br a3ec4o2_ec33e884:

    # emm "Oh goodness me, yes. For all that talk about being unscathed by the accident, she's gained the ugly knowledge of how quickly it can all be over."
    emm "Ai meu Deus, sim. Pelo amor de toda essa conversa sobre sair ileso do acidente, ela ganhou esse conhecimento terrível de como tudo pode rapidamente acabar do nada."

# game/script-a3-emi.rpy:8662
translate pt_br a3ec4o2_eae2b4c6:

    # emm "So she's not going to let people get especially close to her, and she certainly would resent any implication that she cannot work through this on her own."
    emm "Então ela não vai deixar as pessoas ficarem especialmente próximas a ela, e ela certamente iria ressentir qualquer implicação de que ela não consiga passar por isso sozinha."

# game/script-a3-emi.rpy:8664
translate pt_br a3ec4o2_10c41f3d:

    # hi "But I don't think she {b}can{/b}."
    hi "Mas eu não acho que ela {b}consiga{/b}."

# game/script-a3-emi.rpy:8669
translate pt_br a3ec4o2_60f7a665:

    # emm "Oh no? Are you sure you've been dating my daughter and not somebody else? Trust me Hisao, she could get through it on her own."
    emm "Ah não? Você tem certeza de que está namorando a minha filha e não a de outra pessoa? Confia em mim Hisao, ela pode passar por isso sozinha."

# game/script-a3-emi.rpy:8671
translate pt_br a3ec4o2_74778278:

    # hi "But she has nightmares, and can't sleep well, and—"
    hi "Mas ela tem pesadelos, e não consegue dormir bem, e—"

# game/script-a3-emi.rpy:8676
translate pt_br a3ec4o2_bbd69266:

    # emm "And she does this every year. Tell me, if she wasn't able to get through it on her own, do you really think she'd still be alive? She would've killed herself, or something equally melodramatic."
    emm "E ela faz isso todos os anos. Me diga, se ela não fosse capaz de superar isso sozinha, você realmente acha que ela ainda estaria viva? Ela já teria se matado, ou algo igualmente melodramático."

# game/script-a3-emi.rpy:8678
translate pt_br a3ec4o2_e508959d:

    # hi "So what, I shouldn't try to help her?"
    hi "E dai, eu não deveria tentar ajudá-la?"

# game/script-a3-emi.rpy:8683
translate pt_br a3ec4o2_33cc99a7:

    # emm "I didn't say that! I hate seeing my daughter like this, and knowing that she could rely on someone else would let me relax."
    emm "Eu não disse isso! Eu odeio ver a minha filha desse jeito, e saber que ela pode confiar em mais alguém iria me relaxar."

# game/script-a3-emi.rpy:8685
translate pt_br a3ec4o2_a1eff8b4:

    # emm "You just need to understand that accepting help goes against everything Emi thinks about herself and the way the world works."
    emm "Você só precisa entender que aceitar ajuda iria contra tudo o que a Emi pensa sobre si mesma e de como o mundo funciona."

# game/script-a3-emi.rpy:8687
translate pt_br a3ec4o2_81d0f696:

    # emm "If you still want to offer her help, then I guess that's your call. Honestly, I'd like you to, but it'd be silly not to warn you that it's not going to be easy."
    emm "Se você ainda quer oferecer ajuda à ela, então acho que essa é a hora. Honestamente, eu gostaria que você a ajudasse, mas seria estúpido não avisar que isso não será fácil."

# game/script-a3-emi.rpy:8692
translate pt_br a3ec4o2_910ed9da:

    # emm "You just need to be patient with her. She's already closer to you than anyone else she's ever met at Yamaku."
    emm "Você só precisa ser paciente com ela. Ela já é mais próxima a você do que qualquer um que ela tenha conhecido na Yamaku."

# game/script-a3-emi.rpy:8694
translate pt_br a3ec4o2_53de06fc:

    # hi "Well it sure doesn't feel like we're very close."
    hi "Bem, com certeza não pareceu que nós somos próximos."

# game/script-a3-emi.rpy:8705
translate pt_br a3ec4o2_e09d0b46:

    # emi "Good, that makes this part easier."
    hi "Bem, com certeza não pareceu que nós somos próximos."

# game/script-a3-emi.rpy:8707
translate pt_br a3ec4o2_87b7328c:

    # "Emi's voice nearly gives me a heart attack."
    "A voz da Emi quase me dá um ataque do coração."

# game/script-a3-emi.rpy:8709
translate pt_br a3ec4o2_86253193:

    # hi "Whoa! Didn't hear you come back, Emi."
    hi "Wow! Eu não ouvi você voltando, Emi."

# game/script-a3-emi.rpy:8714
translate pt_br a3ec4o2_d5e6a6d9:

    # emi "How convenient."
    emi "Que conveniente."

# game/script-a3-emi.rpy:8716
translate pt_br a3ec4o2_a5d9aa0b:

    # hi "Wait, were you eavesdropping?"
    hi "Pera, você estava escutando?"

# game/script-a3-emi.rpy:8721
translate pt_br a3ec4o2_4f26dba0:

    # emi "Nope. Just happened to come back at the right moment, I guess."
    emi "Não. Só me ocorreu de voltar aqui no momento certo, eu acho."

# game/script-a3-emi.rpy:8726
translate pt_br a3ec4o2_3ea115ef:

    # emm "Emi, Hisao was just—"
    emm "Emi, Hisao só estava—"

# game/script-a3-emi.rpy:8728
translate pt_br a3ec4o2_d2ac4696:

    # "Emi holds up a finger, cutting her mother off."
    "Emi levanta um dedo, cortando sua mãe."

# game/script-a3-emi.rpy:8733
translate pt_br a3ec4o2_b0b14af5:

    # emi "On his way out of the house? Yeah, I know."
    
    emi "Indo para fora de casa? É, eu sei."

# game/script-a3-emi.rpy:8735
translate pt_br a3ec4o2_f9987016:

    # "Emi's trembling with anger now, looking vaguely betrayed."
    "Emi está tremendo com raiva agora, parecendo vagamente traída."

# game/script-a3-emi.rpy:8737
translate pt_br a3ec4o2_554adec7:

    # emm "Emi, don't be ridiculous, we were just—"
    emm "Emi, não seja ridícula, nós só estávamos—"

# game/script-a3-emi.rpy:8742
translate pt_br a3ec4o2_28bf991a:

    # emi "You {b}promised{/b}!"
    emi "Você {b}prometeu{/b}!"

# game/script-a3-emi.rpy:8746
translate pt_br a3ec4o2_c92ee310:

    # "The pain carried in that last word is almost too much for me to bear. The idea that I could hurt her that much is like being kicked in the gut."
    "A dor carregada nessa última palavra é quase demais para eu aguentar. A ideia de que eu podia machucar ela tanto assim é quase como um chute na estômago."

# game/script-a3-emi.rpy:8748
translate pt_br a3ec4o2_11af2e0e:

    # "Emi's mother looks similarly pained by the thought."
    "A mãe da Emi parece semelhantemente aflita pela ideia."

# game/script-a3-emi.rpy:8750
translate pt_br a3ec4o2_4d083dbc:

    # emm "And I kept that promise! Just listen, there's no reason to go throwing people out of the house."
    emm "E eu mantive essa promessa! Apenas escute, não há motivo para ir expulsando as pessoas de casa."

# game/script-a3-emi.rpy:8752
translate pt_br a3ec4o2_5697cbac:

    # "Emi's mother seems to be both angry at her daughter's outburst and embarrassed that I'm a witness to it."
    "A mãe da Emi parece estar irritada com a birra de sua filha e envergonhada que eu esteja testemunhando isso."

# game/script-a3-emi.rpy:8754
translate pt_br a3ec4o2_439acdd9:

    # "There's only one real solution to this problem, I think."
    "Há apenas uma solução verdadeira para esse problema, eu acho."

# game/script-a3-emi.rpy:8756
translate pt_br a3ec4o2_5b4d6d74:

    # hi "It's okay. I'll go."
    hi "Está bem. Eu vou."

# game/script-a3-emi.rpy:8758
translate pt_br a3ec4o2_17fa4223:

    # emm "Now really, that seems a little unnecessary…"
    emm "Agora sério, isso parece um pouco desnecessário."

# game/script-a3-emi.rpy:8760
translate pt_br a3ec4o2_ccbebf78:

    # hi "Don't worry about it. Thank you for dinner, Mrs. Ibarazaki, and for the advice."
    hi "Não se preocupe com isso. Obrigado pelo jantar, Sra. Ibarazaki, e pelos conselhos."

# game/script-a3-emi.rpy:8765
translate pt_br a3ec4o2_8682b0fe:

    # emm "It was my pleasure, Hisao. I'm sorry we didn't get to the dessert."
    emm "O prazer foi meu, Hisao. Me desculpe que nós não conseguimos ter uma sobremesa."

# game/script-a3-emi.rpy:8767
translate pt_br a3ec4o2_67cb332d:

    # hi "That's okay. I have to watch what I eat anyway."
    hi "Está tudo bem. Eu preciso cuidar do que eu como de qualquer maneira."

# game/script-a3-emi.rpy:8769
translate pt_br a3ec4o2_21bc2e04:

    # hi "Good evening, Emi, Mrs. Ibarazaki."
    hi "Boa noite, Emi, Sra. Ibarazaki."

# game/script-a3-emi.rpy:8771
translate pt_br a3ec4o2_0fe5cb19:

    # "The formality of our conversation, coupled with the fact that I'm getting ready to leave, seems to snap Emi out of her anger."
    "A formalidade da nossa conversa, junto com o fato de que eu estava me preparando para ir embora, parecem ter feito a Emi parar de ter esse ataque de raiva."

# game/script-a3-emi.rpy:8776
translate pt_br a3ec4o2_ec363ccd:

    # emi "No, wait. I'm sorry, I've been so… and after last night I just thought… You don't have to go, I take it back, it's okay—"
    emi "Não, espera. Me desculpa, eu estive tão… e depois da noite passada eu só estive pensando… Você não precisa ir embora, eu retiro o que eu disse, está bem—"

# game/script-a3-emi.rpy:8778
translate pt_br a3ec4o2_d91e162f:

    # "I can't help but smile slightly. She can barely articulate her apology, and I really would like to stay…"
    "Eu não consigo fazer nada senão sorrir de leve. Ela mal consegue articular sua desculpa, e eu realmente gostaria de ficar…"

# game/script-a3-emi.rpy:8780
translate pt_br a3ec4o2_f8aba906:

    # "But I don't think I can, right now. I need to think about what her mother said, and about what I'm going to do about us."
    "Mas eu não acho que eu posso, agora. Eu preciso pensar no que a mãe dela disse antes, e sobre o que irei fazer sobre nós."

# game/script-a3-emi.rpy:8782
translate pt_br a3ec4o2_889f8b03:

    # "I don't want to risk accidentally getting Emi angry again in her current state, either."
    "Eu não posso arriscar e acidentalmente irritar a Emi de novo nesse estado que ela está, também."

# game/script-a3-emi.rpy:8784
translate pt_br a3ec4o2_be06c1c8:

    # hi "No, I think I'd better leave. You seem pretty shook up, and, well, I'd only wind up trying to help you again. I know you'd prefer I didn't, so I'm going to leave instead."
    hi "Não, acho melhor eu ir. Você está bem abalada, e bem, eu só iria acabar tentando te ajudar de novo. Eu sei que você preferia que eu não fizesse isso, então ao invés disso eu irei sair."

# game/script-a3-emi.rpy:8789
translate pt_br a3ec4o2_1fba2c13:

    # emi "But—"
    emi "Mas—"

# game/script-a3-emi.rpy:8791
translate pt_br a3ec4o2_a17d550f:

    # hi "Hey, it's not a problem. You don't want a knight on a white charger, right? Just promise me one thing, okay?"
    hi "Ei, não tem problema, Você não quer um cavaleiro montado num cavalo branco, certo? Só me prometa uma coisa, tá?"

# game/script-a3-emi.rpy:8796
translate pt_br a3ec4o2_cf45f9a1:

    # emi "What?"
    emi "O quê?"

# game/script-a3-emi.rpy:8798
translate pt_br a3ec4o2_448fc66c:

    # hi "Don't be angry at your mom, okay? She was just giving me some advice, that's all."
    hi "Não fique irritada com a sua mãe, tá bem? Ela só estava me dando uns conselhos, só isso."

# game/script-a3-emi.rpy:8803
translate pt_br a3ec4o2_639f61bf:

    # "Emi nods, hesitantly, like this simple idea is all that she can grab on to at this point. She's so terribly off-balance, but I can't do anything about that right now."
    "Emi acena, hesitantemente, como se essa simples ideia fosse tudo no que ela poderia se agarrar nesse ponto. Ela está tão terrivelmente desbalanceada, mas não há nada que eu possa fazer agora."

# game/script-a3-emi.rpy:8805
translate pt_br a3ec4o2_c3d21b44:

    # emi "Okay."
    emi "Tá bom."

# game/script-a3-emi.rpy:8807
translate pt_br a3ec4o2_9c103bef:

    # hi "See you tomorrow, okay? Running in the morning. Don't forget!"
    hi "Vejo você amanha, está bem? Correndo de manhã. Não esqueça!"

# game/script-a3-emi.rpy:8809
translate pt_br a3ec4o2_15ca8316:

    # "I can see that I've hurt Emi by deciding to leave. But there's nothing I can do for her as things stand, and I know that she's too stubborn to admit that she wants me to stick around."
    "Eu consigo ver que eu machuquei a Emi ao decidir em ir embora. Mas não há nada que eu possa fazer por ela do jeito que as coisas estão, e eu sei que ela é muito teimosa para admitir que me quer por perto."

# game/script-a3-emi.rpy:8811
translate pt_br a3ec4o2_07c94172:

    # "I watch various emotions cross Emi's face as she tries to process everything that's just happened."
    "Eu vejo varias emoções correrem pela face da Emi enquanto ela tenta processar tudo que acabou de acontecer."

# game/script-a3-emi.rpy:8816
translate pt_br a3ec4o2_aa3c270b:

    # "Shortly comes that calm look again, like last night, and that voice that tries so hard to sound careless."
    "Brevemente vem aquele olhar calmo de novo, como noite passada, e aquela voz que tenta tanto parecer que não se importa."

# game/script-a3-emi.rpy:8818
translate pt_br a3ec4o2_9bcce717:

    # emi "Sure, Hisao. See you around."
    emi "Claro, Hisao. Te vejo por aí."

# game/script-a3-emi.rpy:8820
translate pt_br a3ec4o2_9ee7d4bd:

    # "Both of us are unwilling to concede emotion at this point, and I'm having a hard time keeping up my facade, so I turn on my heel and walk out the door."
    "Ambos não queremos conceder emoções neste ponto, e eu estou tendo dificuldades em manter minha fachada, então eu me viro e saio pela porta."

# game/script-a3-emi.rpy:8827
translate pt_br a3ec4o2_b1eef769:

    # "I shut it behind me slowly, pausing for a moment as the latch catches, my hand on the doorknob."
    "Eu a fecho por de trás de mim bem devagar, pausando por um momento enquanto a trava se prende, minha mão na maçaneta."

# game/script-a3-emi.rpy:8829
translate pt_br a3ec4o2_a61b5ef6:

    # "Did I make the right decision just now? Should I have stayed and tried to work things out?"
    
    "Será que eu tomei a decisão correta agora? Será que eu devia ter ficado e tentado arrumar as coisas?"

# game/script-a3-emi.rpy:8831
translate pt_br a3ec4o2_49f57b9a:

    # "No, I decide. Not in front of her mother like that. In spite of everything, I'd rather keep Emi's mother insulated from the sort of anger that surfaced last night."
    "Não, eu decido. Não na frente da mãe dela daquele jeito. Apesar de tudo, eu prefiro manter a mãe da Emi longe desse tipo de raiva que surgiu noite passada."

# game/script-a3-emi.rpy:8833
translate pt_br a3ec4o2_68abcf7d:

    # "Even though she's probably used to it, some protective instinct wants me to keep Emi's image as a cheerful girl intact."
    "Mesmo que ela esteja provavelmente acostumada com isso, algum instinto protetor quer que eu mantenha a imagem da Emi como uma garota alegre intacta."

# game/script-a3-emi.rpy:8835
translate pt_br a3ec4o2_7472a3d5:

    # "With a start, I realize my hand is still resting on the knob. I take my hand away, put it in my pocket, and head down the slowly darkening street."
    "Com um começo, eu percebo que a minha mão ainda está segurando a maçaneta. Eu retiro minha mão, a coloco no meu bolso, e desço a rua que lentamente vai se escurecendo."

# game/script-a3-emi.rpy:8842
translate pt_br a3ec4o2_67e1da17:

    # "I let out a long breath."
    "Eu deixo escapar um longo suspiro."

# game/script-a3-emi.rpy:8844
translate pt_br a3ec4o2_6716e4b7:

    # "The wait until tomorrow morning comes isn't going to be easy."
    "A espera até amanhã de manhã não será nada fácil."

# game/script-a3-emi.rpy:8846
translate pt_br a3ec4o2_a8f6844f:

    # "In any case, I have to think on what to say to Emi. I must apologize, and I must get through to her somehow."
    "Em qualquer caso, eu preciso pensar no que irei dizer à Emi. Eu devo me desculpar, e devo chegar a ela de alguma forma."

# game/script-a3-emi.rpy:8848
translate pt_br a3ec4o2_f128fadb:

    # "On that account, something has been on my mind for most of the way back to my room."
    "Além do mais, algo esteve na minha cabeça na maior parte do caminho de volta para o meu quarto."

# game/script-a3-emi.rpy:8850
translate pt_br a3ec4o2_78cf2dc7:

    # "The letter of apology from Iwanako."
    "A carta de desculpas da Iwanako."

# game/script-a3-emi.rpy:8852
translate pt_br a3ec4o2_41a2ddb1:

    # "I was so concerned about my new life when I received it that I didn't even bother to really read it."
    "Eu estava tão preocupado com a minha vida nova que quando eu a recebi, eu nem mesmo me preocupei em lê-la."

# game/script-a3-emi.rpy:8854
translate pt_br a3ec4o2_9e02c33e:

    # "Now that I find myself in a similar position, my curiosity got rekindled. What did she want to let me know so badly?"
    "Agora que me encontro em uma posição similar, minha curiosidade foi reacendida. O que será que ela queria tanto que eu soubesse?"

# game/script-a3-emi.rpy:8856
translate pt_br a3ec4o2_39f5ef17:

    # "If nothing else, reading her thoughts might help me frame mine."
    "Se nada mais, ler os pensamentos dela podem me ajudar a montar os meus."
    

# game/script-a3-emi.rpy:8858
translate pt_br a3ec4o2_5d5daed8:

    # "I remember tossing it away. Damn, where did I throw that thing?"
    "Eu me lembro de jogar ela, droga, onde será que eu joguei isso?"

# game/script-a3-emi.rpy:8860
translate pt_br a3ec4o2_4c3c4c68:

    # "I check under my desk. That turns up nothing, so I look for harder-to-reach, more unlikely locations."
    "Eu verifico embaixo da minha escrivaninha. Resulta em nada, então eu procuro por lugares mais improváveis e de difícil acesso."

# game/script-a3-emi.rpy:8862
translate pt_br a3ec4o2_ce617998:

    # "…"
    "…"

# game/script-a3-emi.rpy:8864
translate pt_br a3ec4o2_80a1dc21:

    # "Well, now I know where that lost sock went, at least."
    "Bem, agora eu sei para onde aquela meia perdida foi, pelo menos."

# game/script-a3-emi.rpy:8866
translate pt_br a3ec4o2_91d1d7a1:

    # "Still no letter, though."
    "Sem carta, no entanto."

# game/script-a3-emi.rpy:8868
translate pt_br a3ec4o2_d78a5abd:

    # "It's when I try sweeping my arm under my nightstand that I feel something crinkly jammed between it and the wall."
    "É quando eu tento varrer a minha cabeceira com meu braço que eu sinto algo retorcido esmagado entre ela e a parede."

# game/script-a3-emi.rpy:8870
translate pt_br a3ec4o2_1d2e07d2:

    # "Grunting a little with the effort, I reach for my prize and soon manage to bring it into the light."
    "Grunhindo com um certo esforço, eu alcanço o meu prêmio e logo a trago para a luz."

# game/script-a3-emi.rpy:8872
translate pt_br a3ec4o2_f978f6d6:

    # "Bingo."
    "Bingo."

# game/script-a3-emi.rpy:8879
translate pt_br a3ec4o2_169d14d8:

    # "I sit at my desk and spread the crumpled paper open. A flick turns on the table light."
    "Eu sento na minha escrivaninha e abro o papel todo amassado. Um estalido liga a luz da mesa."

# game/script-a3-emi.rpy:8881
translate pt_br a3ec4o2_c49de01b:

    # "Skipping past the empty pleasantries, I look for the point where I stopped reading. Ah, here it is."
    "Ignorando a parte das gentilezas vazias, eu procuro pelo ponto de onde eu tinha parado de ler. Ah, aqui está."

# game/script-a3-emi.rpy:8887
translate pt_br a3ec4o2_5eb5fbc8:

    # "Giving up on happiness…"
    "Desistindo da felicidade…"

# game/script-a3-emi.rpy:8889
translate pt_br a3ec4o2_cba0877c:

    # "This sounds unpleasantly familiar."
    "Isso soa desagradavelmente familiar."

# game/script-a3-emi.rpy:8897
translate pt_br a3ec4o2_920f684a:

    # "After finishing reading the letter I smooth it out carefully and set it aside on my desk."
    "Depois de terminar de ler a carta eu desamasso ela cuidadosamente e coloco de lado na minha mesa."

# game/script-a3-emi.rpy:8901
translate pt_br a3ec4o2_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:8904
translate pt_br a3ec4o2_00283d1a:

    # n "{vspace=90}Thank you, Iwanako. I wanted to answer 'yes' to your question on that snowy winter day, but I never got to."
    n "{vspace=90}Obrigado, Iwanako. Eu gostaria de dizer “sim” para a sua pergunta naquele dia de neve no inverno, mas eu nunca consegui."

# game/script-a3-emi.rpy:8906
translate pt_br a3ec4o2_4e528fd9:

    # n "By the time we met again, it was too late."
    n "E até que nos encontrássemos de novo, já era tarde demais."

# game/script-a3-emi.rpy:8908
translate pt_br a3ec4o2_6e9d2108:

    # n "Or so I thought. What would have happened if I had behaved differently, back in that dismally sterile hospital room?"
    n "Ou pelo menos era o que eu pensava. O que será que poderia ter acontecido se eu tivesse agido de maneira diferente, naquele quartinho estéril de hospital?"

# game/script-a3-emi.rpy:8910
translate pt_br a3ec4o2_9fa0f1ed:

    # n "I'm sorry. There's no point in wondering now, but there's no point in trying to forget either."
    n "Me desculpe. Mas não há porque de pensar nisso agora, mas também não há porque de tentar esquecer também."

# game/script-a3-emi.rpy:8912
translate pt_br a3ec4o2_90e85921:

    # n "I am who I am because of all that happened to me and all I look forward to experience. Present, future, and past."
    n "Eu sou quem sou por causa de tudo que aconteceu comigo e por tudo pelo que anseio experienciar. Presente, futuro, e passado."

# game/script-a3-emi.rpy:8916
translate pt_br a3ec4o2_41c2efed:

    # n "{vspace=60}And the past may just have taught me an important lesson now."
    n "{vspace=60}E o passado pode ter acabada de me ensinar uma lição importante agora."

# game/script-a3-emi.rpy:8920
translate pt_br a3ec4o2_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:8926
translate pt_br a3ec5o1_82832ea0:

    # "I'm not sure I like the idea of airing private matters to the Student Council."
    "Não tenho certeza se gosto da ideia de falar sobre assuntos privados ao Conselho Estudantil."

# game/script-a3-emi.rpy:8928
translate pt_br a3ec5o1_411b365a:

    # hi "Nothing major."
    hi "Nada grave."

# game/script-a3-emi.rpy:8933
translate pt_br a3ec5o1_3349a56b:

    # mi "Hicchan, lying is a terrible thing to do~!"
    mi "Hisaozinho, mentir é uma coisa feia de se fazer~!"

# game/script-a3-emi.rpy:8935
translate pt_br a3ec5o1_10006c17:

    # "She's not buying it."
    "Ela não tá acreditando."

# game/script-a3-emi.rpy:8937
translate pt_br a3ec5o1_afcd1269:

    # "Okay, give her something, but not too much."
    "Está bem, dê a ela alguma coisa, mas não muito."

# game/script-a3-emi.rpy:8939
translate pt_br a3ec5o1_9dfb4357:

    # hi "We had a disagreement and haven't resolved it yet."
    hi "Nós tivemos um desentendimento e ainda não o resolvemos ainda."

# game/script-a3-emi.rpy:8944
translate pt_br a3ec5o1_03cffce5:

    # mi "Oh? Why not?"
    mi "Oh? Por que não?"

# game/script-a3-emi.rpy:8946
translate pt_br a3ec5o1_c548e197:

    # hi "Because - look, I don't need to talk about this, okay?"
    hi "Porque - olha, eu não preciso falar sobre isso, tá certo?"

# game/script-a3-emi.rpy:8948
translate pt_br a3ec5o1_76f21957:

    # hi "It's not a big deal, okay? I'm fine."
    hi "Não é nada demais, ok? Eu estou bem."

# game/script-a3-emi.rpy:8953
translate pt_br a3ec5o1_718309a7:

    # mi "And Emi? Is she fine too, Hicchan?"
    mi "E a Emi? Ela está bem também, Hisaozinho?"

# game/script-a3-emi.rpy:8957
translate pt_br a3ec5o1_e4cbdb66:

    # "Misha's voice has taken on a decidedly serious edge. This is ridiculous."
    "A voz da Misha toma um tom decididamente sério agora. Isso é ridículo."

# game/script-a3-emi.rpy:8959
translate pt_br a3ec5o1_dc2e1ded:

    # hi "I don't know, okay? I haven't asked. Things are complicated right now."
    hi "Eu não sei, tá? Eu não perguntei. As coisas andam complicadas."

# game/script-a3-emi.rpy:8964
translate pt_br a3ec5o1_77c0a540:

    # mi "What kind of man are you? Things get a little rough and you're going to hide from them?"
    mi "Que tipo de homem é você? As coisas ficam um pouco dificeis e você se esconde delas?"

# game/script-a3-emi.rpy:8968
translate pt_br a3ec5o1_987d6d6c:

    # "Misha's sudden retort catches me completely off guard."
    
    "A réplica repentina de Misha me pega completamente desprevenido."

# game/script-a3-emi.rpy:8973
translate pt_br a3ec5o1_8b3790bc:

    # mi "Shicchan would call that a cowardly act, and she'd be right too!"
    mi "Shizunezinha iria chamar isso de um ato de covardia, e ela estaria certa também!"

# game/script-a3-emi.rpy:8975
translate pt_br a3ec5o1_668fc46b:

    # mi "You two were close! Happy together! And you're just going to roll over and die without a fight?"
    mi "Vocês dois eram tão próximos! Felizes juntos! E você simplesmente irá se virar e morrer sem nem ter lutado?"

# game/script-a3-emi.rpy:8977
translate pt_br a3ec5o1_ee0c1971:

    # mi "You should be willing to fight for your girlfriend, Hisao!"
    mi "Você deveria estar disposto a lutar por sua namorada, Hisao!"

# game/script-a3-emi.rpy:8979
translate pt_br a3ec5o1_ae4418a5:

    # "It seems that Misha is channeling Shizune at the moment. It wouldn't surprise me to find out that Shizune gave her a script to follow based on my answer."
    "Parece que a Misha está canalizando a Shizune neste momento. Eu não ficaria surpreso em descobrir que a Shizune deu a ela um script para seguir conforme a minha resposta."

# game/script-a3-emi.rpy:8981
translate pt_br a3ec5o1_9e103630:

    # "Misha points an imperious arm at the classroom door."
    "Misha aponta um braço imperioso para a porta da sala de aula."
    

# game/script-a3-emi.rpy:8986
translate pt_br a3ec5o1_a9759b73:

    # mi "Now you get out of the classroom and patch things up!"
    mi "Agora saia daqui e vá consertar as coisas!"

# game/script-a3-emi.rpy:8988
translate pt_br a3ec5o1_88334556:

    # hi "Um, we've still got afternoon classes…"
    hi "Ahm, nós ainda temos aula à tarde…"

# game/script-a3-emi.rpy:8990
translate pt_br a3ec5o1_9b1c04f7:

    # "This doesn't seem to dissuade Misha."
    "Isso não parece dissuadir a Misha."
    

# game/script-a3-emi.rpy:8995
translate pt_br a3ec5o1_a5e37d5e:

    # mi "Then after class! You'd better do it, Hicchan! It's important that you don't leave things like this!"
    mi "Então depois da aula! É melhor você ir, Hisaozinho! É importante que você não deixe as coisas assim!"

# game/script-a3-emi.rpy:8997
translate pt_br a3ec5o1_7df9d21b:

    # hi "Why?"
    hi "Por quê?"

# game/script-a3-emi.rpy:9002
translate pt_br a3ec5o1_1fc561aa:

    # "Misha regards me as one would regard an animal's droppings."
    "Misha me trata de um modo como uma pessoa fosse tratar fezes de animais."

# game/script-a3-emi.rpy:9004
translate pt_br a3ec5o1_0b7b82eb:

    # mi "Didn't you care about her, Hisao? That's important, isn't it?"
    mi "Você não se importa com ela, Hisao? Isso é importante, não é?"

# game/script-a3-emi.rpy:9006
translate pt_br a3ec5o1_76557802:

    # "Huh. She's right."
    "Huh. Ela está certa."

# game/script-a3-emi.rpy:9008
translate pt_br a3ec5o1_d7e9e336:

    # "I did… I do care about her."
    "Sim… eu me importo com ela."

# game/script-a3-emi.rpy:9010
translate pt_br a3ec5o1_fee0e287:

    # "Don't I?"
    "Não me importo?"

# game/script-a3-emi.rpy:9012
translate pt_br a3ec5o1_4db780c5:

    # hi "Okay. I'll see her after class."
    hi "Tá bom. Vou vê-la depois da aula."

# game/script-a3-emi.rpy:9017
translate pt_br a3ec5o1_26925f6e:

    # mi "Great~! I'll let Shicchan know you're okay, then~!"
    mi "Ótimo~! Eu direi a Shizunezinha que você está bem, então~!"

# game/script-a3-emi.rpy:9019
translate pt_br a3ec5o1_8d774db6:

    # "The lilt returns. I guess that means that Misha isn't angry at me any more."
    "A melodia cadenciada volta. Eu acho que a Misha não está mais irritada comigo."

# game/script-a3-emi.rpy:9024
translate pt_br a3ec5o1_8e88a84d:

    # "She waves and disappears down the hallway, and I eat my lunch."
    "Ela acena e desaparece pelo corredor, e eu como meu almoço."

# game/script-a3-emi.rpy:9029
translate pt_br a3ec5o1_60fa12e0:

    # "While afternoon classes draw to a close, I prepare myself for the task ahead."
    "Enquanto as aulas da tarde chegam a um término, eu me preparo para a tarefa à seguir."

# game/script-a3-emi.rpy:9031
translate pt_br a3ec5o1_0d050ce5:

    # "I have to see Emi; Misha was at least correct about that. Leaving the question of Emi and me an open issue won't work."
    "Eu preciso ver a Emi; Misha estava ao menos correta sobre isso. Deixar eu e Emi com um assunto pendente não vai dar certo."

# game/script-a3-emi.rpy:9033
translate pt_br a3ec5o1_ac116323:

    # "At the very least, I need to apologize for what I said."
    "E no mínimo, eu terei que me desculpar pelo que disse."

# game/script-a3-emi.rpy:9035
translate pt_br a3ec5o1_7eee68ea:

    # "I consider going to her room to find her, but she's probably still at the track."
    "Eu considero ir ao quarto dela para encontrá-la, mas ela provavelmente ainda está na pista."

# game/script-a3-emi.rpy:9040
translate pt_br a3ec5o1_206b90a8:

    # "The steps out of the main building and down the path to the track make me feel like a doomed man."
    "Os degraus afora do prédio principal e descendo até o caminho da pista me fazem sentir como um homem condenado."

# game/script-a3-emi.rpy:9042
translate pt_br a3ec5o1_a98979d3:

    # "I have a twisting, horrible feeling in my gut that this is all going to go horribly wrong, that I'm not going to accomplish anything."
    "Eu tenho uma sensação, horrível na minha barriga que isso tudo irá acabar horrivelmente errado, que eu não vá conseguir fazer nada."

# game/script-a3-emi.rpy:9044
translate pt_br a3ec5o1_4f2b9f14:

    # "Except for maybe driving the final nail in the coffin of whatever it was Emi and I had."
    "Exceto talvez em pregar o último prego no caixão de tudo aquilo que eu e Emi tivemos uma vez."

# game/script-a3-emi.rpy:9051
translate pt_br a3ec5o1_35bce254:

    # "There she is, just as expected, running laps around the track after everyone else has gone to shower and dinner."
    "Lá está ela, exatamente como o esperado, correndo voltas ao redor da pista depois que todo mundo já foi tomar banho e jantar."

# game/script-a3-emi.rpy:9053
translate pt_br a3ec5o1_cf62423b:

    # "I don't wave, or even make my presence known. I just sit down on the bleachers and watch her run her laps."
    "Eu não aceno, e nem faço minha presença ser percebida. Eu só sento na arquibancada e assisto a ela correr suas voltas."

# game/script-a3-emi.rpy:9063
translate pt_br a3ec5o1_935c3fb6:

    # "It takes her a few trips around the track before she notices me, after which she skids to a stop, eyes wide in surprise."
    "Leva algumas voltas ao redor da pista para que ela me perceba, após o qual ela derrapa até parar, com os olhos arregalados de surpresa."

# game/script-a3-emi.rpy:9071
translate pt_br a3ec5o1_cbaf21ee:

    # "Surprise is quickly masked by anger, which in turn fades behind a mask that I already know is impenetrable."
    "Surpresa é rapidamente mascarada por raiva, que de quebra se esconde atrás de uma máscara que eu já sei que é impenetrável."

# game/script-a3-emi.rpy:9073
translate pt_br a3ec5o1_04e355f0:

    # emi "What are you doing here?"
    emi "O que você está fazendo aqui?"

# game/script-a3-emi.rpy:9075
translate pt_br a3ec5o1_b96389c2:

    # "Not quite the response I'd hoped for, but at this point I don't have much of a choice."
    "Não muito o tipo de resposta que eu esperava, mas nesse ponto eu não tenho muita opção."

# game/script-a3-emi.rpy:9077
translate pt_br a3ec5o1_d136b5d5:

    # hi "I wanted to apologize for what I said the other day."
    hi "Eu queria me desculpar pelo que eu disse no outro dia."

# game/script-a3-emi.rpy:9082
translate pt_br a3ec5o1_5a95d2b2:

    # emi "The other day?"
    emi "O outro dia?"

# game/script-a3-emi.rpy:9087
translate pt_br a3ec5o1_443ec210:

    # "She laughs, a curt exclamation of disbelief."
    "Ela ri, uma curta exclamação de descrença."

# game/script-a3-emi.rpy:9094
translate pt_br a3ec5o1_d7115547:

    # emi "It's been almost a week, Hisao."
    emi "Já se passou quase uma semana, Hisao."

# game/script-a3-emi.rpy:9096
translate pt_br a3ec5o1_522711c7:

    # hi "Yeah, well… better late than never, right?"
    hi "É, bem… antes tarde do que nunca, certo?"

# game/script-a3-emi.rpy:9101
translate pt_br a3ec5o1_3a635476:

    # "Emi crosses her arms and stares at me coolly, as if sizing me up. Finally, she nods."
    "Emi cruza os braços e me olha friamente, como se estivesse me avaliando. Finalmente, ela acena."

# game/script-a3-emi.rpy:9106
translate pt_br a3ec5o1_93ad327b:

    # emi "Hmmph. I suppose you're right. Water under the bridge, then. I forgive you."
    emi "Hmmph. Eu acho que você está certo. Águas passadas, então. Eu te perdoo."

# game/script-a3-emi.rpy:9111
translate pt_br a3ec5o1_254b33af:

    # emi "Is that all?"
    emi "Isso é tudo?"

# game/script-a3-emi.rpy:9120
translate pt_br a3ec5o1_579d89f8:

    # "Her almost impatient question catches me so off-guard that she's halfway down the track before I think to shout after her."
    "A sua quase impaciência na pergunta me pega tão desprevenido que ela já está na metade do caminho voltando à pista antes que eu possa berrar para ela."

# game/script-a3-emi.rpy:9122
translate pt_br a3ec5o1_553a5543:

    # hi "No, wait!"
    hi "Não, espera!"

# game/script-a3-emi.rpy:9132
translate pt_br a3ec5o1_1ebe26a3:

    # "Emi stops, turns, and walks back to me, breathing a little heavily and looking annoyed at my interruption."
    "Emi para, se vira, e caminha em direção a mim, respirando um pouco pesado e parecendo irritada com a minha interrupção."

# game/script-a3-emi.rpy:9134
translate pt_br a3ec5o1_cf45f9a1:

    # emi "What?"
    emi "O quê?"

# game/script-a3-emi.rpy:9136
translate pt_br a3ec5o1_95b4b928:

    # "Okay, I need to make this right, somehow. I have to know where I stand, maybe patch things up."
    "Ok, eu preciso fazer isso certo, de alguma maneira. Eu preciso saber aonde estou, talvez resolver as coisas."

# game/script-a3-emi.rpy:9138
translate pt_br a3ec5o1_f373f499:

    # hi "Can you at least sit down?"
    hi "Você pode ao menos se sentar?"

# game/script-a3-emi.rpy:9143
translate pt_br a3ec5o1_6aebea97:

    # emi "I think we're okay talking here."
    emi "Acho que estamos bem conversando assim."

# game/script-a3-emi.rpy:9145
translate pt_br a3ec5o1_64907b4f:

    # hi "Fine, sure. Look, about us…"
    hi "Está bem, certo. Veja, sobre nós…"

# game/script-a3-emi.rpy:9147
translate pt_br a3ec5o1_61d64386:

    # "I pause, trying to think of a good way to phrase what I'm about to say."
    "Eu pauso, pensando em uma boa maneira de frasear o que estou prestes a dizer."

# game/script-a3-emi.rpy:9149
translate pt_br a3ec5o1_690046cd:

    # "But before I can launch into an impassioned plea for giving me another chance, Emi's already spoken."
    "Mas antes que eu possa lançar um apelo apaixonado pedindo por outra chance, Emi já havia falado."

# game/script-a3-emi.rpy:9154
translate pt_br a3ec5o1_313be44c:

    # emi "There's no more us, Hisao."
    emi "Não existe mais nós, Hisao."

# game/script-a3-emi.rpy:9156
translate pt_br a3ec5o1_f5743db9:

    # hi "Why not?"
    hi "Por que não?"

# game/script-a3-emi.rpy:9161
translate pt_br a3ec5o1_6a8bfaf3:

    # emi "We're just not right for each other."
    emi "Nós não somos certos um para o outro."

# game/script-a3-emi.rpy:9163
translate pt_br a3ec5o1_a840c44d:

    # "She delivers this outrageous statement without even looking in my eyes."
    "Ela dá essa declaração ultrajante sem nem olhar diretamente nos meus olhos."

# game/script-a3-emi.rpy:9165
translate pt_br a3ec5o1_ae4e0c83:

    # hi "I don't believe you! We're great with one another!"
    hi "Eu não acredito em você! Nós somos ótimos um com o outro."

# game/script-a3-emi.rpy:9170
translate pt_br a3ec5o1_eae0249d:

    # emi "Says the guy apologizing for getting thrown out of my house last week."
    emi "Diz o cara se desculpando por ser expulso da minha casa semana passada."

# game/script-a3-emi.rpy:9172
translate pt_br a3ec5o1_9370a48e:

    # hi "It was a fight! I said something really, incredibly stupid and apologized for it!"
    hi "Era uma briga! Eu disse uma coisa realmente, incrivelmente estúpida e me desculpei por isso!"

# game/script-a3-emi.rpy:9177
translate pt_br a3ec5o1_835baed1:

    # emi "And how many times had we already discussed the problem that started the fight? How many times had I told you that there was a set boundary that I wouldn't cross, and how many times did you keep trying to cross it?"
    emi "E quantas vezes nós já discutimos sobre o problema que causou essa briga? Quantas vezes eu te disse que havia um certo limite que eu não atravessaria, e quantas vezes você ficou tentando atravessar?"

# game/script-a3-emi.rpy:9179
translate pt_br a3ec5o1_23a95c95:

    # hi "Because your boundary was stupid!"
    hi "Porque seu limite era idiota!"

# game/script-a3-emi.rpy:9184
translate pt_br a3ec5o1_8e8a9e5c:

    # "Emi rolls her eyes, folds her arm across her chest, and cocks her head to the side."
    "Emi rola seus olhos, cruza seus braços no peito, e inclina a cabeça para o lado."

# game/script-a3-emi.rpy:9186
translate pt_br a3ec5o1_1fab5a93:

    # emi "Do you see this, Hisao? This is why we're not right for one another!"
    emi "Você vê isso, Hisao? É por isso que não somos bons um para o outro."

# game/script-a3-emi.rpy:9188
translate pt_br a3ec5o1_58117965:

    # "Her voice softens a little, and she reaches out to stroke my cheek."
    "Sua voz suaviza um pouco, ela alcança e toca na minha bochecha."

# game/script-a3-emi.rpy:9193
translate pt_br a3ec5o1_4a2a681e:

    # emi "You're a good guy, but we're not going to work."
    emi "Você é um cara legal, mas nós não vamos dar certo."

# game/script-a3-emi.rpy:9195
translate pt_br a3ec5o1_54709eb8:

    # "With a horrible lurching feeling, I realize that she's been practicing this. Maybe every day since I left her house."
    "Com um sentimento horrível, eu percebo que ela vem praticando isso. Talvez todo dia desde que eu saí da casa dela."

# game/script-a3-emi.rpy:9197
translate pt_br a3ec5o1_74a4655d:

    # "Even the cheek-stroke seems rehearsed, like something out of a movie."
    "Até a coisa na minha bochecha parece imitado, como algo saído de um filme."

# game/script-a3-emi.rpy:9199
translate pt_br a3ec5o1_a514d963:

    # "She never intended to give me another chance."
    "Ela nunca teve a intenção de me dar uma outra chance."

# game/script-a3-emi.rpy:9201
translate pt_br a3ec5o1_78decb1f:

    # "Hell, she probably would have been fine with never seeing me again."
    "Inferno, ela provavelmente estava de bem com a idéia de nunca mais me ver de novo."

# game/script-a3-emi.rpy:9203
translate pt_br a3ec5o1_e184148b:

    # hi "So that's it, then? Nothing else to say but 'Gee, it was fun while it lasted, but so long?'"
    hi "Então, é isso? Nada mais a dizer alem de um “Pô, foi bom enquanto durou, mas adeus?”"

# game/script-a3-emi.rpy:9208
translate pt_br a3ec5o1_641b6051:

    # "This actually seems to amuse Emi far more than I wanted it to. She gives a rather morbid sounding chuckle."
    "Isso na verdade parece divertir a Emi mais do que eu queria. Ela dá uma uma risada soando um tanto mórbida."

# game/script-a3-emi.rpy:9210
translate pt_br a3ec5o1_2cab9535:

    # emi "That's how I've lived my life, Hisao. You should know that by now."
    emi "É assim que eu tenho vivivo minha vida, Hisao. Você deveria saber disso até agora."

# game/script-a3-emi.rpy:9215
translate pt_br a3ec5o1_acfd39bc:

    # emi "And it was fun."
    emi "E foi divertido."

# game/script-a3-emi.rpy:9217
translate pt_br a3ec5o1_792868d5:

    # "A sad smile. She shivers slightly, and the smile vanishes."
    "Um sorriso triste. Ela treme ligeiramente, e o sorriso desaparece."

# game/script-a3-emi.rpy:9222
translate pt_br a3ec5o1_81ad0636:

    # emi "But it's over now. It's for the best."
    emi "Mas está acabado agora. É para o melhor."

# game/script-a3-emi.rpy:9224
translate pt_br a3ec5o1_8490a4d8:

    # "I want to yell, to scream at her. Make her see reason, that this is stupid, the whole act. That she's just afraid of me, afraid of what being close to someone means."
    "Eu quero gritar, berrar para ela. Fazer ela ver como, isso é tão estúpido, toda essa mentira. Ela só está com medo de mim, medo de saber o que é estar perto de alguém."

# game/script-a3-emi.rpy:9226
translate pt_br a3ec5o1_97acbdc7:

    # "I want to tell her that I love her and that I can't just give up on her at the drop of a hat."
    "Eu quero dizer à ela como eu a amo e que eu não posso simplesmente desistir de tudo."

# game/script-a3-emi.rpy:9228
translate pt_br a3ec5o1_666122cb:

    # "Except… there's no point. She's made up her mind. We're done."
    "Exceto… não tem jeito. Ela já tomou sua decisão. Estamos acabados."

# game/script-a3-emi.rpy:9230
translate pt_br a3ec5o1_982f52e4:

    # hi "Fine."
    hi "Certo."

# game/script-a3-emi.rpy:9235
translate pt_br a3ec5o1_6f7d71c6:

    # "Emi nods, satisfied. I want to hit something."
    "Emi acena, satisfeita. Eu quero bater em alguma coisa."

# game/script-a3-emi.rpy:9237
translate pt_br a3ec5o1_481d5cf5:

    # emi "Good."
    emi "Ótimo."
    

# game/script-a3-emi.rpy:9242
translate pt_br a3ec5o1_2e42a9bd:

    # "She brightens with a false cheeriness."
    "Ela se ilumina com uma falsa jovialidade."

# game/script-a3-emi.rpy:9244
translate pt_br a3ec5o1_d5427a34:

    # emi "See you around, Hisao."
    emi "Vejo você por aí, Hisao."

# game/script-a3-emi.rpy:9246
translate pt_br a3ec5o1_4e0987bf:

    # hi "No you won't. You won't even try."
    hi "Não você não vai. Você não vai nem tentar."

# game/script-a3-emi.rpy:9255
translate pt_br a3ec5o1_db767434:

    # "She shrugs, as if to say 'Have it your way,' and turns her back on me once more, quickly accelerating around the curve of the track."
    "Ela dá de ombros, como se quisesse dizer “Como você quiser,” e se vira de costas mais uma vez, rápidamente acelerando ao redor da curva da pista."

# game/script-a3-emi.rpy:9257
translate pt_br a3ec5o1_a6699bf2:

    # "I feel numb. This is it. The end of the road for us, whatever that was. Closure, at least."
    "Eu me sinto paralisado. É isso. O fim da linha para nós, o que quer que seja. Encerramento, ao menos."

# game/script-a3-emi.rpy:9259
translate pt_br a3ec5o1_93690a9e:

    # "Emi rounds the track again without sparing me a second glance. She's running much faster now, and I can't help but think of that first run together."
    "Emi dá uma volta na pista sem nem me olhar de relance uma segunda vez. Ela está correndo muito mais rápido agora, eu não consigo pensar em nada senão aquela primeira corrida juntos."
    

# game/script-a3-emi.rpy:9261
translate pt_br a3ec5o1_f5c23dad:

    # "I ran to catch you, to try to prove I wasn't as weak as I knew I was. But it ended badly for me, didn't it?"
    "Eu corri para alcançar você, para tentar provar que eu não era tão fraco quanto eu achei que fosse. Mas isso acabou terrivelmente mal para mim, não foi?"

# game/script-a3-emi.rpy:9263
translate pt_br a3ec5o1_c35115bf:

    # "And now, you're off running too fast for me again, and I have the choice to run after you again."
    "E agora, você está correndo rápido demais para mim de novo, e eu tenho a escolha de correr atrás de você de novo."

# game/script-a3-emi.rpy:9265
translate pt_br a3ec5o1_46b3af49:

    # "But I won't. Not this time. You'd never let me catch you."
    "Mas eu não vou. Não dessa vez. Você nunca iria me deixar alcança-la."

# game/script-a3-emi.rpy:9272
translate pt_br a3ec5o1_810668f8:

    # "I don't even notice walking away from the track, or walking into my room, or pulling a book out of my bag to read."
    
    "Eu nem percebo eu indo embora da pista, ou caminhando até meu quarto, ou puxando um livro da minha mochila para ler."

# game/script-a3-emi.rpy:9274
translate pt_br a3ec5o1_8ce04333:

    # "Just before bed, I reset my alarm. Emi and I have had our final encounter."
    "Logo antes de dormir, eu reseto meu alarme. Emi e eu tivemos nosso encontro final."

# game/script-a3-emi.rpy:9279
translate pt_br a3ec5o1_9f569e61:

    # "We don't speak again after that."
    "Não voltamos a nos falar depois disso."

# game/script-a3-emi.rpy:9284
translate pt_br a3ec5o2_6270ef53:

    # "Well, I suppose someone else knowing about my problem can't hurt. Heck, maybe Misha can even offer some advice."
    "Bem, eu acho que alguém saber do meu problema não deve doer. Que coisa, talvez a Misha possa até me dar uma ajuda."

# game/script-a3-emi.rpy:9286
translate pt_br a3ec5o2_c745f9e1:

    # hi "We had a fight at her house."
    hi "Nós tivemos uma briga na casa dela."
    

# game/script-a3-emi.rpy:9288
translate pt_br a3ec5o2_5baa6e55:

    # hi "I keep trying to get close to her, and she won't let me get close, and…"
    hi "Eu tentei me aproximar dela, e ela não deixava eu me aproximar, e…"

# game/script-a3-emi.rpy:9290
translate pt_br a3ec5o2_330a09c9:

    # hi "I said something stupid, and she threw me out."
    hi "Eu disse uma coisa idiota, e ela me expulsou de casa."

# game/script-a3-emi.rpy:9295
translate pt_br a3ec5o2_55f6f24e:

    # mi "Have you talked to her since then?"
    mi "Você já falou com ela desde aquilo?"

# game/script-a3-emi.rpy:9297
translate pt_br a3ec5o2_072256c5:

    # "Misha looks genuinely concerned. I'm surprised, as I'd almost expected her to drop the subject after finding out what the trouble was."
    "Misha parece genuinamente preocupada. Estou surpreso, como se eu estivesse esperando que ela fosse mudar de assunto assim que ela descobrisse o que era o problema."

# game/script-a3-emi.rpy:9299
translate pt_br a3ec5o2_deaf3471:

    # "Even more surprising is how quickly I find myself spilling my guts to her."
    "Ainda mais surpreso é o quão rápido eu me encontro dizendo tudo para ela."

# game/script-a3-emi.rpy:9301
translate pt_br a3ec5o2_f7e46617:

    # hi "No, I haven't. I just can't bring myself to face her after that."
    hi "Não, eu não falei. Eu simplesmente não consigo encará-la depois daquilo."

# game/script-a3-emi.rpy:9303
translate pt_br a3ec5o2_d213830b:

    # hi "I made a complete fool of myself, and she probably hates me now anyway. Especially since I haven't seen her since then."
    hi "Eu me fiz de um completo babaca, e ela provavelmente me odeia agora de qualquer jeito. Especialmente já que eu não vi ela desde então."

# game/script-a3-emi.rpy:9308
translate pt_br a3ec5o2_7570452f:

    # mi "You're pretty slow, Hicchan."
    mi "Você é bem lento, Hisaozinho."
    

# game/script-a3-emi.rpy:9312
translate pt_br a3ec5o2_56bf7896:

    # "This doesn't sound like advice."
    "Isso não me parece com um conselho."

# game/script-a3-emi.rpy:9314
translate pt_br a3ec5o2_0f638bea:

    # hi "Huh?"
    hi "Huh?"

# game/script-a3-emi.rpy:9319
translate pt_br a3ec5o2_944de350:

    # "Misha places her hands on her hips and launches into a speech that would sound more plausible coming from Shizune."
    "Misha coloca suas mãos no quadríl e começa um discurso que soaria mais plausível vindo da Shizune."

# game/script-a3-emi.rpy:9321
translate pt_br a3ec5o2_73c61884:

    # mi "The solution to your problem is simple! You have to go and apologize to her! Leaving things like this will just make things worse!"
    mi "A solução para o seu problema é simples! Você precisa ir e se desculpar com ela! Deixar as coisas assim só vai piorar tudo!"

# game/script-a3-emi.rpy:9323
translate pt_br a3ec5o2_88d063bd:

    # mi "You can't know that she hates you now unless she tells you! Otherwise, there's no evidence that what you fear is true!"
    mi "Você não tem como saber se ela te odeia a não ser que ela te diga! Senão, não há evidência de que o que você teme seja verdade!"

# game/script-a3-emi.rpy:9325
translate pt_br a3ec5o2_ca2425d0:

    # mi "And if you really care about her, shouldn't you be worried about how she's taking all this?"
    mi "E se você realmente se importa com ela, você não devia se preocupar em como ela está passando por tudo isso?"

# game/script-a3-emi.rpy:9329
translate pt_br a3ec5o2_365b649a:

    # "With a sudden start, I realize that she's right. I've kept waking up to an early alarm because part of me wants to meet Emi at the track for our runs."
    "Com um começo súbito, eu percebo que ela está certa. Eu fiquei acordando mais cedo com um alarme porque parte de mim quer que eu me encontre com a Emi na pista para nossas corridas."

# game/script-a3-emi.rpy:9331
translate pt_br a3ec5o2_0c8cbd64:

    # "I've kept running, because I know that Emi would worry about me if I didn't stay healthy."
    "Eu continuei correndo, porque eu sei que Emi iria se preocupar comigo se eu não ficasse saudável."

# game/script-a3-emi.rpy:9333
translate pt_br a3ec5o2_7aa84486:

    # "When I went on the roof yesterday, I was half-hoping that she would be up there, and felt disappointed when she wasn't."
    "Quando eu fui ao terraço ontem, eu estava meio que esperando que ela fosse estar lá em cima, e fiquei desapontado quando ela não estava."

# game/script-a3-emi.rpy:9335
translate pt_br a3ec5o2_44383294:

    # hi "I'm an idiot."
    hi "Eu sou um idiota."

# game/script-a3-emi.rpy:9340
translate pt_br a3ec5o2_28d2e568:

    # mi "Kinda, Hicchan~!"
    mi "Tipo isso, Hisaozinho~!"

# game/script-a3-emi.rpy:9345
translate pt_br a3ec5o2_ebe286f7:

    # mi "So~! Go and apologize to her as soon as you can, okay~?"
    mi "Então~! Vá e se desculpe com ela assim que puder, okay~?"

# game/script-a3-emi.rpy:9347
translate pt_br a3ec5o2_499e3303:

    # "I open my mouth to say that I'll do it right away, but the lunch bell rings and I realize that I still have afternoon classes to attend."
    "Eu abro a minha boca para dizer que eu iria fazer isso agora mesmo, mas o sinal toca e eu percebo que eu tenho as aulas da tarde para ir ainda."

# game/script-a3-emi.rpy:9349
translate pt_br a3ec5o2_4e107032:

    # hi "First thing after class is over, I'll go see her. I promise."
    hi "Primeira coisa depois que a aula acabar, eu vou ver ela. Eu prometo."

# game/script-a3-emi.rpy:9351
translate pt_br a3ec5o2_2525e2b1:

    # hi "And uh, thanks for the advice, I guess."
    hi "E uh, obrigado pelo conselho, eu acho."

# game/script-a3-emi.rpy:9356
translate pt_br a3ec5o2_b0e33fa9:

    # "Misha beams at me, as if I were a child that had just learned his ABCs."
    "Misha sorri para mim, como se eu fosse uma criança que acabou de aprender o ABC."

# game/script-a3-emi.rpy:9358
translate pt_br a3ec5o2_0f592a23:

    # mi "Good! I'll let Shicchan know that you're okay, then~!"
    mi "Ótimo! Eu irei dizer à Shizunezinha que você está bem, então~!"

# game/script-a3-emi.rpy:9360
translate pt_br a3ec5o2_b9f050c2:

    # hi "Er, yeah. You do that."
    hi "Er, sim. Faça isso."

# game/script-a3-emi.rpy:9365
translate pt_br a3ec5o2_9d9d0b68:

    # "With a wave (and completely disregarding the fact that people are starting to trickle back into the classroom, as opposed to out of it), Misha departs the classroom."
    "Com um aceno (e completamente ignorando o fato de que as pessoas estão começando a voltar, ao invés de sair), Misha sai da sala de aula."

# game/script-a3-emi.rpy:9367
translate pt_br a3ec5o2_a08c18fe:

    # "I suppose she and Shizune have student council business again."
    "Eu suponho que ela e Shizune tenham negócios do Conselho Estudantil à fazer de novo."

# game/script-a3-emi.rpy:9372
translate pt_br a3ec5o2_1f72350b:

    # "While the afternoon wears on, I find myself impatient for lessons to end. I need to see Emi now."
    "Enquanto a tarde chega, eu me encontro impaciente para as aulas acabarem. Eu preciso ver a Emi agora."

# game/script-a3-emi.rpy:9374
translate pt_br a3ec5o2_d3ee333f:

    # "I have to try to set things right. Even if Emi hates me now, I have to at least apologize."
    "Eu preciso tentar fazer as coisas certas. Mesmo que a Emi me odeio agora, eu preciso ao menos me desculpar."

# game/script-a3-emi.rpy:9376
translate pt_br a3ec5o2_bb6100ab:

    # "I owe her that much."
    "Eu devo tudo isso à ela."

# game/script-a3-emi.rpy:9378
translate pt_br a3ec5o2_bd2f4cda:

    # "Should I meet her in her room? No, I decide, it would delay things too much. If I know Emi, then I can find her at the track."
    "Devo encontrá-la no seu quarto? Não, eu decido, isso iria demorar muito as coisas. Se eu conheço a Emi, então eu posso encontrá-la na pista."

# game/script-a3-emi.rpy:9380
translate pt_br a3ec5o2_ec1b96c5:

    # "Still have no idea what I'm going to say when I get there, but I take comfort in knowing that Emi probably wouldn't have a plan for something like this either."
    "Ainda não faço ideia do que eu irei dizer quando eu chegar lá, mas eu tomo como conforto que a Emi provavelmente não terá um plano para algo como isso também."

# game/script-a3-emi.rpy:9382
translate pt_br a3ec5o2_82d46b6f:

    # "Play it by ear. Stop being nervous, and just get to the track. Figure the rest out when I get there."
    "Vá com calma. Pare de se preocupar, e apenas vá para a pista. Descubra o resto quando eu chegar lá."

# game/script-a3-emi.rpy:9387
translate pt_br a3ec5o2_0d2cc8a7:

    # "The track looms ahead, and another jolt of nerves hits me in the gut. I resist the urge to turn and walk away, and instead note with satisfaction that I was right and Emi is still running."
    "A pista surge à minha frente, e outro choque de nervos me acerta no estômago. Eu resisto a vontade de me virar e ir embora, ao invés eu noto com extrema satisfação que eu estava certo que a Emi ainda esta correndo."

# game/script-a3-emi.rpy:9389
translate pt_br a3ec5o2_b12d8b7b:

    # "I don't make myself immediately known; I find a seat in the bleachers and watch her run instead, thinking back to earlier meetings."
    "Eu não me faço imediatamente presente; Eu encontro um banco na arquibancada e assisto ela correr ao invés, pensando nos antigos encontros."

# game/script-a3-emi.rpy:9399
translate pt_br a3ec5o2_6c50f029:

    # "After a few trips around the track, Emi notices me and skids to a halt, an expression of surprise that slides easily into one of anger."
    "Depois de algumas voltas, Emi me percebe e desliza até parar, uma expressão de surpresa que se desliza facilmente em uma de raiva."

# game/script-a3-emi.rpy:9404
translate pt_br a3ec5o2_04e355f0:

    # emi "What are you doing here?"
    emi "O que você está fazendo aqui?"

# game/script-a3-emi.rpy:9406
translate pt_br a3ec5o2_b96389c2:

    # "Not quite the response I'd hoped for, but at this point I don't have much of a choice."
    "Não é muito a resposta que eu esperava, mas nessa altura eu não tenho muita escolha."

# game/script-a3-emi.rpy:9408
translate pt_br a3ec5o2_d136b5d5:

    # hi "I wanted to apologize for what I said the other day."
    hi "Eu queria me desculpar pelo que eu disse no outro dia."

# game/script-a3-emi.rpy:9413
translate pt_br a3ec5o2_5a95d2b2:

    # emi "The other day?"
    emi "O outro dia?"

# game/script-a3-emi.rpy:9418
translate pt_br a3ec5o2_443ec210:

    # "She laughs, a curt exclamation of disbelief."
    "Ela rí, uma curta exclamação de descrença."
    

# game/script-a3-emi.rpy:9423
translate pt_br a3ec5o2_d7115547:

    # emi "It's been almost a week, Hisao."
    emi "Isso foi a quase uma semana, Hisao."

# game/script-a3-emi.rpy:9425
translate pt_br a3ec5o2_522711c7:

    # hi "Yeah, well… better late than never, right?"
    
    hi "Sim, bem… antes tarde do que nunca, certo?"

# game/script-a3-emi.rpy:9430
translate pt_br a3ec5o2_3a635476:

    # "Emi crosses her arms and stares at me coolly, as if sizing me up. Finally, she nods."
    "Emi cruza os braços e me encara friamente, como se estivesse me analisando. Finalmente, ela acena com a cabeça."

# game/script-a3-emi.rpy:9435
translate pt_br a3ec5o2_93ad327b:

    # emi "Hmmph. I suppose you're right. Water under the bridge, then. I forgive you."
    emi "Hmmph. Acho que você está certo. São águas passadas, então. eu te perdôo."

# game/script-a3-emi.rpy:9440
translate pt_br a3ec5o2_254b33af:

    # emi "Is that all?"
    emi "Isso é tudo?"

# game/script-a3-emi.rpy:9449
translate pt_br a3ec5o2_9eee6a70:

    # "Her almost impatient question catches me so off-guard that she's already halfway down the track before I think to shout after her."
    "A sua pergunta quase impaciente me pega tão desprevenido que ela já está à meio caminho da pista antes que eu consiga berrar para ela."

# game/script-a3-emi.rpy:9451
translate pt_br a3ec5o2_553a5543:

    # hi "No, wait!"
    hi "Não, espera!"

# game/script-a3-emi.rpy:9456
translate pt_br a3ec5o2_77dee3a3:

    # "She doesn't seem to have heard me - or she doesn't want to hear me - and so I give chase, disregarding completely the fact that I am not dressed for it."
    "Ela não parece ter me ouvido - ou ela não quer ouvir - então eu corro atrás, ignorando completamente o fato de que eu não estou vestido para isso."

# game/script-a3-emi.rpy:9461
translate pt_br a3ec5o2_06b19e7a:

    # "My feet hurt, and my shirt collar feels like a noose around my neck, but I still chase after her, because if I don't I'll lose my chance."
    "Meus pés doem, e meu colarinho da camisa parece que estar amarrado no meu pescoço, mas ainda assim eu corro atrás dela, porque senão eu vou perder minha chance."

# game/script-a3-emi.rpy:9463
translate pt_br a3ec5o2_8d7ca229:

    # "Emi hasn't started to really accelerate yet, which is probably the only reason why I'm able to catch up to her, to reach out and tap her on the shoulder, just before my legs give up running in dress shoes and stumble to a stop."
    "Emi não começou a correr ainda, o que será provavelmente o único motivo pelo qual eu sou capaz de alcançá-la, e lhe dar um toque no ombro, logo antes das minhas pernas desistirem de correr em um tênis normal e cambalear até parar."

# game/script-a3-emi.rpy:9468
translate pt_br a3ec5o2_2561d850:

    # "Surprisingly (fortunately?) all that running seems to have paid off. I'm short of breath, yes, but at least my heart isn't actively trying to force its way out of my ribcage."
    "Surpreendentemente (felizmente?) toda essa corrida parece ter valido a pena. Estou sem ar, sim, mas pelo menos meu coração não está ativamente tentando sair pelas minhas costelas."

# game/script-a3-emi.rpy:9473
translate pt_br a3ec5o2_31a2be0e:

    # "My touch on her shoulder has stopped Emi, and while there is a flash of concern when she sees me catching my breath, it seems that she has a good idea of what I'm capable of too."
    "Meu toque no ombro dela parece ter parado Emi, e enquanto há uma certa preocupação enquanto ela me vê retomando o fôlego, parece que ela tem uma boa ideia do que eu sou capaz também."

# game/script-a3-emi.rpy:9475
translate pt_br a3ec5o2_69e896af:

    # "The concern is short-lived."
    "A preocupação é curta."

# game/script-a3-emi.rpy:9480
translate pt_br a3ec5o2_cf45f9a1:

    # emi "What?"
    emi "O que?"

# game/script-a3-emi.rpy:9482
translate pt_br a3ec5o2_3341c279:

    # "She seems so irritated by my being still there that I almost lose my nerve, but I've lost my nerve enough."
    "Ela parece tão irritada por eu ainda estar ali que eu quase perco a cabeça, embora eu tenha realmente perdido a cabeça o suficiente."

# game/script-a3-emi.rpy:9484
translate pt_br a3ec5o2_782da3c2:

    # hi "I need to explain myself. Why I can't just let the matter rest."
    hi "Eu preciso me explicar. Porque eu não posso deixar as coisas assim."

# game/script-a3-emi.rpy:9489
translate pt_br a3ec5o2_aecaea22:

    # "Emi folds her arms and bounces one blade on the ground in an approximation of tapping her foot impatiently. Angry as she is, and as nervous as I am, she still looks beautiful."
    "Emi cruza os braços e quica uma lamina no chão o que seria aproximadamente o bater do pé de modo impaciente. Irritada como ela está, e nervoso como estou, as coisas parecem lindas."

# game/script-a3-emi.rpy:9491
translate pt_br a3ec5o2_218d656d:

    # emi "Okay, Hisao. Explain."
    emi "Okay, Hisao. Explique."

# game/script-a3-emi.rpy:9493
translate pt_br a3ec5o2_d16ee548:

    # hi "The thing is, I know that you're really sensitive about the accident and about your dad."
    hi "A coisa é, que eu sei que você é muito sensível quanto o acidente e o seu pai."

# game/script-a3-emi.rpy:9495
translate pt_br a3ec5o2_3c6b19c4:

    # "I can see Emi's face twitch at the mention of the two things that have been steadily driving us apart, or at least made me feel like we're being driven apart."
    "Eu consigo ver a cara da Emi se contorcer quando mencionado as duas coisas que estiveram lentamente nos separando, ou pelo menos fez eu sentir que estava me separando."

# game/script-a3-emi.rpy:9497
translate pt_br a3ec5o2_69b92b2e:

    # hi "But that's why I want to know about them, I think."
    hi "Mas é por isso que eu quero saber sobre elas, eu acho."
    

# game/script-a3-emi.rpy:9499
translate pt_br a3ec5o2_958d0ef1:

    # hi "Because I see how much they hurt you, and I want to be there to comfort you."
    hi "Porque eu vejo como isso te machuca, e eu quero estar lá para te confortar."

# game/script-a3-emi.rpy:9501
translate pt_br a3ec5o2_ce3516da:

    # hi "It makes me miserable, seeing you sleepless and depressed - and don't pretend you aren't, because I know, okay?"
    hi "Isso me deixa miserável, ver você sem dormir e deprimida - e não finja que você não está, porque eu sei, okay?"

# game/script-a3-emi.rpy:9503
translate pt_br a3ec5o2_e87faeca:

    # hi "I just remember that night when you fell asleep with me and had that nightmare, and that you were happy to have me there when you woke up."
    hi "Eu apenas me lembro daquela noite quando você acabou dormindo comigo e teve aquele pesadelo, e que você esteve tão feliz de me ter ali quando você acordou."

# game/script-a3-emi.rpy:9505
translate pt_br a3ec5o2_d70adea0:

    # hi "I want to be able to be there for you like that whenever you need me to be."
    hi "Eu quero ser capaz de estar lá para você quando você bem quiser que eu esteja."

# game/script-a3-emi.rpy:9510
translate pt_br a3ec5o2_68cb0611:

    # "The stern face cracks, slightly. Emi interrupts before I can continue further."
    "O rosto severo se racha, ligeiramente. Emi interrompe antes que eu possa continuar."

# game/script-a3-emi.rpy:9512
translate pt_br a3ec5o2_1ac23bdd:

    # emi "Just… stop right there. We can't see each other any more, okay?"
    emi "Apenas… pare por aí. Nós não podemos mais nos ver, okay?"

# game/script-a3-emi.rpy:9517
translate pt_br a3ec5o2_d71133cb:

    # "She's rushing now, looking everywhere but at me. I'm surprised she doesn't bolt, she knows I can't catch her…"
    "Ela está fugindo agora, olhando para tudo que é lugar menos para mim. Estou surpreso que ela não saia correndo, ela sabe que eu não consigo seguir ela…"

# game/script-a3-emi.rpy:9519
translate pt_br a3ec5o2_37f63bf6:

    # emi "We're not… we're not right for one another."
    emi "Nós não… nós não fomos feitos um para o outro."

# game/script-a3-emi.rpy:9521
translate pt_br a3ec5o2_3f7d8273:

    # hi "That's not true, and you know it."
    hi "Isso não é verdade, e você sabe disso."

# game/script-a3-emi.rpy:9526
translate pt_br a3ec5o2_b8e53f76:

    # emi "No, it's true. You're too—"
    emi "Não, isso é verdade. Você também—"

# game/script-a3-emi.rpy:9528
translate pt_br a3ec5o2_66a79efa:

    # hi "I know. I know that I've been pushy about knowing your past."
    hi "Eu sei. eu sei que eu fui intrometido em querer saber sobre o seu passado."

# game/script-a3-emi.rpy:9530
translate pt_br a3ec5o2_0cb7d29b:

    # hi "If you can't tell me yet, then at least let me be there even if I don't know the reason."
    hi "Se você não pode me contar ainda, pelo menos me deixe estar lá mesmo que eu não saiba o motivo."

# game/script-a3-emi.rpy:9532
translate pt_br a3ec5o2_3b568386:

    # hi "It's okay, I promise. I won't ask why you need comfort, I'll just give it freely."
    hi "Está tudo bem, eu prometo. Eu não irei mais perguntar porque você precisa de um consolo, eu vou apenas dar-lhe livremente."

# game/script-a3-emi.rpy:9537
translate pt_br a3ec5o2_8ab74e60:

    # "Emi's shaking her head, and tears seem to be threatening the corners of her eyes."
    "Emi está sacudindo a cabeça dela, e lagrimas parecem estar ameaçando o canto de seus olhos."

# game/script-a3-emi.rpy:9539
translate pt_br a3ec5o2_540334db:

    # emi "Stop saying that!"
    emi "Pare de dizer isso!"
    

# game/script-a3-emi.rpy:9541
translate pt_br a3ec5o2_32dc58b0:

    # hi "Why? Because you're afraid you'll take me up on it?"
    hi "Porque? Por que você está com medo de me aceitar?"

# game/script-a3-emi.rpy:9546
translate pt_br a3ec5o2_f44ddb25:

    # emi "I'm not afraid!"
    emi "Não estou com medo!"

# game/script-a3-emi.rpy:9548
translate pt_br a3ec5o2_4129e9aa:

    # "I can't keep the chiding tone from my voice as I respond."
    "Eu não consigo manter o tom de repreensão da minha voz enquanto eu respondo."

# game/script-a3-emi.rpy:9550
translate pt_br a3ec5o2_72ac50c8:

    # hi "Yes, you are. You told me so yourself, remember? That's okay, really it is."
    hi "Sim, você está. Você mesmo me disse isso, lembra? Está tudo bem, realmente está."

# game/script-a3-emi.rpy:9552
translate pt_br a3ec5o2_6a1cb71f:

    # hi "However, it seems to me that someone who'd manage to come out of that wreck and still be as energetic and cheerful as you are would be determined enough to face that fear."
    hi "Contudo, para mim parece que alguém que tenha conseguido sair daqueles destroços e ainda ser tão energética e animada como você é já seria determinação suficiente para encarar esse medo."

# game/script-a3-emi.rpy:9557
translate pt_br a3ec5o2_29a1a2e4:

    # emi "Determination? What do you know about determination?"
    emi "Determinação? O que você sabe sobre determinação?"

# game/script-a3-emi.rpy:9559
translate pt_br a3ec5o2_bf363f42:

    # hi "I know that there's a girl so determined to take care of a total stranger that she'd steal his food at a festival."
    hi "Eu sei que há uma garota que é tão determinada em cuidar de um estranho total que ela iria até roubar a sua comida durante o festival."

# game/script-a3-emi.rpy:9561
translate pt_br a3ec5o2_889126a9:

    # hi "I know that there's a girl so determined to help me with my own problems that she'd draw up a complete dietary and exercise plan, and that she'd not only draw up the plans, but she'd follow them with me, even when she couldn't run."
    hi "Eu sei que há uma garota tão determinada em me ajudar com meus próprios problemas que ela iria desenhar planos dietéticos e de exercícios completos, e que ela não iria apenas desenhá-los mas sim seguí-los comigo, até mesmo quando ela não consiga correr."

# game/script-a3-emi.rpy:9563
translate pt_br a3ec5o2_2595e9e3:

    # hi "Determined enough to keep me at arm's length that she'd put herself through emotional pain if she thought it was the right thing to do."
    hi "Determinada o suficiente a ponto de me manter à um braço de distância depois de passar por uma dor emocional se ela pensasse que isso fosse a coisa certa a se fazer."

# game/script-a3-emi.rpy:9565
translate pt_br a3ec5o2_2125d8fb:

    # hi "Although, there's one thing that this determined girl didn't quite plan for, which was that I might feel that same kind of determination to keep her from being hurt."
    hi "Embora, há uma coisa que essa garota determinada não tenha conseguido planejar direito, que é que talvez eu sinta essa mesma determinação em tentar evitá-la de se machucar."

# game/script-a3-emi.rpy:9567
translate pt_br a3ec5o2_89baae77:

    # hi "I fell in love with you, and I refuse to let that be thrown away because you're afraid of losing me."
    hi "Eu me apaixonei por você, e eu recuso deixar isso ser jogado fora porque você tem medo de me perder."

# game/script-a3-emi.rpy:9572
translate pt_br a3ec5o2_29afdbca:

    # "What little control Emi still has at this point cracks, and I find myself suddenly enveloped in her embrace as she cries."
    "O pouco controle que a Emi tem nesse ponto se quebra, e eu me encontro de repente envolto de seus braços enquanto ela chora."

# game/script-a3-emi.rpy:9574
translate pt_br a3ec5o2_c75a78b6:

    # emi "Why are you doing this? Why can't you just leave me alone?"
    emi "Porque você está fazendo isso? Porque você não pode simplesmente me deixar em paz?"

# game/script-a3-emi.rpy:9579
translate pt_br a3ec5o2_d1bb2ed3:

    # "I hold her close and plant a kiss on the top of her head."
    "Eu a seguro bem perto e dou um beijo em sua testa."

# game/script-a3-emi.rpy:9581
translate pt_br a3ec5o2_d4ffafbf:

    # hi "I'm sorry, Emi. You helped me when I first arrived, so now I have to help you. It's only fair."
    hi "Me desculpe, Emi. Você me ajudou quando eu tinha recém chegado, então agora é minha vez de te ajudar. É apenas o justo."

# game/script-a3-emi.rpy:9583
translate pt_br a3ec5o2_e75dbe1d:

    # emi "You're utterly hopeless, did you know that?"
    emi "Você é totalmente sem esperança, sabia disso?"

# game/script-a3-emi.rpy:9585
translate pt_br a3ec5o2_12df97b5:

    # "She hiccups and trembles a little."
    "Ela soluça e treme um pouco."

# game/script-a3-emi.rpy:9587
translate pt_br a3ec5o2_9c4ea2c3:

    # hi "Funny, I could say the same about you."
    hi "Engraçado, eu poderia dizer a mesma coisa sobre você."

# game/script-a3-emi.rpy:9589
translate pt_br a3ec5o2_a6330d99:

    # emi "Can you do something for me, Hisao?"
    emi "Você pode fazer uma coisa para mim, Hisao?"

# game/script-a3-emi.rpy:9591
translate pt_br a3ec5o2_166a03d6:

    # hi "Anything."
    hi "Qualquer coisa."

# game/script-a3-emi.rpy:9597
translate pt_br a3ec5o2_e73c3ed7:

    # emi "Can you go, now?"
    emi "Você pode ir embora, agora?"

# game/script-a3-emi.rpy:9599
translate pt_br a3ec5o2_ec78288c:

    # "It feels like she's just shoved a knife through my chest."
    "Eu sinto como se ela tivesse acabado de enfiar uma faca no meu peito."

# game/script-a3-emi.rpy:9601
translate pt_br a3ec5o2_f2913ad5:

    # hi "Go?"
    hi "Ir?"

# game/script-a3-emi.rpy:9606
translate pt_br a3ec5o2_9a21e210:

    # emi "I need to… I need to think, okay?"
    emi "Eu preciso… eu preciso pensar, okay?"

# game/script-a3-emi.rpy:9608
translate pt_br a3ec5o2_4b2a3357:

    # emi "I can't just tell you everything yet. I'm still scared, and when you're around, I can't think clearly."
    emi "Eu não posso simplesmente te dizer tudo ainda. Eu estou com medo, e quando você está por perto, eu não consigo pensar claramente."

# game/script-a3-emi.rpy:9610
translate pt_br a3ec5o2_5a01c2db:

    # emi "But do me another favor."
    emi "Mas me faça outro favor."

# game/script-a3-emi.rpy:9612
translate pt_br a3ec5o2_111a58e1:

    # hi "What's that?"
    hi "O que seria?"

# game/script-a3-emi.rpy:9617
translate pt_br a3ec5o2_95c5efac:

    # emi "Show up for our morning run tomorrow?"
    emi "Aparece amanhã para nossa corrida matinal?"

# game/script-a3-emi.rpy:9619
translate pt_br a3ec5o2_3e3afdda:

    # "I smile, feeling better than I have all week."
    "Eu sorrio, me sentindo melhor do que estive na semana inteira."

# game/script-a3-emi.rpy:9621
translate pt_br a3ec5o2_5b0f7a1c:

    # hi "Of course. I wouldn't miss it for the world."
    hi "É claro. Eu não perderia mesmo que o mundo dependesse disso."

# game/script-a3-emi.rpy:9626
translate pt_br a3ec5o2_5b24fe88:

    # "Emi steps back slowly, almost reluctantly. She sniffles a little and then grins at me, a real smile that lights up the track, overpowering the fading evening's light."
    "Emi anda para trás devagar, quase relutante. Ela funga um pouco e então sorri para mim, um sorriso verdadeiro que ilumina a pista, dominando a luz da noite que vem chegando."

# game/script-a3-emi.rpy:9631
translate pt_br a3ec5o2_d91f8844:

    # emi "See you tomorrow, Hisao."
    emi "Te vejo amanhã, Hisao."

# game/script-a3-emi.rpy:9633
translate pt_br a3ec5o2_16a7dec2:

    # hi "Okay."
    hi "Okay."

# game/script-a3-emi.rpy:9641
translate pt_br a3ec5o2_699c76bd:

    # "She darts forward suddenly, planting a soft kiss on my lips, then steps back shyly."
    "Ela corre para frente de repente, plantando um beijo macio em meus lábios, então andando para trás timidamente."

# game/script-a3-emi.rpy:9650
translate pt_br a3ec5o2_a8daa451:

    # "Spinning on her back foot, she takes off running again, and I know that our conversation's at an end."
    "Girando seu pé para trás, ela começa a correr de novo, e eu sei que nossa conversa tinha chegado a um fim."

# game/script-a3-emi.rpy:9652
translate pt_br a3ec5o2_308fd039:

    # "My lips tingle with the warmth of that brief kiss and the memories of other, longer kisses."
    
    "Meus lábios formigam com o calor daquele beijo breve e as memórias, de outros beijos mais longos."

# game/script-a3-emi.rpy:9654
translate pt_br a3ec5o2_adfe688b:

    # "I walk back to my room with a spring in my step."
    "Eu caminho de volta para o meu quarto quase saltitando."

# game/script-a3-emi.rpy:9656
translate pt_br a3ec5o2_fce2cb88:

    # "Tomorrow when my alarm goes off, I'll get up."
    "Amanhã quando meu alarme tocar, eu irei me levantar."
    

translate pt_br strings:

    # game/script-a3-emi.rpy:1119
    old "Why do I get the feeling that she's convincing herself as well as me?"
    new "Por que eu sinto que ela está se convencendo tanto quanto me convencendo?"

    # game/script-a3-emi.rpy:1119
    old "Press Emi."
    new "Forçar o assunto."

    # game/script-a3-emi.rpy:1119
    old "Let it rest."
    new "Deixar para lá."

    # game/script-a3-emi.rpy:5923
    old "I suppose I can spare a few minutes."
    new "Suponho que tenho alguns minutos."

    # game/script-a3-emi.rpy:5923
    old "No, I have other things to worry about."
    new "Não, eu tenho outras coisas para me preocupar."

    # game/script-a3-emi.rpy:6924
    old "Sure, why not?"
    new "Claro, por que não?"

    # game/script-a3-emi.rpy:6924
    old "No, this is my problem."
    new "Não, esse problema é meu."

    # game/script-a3-emi.rpy:7721
