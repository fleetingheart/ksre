# game/script-a3-emi.rpy:10
translate pt_br a3_emi_eet_ees_scienca_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:16
translate pt_br a3_emi_eet_ees_scienca_15a98fa6:

    # n "{vspace=90}My head's in a spin all through Mutou's class."
    n "{vspace=90}Minha cabeça girou durante toda a aula de Mutou."

# game/script-a3-emi.rpy:18
translate pt_br a3_emi_eet_ees_scienca_9475f130:

    # n "I'm going to have dinner."
    n "Eu vou jantar."

# game/script-a3-emi.rpy:20
translate pt_br a3_emi_eet_ees_scienca_28dc41be:

    # n "With Emi."
    n "Com a Emi."

# game/script-a3-emi.rpy:22
translate pt_br a3_emi_eet_ees_scienca_0c7ebe42:

    # n "Who wants to be my girlfriend, no less."
    n "Que quer se tornar minha namorada, nada menos."

# game/script-a3-emi.rpy:24
translate pt_br a3_emi_eet_ees_scienca_c31dcf22:

    # n "A date…"
    n "Um encontro…"

# game/script-a3-emi.rpy:26
translate pt_br a3_emi_eet_ees_scienca_3816071a:

    # n "And then she kissed me."
    n "Então ela me beijou."

# game/script-a3-emi.rpy:28
translate pt_br a3_emi_eet_ees_scienca_3d029ca4:

    # n "That kiss. I keep going back to it, playing it over in my mind again and again."
    
    n "Aquele beijo, eu fico voltando a ele, repassando ele de novo e de novo na minha cabeça."

# game/script-a3-emi.rpy:30
translate pt_br a3_emi_eet_ees_scienca_cf3c0ca0:

    # n "Everything about that moment felt so right."
    n "Tudo sobre aquele momento parecia tão certo."

# game/script-a3-emi.rpy:32
translate pt_br a3_emi_eet_ees_scienca_ed009a62:

    # n "{vspace=30}My mind drifts off, lost in thoughts of Emi."
    n "{vspace=30}Minha mente viaja, perdida em pensamentos na Emi."

# game/script-a3-emi.rpy:36
translate pt_br a3_emi_eet_ees_scienca_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a3-emi.rpy:42
translate pt_br a3_emi_eet_ees_scienca_b3b5c77f:

    # mu "Nakai? Hello?"
    mu "Nakai? Olá?"

# game/script-a3-emi.rpy:44
translate pt_br a3_emi_eet_ees_scienca_3a9fbd58:

    # "It seems like I've drifted a bit too far."
    "Parece que eu viajei um pouco longe demais."

# game/script-a3-emi.rpy:46
translate pt_br a3_emi_eet_ees_scienca_867ff869:

    # hi "Huh? What?"
    hi "Hã? O quê?"

# game/script-a3-emi.rpy:51
translate pt_br a3_emi_eet_ees_scienca_0e1b3b49:

    # mu "Egad! You've contracted some kind of amnesia!"
    mu "Opa! Você contraiu algum tipo de amnésia!"

# game/script-a3-emi.rpy:53
translate pt_br a3_emi_eet_ees_scienca_71f0eb36:

    # mu "Someone get the nurse!"
    mu "Alguém chame o enfermeiro!"

# game/script-a3-emi.rpy:55
translate pt_br a3_emi_eet_ees_scienca_0a49a0cf:

    # "The class chuckles at Mutou's antics."
    "A classe ri das piadas do Mutou."

# game/script-a3-emi.rpy:57
translate pt_br a3_emi_eet_ees_scienca_0bd24c48:

    # hi "Sorry, sir."
    hi "Desculpe, senhor."

# game/script-a3-emi.rpy:62
translate pt_br a3_emi_eet_ees_scienca_81ae6327:

    # mu "Hmm, won't happen again and all that, right?"
    mu "Hmm, não acontecerá de novo certo?"

# game/script-a3-emi.rpy:64
translate pt_br a3_emi_eet_ees_scienca_ee8aef65:

    # hi "Exactly."
    hi "Certo."

# game/script-a3-emi.rpy:66
translate pt_br a3_emi_eet_ees_scienca_07a490bb:

    # "Mutou brightens considerably."
    "Mutou se alegra consideravelmente."

# game/script-a3-emi.rpy:71
translate pt_br a3_emi_eet_ees_scienca_f4f17cce:

    # mu "Well! Lovely to hear!"
    mu "Bom! Ótimo ouvir isso!"

# game/script-a3-emi.rpy:73
translate pt_br a3_emi_eet_ees_scienca_a41b8868:

    # mu "I'd hate to have my star pupil slacking off, after all."
    
    mu "Eu odiaria ver meu pupilo estrela relaxando, afinal de contas."

# game/script-a3-emi.rpy:78
translate pt_br a3_emi_eet_ees_scienca_97b1f6d3:

    # "I've been doing well, but I hardly qualify as a star pupil, I think."
    "Eu tenho ido bem, mas eu dificilmente me qualificaria como um pupilo estrela, eu acho."

# game/script-a3-emi.rpy:80
translate pt_br a3_emi_eet_ees_scienca_af1cb1e4:

    # "I'm fairly certain that this class is the sort that everyone does well in. It's just memorizing formulas."
    
    "Eu tenho quase certeza que esse é o tipo de matéria que todo mundo vai bem. É só memorizar fórmulas."

# game/script-a3-emi.rpy:82
translate pt_br a3_emi_eet_ees_scienca_8de748f9:

    # "True to my word, I manage to pay attention for the rest of the class."
    "Mantendo minha palavra, eu consigo prestar atenção ao resto da aula."

# game/script-a3-emi.rpy:91
translate pt_br a3_emi_eet_ees_scienca_f6185feb:

    # mu "Nakai, may I have a word with you?"
    mu "Nakai, posso ter uma palavrinha com você?"

# game/script-a3-emi.rpy:93
translate pt_br a3_emi_eet_ees_scienca_a8aefd35:

    # "I wonder if I'm in trouble for earlier."
    "Me pergunto se estou em apuros por mais cedo."

# game/script-a3-emi.rpy:95
translate pt_br a3_emi_eet_ees_scienca_5a036de1:

    # hi "Uh, sure."
    hi "Er, claro."

# game/script-a3-emi.rpy:97
translate pt_br a3_emi_eet_ees_scienca_4a1c05ff:

    # hi "Am I in trouble?"
    
    hi "Estou em apuros?"

# game/script-a3-emi.rpy:102
translate pt_br a3_emi_eet_ees_scienca_1d50d316:

    # "Mutou looks genuinely confused for a moment."
    "Mutou parece genuinamente confuso por um momento."

# game/script-a3-emi.rpy:104
translate pt_br a3_emi_eet_ees_scienca_628e116e:

    # mu "Beg your pardon?"
    mu "Como é?"

# game/script-a3-emi.rpy:106
translate pt_br a3_emi_eet_ees_scienca_60653050:

    # "He tilts his head to one side and thinks for a moment."
    "Ele vira a cabeça para um lado e pensa por um momento."

# game/script-a3-emi.rpy:111
translate pt_br a3_emi_eet_ees_scienca_3985dd59:

    # mu "Oh, that! No, no, you're not in any sort of trouble."
    mu "Ah, aquilo! Não, não, você não está em nenhum tipo de apuro."

# game/script-a3-emi.rpy:113
translate pt_br a3_emi_eet_ees_scienca_fe46af35:

    # mu "There's just a question I want to ask you."
    mu "Tem uma pergunta que eu quero lhe fazer."

# game/script-a3-emi.rpy:115
translate pt_br a3_emi_eet_ees_scienca_111a58e1:

    # hi "What's that?"
    hi "E o que seria?"

# game/script-a3-emi.rpy:120
translate pt_br a3_emi_eet_ees_scienca_4ac04583:

    # mu "Nothing terrible, I was just wondering what your plans for after graduation are."
    mu "Nada terrível, eu só estava pensando quais são seus planos pós-graduação."

# game/script-a3-emi.rpy:124
translate pt_br a3_emi_eet_ees_scienca_f5d0d72f:

    # mu "Are you going to university?"
    mu "Você vai para a universidade?"

# game/script-a3-emi.rpy:126
translate pt_br a3_emi_eet_ees_scienca_1312097b:

    # hi "Yeah, I guess. I can't really see a reason not to go."
    hi "É, eu acho. Não consigo ver motivos para não ir."

# game/script-a3-emi.rpy:128
translate pt_br a3_emi_eet_ees_scienca_2d060ffe:

    # mu "Given any thought to what you'll study?"
    mu "Já pensou no que vai estudar?"

# game/script-a3-emi.rpy:130
translate pt_br a3_emi_eet_ees_scienca_87b8c977:

    # hi "Not really, no. I figure I'll come up with something when I get there."
    hi "Na verdade não. Eu acho que até lá eu terei pensado em algo."

# game/script-a3-emi.rpy:135
translate pt_br a3_emi_eet_ees_scienca_ec1cca9e:

    # "Mutou laughs."
    "Mutou ri."

# game/script-a3-emi.rpy:137
translate pt_br a3_emi_eet_ees_scienca_b268058b:

    # mu "Taking things as they come, eh?"
    
    mu "Deixar a vida te levar não é?"
    

# game/script-a3-emi.rpy:139
translate pt_br a3_emi_eet_ees_scienca_a2ec98ef:

    # mu "I'd argue against it, but that's how I did things when I went to university."
    mu "Eu te convenceria do contrário, mas eu também fiz do mesmo jeito quando fui pra universidade"

# game/script-a3-emi.rpy:141
translate pt_br a3_emi_eet_ees_scienca_4f667d90:

    # mu "Well, not really."
    mu "Bom, não exatamente."

# game/script-a3-emi.rpy:143
translate pt_br a3_emi_eet_ees_scienca_eff4d5fa:

    # mu "I knew I'd go into a science, I just wasn't sure which one."
    mu "Eu sabia que iria fazer alguma ciência. Só não sabia qual."

# game/script-a3-emi.rpy:145
translate pt_br a3_emi_eet_ees_scienca_09553ba6:

    # mu "Ended up with physics, but could just as well have gone for astronomy or what have you."
    mu "Acabei optando por física, mas eu poderia ter feito astronomia também ou o que fosse."

# game/script-a3-emi.rpy:150
translate pt_br a3_emi_eet_ees_scienca_63e79513:

    # mu "Actually I did go for chemistry first, but there were all sorts of things…"
    mu "Na verdade eu optei por química primeiro, mas havia todo tipo de opção."

# game/script-a3-emi.rpy:152
translate pt_br a3_emi_eet_ees_scienca_ae1d1679:

    # "Mutou trails off, and frowns slightly."
    "Mutou divaga e franze a testa um pouco."

# game/script-a3-emi.rpy:154
translate pt_br a3_emi_eet_ees_scienca_6bd23bfc:

    # "It takes a minute for him to recover his train of thought, and I wait patiently for him to continue."
    "Demora cerca de um minuto para ele recuperar a sua linha de pensamento, eu espero pacientemente para que ele continue."

# game/script-a3-emi.rpy:159
translate pt_br a3_emi_eet_ees_scienca_87482d27:

    # mu "So anyway, I did a lot of physics as well, because I had an interest in that, but I wasn't sure if it was for me."
    mu "De qualquer forma, eu fazia muita física também, porque eu era interessado, mas eu não tinha certeza se era pra mim."

# game/script-a3-emi.rpy:164
translate pt_br a3_emi_eet_ees_scienca_8444312d:

    # mu "So I went back to chemistry, and here we are. Yes?"
    
    mu "Então eu voltei pra química e aqui estamos. Sim?"

# game/script-a3-emi.rpy:169
translate pt_br a3_emi_eet_ees_scienca_cdf74e18:

    # "He smiles at me enthusiastically, as if waiting for me to confirm that yes, here is where we are."
    "Ele sorri entusiasmado, como que esperando que eu confirmasse que sim, aqui estamos."

# game/script-a3-emi.rpy:171
translate pt_br a3_emi_eet_ees_scienca_1c1105c6:

    # "Somehow I get the feeling that Mutou had a plan for this conversation, but I'll be damned if I can figure it out."
    "De alguma forma eu tenho a impressão de que o Mutou tinha um plano para essa conversa, mas parabéns para mim se eu conseguir entender."

# game/script-a3-emi.rpy:173
translate pt_br a3_emi_eet_ees_scienca_fe89e9d3:

    # hi "I'm sorry, I'm not following you."
    hi "Desculpa, eu não estou te entendendo."

# game/script-a3-emi.rpy:175
translate pt_br a3_emi_eet_ees_scienca_2f95be7a:

    # "Mutou frowns and rubs his chin a bit, looking perplexed. He then snaps his fingers as if he's remembered what the point of all this was."
    "Mutou franze mais e coça o queixo parecendo perplexo. Então ele estala os dedos como se ele se lembrasse do que se tratava aquela conversa."

# game/script-a3-emi.rpy:177
translate pt_br a3_emi_eet_ees_scienca_b216e9b6:

    # mu "Right! Yes! You!"
    mu "Certo! Sim! Você!"

# game/script-a3-emi.rpy:179
translate pt_br a3_emi_eet_ees_scienca_f10eafa0:

    # hi "Me?"
    hi "Eu?"

# game/script-a3-emi.rpy:181
translate pt_br a3_emi_eet_ees_scienca_ae3967dd:

    # mu "Yes! You should look into studying one of the sciences!"
    mu "Sim! Você deveria procurar estudar alguma das ciências!"

# game/script-a3-emi.rpy:183
translate pt_br a3_emi_eet_ees_scienca_bf24af5d:

    # mu "You're fantastic at it."
    mu "Você é bom nisso."

# game/script-a3-emi.rpy:185
translate pt_br a3_emi_eet_ees_scienca_32e22e1e:

    # mu "Unless you'd rather just go into math."
    mu "A não ser que você prefira só ir fazer matemática."

# game/script-a3-emi.rpy:190
translate pt_br a3_emi_eet_ees_scienca_d936ca48:

    # "Mutou makes a sour face."
    "Mutou faz uma cara amarga."

# game/script-a3-emi.rpy:192
translate pt_br a3_emi_eet_ees_scienca_5ea95289:

    # mu "Not a big fan of straight math. I always liked the experiments more than the proofs."
    mu "Não sou muito fã da matemática direta. Eu sempre gostei dos experimentos mais do que dos resultados."

# game/script-a3-emi.rpy:194
translate pt_br a3_emi_eet_ees_scienca_c57cad1d:

    # hi "You're saying I should study science at university?"
    
    hi "Você esta dizendo que eu deveria estudar ciências na universidade?"

# game/script-a3-emi.rpy:196
translate pt_br a3_emi_eet_ees_scienca_06805c1b:

    # "Mutou seems thrown off balance by my question."
    "Mutou parece perder o equilíbrio com minha pergunta."

# game/script-a3-emi.rpy:201
translate pt_br a3_emi_eet_ees_scienca_2d3e99ea:

    # mu "Well, sort of."
    mu "Bom, mais ou menos isso."

# game/script-a3-emi.rpy:206
translate pt_br a3_emi_eet_ees_scienca_4b406844:

    # mu "You could also join the science club!"
    mu "Você também poderia se juntar ao clube de ciências!"

# game/script-a3-emi.rpy:208
translate pt_br a3_emi_eet_ees_scienca_3957abb0:

    # mu "Trouble is, there's not actually a science club."
    mu "O problema é que… não temos um clube de ciências."

# game/script-a3-emi.rpy:210
translate pt_br a3_emi_eet_ees_scienca_73ff24fb:

    # mu "But there could be!"
    mu "Mas poderia ter!"

# game/script-a3-emi.rpy:212
translate pt_br a3_emi_eet_ees_scienca_327fb976:

    # mu "You could even be a charter member!"
    mu "Você pode até ser um membro do conselho!"

# game/script-a3-emi.rpy:214
translate pt_br a3_emi_eet_ees_scienca_bd9457aa:

    # mu "A founding father!"
    mu "Um pai fundador!"

# game/script-a3-emi.rpy:216
translate pt_br a3_emi_eet_ees_scienca_8eff14d6:

    # mu "Of course, you'd need to find other members."
    mu "Claro, você teria que procurar por outros membros."

# game/script-a3-emi.rpy:221
translate pt_br a3_emi_eet_ees_scienca_397c6726:

    # mu "Well, only if you wanted to."
    mu "Bom, só se você quisesse."

# game/script-a3-emi.rpy:223
translate pt_br a3_emi_eet_ees_scienca_1f341fff:

    # mu "We could just start it up with the two of us."
    mu "Poderiamos começar com só nós dois."

# game/script-a3-emi.rpy:225
translate pt_br a3_emi_eet_ees_scienca_0815dcf2:

    # mu "And um."
    mu "E… err…"

# game/script-a3-emi.rpy:230
translate pt_br a3_emi_eet_ees_scienca_35d9dc44:

    # mu "I could give you things to read, and we could talk about them."
    
    mu "Eu poderia te dar coisas para ler, e nós poderiamos falar sobre elas."

# game/script-a3-emi.rpy:232
translate pt_br a3_emi_eet_ees_scienca_0ae31207:

    # mu "Er, and I could help you get ready for university and such as well."
    mu "É, e eu poderia te ajudar a se preparar para a faculdade também."

# game/script-a3-emi.rpy:237
translate pt_br a3_emi_eet_ees_scienca_2d4fc22a:

    # mu "Wait!"
    mu "Espera!"

# game/script-a3-emi.rpy:239
translate pt_br a3_emi_eet_ees_scienca_43e0d8d6:

    # "Mutou rummages around in his briefcase and tosses me a book."
    "Mutou remexe na sua maleta e me entrega um livro."
    

# game/script-a3-emi.rpy:244
translate pt_br a3_emi_eet_ees_scienca_93e6a32a:

    # mu "Read that."
    mu "Leia isso."

# game/script-a3-emi.rpy:246
translate pt_br a3_emi_eet_ees_scienca_e13c6d18:

    # mu "If it's interesting, then we can talk about it."
    mu "Se lhe for interessante, a gente pode falar sobre isso."

# game/script-a3-emi.rpy:248
translate pt_br a3_emi_eet_ees_scienca_2ffb81b6:

    # "'A Brief History of Time?'"
    "“Uma Breve História do Tempo?”"

# game/script-a3-emi.rpy:250
translate pt_br a3_emi_eet_ees_scienca_acd6bd8c:

    # "I don't know if I actually want to read this, but Mutou seems pretty excited about it."
    "Eu não sei se eu quero ler isso mas Mutou parece bem empolgado."

# game/script-a3-emi.rpy:252
translate pt_br a3_emi_eet_ees_scienca_bd77b775:

    # hi "What's it about?"
    hi "É sobre o que?"

# game/script-a3-emi.rpy:257
translate pt_br a3_emi_eet_ees_scienca_d32f4c8f:

    # mu "Time. Space. Space-time. Black holes and such."
    
    mu "Tempo. Espaço. Espaço-tempo. Buracos negros. Essas coisas."

# game/script-a3-emi.rpy:259
translate pt_br a3_emi_eet_ees_scienca_e367fed6:

    # mu "And it's not that dense. Just to see if that sort of thing's interesting for you, you understand."
    mu "E não é tão complicado. Apenas para ver se é o tipo de coisa que te interessa, entende?"

# game/script-a3-emi.rpy:261
translate pt_br a3_emi_eet_ees_scienca_ba528a5b:

    # mu "Hang around after class, and we can either discuss it, or I can show you how to make explosives in the lab."
    mu "Fique aí depois da aula, e nós podemos discutir sobre ele, ou eu posso te ensinar a fazer explosivos no laboratório."

# game/script-a3-emi.rpy:266
translate pt_br a3_emi_eet_ees_scienca_b3b8effd:

    # "He waves a hand at my quizzical expression."
    "Ele acena com a mão em resposta à minha expressão confusa."

# game/script-a3-emi.rpy:268
translate pt_br a3_emi_eet_ees_scienca_ddc7b293:

    # mu "Joking, sorry."
    mu "Brincadeira, desculpe."

# game/script-a3-emi.rpy:270
translate pt_br a3_emi_eet_ees_scienca_3d64d466:

    # mu "Still, I've kept you here long enough for now."
    mu "Então, eu já te prendi por tempo o suficiente aqui."

# game/script-a3-emi.rpy:272
translate pt_br a3_emi_eet_ees_scienca_14119bd6:

    # mu "Think about science as a career path, Nakai. I think you'd enjoy it."
    mu "Pense na ciência como uma carreira, Nakai. Eu acho que você iria gostar."

# game/script-a3-emi.rpy:274
translate pt_br a3_emi_eet_ees_scienca_69cef357:

    # hi "Uh, okay. I will. Thank you for the book."
    
    hi "Eh, ok, eu vou pensar. Obrigado pelo livro."

# game/script-a3-emi.rpy:281
translate pt_br a3_emi_eet_ees_scienca_a72fedac:

    # "I leave the classroom and look up at the clock; quite a chunk of time to kill until Emi's out of practice."
    "Eu saio da sala de aula e olho para o relógio; um bom tempo para matar até a Emi sair do treino."

# game/script-a3-emi.rpy:283
translate pt_br a3_emi_eet_ees_scienca_41a18c00:

    # "Guess I'll give this book a look; I should probably shower as well."
    "Acho que vou dar uma olhada neste livro; eu provavelmente deveria tomar um banho também."

# game/script-a3-emi.rpy:285
translate pt_br a3_emi_eet_ees_scienca_0f93e60e:

    # "Showering before a date's only proper, right?"
    
    "Tomar um banho antes de um encontro é no mínimo apropriado, certo?"

# game/script-a3-emi.rpy:287
translate pt_br a3_emi_eet_ees_scienca_bc26944c:

    # "I head back to the dorms."
    "Eu volto aos dormitórios."

# game/script-a3-emi.rpy:292
translate pt_br a3_emi_eet_ees_scienca_0b897439:

    # "I wonder where I'm supposed to meet Emi, anyway."
    "De qualquer forma, eu me pergunto onde eu supostamente fiquei de encontrar ela."

# game/script-a3-emi.rpy:294
translate pt_br a3_emi_eet_ees_scienca_5b699534:

    # "She said 'after practice,' but she didn't say where I should find her."
    "Ela disse “depois do treino” mas não disse onde eu a encontraria."

# game/script-a3-emi.rpy:296
translate pt_br a3_emi_eet_ees_scienca_034f77f1:

    # "I guess I can just swing by the track; that's probably best, anyway."
    "Acho que eu posso passar pela pista de corrida, é provavelmente minha melhor chance de achá-la."

# game/script-a3-emi.rpy:298
translate pt_br a3_emi_eet_ees_scienca_5d80b459:

    # "If she needs a shower, I can just wait for her in her room or something."
    "Se ela precisar de um banho, eu posso esperá-la no quarto dela ou algo do tipo."

# game/script-a3-emi.rpy:300
translate pt_br a3_emi_eet_ees_scienca_727cb58d:

    # "Or in the hallway, I guess; that would be better as well."
    "Ou no corredor, eu acho; isso seria melhor também."

# game/script-a3-emi.rpy:302
translate pt_br a3_emi_eet_ees_scienca_b0473297:

    # "I take a quick shower, remembering to take my medication once I hop out."
    
    "Eu tomo um banho rápido, lembrando de tomar meu medicamento quando saio."

# game/script-a3-emi.rpy:304
translate pt_br a3_emi_eet_ees_scienca_dffd4234:

    # "Now, for a look at this book."
    "Agora, uma olhada nesse livro."

# game/script-a3-emi.rpy:322
translate pt_br a3_emi_definitions_4e17e492:

    # "I wake with a start."
    "Eu acordo em um pulo."

# game/script-a3-emi.rpy:324
translate pt_br a3_emi_definitions_ae963591:

    # "Shit! What time is it?"
    "Droga! Que horas são?"

# game/script-a3-emi.rpy:326
translate pt_br a3_emi_definitions_7acfdd73:

    # "A glance at the clock reveals that I've been asleep for nearly an hour."
    "Uma olhada no relógio mostra que eu cochilei por quase uma hora."

# game/script-a3-emi.rpy:328
translate pt_br a3_emi_definitions_e0485a22:

    # hi "Thank goodness."
    hi "Ainda bem."

# game/script-a3-emi.rpy:330
translate pt_br a3_emi_definitions_b4bf8be6:

    # "Emi's practice should be finishing up soon."
    "O treino da Emi deve terminar em breve."

# game/script-a3-emi.rpy:332
translate pt_br a3_emi_definitions_d00a63a9:

    # "I throw on some casual clothes and head for the track."
    "Eu visto umas roupas casuais e vou para a pista de corrida."

# game/script-a3-emi.rpy:337
translate pt_br a3_emi_definitions_53d50a9c:

    # "Somehow I get the feeling we won't be doing anything fancy for dinner."
    "De alguma forma eu tenho a sensação de que não teremos nada chique para o jantar."
    

# game/script-a3-emi.rpy:339
translate pt_br a3_emi_definitions_c4a17058:

    # "Emi doesn't strike me as a very fancy sort of person."
    "Emi não me parece ser esse tipo de pessoa refinada."

# game/script-a3-emi.rpy:341
translate pt_br a3_emi_definitions_54682d0e:

    # "Still, I suppose there's a lot I have yet to know about Emi."
    "Ainda sim, suponho que há muito o que eu ainda não sei sobre a Emi."

# game/script-a3-emi.rpy:343
translate pt_br a3_emi_definitions_d64ea69a:

    # "Despite our newfound closeness, I still feel like I don't know her as well as I should."
    "Apesar da nossa nova encontrada proximidade, eu sinto que não a conheço tão bem quanto deveria."

# game/script-a3-emi.rpy:345
translate pt_br a3_emi_definitions_147987d9:

    # "Ah well, I have lots of time to fix that."
    "Bem, não faz mal, eu tenho bastante tempo pra consertar isso."

# game/script-a3-emi.rpy:347
translate pt_br a3_emi_definitions_7f8abb80:

    # "To be honest, I'm looking forward to getting to know her more."
    "Para ser sincero, eu mal posso esperar para conhecê-la melhor."

# game/script-a3-emi.rpy:349
translate pt_br a3_emi_definitions_ad17c48d:

    # "I'm so caught up in my own thoughts that I hardly register that I'm already at the track."
    "Eu fico tão perdido nos meus pensamentos que mal percebo que já estou na pista de corrida."

# game/script-a3-emi.rpy:351
translate pt_br a3_emi_definitions_982a423b:

    # "Emi is nowhere to be found."
    "Emi não está em lugar algum."

# game/script-a3-emi.rpy:353
translate pt_br a3_emi_definitions_62893847:

    # "I don't even see any signs of the track team."
    "Eu não vejo sinais nem do time de corrida."

# game/script-a3-emi.rpy:355
translate pt_br a3_emi_definitions_0d2ea8a4:

    # "This could be embarrassing."
    "Isso pode vir a ser embaraçoso."

# game/script-a3-emi.rpy:357
translate pt_br a3_emi_definitions_1501abf3:

    # "I turn to head toward the girls' dormitory when I hear a shout."
    "Eu me direciono ao dormitório feminino quando ouço um grito."

# game/script-a3-emi.rpy:359
translate pt_br a3_emi_definitions_41268bd2:

    # emi "Hey, Hisao!"
    emi "Ei, Hisao!"

# game/script-a3-emi.rpy:366
translate pt_br a3_emi_definitions_0abe1912:

    # "I turn around to see Emi making a beeline for me with a gym bag slung over her shoulder."
    "Eu me viro para ver a Emi vindo em minha direção com uma mochila de ginásio no ombro."

# game/script-a3-emi.rpy:368
translate pt_br a3_emi_definitions_4cddf139:

    # "She's changed into some decidedly more casual clothing; a pair of shorts and an olive green top."
    "Ela se trocou para algo definitivamente mais casual, um shorts e um top verde-oliva."

# game/script-a3-emi.rpy:370
translate pt_br a3_emi_definitions_98275c52:

    # "Her running blades have been replaced by more realistic-looking legs that probably wouldn't fool anyone."
    "Suas próteses de corrida foram trocados por um par de pernas mais realísticas, que provavelmente enganariam a ninguém."

# game/script-a3-emi.rpy:372
translate pt_br a3_emi_definitions_750be4f9:

    # "Emi doesn't seem to care about that, a fact which makes me smile."
    "Emi não parece se importar com isso, um fato que me faz sorrir."

# game/script-a3-emi.rpy:377
translate pt_br a3_emi_definitions_26ec0a3e:

    # emi "Hey, you came!"
    emi "Ei, você veio!"

# game/script-a3-emi.rpy:382
translate pt_br a3_emi_definitions_207ff876:

    # emi "I mean I figured you would, but still…"
    emi "Quer dizer, eu imaginei que você viria, mas bem…"

# game/script-a3-emi.rpy:387
translate pt_br a3_emi_definitions_9c0aecca:

    # "I suddenly find myself wrapped in a rather affectionate hug, and it proves to be impossible for me to keep what must be the world's largest grin off my face."
    "De repente, sou abraçado de uma maneira bem amorosa e acaba sendo impossível esconder o maior sorriso do rosto."

# game/script-a3-emi.rpy:389
translate pt_br a3_emi_definitions_5f0487f3:

    # hi "Well, of course I came!"
    hi "Bom, é claro que eu vim!"

# game/script-a3-emi.rpy:391
translate pt_br a3_emi_definitions_24e52595:

    # hi "I'd be crazy not to, right?"
    hi "Eu seria louco se não viesse, certo?"

# game/script-a3-emi.rpy:393
translate pt_br a3_emi_definitions_9102d456:

    # "Emi ponders for a moment."
    "Emi pondera por um momento."

# game/script-a3-emi.rpy:398
translate pt_br a3_emi_definitions_25ceccab:

    # emi "You know, that's true."
    emi "Bem, é verdade."

# game/script-a3-emi.rpy:403
translate pt_br a3_emi_definitions_c159b678:

    # emi "I mean I'm pretty amazing, after all."
    
    emi "Quer dizer, eu sou bem incrível afinal de contas."

# game/script-a3-emi.rpy:405
translate pt_br a3_emi_definitions_a8f2ec77:

    # "I shrug in response."
    
    "Eu encolho os ombros em resposta."

# game/script-a3-emi.rpy:407
translate pt_br a3_emi_definitions_2d969fbf:

    # hi "I certainly think so."
    hi "Eu certamente concordo."

# game/script-a3-emi.rpy:412
translate pt_br a3_emi_definitions_4683b48d:

    # "It's an offhand remark, which is why I'm surprised to see that it seems to have caught Emi by surprise."
    "Eu falei por falar, o que me surpreende é que isso a pegou desprevenida."

# game/script-a3-emi.rpy:417
translate pt_br a3_emi_definitions_19867c98:

    # "She blushes and smiles warmly at me before planting a kiss on my lips."
    "Ela cora e sorri antes de me roubar um beijo nos lábios."

# game/script-a3-emi.rpy:419
translate pt_br a3_emi_definitions_1f941396:

    # "Now it's my turn to be surprised."
    
    "Agora é a minha vez de ser pego desprevenido."

# game/script-a3-emi.rpy:424
translate pt_br a3_emi_definitions_9e0d98a0:

    # "Emi steps back, resting her weight on her back heel, looking pleased with herself."
    "Emi dá um passo para trás, se apoiando nos calcanhares, parecendo feliz consigo mesma."

# game/script-a3-emi.rpy:426
translate pt_br a3_emi_definitions_7bd086b3:

    # "My brain fumbles for an appropriate response."
    
    "Meu cérebro se embaralha procurando por uma resposta apropriada."

# game/script-a3-emi.rpy:428
translate pt_br a3_emi_definitions_35c4f685:

    # hi "…"
    hi "…"

# game/script-a3-emi.rpy:430
translate pt_br a3_emi_definitions_5813ea8a:

    # hi "I should compliment you more often."
    hi "Eu devia te elogiar mais vezes."

# game/script-a3-emi.rpy:435
translate pt_br a3_emi_definitions_3feff31d:

    # "Emi laughs and gives me a playful shove."
    "Emi ri e de brincadeira me dá um empurrão."

# game/script-a3-emi.rpy:440
translate pt_br a3_emi_definitions_16762d09:

    # emi "Jerk."
    emi "Idiota."

# game/script-a3-emi.rpy:445
translate pt_br a3_emi_definitions_17633a63:

    # "I throw an arm around Emi's shoulders and am pleased when she immediately leans into me as if it were the most natural thing in the world."
    "Eu jogo um braço em volta dos ombros da Emi e fico feliz de ver que ela imediatamente se apoia em mim, como se fosse a coisa mais natural do mundo."

# game/script-a3-emi.rpy:447
translate pt_br a3_emi_definitions_16ab0094:

    # hi "So, where to?"
    hi "Então, para onde vamos?"

# game/script-a3-emi.rpy:452
translate pt_br a3_emi_definitions_b2652e9a:

    # emi "I'm not actually sure."
    emi "Eu não tenho certeza."

# game/script-a3-emi.rpy:457
translate pt_br a3_emi_definitions_69449bd2:

    # emi "Where do people go on dates around here, anyway?"
    emi "Aonde as pessoas vão por aqui afinal?"

# game/script-a3-emi.rpy:459
translate pt_br a3_emi_definitions_2f0b2a3e:

    # "That's a damned good question."
    "Essa é uma boa pergunta."

# game/script-a3-emi.rpy:461
translate pt_br a3_emi_definitions_bc03e87b:

    # hi "I've got no idea."
    hi "Eu tenho uma ideia."

# game/script-a3-emi.rpy:463
translate pt_br a3_emi_definitions_aeaf8e56:

    # hi "Why don't we just head down to the Aura-Mart and grab something portable?"
    
    hi "Por que não descemos até o Aura-Mart e compramos algo?"

# game/script-a3-emi.rpy:465
translate pt_br a3_emi_definitions_99b9c980:

    # "Emi's face brightens at this idea."
    "Emi parece gostar da ideia."

# game/script-a3-emi.rpy:470
translate pt_br a3_emi_definitions_b0f9bfdf:

    # emi "A picnic!"
    emi "Um piquenique!"

# game/script-a3-emi.rpy:475
translate pt_br a3_emi_definitions_01fb0b5f:

    # emi "I think you're on to something, Hisao."
    emi "Eu acho que você está no caminho certo, Hisao."

# game/script-a3-emi.rpy:480
translate pt_br a3_emi_definitions_45095e39:

    # "Emi snakes her arm around my waist, and we begin to head for the front gate."
    "Emi joga os braços em volta da minha cintura e começa a andar em direção ao portão principal."

# game/script-a3-emi.rpy:482
translate pt_br a3_emi_definitions_31c35444:

    # "I'm entirely unsure of what I'm meant to do in this situation, but at least Emi seems to be equally clueless."
    "Eu não tenho a menor ideia do que fazer nesta situação, mas pelo menos a Emi parece saber tanto quanto eu."

# game/script-a3-emi.rpy:487
translate pt_br a3_emi_definitions_c02b5568:

    # "Despite the relaxing feeling of being with Emi, I still can't help feeling a little tense."
    "Apesar de ser relaxante estar com a Emi, eu não consigo deixar de ficar um pouco tenso."

# game/script-a3-emi.rpy:489
translate pt_br a3_emi_definitions_19085674:

    # "What if I do something wrong?"
    "E se eu fizer algo errado?"

# game/script-a3-emi.rpy:491
translate pt_br a3_emi_definitions_8e94deef:

    # "I'd hate to make an ass out of myself."
    "Eu não quero parecer um babaca."

# game/script-a3-emi.rpy:496
translate pt_br a3_emi_definitions_e9ed1ae9:

    # "The trip to the Aura-Mart is accompanied by Emi's chatter about how practice went."
    "A viagem até o Aura-Mart é acompanhada pela Emi falando sobre o treino."

# game/script-a3-emi.rpy:498
translate pt_br a3_emi_definitions_b94a04f7:

    # "I keep quiet for the most part, merely enjoying the warmth of being around Emi."
    
    "Eu fico quieto pela maior parte do tempo, apenas aproveitando a sensação de estar perto da Emi."

# game/script-a3-emi.rpy:500
translate pt_br a3_emi_definitions_2975f30b:

    # "We get a few odd looks from passersby, but I don't mind."
    "Nós ganhamos alguns olhares indiscretos das pessoas que passam, mas eu não ligo."

# game/script-a3-emi.rpy:502
translate pt_br a3_emi_definitions_931be06b:

    # "We wind up buying some bread and instant noodles, realizing too late that we cannot actually cook the latter in the park."
    "Nós acabamos comprando pão e miojo, sendo tarde demais para perceber que não podemos cozinhar o mesmo no parque."

# game/script-a3-emi.rpy:507
translate pt_br a3_emi_definitions_c0b1087b:

    # emi "Oh well. I'll make it for lunch or something."
    emi "Fazer o quê. Eu cozinho no almoço ou algo do tipo."

# game/script-a3-emi.rpy:509
translate pt_br a3_emi_definitions_d858491e:

    # hi "That'll work."
    hi "Vai servir."

# game/script-a3-emi.rpy:518
translate pt_br a3_emi_definitions_3428ffca:

    # "The park is located after a brief loss of direction that I blame entirely on Emi."
    "Chegamos ao parque após uma breve falha de direção, a qual eu culpo inteiramente a Emi."

# game/script-a3-emi.rpy:520
translate pt_br a3_emi_definitions_4a3d4fc2:

    # "She, of course, blames me."
    "Ela, é claro, culpa a mim."

# game/script-a3-emi.rpy:529
translate pt_br a3_emi_definitions_1fc48247:

    # "We find a spot beneath a tree and sit down. I lean back against the trunk, Emi sits across from me."
    "Achamos um ótimo lugar embaixo de uma árvore para sentar. Eu me sento apoiado ao tronco e a Emi senta na minha frente."

# game/script-a3-emi.rpy:533
translate pt_br a3_emi_definitions_34ab8448:

    # hi "I guess we should have brought a blanket or something to sit on, huh?"
    hi "Acho que devíamos ter trazido um pano para sentar em cima né?"

# game/script-a3-emi.rpy:541
translate pt_br a3_emi_definitions_18357699:

    # "Emi shrugs."
    "Emi encolhe os ombros."

# game/script-a3-emi.rpy:546
translate pt_br a3_emi_definitions_5d96d514:

    # emi "I don't mind."
    emi "Eu não ligo."

# game/script-a3-emi.rpy:548
translate pt_br a3_emi_definitions_6e7ddf6e:

    # hi "Neither do I."
    hi "Nem eu."

# game/script-a3-emi.rpy:553
translate pt_br a3_emi_definitions_d856fafa:

    # "Emi tosses me a package of bread and we dig in."
    
    "Emi me joga o pão e nós começamos a comer."

# game/script-a3-emi.rpy:555
translate pt_br a3_emi_definitions_9c52b46c:

    # "Curry bread. Interesting."
    "Pão de curry. Interessante."

# game/script-a3-emi.rpy:557
translate pt_br a3_emi_definitions_e0d3cfe1:

    # "I guess I wasn't really paying attention to what I grabbed in the store."
    
    "Acho que eu não estava prestando atenção ao que estava pegando na loja."

# game/script-a3-emi.rpy:562
translate pt_br a3_emi_definitions_86ccae53:

    # emi "Hey, Hisao. You look like your bread's a little spicy."
    emi "Ei Hisao. Você tá com uma cara de que seu pão é um pouco picante."

# game/script-a3-emi.rpy:564
translate pt_br a3_emi_definitions_50b71ca0:

    # "I shake my head, trying in vain to keep an image of manliness."
    "Eu balanço a cabeça, tentando, em vão, manter minha imagem de machão."

# game/script-a3-emi.rpy:566
translate pt_br a3_emi_definitions_56db316a:

    # hi "Nah, it's hardly spicy at all."
    hi "Não, nem está tão picante assim."

# game/script-a3-emi.rpy:571
translate pt_br a3_emi_definitions_98ecd4c9:

    # emi "I see, I see. That must be why your face has gotten so red."
    emi "Entendo. Deve ser por isso que sua cara tá toda vermelha."

# game/script-a3-emi.rpy:573
translate pt_br a3_emi_definitions_1611df17:

    # hi "Yes, exactly. The lack of spice has uh… gotten my blood up."
    hi "Sim, exatamente. A falta de tempero me err… deixou com o sangue fervendo."

# game/script-a3-emi.rpy:575
translate pt_br a3_emi_definitions_340c3bb1:

    # hi "Because of the disappointment."
    hi "Pois é desapontador."

# game/script-a3-emi.rpy:580
translate pt_br a3_emi_definitions_6440aad7:

    # "Emi laughs and swallows the last of her bread."
    "Emi ri e engole o resto do pão."

# game/script-a3-emi.rpy:585
translate pt_br a3_emi_definitions_70f1afd2:

    # emi "Well, if you can't handle it, I'll be glad to take it off of your hands."
    emi "Bom, se você não estiver aguentando, eu ficaria feliz de tirar da sua mão."

# game/script-a3-emi.rpy:587
translate pt_br a3_emi_definitions_e4fd05f9:

    # hi "Hey, just because you wolfed down yours so quickly doesn't mean I'm just going to give you mine."
    hi "Ei, só porque você devorou o seu tão rapido não quer dizer que eu vou te dar o meu."

# game/script-a3-emi.rpy:592
translate pt_br a3_emi_definitions_283f3afa:

    # "Emi mock-pouts, causing me to nearly choke on my bread with laughter."
    "Emi faz um beicinho, fazendo com que eu quase engasgue com meu pão rindo."

# game/script-a3-emi.rpy:594
translate pt_br a3_emi_definitions_674ffc1d:

    # emi "Aw, come on Hisao!"
    emi "Ah, fala sério Hisao!"

# game/script-a3-emi.rpy:599
translate pt_br a3_emi_definitions_0fe62206:

    # emi "Aren't you supposed to be concerned with making sure I've got enough to eat now?"
    emi "Você não deveria estar preocupado em ter certeza que eu estou comendo o suficiente?"

# game/script-a3-emi.rpy:601
translate pt_br a3_emi_definitions_e77ec99f:

    # emi "We're dating, you know!"
    emi "Estamos namorando!"

# game/script-a3-emi.rpy:606
translate pt_br a3_emi_definitions_7843de3e:

    # emi "Though…"
    emi "Apesar que…"

# game/script-a3-emi.rpy:608
translate pt_br a3_emi_definitions_8dbd99ba:

    # "Emi looks troubled all of a sudden."
    "Emi parece um pouco incomodada de repente."

# game/script-a3-emi.rpy:613
translate pt_br a3_emi_definitions_359d541d:

    # emi "I can't say I feel any different."
    emi "Eu não me sinto diferente."

# game/script-a3-emi.rpy:615
translate pt_br a3_emi_definitions_0ed9b29d:

    # hi "Hmm? What do you mean by that?"
    hi "Hmm? O que você quer dizer com isso?"

# game/script-a3-emi.rpy:620
translate pt_br a3_emi_definitions_185bd514:

    # emi "What makes this a date?"
    emi "O que faz disso um encontro?"

# game/script-a3-emi.rpy:622
translate pt_br a3_emi_definitions_25ddb460:

    # emi "It's just what we would have done anyway, really."
    emi "É apenas o que nós teríamos feito de qualquer forma."

# game/script-a3-emi.rpy:624
translate pt_br a3_emi_definitions_e732113a:

    # emi "But this should feel different because before when we had lunch we were friends, and now we're a level above friends."
    emi "Mas isso deveria me fazer sentir diferente, antes do almoço éramos amigos e agora estamos um nível acima."

# game/script-a3-emi.rpy:626
translate pt_br a3_emi_definitions_a4f727d4:

    # hi "You sound like Rin."
    hi "Você está parecendo a Rin."

# game/script-a3-emi.rpy:631
translate pt_br a3_emi_definitions_9bf45d72:

    # "Laughter escapes, and Emi grins."
    "Uma risada escapa e Emi sorri."

# game/script-a3-emi.rpy:636
translate pt_br a3_emi_definitions_ab5e369e:

    # emi "Well, she might've put the thought into my mind."
    
    emi "Bom, ela teria algo a dizer sobre isso."

# game/script-a3-emi.rpy:641
translate pt_br a3_emi_definitions_cfa3e65c:

    # emi "We've talked about that sort of thing before."
    emi "Nós já conversamos sobre isso antes."

# game/script-a3-emi.rpy:643
translate pt_br a3_emi_definitions_b5b7ab38:

    # hi "Really? About me?"
    hi "Sério? Sobre mim?"

# game/script-a3-emi.rpy:648
translate pt_br a3_emi_definitions_80c5290c:

    # emi "Not really. Just… stuff, really."
    
    emi "Não exatamente. Apenas… algumas coisas."

# game/script-a3-emi.rpy:653
translate pt_br a3_emi_definitions_3d57e5f4:

    # emi "Rin thinks that the change of a label from 'friend' to 'girlfriend' seems arbitrary most of the time."
    emi "Rin pensa que a mudança do título de “amiga” para “namorada” é abitrário na maioria das vezes."

# game/script-a3-emi.rpy:655
translate pt_br a3_emi_definitions_8607efdf:

    # emi "Like there's no difference between the two."
    emi "Como se não houvesse diferença entre os dois."

# game/script-a3-emi.rpy:657
translate pt_br a3_emi_definitions_4365fd69:

    # hi "I can think of at least one, you know."
    hi "Eu consigo pensar em pelo menos uma."

# game/script-a3-emi.rpy:659
translate pt_br a3_emi_definitions_a47326ea:

    # hi "You don't tend to kiss your friends quite as much."
    hi "Você não costuma beijar seus amigos."

# game/script-a3-emi.rpy:664
translate pt_br a3_emi_definitions_ab0f69d4:

    # "For the second time today, Emi blushes slightly and giggles."
    "Pela segunda vez no dia, Emi cora e dá uma risadinha."

# game/script-a3-emi.rpy:669
translate pt_br a3_emi_definitions_189bb8ec:

    # emi "I suppose you're right."
    
    emi "Você pode ter razão."

# game/script-a3-emi.rpy:671
translate pt_br a3_emi_definitions_74a346d6:

    # hi "Exactly. I'm always right about things like this."
    
    hi "Exato. Eu estou sempre certo nesse assunto."

# game/script-a3-emi.rpy:676
translate pt_br a3_emi_definitions_7053469f:

    # "Emi rolls her eyes and chuckles."
    "Emi da uma risada sarcástica e rola os olhos."

# game/script-a3-emi.rpy:678
translate pt_br a3_emi_definitions_dba05d1d:

    # emi "Guess you're pretty smart, huh?"
    
    emi "Acho que você é bem esperto, né?"

# game/script-a3-emi.rpy:680
translate pt_br a3_emi_definitions_0066f219:

    # "I nod in agreement."
    "Eu balanço a cabeça concordando."

# game/script-a3-emi.rpy:682
translate pt_br a3_emi_definitions_89a9aa28:

    # hi "Yep."
    hi "Yep."

# game/script-a3-emi.rpy:684
translate pt_br a3_emi_definitions_187c0350:

    # hi "Even Mutou thinks so. He thinks I should go into some scientific study after graduation."
    
    hi "Até o Mutou pensa que sim. Ele acha que eu deveria estudar alguma ciência depois de me formar."

# game/script-a3-emi.rpy:689
translate pt_br a3_emi_definitions_3de31db1:

    # "Emi raises an eyebrow."
    "Emi levanta uma sombrancelha."

# game/script-a3-emi.rpy:691
translate pt_br a3_emi_definitions_778a2d5a:

    # emi "Oh really?"
    emi "Não diga."

# game/script-a3-emi.rpy:693
translate pt_br a3_emi_definitions_f247f138:

    # hi "Yeah, I'm thinking I actually might do just that."
    hi "Sim, e eu acho que eu provavelmente vou fazer isso mesmo."

# game/script-a3-emi.rpy:695
translate pt_br a3_emi_definitions_ee390c3b:

    # "Really, the more I consider the idea, the more it appeals to me."
    
    "Sério, quanto mais eu considero a ideia, mais ela me parece atraente."

# game/script-a3-emi.rpy:697
translate pt_br a3_emi_definitions_1a5f1045:

    # "I make a mental note to look into it a little more closely."
    "Eu faço uma nota mental pra pensar nisso com mais cuidado mais tarde."

# game/script-a3-emi.rpy:699
translate pt_br a3_emi_definitions_1ed9dcba:

    # hi "So what are you thinking of doing after graduation?"
    hi "E você, o que pensa em fazer depois de se formar?"

# game/script-a3-emi.rpy:701
translate pt_br a3_emi_definitions_66b207d9:

    # hi "Still planning on running?"
    hi "Ainda planeja correr?"

# game/script-a3-emi.rpy:706
translate pt_br a3_emi_definitions_7a2119e0:

    # "Emi shrugs, seeming almost a bit hesitant."
    "Emi encolhe os ombros, parecendo um pouco hesitante."

# game/script-a3-emi.rpy:711
translate pt_br a3_emi_definitions_ee17fe9f:

    # emi "I dunno. If I'm good enough and I can find a team, I guess?"
    emi "Não sei. Se eu for boa o suficiente e conseguir encontrar um time, eu acho?"

# game/script-a3-emi.rpy:713
translate pt_br a3_emi_definitions_56c5e17e:

    # hi "You mean you aren't sure?"
    hi "Quer dizer que você não tem certeza?"

# game/script-a3-emi.rpy:718
translate pt_br a3_emi_definitions_78e9f252:

    # emi "I haven't… really thought about it, to be honest."
    emi "Eu não… tenho pensado muito sobre isso pra falar a verdade."

# game/script-a3-emi.rpy:720
translate pt_br a3_emi_definitions_ff728ce7:

    # hi "Really?"
    hi "Sério?"
    

# game/script-a3-emi.rpy:722
translate pt_br a3_emi_definitions_79aab26d:

    # hi "You probably should, you know. Graduation isn't that far off."
    
    hi "Você provavelmente deveria, sabe. A graduação não está tão longe."

# game/script-a3-emi.rpy:727
translate pt_br a3_emi_definitions_4ac557af:

    # "Emi fidgets a little nervously."
    
    "Emi fica inquieta e um pouco desconfortável."

# game/script-a3-emi.rpy:729
translate pt_br a3_emi_definitions_adf1802f:

    # emi "Yeah, well… it's far enough, right?"
    emi "É, bem… está longe o suficiente, certo?"

# game/script-a3-emi.rpy:734
translate pt_br a3_emi_definitions_abc055a6:

    # emi "Besides, I've got other things to think about."
    emi "Além de que, eu tenho outras coisas a pensar."

# game/script-a3-emi.rpy:739
translate pt_br a3_emi_definitions_534a36fa:

    # "There's a mischievous flash behind Emi's eyes, and I suddenly find myself gloriously pinned against the tree."
    "Um brilho malicioso passa nos olhos da Emi e eu me encontro gloriosamente pressionado contra a árvore."

# game/script-a3-emi.rpy:744
translate pt_br a3_emi_definitions_757b745b:

    # emi "Like making sure this is a real date, right?"
    emi "Como fazer com que esse seja um encontro de verdade, certo?"

# game/script-a3-emi.rpy:749
translate pt_br a3_emi_definitions_34b65fd9:

    # emi "I mean if we don't kiss then it's not a date at all, right?"
    emi "Quer dizer, se não nos beijarmos não é um encontro de verdade, certo?"

# game/script-a3-emi.rpy:751
translate pt_br a3_emi_definitions_fb9580dd:

    # hi "I suppose s— mmmph." with vpunch
    hi "Eu suponho q- mmmph." with vpunch

# game/script-a3-emi.rpy:753
translate pt_br a3_emi_definitions_2eea2b94:

    # "Strawberries and curry. Not the best combination, but I don't think I mind."
    "Morangos e curry. Não é a melhor combinação mas eu acho que não me importo."

# game/script-a3-emi.rpy:758
translate pt_br a3_emi_definitions_6eb7b73a:

    # "Emi sits back on my legs and grins again."
    "Emi se senta nas minhas pernas e sorri de novo."

# game/script-a3-emi.rpy:760
translate pt_br a3_emi_definitions_9cd04634:

    # emi "There. Science would approve, right?"
    emi "Aí, a ciência aprovaria não é?"

# game/script-a3-emi.rpy:762
translate pt_br a3_emi_definitions_5f131064:

    # "I have the oddest mental image of Mutou nodding seriously and making a mark on some checklist."
    "Eu tenho a estranha imagem mental do Mutou balançando a cabeça seriamente e marcando um “X” em um item da lista."

# game/script-a3-emi.rpy:764
translate pt_br a3_emi_definitions_8dcd2f99:

    # "I can't help laughing at the idea."
    "Eu não consigo não rir da ideia."

# game/script-a3-emi.rpy:769
translate pt_br a3_emi_definitions_a334c6e2:

    # emi "Well I'll admit, this is the first time I've ever witnessed a kiss being met with laughter."
    emi "Bom, eu admito, é a primeira vez que eu vejo um beijo ser respondido com uma risada."

# game/script-a3-emi.rpy:771
translate pt_br a3_emi_definitions_9ad75397:

    # emi "Should I feel offended?"
    emi "Eu deveria me sentir ofendida?"

# game/script-a3-emi.rpy:773
translate pt_br a3_emi_definitions_78097132:

    # hi "Heh, no, no."
    hi "Heh, não, não."

# game/script-a3-emi.rpy:775
translate pt_br a3_emi_definitions_e75a4180:

    # hi "I'm sure science approves."
    hi "Tenho certeza que a ciência aprova."

# game/script-a3-emi.rpy:780
translate pt_br a3_emi_definitions_082fc6bd:

    # "Emi beams at me, and I find it increasingly difficult to keep my brain functioning properly."
    "Emi parece radiante, tão radiante que fica cada vez mais difícil manter meu cérebro funcionando corretamente."

# game/script-a3-emi.rpy:782
translate pt_br a3_emi_definitions_b1c20091:

    # emi "Oh good!"
    emi "Ah que bom!"

# game/script-a3-emi.rpy:784
translate pt_br a3_emi_definitions_6f8f5ce2:

    # "It is at this point I notice that Emi has stolen the remainder of my curry bread while I was otherwise occupied with images of teachers wielding clipboards."
    "É nesse momento que eu percebo que a Emi roubou o resto do meu pão de curry enquanto eu estava ocupado com imagens de professores com pranchetas."

# game/script-a3-emi.rpy:786
translate pt_br a3_emi_definitions_d5322af5:

    # hi "Hey!"
    hi "Ei!"

# game/script-a3-emi.rpy:791
translate pt_br a3_emi_definitions_16bdb200:

    # "Emi tries to look innocent, but considering she's just crammed the last bits of my bread into her mouth it does not appear to be working."
    "Emi tenta parecer inocente mas não parece funcionar já que ela acabou de empurrar o último pedaço de pão pra dentro da boca."

# game/script-a3-emi.rpy:793
translate pt_br a3_emi_definitions_5124487e:

    # emi "Mmph? F'orry, couln't refisft."
    emi "Mmph? F'esculpa não v'esisti."

# game/script-a3-emi.rpy:795
translate pt_br a3_emi_definitions_60aeb693:

    # hi "Thief!"
    hi "Ladra!"

# game/script-a3-emi.rpy:800
translate pt_br a3_emi_definitions_c1609e14:

    # "A shrug from my companion is all I get in response."
    "Minha única resposta é um encolho de ombros."

# game/script-a3-emi.rpy:802
translate pt_br a3_emi_definitions_a583e1e9:

    # hi "You used your feminine wiles on me!"
    hi "Você usou seus dotes femininos em mim!"

# game/script-a3-emi.rpy:804
translate pt_br a3_emi_definitions_9ceb18fd:

    # "I wasn't that hungry anyway, but I still feel that the point needs to be made."
    "Eu não estava tão faminto mas sinto que a bronca deve ser dada."

# game/script-a3-emi.rpy:809
translate pt_br a3_emi_definitions_3ad5a485:

    # "Emi seems confused by the phrase 'feminine wiles,' but the understanding dawns on her features after a moment's thought."
    "Emi parece confusa com a frase “dotes femininos” mas o entendimento cai a ela depois de um momento de pensamento."

# game/script-a3-emi.rpy:814
translate pt_br a3_emi_definitions_c32ac0f7:

    # emi "Wasn't anything of the sort!"
    emi "Não foi nada do tipo!"

# game/script-a3-emi.rpy:819
translate pt_br a3_emi_definitions_5126aeb3:

    # emi "You were laughing! Feminine wiles don't involve laughing!"
    emi "Você estava rindo! Dotes femininos não envolvem risadas!"

# game/script-a3-emi.rpy:821
translate pt_br a3_emi_definitions_469cb850:

    # "I guess I can't argue with this."
    "Acho que não posso argumentar com isso."

# game/script-a3-emi.rpy:823
translate pt_br a3_emi_definitions_2838d1b0:

    # hi "That doesn't change your thievery."
    hi "Isso não muda sua ladroagem."

# game/script-a3-emi.rpy:828
translate pt_br a3_emi_definitions_830b4959:

    # "Emi laughs at my injured tone and gives me a playful shove."
    "Emi ri do meu tom de sentido e me dá um empurrão de brincadeira."

# game/script-a3-emi.rpy:833
translate pt_br a3_emi_definitions_5006dc3c:

    # emi "Fine, you can have the instant noodles."
    emi "Tudo bem, você pode ficar com o macarrão."

# game/script-a3-emi.rpy:835
translate pt_br a3_emi_definitions_2cf5043f:

    # hi "Are you kidding? That stuff's terrible!"
    hi "Tá de brincadeira? Aquilo é horrível!"

# game/script-a3-emi.rpy:837
translate pt_br a3_emi_definitions_6a9d4567:

    # hi "If anything, you should definitely eat it as punishment!"
    hi "Você que deveria comê-lo como punição!"

# game/script-a3-emi.rpy:842
translate pt_br a3_emi_definitions_1fb59a7d:

    # "Another laugh from the girl sitting on my legs."
    "Outra risada da garota sentada nas minhas pernas."

# game/script-a3-emi.rpy:844
translate pt_br a3_emi_definitions_c470ba8c:

    # "…Both of which have fallen asleep by now."
    "…ambas as quais já estão dormentes."

# game/script-a3-emi.rpy:861
translate pt_br a3_emi_definitions_2ec1ccdd:

    # "I twitch one leg to try waking it up, which has the unintended effect of unbalancing Emi, who falls to the side with a startled 'Eep!'"
    "Eu mexo uma perna para tentar fazer o sangue correr, o que tem o efeito não intencional de desequilibrar a Emi, que cai para o lado com um “Opa!”"

# game/script-a3-emi.rpy:863
translate pt_br a3_emi_definitions_291ee975:

    # hi "Whoops! Sorry about that."
    hi "Opa! Desculpa."

# game/script-a3-emi.rpy:865
translate pt_br a3_emi_definitions_273ebd02:

    # hi "Legs fell asleep on me."
    hi "Minhas pernas ficaram dormentes."

# game/script-a3-emi.rpy:867
translate pt_br a3_emi_definitions_3f396131:

    # "Emi remains on the ground, giggling."
    "Emi fica no chão, rindo."

# game/script-a3-emi.rpy:869
translate pt_br a3_emi_definitions_5f8dd429:

    # "I stand up a little shakily, feeling the nerves in my legs return to normal."
    "Eu me levanto um pouco bambo, sentindo os nervos das minhas pernas voltando ao normal."

# game/script-a3-emi.rpy:871
translate pt_br a3_emi_definitions_0952903a:

    # "My eyes wander over the scenery before fixing on the figure of Emi, who has yet to get up."
    "Meus olhos passam pelo cenário antes de se fixarem na Emi que ainda não levantou."

# game/script-a3-emi.rpy:878
translate pt_br a3_emi_definitions_4b15e252:

    # "Her hair is splayed out around her head, her arms are spread, and laughter is bubbling up through her mouth."
    "Seu cabelo está espalhado em volta da cabeça, seus braços abertos e uma risada está quase saindo dela."

# game/script-a3-emi.rpy:880
translate pt_br a3_emi_definitions_a5f2b003:

    # "Everything about Emi seems condensed into this one image."
    "Tudo sobre a Emi se resume nessa imagem."

# game/script-a3-emi.rpy:882
translate pt_br a3_emi_definitions_ed9b9d89:

    # "Her energy, her spirit, her childish giggling."
    "Sua energia, seu espírito, sua risada infantil."

# game/script-a3-emi.rpy:884
translate pt_br a3_emi_definitions_b1033e1c:

    # "The urge to lay down on the grass with her rises swiftly from the back of my mind to the forefront of my thoughts, and indeed I am convinced that I would love nothing more than to do just that."
    "Me sinto impelido a deitar no chão com ela e me convenço de que eu gostaria de nada menos que isso."

# game/script-a3-emi.rpy:886
translate pt_br a3_emi_definitions_0ddc4540:

    # "Unfortunately the sun has set, and it is probably time for us to get back to the dormitories."
    "Infelizmente o sol se pôs e provavelmente já é hora de voltar aos dormitórios."

# game/script-a3-emi.rpy:888
translate pt_br a3_emi_definitions_aa57e11c:

    # "While Emi may be happy to stay out here all night, I don't think I have that ability."
    "Enquanto a Emi estaria satisfeita em ficar aqui fora a noite toda eu não acho que tenho essa habilidade."

# game/script-a3-emi.rpy:890
translate pt_br a3_emi_definitions_7c9fa530:

    # "Besides, homework soon beckons."
    "Ainda porque a lição de casa me chama."

# game/script-a3-emi.rpy:892
translate pt_br a3_emi_definitions_aed72eb6:

    # "It wouldn't make sense to start thinking about things like university and then slack off, would it?"
    "Não faria sentido começar a pensar na faculdade e depois relaxar, faria?"

# game/script-a3-emi.rpy:894
translate pt_br a3_emi_definitions_32f3fc84:

    # "I extend a hand to Emi to help her up."
    "Eu ofereço a mão para ajudar a Emi a se levantar."

# game/script-a3-emi.rpy:896
translate pt_br a3_emi_definitions_51333a40:

    # hi "We should probably get going."
    hi "Nós provavelmente deveríamos voltar."

# game/script-a3-emi.rpy:901
translate pt_br a3_emi_definitions_4286a386:

    # "Emi makes a sour face."
    "Emi faz uma cara amarga."

# game/script-a3-emi.rpy:903
translate pt_br a3_emi_definitions_460a04ca:

    # emi "You're right."
    emi "Você está certo."

# game/script-a3-emi.rpy:916
translate pt_br a3_emi_definitions_08f83901:

    # "She grabs my proffered hand, and I pull her to her feet and into a hug."
    "Ela pega a minha mão e eu puxo ela para um abraço."

# game/script-a3-emi.rpy:918
translate pt_br a3_emi_definitions_b8bd7b98:

    # "This time I'm the one who kisses her, unable to resist having Emi against me."
    "Dessa vez eu que a beijo, não conseguindo resistir a Emi pressionada contra mim."

# game/script-a3-emi.rpy:920
translate pt_br a3_emi_definitions_dc71697a:

    # hi "Seems a shame to leave, you know."
    hi "Mas é uma pena ter que ir."

# game/script-a3-emi.rpy:925
translate pt_br a3_emi_definitions_7cbaab54:

    # emi "Yeah, it does."
    emi "É, uma pena."

# game/script-a3-emi.rpy:930
translate pt_br a3_emi_definitions_6d58aebc:

    # emi "But if we don't get back to the school soon, we'll probably get into trouble."
    emi "Mas se não voltarmos à escola logo provavelmente arranjaremos problemas."

# game/script-a3-emi.rpy:932
translate pt_br a3_emi_definitions_4790dc4f:

    # "Emi pokes me in the ribs playfully."
    "Emi me cutuca na costela de brincadeira."

# game/script-a3-emi.rpy:937
translate pt_br a3_emi_definitions_6b65809e:

    # emi "And you need to do your homework, I'm sure."
    emi "E você precisa fazer sua lição de casa, eu aposto."

# game/script-a3-emi.rpy:939
translate pt_br a3_emi_definitions_37495b88:

    # hi "Sadly, you're absolutely right."
    hi "Infelizmente, você está absolutamente correta."

# game/script-a3-emi.rpy:944
translate pt_br a3_emi_definitions_7613d788:

    # "I throw my arm around her shoulders, and we make the trek back to the school, accompanied by occasional bouts of laughter as our conversation jumps from subject to subject."
    "Eu jogo meus braços em volta dos ombros dela e nós fazemos o caminho de volta à escola acompanhado por algumas risadas enquanto a conversa muda de assunto para assunto."

# game/script-a3-emi.rpy:946
translate pt_br a3_emi_definitions_a0b31930:

    # "Everything from running, to school, to the peculiar way that one of the cafeteria workers smells."
    "Tudo, corrida, escola e até um cheiro peculiar que um dos servidores do refeitório tem."

# game/script-a3-emi.rpy:953
translate pt_br a3_emi_definitions_7197d70c:

    # "All too soon we find ourselves outside of the girls' dormitory building."
    "Mais cedo do que o esperado, nos encontramos em frente do dormitório feminino."

# game/script-a3-emi.rpy:958
translate pt_br a3_emi_definitions_1d97fae6:

    # emi "Well, I guess I'll be going, then."
    emi "Bom, acho que vou indo então."

# game/script-a3-emi.rpy:960
translate pt_br a3_emi_definitions_29155028:

    # hi "I guess so, huh?"
    hi "Acho que sim, né?"

# game/script-a3-emi.rpy:965
translate pt_br a3_emi_definitions_2f477bb4:

    # "Emi grins at me again with that mischievous look."
    "Emi dá uma risada me dando aquele olhar malicioso."

# game/script-a3-emi.rpy:967
translate pt_br a3_emi_definitions_ae031d32:

    # emi "Are you going to be able to survive without me?"
    emi "Você vai conseguir sobreviver sem mim?"

# game/script-a3-emi.rpy:969
translate pt_br a3_emi_definitions_e33f02ef:

    # "I laugh."
    "Eu rio."

# game/script-a3-emi.rpy:971
translate pt_br a3_emi_definitions_f524916a:

    # hi "I'm sure I'll manage."
    hi "Eu dou um jeito."

# game/script-a3-emi.rpy:976
translate pt_br a3_emi_definitions_61a5fa32:

    # emi "How terrible! Aren't you supposed to say something like 'I'll be counting the seconds you are away?'"
    emi "Que horrível! Você não deveria dizer algo como “Estarei contando os segundos?”"

# game/script-a3-emi.rpy:978
translate pt_br a3_emi_definitions_c25de446:

    # hi "Nah, I don't think so."
    hi "Não, acho que não."

# game/script-a3-emi.rpy:986
translate pt_br a3_emi_definitions_81b3f5c2:

    # "Emi pulls me down into a quick goodbye kiss and steps back, looking unexpectedly shy."
    "Emi me puxa pra um beijo de despedida e dá um passo pra trás, parecendo inesperadamente tímida."

# game/script-a3-emi.rpy:988
translate pt_br a3_emi_definitions_476cb873:

    # emi "Thanks for dinner."
    emi "Obrigada pelo jantar."

# game/script-a3-emi.rpy:990
translate pt_br a3_emi_definitions_d0f45900:

    # emi "I really had fun."
    emi "Eu me diverti bastante."

# game/script-a3-emi.rpy:995
translate pt_br a3_emi_definitions_30b916fe:

    # emi "Honestly, I did."
    emi "Sério, eu adorei."

# game/script-a3-emi.rpy:997
translate pt_br a3_emi_definitions_659fb68f:

    # hi "So did I."
    hi "Eu também."

# game/script-a3-emi.rpy:999
translate pt_br a3_emi_definitions_d0f01ea9:

    # hi "I think we shall have to do it again, sometime."
    hi "Eu acho que nós temos que fazer de novo algum dia."

# game/script-a3-emi.rpy:1004
translate pt_br a3_emi_definitions_f3d180ed:

    # "Emi laughs at my deadpan delivery and nods."
    "Emi ri da minha face sem expressão e balança a cabeça."

# game/script-a3-emi.rpy:1006
translate pt_br a3_emi_definitions_0ec3426f:

    # emi "See you bright and early tomorrow morning, right?"
    emi "Te vejo cedo e animado pela manhã, certo?"

# game/script-a3-emi.rpy:1011
translate pt_br a3_emi_definitions_793f8f55:

    # emi "You've gotta run off that bread, after all."
    emi "Você tem que correr e gastar aquele pão, afinal de contas."

# game/script-a3-emi.rpy:1013
translate pt_br a3_emi_definitions_ffe65bfb:

    # hi "Of course. Despite the fact that you ate most of it."
    hi "É claro, apesar do fato de que você comeu a maior parte dele."

# game/script-a3-emi.rpy:1018
translate pt_br a3_emi_definitions_df12de13:

    # emi "Yes, despite that."
    emi "Sim, apesar disso."

# game/script-a3-emi.rpy:1023
translate pt_br a3_emi_definitions_5bf52d09:

    # emi "See you later, Hisao!"
    emi "Até mais Hisao!"

# game/script-a3-emi.rpy:1034
translate pt_br a3_emi_definitions_eeeab59e:

    # "As Emi turns to head inside, I notice something weird."
    "Emi se vira para entrar e eu percebo algo estranho."

# game/script-a3-emi.rpy:1036
translate pt_br a3_emi_definitions_ec05250b:

    # "Something so weird that I'm surprised I didn't notice it earlier."
    "Algo tão estranho que eu fico surpreso que eu não tenha percebido antes."

# game/script-a3-emi.rpy:1038
translate pt_br a3_emi_definitions_61603032:

    # "She's limping slightly, favoring the left leg."
    "Ela está mancando um pouco, favorecendo a perna esquerda."

# game/script-a3-emi.rpy:1042
translate pt_br a3_emi_definitions_8659879e:

    # hi "Hey, Emi!"
    hi "Ei, Emi!"

# game/script-a3-emi.rpy:1053
translate pt_br a3_emi_definitions_19972527:

    # emi "Hmm?"
    emi "Hmm?"

# game/script-a3-emi.rpy:1055
translate pt_br a3_emi_definitions_79b3d0dc:

    # hi "Is your leg okay?"
    hi "Sua perna está bem?"

# game/script-a3-emi.rpy:1060
translate pt_br a3_emi_definitions_120a2642:

    # "Emi looks confused, or at least fakes confusion."
    "Emi parece confusa, ou pelo menos finge estar confusa."

# game/script-a3-emi.rpy:1065
translate pt_br a3_emi_definitions_a0a354f2:

    # emi "What are you talking about?"
    emi "Do que você está falando?"

# game/script-a3-emi.rpy:1067
translate pt_br a3_emi_definitions_21b9321f:

    # hi "Your right leg. You're limping."
    hi "Sua perna direita. Você está mancando."

# game/script-a3-emi.rpy:1075
translate pt_br a3_emi_definitions_afd871b2:

    # "There's the briefest flash of concern on Emi's face."
    "Preocupação brilha rapidamente no rosto da Emi."

# game/script-a3-emi.rpy:1077
translate pt_br a3_emi_definitions_9e79cfcb:

    # "Either she didn't want me to know, or she didn't think I'd notice - or, I prefer to think, she just didn't realize it."
    "Ou ela não queria que eu soubesse, ou ela pensou que eu não perceberia- ou, eu prefiro pensar, ela apenas não tinha percebido."

# game/script-a3-emi.rpy:1082
translate pt_br a3_emi_definitions_508517ae:

    # emi "Oh, that."
    emi "Ah, isso."

# game/script-a3-emi.rpy:1084
translate pt_br a3_emi_definitions_88ed0cab:

    # "She shrugs casually."
    "Ela encolhe os ombros casualmente."

# game/script-a3-emi.rpy:1089
translate pt_br a3_emi_definitions_3661c41b:

    # emi "Must've gotten knocked a little out of alignment during the picnic."
    emi "Deve ter desalinhado em algum momento no piquenique."

# game/script-a3-emi.rpy:1094
translate pt_br a3_emi_definitions_b7440726:

    # emi "No idea what would have caused that, of course."
    emi "Não tenho nem ideia do que poderia ter causado isso, é claro."

# game/script-a3-emi.rpy:1096
translate pt_br a3_emi_definitions_4a31df9c:

    # "I think back to being pinned under the tree."
    "Eu lembro do momento em que eu fui pressionado contra a árvore."

# game/script-a3-emi.rpy:1098
translate pt_br a3_emi_definitions_9a287fc4:

    # hi "Ah."
    hi "Ah."

# game/script-a3-emi.rpy:1100
translate pt_br a3_emi_definitions_8f9dff5f:

    # hi "You should have told me! We could have stopped and fixed it, you know."
    hi "Você devia ter me dito! Nós poderíamos ter parado e consertado."

# game/script-a3-emi.rpy:1102
translate pt_br a3_emi_definitions_0b8e06ce:

    # "Emi waves a hand airily."
    "Emi balança a mão como se dizesse que não era nada."

# game/script-a3-emi.rpy:1107
translate pt_br a3_emi_definitions_ec47ea25:

    # emi "Nah, it's not that big of a deal."
    emi "Não precisava, não é nada demais."

# game/script-a3-emi.rpy:1112
translate pt_br a3_emi_definitions_8977c72c:

    # emi "Don't worry about it, okay Hisao?"
    emi "Não se preocupe, tá bom Hisao?"

# game/script-a3-emi.rpy:1117
translate pt_br a3_emi_definitions_907d83cd:

    # emi "It's fine."
    emi "Está tudo certo."

# game/script-a3-emi.rpy:1135
translate pt_br a3_emi_definitions_4cdf677a:

    # emi "Now really, I need to get going."
    emi "Agora é sério, eu preciso ir."

# game/script-a3-emi.rpy:1140
translate pt_br a3_emi_definitions_6f625974:

    # emi "Your attempts to keep me around are doomed to fail!"
    emi "Suas tentativas de me prender aqui estão fadadas a falhar!"

# game/script-a3-emi.rpy:1142
translate pt_br a3_emi_definitions_28f6dfcb:

    # hi "Heh, of course."
    
    hi "Heh, claro."

# game/script-a3-emi.rpy:1144
translate pt_br a3_emi_definitions_8b0690d1:

    # hi "Just prolonging the goodbye, I suppose."
    hi "Apenas prolongando o adeus, eu suponho."

# game/script-a3-emi.rpy:1146
translate pt_br a3_emi_definitions_d6c7a476:

    # "Another grin lights up Emi's face."
    "Outro sorriso faz brilhar o rosto da Emi."

# game/script-a3-emi.rpy:1151
translate pt_br a3_emi_definitions_b7ee3ae8:

    # emi "Goodnight, Hisao."
    emi "Boa noite, Hisao."

# game/script-a3-emi.rpy:1153
translate pt_br a3_emi_definitions_fbcbd67e:

    # hi "Goodnight."
    
    hi "Boa noite."

# game/script-a3-emi.rpy:1160
translate pt_br a3_emi_definitions_11ad5102:

    # "As she limps inside, I find myself hoping she's okay despite her assurances that she's fine."
    "Enquanto ela manca para dentro do dormitório, eu fico me perguntando se ela está realmente bem, apesar de todas as garantias que ela me deu."

# game/script-a3-emi.rpy:1162
translate pt_br a3_emi_definitions_c3e802b2:

    # "I think I can call this a successful first date."
    "Eu acho que posso chamar isso de um sucesso como primeiro encontro."

# game/script-a3-emi.rpy:1164
translate pt_br a3_emi_definitions_76862fb7:

    # "Hell, any day that ends with Emi pinning me under a tree to kiss me can't be bad, can it?"
    "Poxa, qualquer dia que termina com Emi me pressionando contra uma árvore e me beijando não pode ser ruim, pode?"

# game/script-a3-emi.rpy:1166
translate pt_br a3_emi_definitions_1abe9e96:

    # "I head back to my room, mentally thank the gods that Kenji doesn't ambush me in the hallway, and get started on my homework."
    "Eu volto para o meu quarto, mentalmente agradecendo aos deuses o fato do Kenji não ter me emboscado no corredor, e volto a fazer minha lição de casa."

# game/script-a3-emi.rpy:1182
translate pt_br a3_emi_invisible_rock_685a5748:

    # "The morning is far too early for my taste."
    "A manhã está cedo demais para o meu gosto."

# game/script-a3-emi.rpy:1184
translate pt_br a3_emi_invisible_rock_ee0f0fa3:

    # "It doesn't help that I had trouble sleeping last night."
    "E não ajuda que eu tive problemas para dormir ontem a noite."

# game/script-a3-emi.rpy:1186
translate pt_br a3_emi_invisible_rock_92af9957:

    # "There were simply too many things to think about. My mind refused to slow down."
    "Haviam simplesmente muitas coisas pra pensar, minha mente não conseguiu parar."

# game/script-a3-emi.rpy:1188
translate pt_br a3_emi_invisible_rock_42266a4c:

    # "Instead I replayed the rooftop, the park, and everything else over and over in my mind."
    "Ao invés disso eu revivi as cenas do telhado, do parque, e tudo mais de novo e de novo na minha mente."

# game/script-a3-emi.rpy:1190
translate pt_br a3_emi_invisible_rock_a104ba75:

    # "There's a small part of my mind that is still paranoid that this has all been some kind of joke."
    
    "Alguma parte dela ainda está paranóica pensando que isso é apenas alguma pegadinha."

# game/script-a3-emi.rpy:1192
translate pt_br a3_emi_invisible_rock_5a108556:

    # "That I'll meet up with Emi at the track, and she'll act like nothing happened yesterday."
    "Que eu vou me encontrar com a Emi na pista de corrida e ela vai agir como se nada tivesse acontecido ontem."

# game/script-a3-emi.rpy:1194
translate pt_br a3_emi_invisible_rock_89a9127c:

    # "Pushing these thoughts to the back of my mind, I throw on my running clothes and open the door."
    
    "Empurrando esses pensamentos para trás da minha mente, eu visto as minhas roupas de corrida e abro a porta."

# game/script-a3-emi.rpy:1200
translate pt_br a3_emi_invisible_rock_2b82c8ff:

    # "Emi's waiting for me with her usual smile."
    "Emi está me esperando com o seu sorriso de sempre."

# game/script-a3-emi.rpy:1205
translate pt_br a3_emi_invisible_rock_d198e095:

    # emi "You're late!"
    emi "Você está atrasado!"

# game/script-a3-emi.rpy:1210
translate pt_br a3_emi_invisible_rock_f0c39461:

    # emi "Or at least, you're not early today."
    emi "Ou pelo menos não está tão adiantado hoje."

# game/script-a3-emi.rpy:1215
translate pt_br a3_emi_invisible_rock_2ecf04ef:

    # emi "Are you tired or something?"
    
    emi "Você está cansado ou algo do tipo?"

# game/script-a3-emi.rpy:1217
translate pt_br a3_emi_invisible_rock_d039dee4:

    # "I find myself ruefully rubbing the back of my head."
    
    "Eu me encontro coçando minha cabeça com grande pesar."

# game/script-a3-emi.rpy:1219
translate pt_br a3_emi_invisible_rock_e004f71c:

    # hi "Something like that, yeah."
    hi "Algo do tipo, é."

# game/script-a3-emi.rpy:1221
translate pt_br a3_emi_invisible_rock_50d3d545:

    # hi "Lots to think about and all that."
    hi "Muito a pensar, essas coisas."

# game/script-a3-emi.rpy:1226
translate pt_br a3_emi_invisible_rock_d5c6d9dd:

    # "Emi giggles at my mild understatement."
    "Emi ri da minha fala suave."

# game/script-a3-emi.rpy:1231
translate pt_br a3_emi_invisible_rock_e5033404:

    # emi "Yeah, I didn't sleep that well either."
    emi "É, eu não dormi muito bem também."

# game/script-a3-emi.rpy:1236
translate pt_br a3_emi_invisible_rock_c3609a0e:

    # emi "I was actually glad you weren't early, 'cause I wasn't early either."
    emi "Na verdade eu fiquei contente que você não estava lá cedo, porque eu também não estava."

# game/script-a3-emi.rpy:1238
translate pt_br a3_emi_invisible_rock_7ce3aab6:

    # "I wonder if the same thing kept us awake."
    "Eu imagino se foram as mesmas coisas que nos deixaram acordados."

# game/script-a3-emi.rpy:1240
translate pt_br a3_emi_invisible_rock_a6a67833:

    # "The image of her weeping face passes through my mind."
    "A imagem da cara de choro dela passa pela minha cabeça."

# game/script-a3-emi.rpy:1242
translate pt_br a3_emi_invisible_rock_fdcc44c9:

    # hi "What kept you up?"
    hi "O que te deixou acordada?"

# game/script-a3-emi.rpy:1247
translate pt_br a3_emi_invisible_rock_8b6da760:

    # "Emi's expression falters, but she quickly notices my curiosity and forces a smile."
    
    "Emi hesita na expressão, mas ela rapidamente percebe minha curiosidade e força um sorriso."

# game/script-a3-emi.rpy:1252
translate pt_br a3_emi_invisible_rock_659d84e0:

    # emi "Nothing important."
    emi "Nada importante."

# game/script-a3-emi.rpy:1254
translate pt_br a3_emi_invisible_rock_2f62c72a:

    # "She's obviously not telling me something."
    "Ela obviamente não está me contando alguma coisa."

# game/script-a3-emi.rpy:1256
translate pt_br a3_emi_invisible_rock_aaaf87c8:

    # "The question is, should I press the issue?"
    "A questão é, eu deveria forçar o assunto?"

# game/script-a3-emi.rpy:1258
translate pt_br a3_emi_invisible_rock_145b86db:

    # "Something's clearly been bothering her for a while."
    
    "Algo está claramente a incomodando já faz um tempo."

# game/script-a3-emi.rpy:1260
translate pt_br a3_emi_invisible_rock_11265078:

    # "I want to help her, but would it just come off as me being nosy?"
    "Eu quero ajudá-la mas será que não iria apenas parecer intromissão minha?"

# game/script-a3-emi.rpy:1262
translate pt_br a3_emi_invisible_rock_cc73f35c:

    # "She's got to know I care about her, though."
    "Mas ela tem que ver que eu me importo."

# game/script-a3-emi.rpy:1264
translate pt_br a3_emi_invisible_rock_cf490c98:

    # hi "Are you sure?"
    hi "Tem certeza?"

# game/script-a3-emi.rpy:1266
translate pt_br a3_emi_invisible_rock_342852e7:

    # hi "If something's bothering you, I'm here to help you sort it out."
    hi "Se algo está te incomodando, eu estou aqui para te ajudar."

# game/script-a3-emi.rpy:1271
translate pt_br a3_emi_invisible_rock_e11dcbea:

    # "Emi laughs then, but it's not her usual laugh. There's an edge to it that seems almost bitter."
    
    "Emi então ri, mas não é a risada normal dela. Tem uma ponta que parece um pouco amargo."

# game/script-a3-emi.rpy:1276
translate pt_br a3_emi_invisible_rock_772cc45f:

    # emi "Sort it out?"
    emi "Me ajudar?"

# game/script-a3-emi.rpy:1278
translate pt_br a3_emi_invisible_rock_23c11ec4:

    # emi "I'm not sure it can be sorted out, Hisao."
    emi "Não acho que seja algo que possa ser ajudado, Hisao."

# game/script-a3-emi.rpy:1280
translate pt_br a3_emi_invisible_rock_a7313e8b:

    # "An almost grim smile crosses her lips."
    "Um sorriso quase sinistro se dá nos lábios dela."
    

# game/script-a3-emi.rpy:1282
translate pt_br a3_emi_invisible_rock_c3d29ec8:

    # "It's like a smile of resignation."
    "É um sorriso de resignação."

# game/script-a3-emi.rpy:1287
translate pt_br a3_emi_invisible_rock_1cb7c597:

    # emi "I don't think you could help me, anyway."
    emi "Eu não acho que você poderia me ajudar de qualquer forma."

# game/script-a3-emi.rpy:1289
translate pt_br a3_emi_invisible_rock_ead401c2:

    # "That hurts."
    "Essa doeu."

# game/script-a3-emi.rpy:1291
translate pt_br a3_emi_invisible_rock_80db5263:

    # "I don't want to say that it hurts to her, but it does."
    "Eu não vou dizer a ela que doeu, mas doeu."

# game/script-a3-emi.rpy:1293
translate pt_br a3_emi_invisible_rock_00b8ebe3:

    # "Doesn't she realize I want to be there for her when things go wrong?"
    "Ela não percebe que eu apenas quero estar ao lado dela caso as coisas deem errado?"

# game/script-a3-emi.rpy:1295
translate pt_br a3_emi_invisible_rock_6978d4ff:

    # hi "Well, I won't push you on the matter."
    hi "Bom, eu não vou forçar mais o assunto."

# game/script-a3-emi.rpy:1297
translate pt_br a3_emi_invisible_rock_7b6ea813:

    # hi "But I'm here for you if you decide later that you'd like to talk about it."
    hi "Mas estou aqui caso você decida depois que quer falar sobre isso."

# game/script-a3-emi.rpy:1299
translate pt_br a3_emi_invisible_rock_e818da8c:

    # hi "It might help."
    hi "Talvez ajude."

# game/script-a3-emi.rpy:1304
translate pt_br a3_emi_invisible_rock_7f48c783:

    # "I can see the debate raging behind Emi's eyes."
    "Eu consigo ver a discussão em chamas atrás dos olhos da Emi."

# game/script-a3-emi.rpy:1306
translate pt_br a3_emi_invisible_rock_8f5561e4:

    # "It seems like she wants to tell me, but she's not sure whether or not she can."
    "Parece que ela quer me contar, mas não tem certeza se ela consegueria."

# game/script-a3-emi.rpy:1308
translate pt_br a3_emi_invisible_rock_8a983934:

    # hi "Hey, forget about it for now, okay?"
    hi "Ei, esquece por agora, está bem?"

# game/script-a3-emi.rpy:1310
translate pt_br a3_emi_invisible_rock_7a92df35:

    # hi "We've got running to do."
    hi "Temos uma corrida a fazer."

# game/script-a3-emi.rpy:1312
translate pt_br a3_emi_invisible_rock_69251a59:

    # "The mention of running, something that she can handle, brings Emi back to her usual self."
    "A menção de uma corrida, algo que Emi consegue lidar, traz de volta seu eu usual."

# game/script-a3-emi.rpy:1317
translate pt_br a3_emi_invisible_rock_5acebdd5:

    # emi "Right!"
    emi "Certo!"

# game/script-a3-emi.rpy:1322
translate pt_br a3_emi_invisible_rock_3814f468:

    # emi "Hurry up and stretch out, Hisao!"
    emi "Se alonga logo Hisao!"

# game/script-a3-emi.rpy:1327
translate pt_br a3_emi_invisible_rock_22042dd1:

    # emi "We've got to get moving!"
    emi "Nós temos que ir!"

# game/script-a3-emi.rpy:1338
translate pt_br a3_emi_invisible_rock_15b3fec5:

    # "She takes off like a shot, far quicker than I'm used to."
    "Ela dispara como um tiro, bem mais rápido do que eu estou acostumado."

# game/script-a3-emi.rpy:1346
translate pt_br a3_emi_invisible_rock_4640892e:

    # "Still, I try to keep pace with her, recklessly testing my limits."
    "Ainda sim, eu tento manter o ritmo dela, testando meus limites de forma imprudente."

# game/script-a3-emi.rpy:1348
translate pt_br a3_emi_invisible_rock_20b2ad9e:

    # "It gives me a feeling of freedom, like my heart is no longer important."
    
    "Me dá uma sensação de liberdade, meu coração não parece mais importante."

# game/script-a3-emi.rpy:1350
translate pt_br a3_emi_invisible_rock_becb3940:

    # "I find myself wanting to laugh, filled with the feeling of moving beyond what I once called my boundaries."
    "Me encontro querendo rir, ocupado pelo sentimento de ultrapassar meus limites."

# game/script-a3-emi.rpy:1352
translate pt_br a3_emi_invisible_rock_23581080:

    # "The nurse's warnings to not overdo things echo in my mind, and I disregard them."
    "Os avisos do enfermeiro de não exagerar ecoam minha mente e eu os ignoro."

# game/script-a3-emi.rpy:1354
translate pt_br a3_emi_invisible_rock_d9542541:

    # "This feeling I have, this willingness to risk a heart attack for something so trivial as a morning run, feels out of character for me."
    "Este sentimento, esta boa vontade de arriscar ter um ataque cardíaco por algo tão trivial como uma corrida matinal, parece fora de si para mim."

# game/script-a3-emi.rpy:1356
translate pt_br a3_emi_invisible_rock_2a012b8c:

    # "But is it?"
    "Mas é mesmo?"

# game/script-a3-emi.rpy:1358
translate pt_br a3_emi_invisible_rock_19a19681:

    # "Or rather, should it be?"
    "Ou melhor, deveria ser?"

# game/script-a3-emi.rpy:1360
translate pt_br a3_emi_invisible_rock_433dc596:

    # "I've got a weak heart, sure."
    "Eu tenho um coração fraco, claro."

# game/script-a3-emi.rpy:1362
translate pt_br a3_emi_invisible_rock_27dc76f9:

    # "It'll never be capable of the kind of speed and endurance Emi's capable of."
    "Eu nunca alcançarei a velocidade e resistência que a Emi tem."

# game/script-a3-emi.rpy:1364
translate pt_br a3_emi_invisible_rock_08042c25:

    # "Though I probably wouldn't be able to get that good even if I had a healthy heart."
    "Apesar que eu provavelmente não ficaria tão bom nem se eu tivesse de fato um coração saudável."

# game/script-a3-emi.rpy:1368
translate pt_br a3_emi_invisible_rock_e72ef4d1:

    # "As we round the final bend, I feel my legs screaming in protest, but for the first time, I ignore them."
    "Enquanto viramos a última curva, minhas pernas gritam em protesto mas eu as ignoro."

# game/script-a3-emi.rpy:1370
translate pt_br a3_emi_invisible_rock_87493504:

    # "I accelerate to finish at a sprint, nearly catching up to Emi."
    "Eu acelero para terminar em um arranco, quase alcançando a Emi."

# game/script-a3-emi.rpy:1372
translate pt_br a3_emi_invisible_rock_47657e10:

    # "That was never going to happen, of course."
    "Isso nunca ocorreria, é claro."

# game/script-a3-emi.rpy:1374
translate pt_br a3_emi_invisible_rock_09175dd3:

    # "Still, I feel surprisingly good."
    "Ainda sim, eu me sinto surpreendentemente bem."

# game/script-a3-emi.rpy:1376
translate pt_br a3_emi_invisible_rock_cf646b99:

    # "Oh sure, my legs feel like they're about to catch fire, and I'm having trouble staying upright."
    "Claro, minhas pernas parecem que vão pegar fogo e eu tenho dificuldades para ficar em pé."

# game/script-a3-emi.rpy:1378
translate pt_br a3_emi_invisible_rock_6ecfa003:

    # "But there's been a shift of some sort today."
    "Mas teve alguma mudança de algum tipo hoje."

# game/script-a3-emi.rpy:1380
translate pt_br a3_emi_invisible_rock_a8cf9d5a:

    # "And it's all thanks to the girl grinning at the finish line, waiting for me."
    
    "E é tudo graças à garota sorrindo na linha de chegada, esperando por mim."

# game/script-a3-emi.rpy:1388
translate pt_br a3_emi_invisible_rock_2ebf6676:

    # hi "That felt a little faster than usual."
    hi "Bom, isso foi um pouco mais rápido do que de costume."

# game/script-a3-emi.rpy:1390
translate pt_br a3_emi_invisible_rock_ca88186b:

    # "My comment is met with a grin and a shrug."
    "Meu comentário é respondido com um sorriso e uma encolhida de ombros."

# game/script-a3-emi.rpy:1395
translate pt_br a3_emi_invisible_rock_3ca7e76e:

    # emi "Can't have you think I was going to go soft on you, now can I?"
    
    emi "Não posso ter você pensando que eu vou te dar esse mole agora, posso?"

# game/script-a3-emi.rpy:1400
translate pt_br a3_emi_invisible_rock_749c30b1:

    # emi "But you managed to handle it just fine."
    emi "Mas você conseguiu aguentar bem."

# game/script-a3-emi.rpy:1402
translate pt_br a3_emi_invisible_rock_15bb78a3:

    # hi "Well, I couldn't have done it without you."
    hi "Bom, eu não teria conseguido sem você."

# game/script-a3-emi.rpy:1407
translate pt_br a3_emi_invisible_rock_dd4b83fd:

    # "Still feeling the high from the run and moved by a surge of gratitude, I seize Emi in a hug."
    "Ainda alto da corrida e movido por uma onda de gratidão, eu abraço a Emi."

# game/script-a3-emi.rpy:1409
translate pt_br a3_emi_invisible_rock_9d5a9627:

    # hi "Thanks."
    hi "Obrigado."

# game/script-a3-emi.rpy:1411
translate pt_br a3_emi_invisible_rock_00989c04:

    # hi "Really, I'm not just saying that."
    hi "Sério, não estou apenas dizendo por dizer."

# game/script-a3-emi.rpy:1413
translate pt_br a3_emi_invisible_rock_ac84899e:

    # hi "I'm in your debt."
    hi "Eu te devo uma."

# game/script-a3-emi.rpy:1418
translate pt_br a3_emi_invisible_rock_98b9ac44:

    # "Emi seems flustered by my words, squirming uncomfortably."
    "Emi parece envergonhada pelas minhas palavras, se contorcendo inconfortável."

# game/script-a3-emi.rpy:1420
translate pt_br a3_emi_invisible_rock_e2937a71:

    # emi "Don't be silly, Hisao."
    emi "Não seja bobo, Hisao."

# game/script-a3-emi.rpy:1425
translate pt_br a3_emi_invisible_rock_a9b8ebe9:

    # emi "Someone had to haul you out here, didn't they?"
    emi "Alguém tinha que te arrastar até aqui, certo?"

# game/script-a3-emi.rpy:1430
translate pt_br a3_emi_invisible_rock_66dc4e43:

    # emi "And it's not like you're not doing anything for me, right?"
    emi "E não é como se você não estivesse fazendo nada por mim também, certo?"

# game/script-a3-emi.rpy:1435
translate pt_br a3_emi_invisible_rock_53649164:

    # emi "I needed a running partner, remember?"
    emi "Eu preciso de um parceiro de corrida, lembra?"

# game/script-a3-emi.rpy:1440
translate pt_br a3_emi_invisible_rock_97616939:

    # "I shake my head, still pointedly not letting go of Emi, who stops squirming and merely looks up at me with a quickly deepening blush that almost seems out of character."
    "Eu balanço a cabeça, ainda abraçado à Emi, que para de se remexer e apenas olha pra mim com um corar que não parece ela."

# game/script-a3-emi.rpy:1442
translate pt_br a3_emi_invisible_rock_afdf5ae8:

    # hi "No, that's not true."
    hi "Não, isso não é verdade."

# game/script-a3-emi.rpy:1444
translate pt_br a3_emi_invisible_rock_723e3459:

    # hi "You wanted a running partner, but you didn't need one."
    hi "Você queria um parceiro de corrida mas você não precisava de um."

# game/script-a3-emi.rpy:1446
translate pt_br a3_emi_invisible_rock_74aebe84:

    # hi "If I hadn't shown up the day after the festival, you would still run, right?"
    hi "Se eu não tivesse aparecido no dia depois do festival você ainda teria corrido não é?"

# game/script-a3-emi.rpy:1448
translate pt_br a3_emi_invisible_rock_5172d36e:

    # hi "But it doesn't work the other way around."
    hi "Mas não funciona ao contrário."
    

# game/script-a3-emi.rpy:1450
translate pt_br a3_emi_invisible_rock_c458705e:

    # hi "I only managed to make it out a few times before the festival."
    hi "Eu só consegui fazer acontecer algumas vezes antes do festival."

# game/script-a3-emi.rpy:1452
translate pt_br a3_emi_invisible_rock_38b5c26b:

    # hi "And without you, I probably wouldn't have made it out at all after that."
    hi "E sem você eu provavelmente teria parado com tudo depois dele."

# game/script-a3-emi.rpy:1457
translate pt_br a3_emi_invisible_rock_adbe0b75:

    # "Emi smiles at me and prods my chest with one finger."
    "Emi sorri e me cutuca no peito com o dedo."

# game/script-a3-emi.rpy:1462
translate pt_br a3_emi_invisible_rock_d1177a2d:

    # emi "You are pretty lazy, Hisao."
    emi "Você é bem preguiçoso Hisao."

# game/script-a3-emi.rpy:1464
translate pt_br a3_emi_invisible_rock_c43e88f5:

    # hi "Hey, I was giving you a compliment!"
    hi "Ei, eu estava te elogiando!"

# game/script-a3-emi.rpy:1469
translate pt_br a3_emi_invisible_rock_e23d3eec:

    # emi "Well… you're welcome, I guess."
    emi "Bom… obrigada, eu acho."

# game/script-a3-emi.rpy:1471
translate pt_br a3_emi_invisible_rock_7a8ef15b:

    # hi "I'll pay you back somehow."
    
    hi "Eu vou te compensar por isso de alguma forma."

# game/script-a3-emi.rpy:1476
translate pt_br a3_emi_invisible_rock_37d4c9b5:

    # emi "Oh, uh, well…"
    emi "Oh… é… bem…"

# game/script-a3-emi.rpy:1481
translate pt_br a3_emi_invisible_rock_4287f81c:

    # emi "That's not necessary, you know."
    emi "Isso não é necessário sabe."

# game/script-a3-emi.rpy:1486
translate pt_br a3_emi_invisible_rock_1b13520b:

    # emi "I mean I kinda like you, Hisao."
    emi "Quer dizer, eu gosto de você Hisao."

# game/script-a3-emi.rpy:1491
translate pt_br a3_emi_invisible_rock_02923efb:

    # emi "And being able to run with you in the mornings isn't exactly a bad deal for me either, so…"
    emi "E poder correr com você pelas manhãs não é ruim para mim também, então…"

# game/script-a3-emi.rpy:1493
translate pt_br a3_emi_invisible_rock_f5e1391f:

    # "For someone who gets so much praise, she seems unused to gratitude."
    "Para alguém que recebe tantos elogios ela parece não estar acostumada com gratidão."

# game/script-a3-emi.rpy:1495
translate pt_br a3_emi_invisible_rock_129ca422:

    # "I can't think of anything else to say, so we fall silent."
    "Eu não consigo pensar em mais nada para dizer então ficamos em silêncio."

# game/script-a3-emi.rpy:1497
translate pt_br a3_emi_invisible_rock_ca539ec6:

    # "I become aware of Emi's breathing, of the dampness of her clothing, and of the scent of her."
    "Eu fico consciente da respiração da Emi, a umidade das roupas dela e seu cheiro."

# game/script-a3-emi.rpy:1499
translate pt_br a3_emi_invisible_rock_cf12642b:

    # "Coming off of anyone else, it would stink."
    "Vindo de qualquer outra pessoa, cheiraria mal."

# game/script-a3-emi.rpy:1501
translate pt_br a3_emi_invisible_rock_613f8473:

    # "Coming off of Emi, it fits her in a way nothing else could."
    
    "Vindo da Emi, se encaixa nela como nada mais encaixaria."

# game/script-a3-emi.rpy:1503
translate pt_br a3_emi_invisible_rock_e3d3b0f7:

    # "Her skin is cool, slick with sweat, and a breeze causes goosebumps to rise."
    "Sua pele esta fria, molhada de suor e uma brisa causa calafrios."

# game/script-a3-emi.rpy:1508
translate pt_br a3_emi_invisible_rock_a5b4f599:

    # "Almost without thinking about it, I lean down and meet Emi's mouth which has already moved to meet my own."
    "Quase sem pensar eu me abaixo pra encontrar com a boca dela que já se move em direção a minha."

# game/script-a3-emi.rpy:1510
translate pt_br a3_emi_invisible_rock_a272b8b7:

    # "Her lips are soft, and she hums happily as we kiss, sending vibrations from her mouth to mine."
    "Seus lábios são suaves gemem com felicidade enquanto nos beijamos, mandando vibrações da sua boca para a minha."

# game/script-a3-emi.rpy:1512
translate pt_br a3_emi_invisible_rock_e658f3ec:

    # "There's a startling rightness to everything about this moment. We fit one another perfectly."
    "Tem um brilhante sentimento de que tudo sobre este momento é certo. Nós nos completamos perfeitamente."

# game/script-a3-emi.rpy:1517
translate pt_br a3_emi_invisible_rock_fcb1facf:

    # "The kiss ends, and I finally let my arms drop back to my sides."
    "O beijo acaba e eu finalmente volto meus braços ao lugar."

# game/script-a3-emi.rpy:1522
translate pt_br a3_emi_invisible_rock_e4dca0cc:

    # "Emi is smiling warmly at me and giggles again."
    
    "Emi dá um sorriso aconchegante e ri pra mim de novo."

# game/script-a3-emi.rpy:1527
translate pt_br a3_emi_invisible_rock_a3b71fb2:

    # emi "Come on Hisao, we'd better go see the nurse."
    emi "Vamos Hisao, temos que ver o enfermeiro."

# game/script-a3-emi.rpy:1531
translate pt_br a3_emi_invisible_rock_e2673aea:

    # "Then it happens."
    "E então acontece."

# game/script-a3-emi.rpy:1541
translate pt_br a3_emi_invisible_rock_5ec5d16a:

    # "As she turns to begin walking, she gives out a tiny yelp and stumbles forward."
    "Quando ela dá meia volta para andar ela da um pequeno ganido e tropeça."

# game/script-a3-emi.rpy:1543
translate pt_br a3_emi_invisible_rock_e1a06dae:

    # hi "Emi!"
    hi "Emi!"

# game/script-a3-emi.rpy:1550
translate pt_br a3_emi_invisible_rock_141a2ebf:

    # "I leap to steady her and notice with some concern that she's favoring the same leg as last night."
    "Eu corro para dar suporte a ela e percebo com preocupação que ela favorece a mesma perna de ontem a noite."

# game/script-a3-emi.rpy:1552
translate pt_br a3_emi_invisible_rock_f9d20be3:

    # hi "Your leg…"
    hi "Sua perna…"

# game/script-a3-emi.rpy:1557
translate pt_br a3_emi_invisible_rock_27cf0d6b:

    # "Emi seems panicked and pushes away from me."
    "Emi parece entrar em pânico e me empurra."

# game/script-a3-emi.rpy:1559
translate pt_br a3_emi_invisible_rock_86cd46fa:

    # emi "It's fine!"
    emi "Está tudo bem!"

# game/script-a3-emi.rpy:1561
translate pt_br a3_emi_invisible_rock_26ed0b8f:

    # "My expression must seem hurt, because she hastens to apologize."
    "Minha expressão parece de sentido, porque ela se apressa em se desculpar."

# game/script-a3-emi.rpy:1566
translate pt_br a3_emi_invisible_rock_0a9d6829:

    # emi "Sorry! Sorry!"
    emi "Desculpa! Desculpa!"

# game/script-a3-emi.rpy:1568
translate pt_br a3_emi_invisible_rock_b4c1f904:

    # emi "Didn't mean to push you like that!"
    emi "Eu não queria te empurrar desse jeito!"

# game/script-a3-emi.rpy:1573
translate pt_br a3_emi_invisible_rock_02f134f4:

    # emi "I was just…"
    emi "Eu só estava…"

# game/script-a3-emi.rpy:1575
translate pt_br a3_emi_invisible_rock_1a2a9bfc:

    # "She stumbles for something to say."
    "Ela procura por algo a dizer."

# game/script-a3-emi.rpy:1580
translate pt_br a3_emi_invisible_rock_94b0f674:

    # emi "It's nothing, really."
    emi "Não é nada, sério."

# game/script-a3-emi.rpy:1582
translate pt_br a3_emi_invisible_rock_90398009:

    # hi "Hey, don't worry about it."
    hi "Ei, não se preocupe, está bem."

# game/script-a3-emi.rpy:1584
translate pt_br a3_emi_invisible_rock_167b95bc:

    # "She's so flustered, I decide to shrug the whole thing off."
    "Ela está tão afobada que eu decido abafar toda aquela situação."

# game/script-a3-emi.rpy:1586
translate pt_br a3_emi_invisible_rock_b9088bc1:

    # "But there's a cold feeling in the pit of my stomach now that won't go away."
    "Mas tem uma ponta gelada no meu estômago que não passa."

# game/script-a3-emi.rpy:1588
translate pt_br a3_emi_invisible_rock_0c973c39:

    # "I tried to step in and help her, and she pushed me away."
    "Eu tentei entrar para ajudar, e ela me empurrou para fora."

# game/script-a3-emi.rpy:1590
translate pt_br a3_emi_invisible_rock_f843ace5:

    # "Smiling, I shove those thoughts to the back of my mind and concentrate on Emi."
    "Sorrindo, eu jogo esses pensamentos para depois e me concentro só na Emi."

# game/script-a3-emi.rpy:1592
translate pt_br a3_emi_invisible_rock_e2f62d4a:

    # hi "I just don't want you getting hurt, that's all."
    hi "Eu só não quero que você se machuque, só isso."

# game/script-a3-emi.rpy:1597
translate pt_br a3_emi_invisible_rock_2ceab32d:

    # emi "You don't have to worry about me, honest."
    emi "Você não precisa se preocupar comigo, sério."

# game/script-a3-emi.rpy:1602
translate pt_br a3_emi_invisible_rock_fd4b5979:

    # emi "I'm fine!"
    emi "Estou bem!"

# game/script-a3-emi.rpy:1604
translate pt_br a3_emi_invisible_rock_fabf8dd1:

    # "Yes, you say that, but I don't believe you."
    "Sim, você diz isso, mas eu não acredito em você."

# game/script-a3-emi.rpy:1607
translate pt_br a3_emi_invisible_rock_1b54cfe8:

    # "Why won't you tell me what's wrong?"
    "Por que você não me diz o que há de errado?"

# game/script-a3-emi.rpy:1609
translate pt_br a3_emi_invisible_rock_b248864b:

    # "It's like she gets offended by my trying to help."
    "É como se ela se sentisse ofendida pela minha ajuda."

# game/script-a3-emi.rpy:1611
translate pt_br a3_emi_invisible_rock_9024f87e:

    # "What am I supposed to make of that?"
    "O que eu deveria pensar disso?"

# game/script-a3-emi.rpy:1613
translate pt_br a3_emi_invisible_rock_bc1049e1:

    # "I keep worrying about you regardless, and not saying anything yesterday just makes me feel guilty about today."
    "Eu continuo a me preocupar com você e não ter dito nada ontem me faz sentir culpado hoje."

# game/script-a3-emi.rpy:1615
translate pt_br a3_emi_invisible_rock_a3c7fe52:

    # "I should have at least asked."
    "Eu deveria ter ao menos perguntado."

# game/script-a3-emi.rpy:1617
translate pt_br a3_emi_invisible_rock_fb5249f9:

    # "Would she have reacted the same way last night?"
    
    "Ela teria reagido da mesma forma ontem a noite?"

# game/script-a3-emi.rpy:1619
translate pt_br a3_emi_invisible_rock_ba96e530:

    # "Guess I'll never know now."
    "Acho que nunca saberei."

# game/script-a3-emi.rpy:1626
translate pt_br a3_emi_invisible_rock_09777475:

    # "I'm still trying to sort out what happened on the track as we arrive in front of the nurse's office."
    "Eu ainda estou tentando entender o que realmente aconteceu na pista de corrida quando nós chegamos ao escritório do enfermeiro."

# game/script-a3-emi.rpy:1628
translate pt_br a3_emi_invisible_rock_67c339fb:

    # "Emi raises her hand to knock, hesitates and turns to me smiling guiltily."
    "Emi levanta a mão pra bater na porta, hesita e vira para mim sorrindo com culpa."

# game/script-a3-emi.rpy:1637
translate pt_br a3_emi_invisible_rock_7e11096c:

    # emi "Hey, can you do me a favor?"
    
    emi "Ei, pode me fazer um favor?"

# game/script-a3-emi.rpy:1639
translate pt_br a3_emi_invisible_rock_2f6a93ba:

    # hi "Of course."
    hi "Claro."

# game/script-a3-emi.rpy:1644
translate pt_br a3_emi_invisible_rock_8961c540:

    # emi "Can you tell the nurse that I'll see him later?"
    emi "Pode dizer ao enfermeiro que eu vejo ele mais tarde?"

# game/script-a3-emi.rpy:1649
translate pt_br a3_emi_invisible_rock_df55753c:

    # emi "I just remembered that I've got some… stuff to take care of before class."
    emi "Eu acabei de lembrar que eu tenho algumas… coisas a fazer antes da aula."

# game/script-a3-emi.rpy:1654
translate pt_br a3_emi_invisible_rock_b52715c4:

    # emi "So I really need to get moving."
    emi "Então eu realmente preciso ir."

# game/script-a3-emi.rpy:1659
translate pt_br a3_emi_invisible_rock_f88d761d:

    # "I peer at her closely, and she fidgets under my stare."
    "Eu lanço um olhar desconfiado que deixa ela bem inquieta."

# game/script-a3-emi.rpy:1661
translate pt_br a3_emi_invisible_rock_8262e3dc:

    # "Yeah, she's clearly just avoiding the nurse."
    "É, ela esta claramente evitando o enfermeiro."

# game/script-a3-emi.rpy:1663
translate pt_br a3_emi_invisible_rock_3632eef3:

    # "That leg of hers…"
    "Essa perna dela…"

# game/script-a3-emi.rpy:1665
translate pt_br a3_emi_invisible_rock_99936ab0:

    # "Well, whatever. I said I'd help, and so I will."
    "Bom, tanto faz. Eu disse que ia ajudar então eu vou."

# game/script-a3-emi.rpy:1667
translate pt_br a3_emi_invisible_rock_38357576:

    # "But I'll make damn sure she sees the nurse before the day's out."
    "Mas vou ter certeza de que ela vai ver o enfermeiro antes do dia terminar."

# game/script-a3-emi.rpy:1669
translate pt_br a3_emi_invisible_rock_7c52ab3e:

    # hi "Yeah, okay. I'll let him know."
    hi "Tá bem, eu o aviso."

# game/script-a3-emi.rpy:1674
translate pt_br a3_emi_invisible_rock_c7b18935:

    # "Emi looks like I've just given her a pony on Christmas."
    "Parece que eu acabei de dar um pônei de natal para ela."

# game/script-a3-emi.rpy:1679
translate pt_br a3_emi_invisible_rock_d0352384:

    # emi "Thank you so much!"
    emi "Obrigada!"

# game/script-a3-emi.rpy:1684
translate pt_br a3_emi_invisible_rock_f78e62a9:

    # emi "You're the best, Hisao!"
    emi "Você é o melhor, Hisao!"

# game/script-a3-emi.rpy:1689
translate pt_br a3_emi_invisible_rock_474501db:

    # "I am rewarded for my complicity in her lie by a kiss that makes it all worth it, or so I tell myself."
    "Eu sou recompensado pelo meu papel de cúmplice na mentira dela com um beijo, o que faz tudo valer a pena, é o que eu falo pra mim mesmo."

# game/script-a3-emi.rpy:1694
translate pt_br a3_emi_invisible_rock_4908513c:

    # "As Emi heads out of the building, trying hard not to let her limp show, I knock on the door of the office."
    "Enquanto a Emi sai do prédio, tentando muito não deixar na cara que está mancando, eu bato na porta do escritório."

# game/script-a3-emi.rpy:1696
translate pt_br a3_emi_invisible_rock_4b2b8e3e:

    # nk "Ah, Hisao. Come on in."
    nk "Ah Hisao, pode entrar."

# game/script-a3-emi.rpy:1704
translate pt_br a3_emi_invisible_rock_06312b56:

    # nk "I don't see Emi with you."
    nk "Eu não vejo a Emi com você."

# game/script-a3-emi.rpy:1709
translate pt_br a3_emi_invisible_rock_b55b4654:

    # nk "She's not sick again, is she?"
    nk "Ela não está doente de novo, está?"

# game/script-a3-emi.rpy:1711
translate pt_br a3_emi_invisible_rock_7dad4c7a:

    # "From the tone of his voice, I don't think the nurse is expecting me to say 'Yes, she's ill.'"
    "Pelo tom de voz dele, eu não acho que ele esteja esperando que eu diga “Sim, ela esta doente”."

# game/script-a3-emi.rpy:1713
translate pt_br a3_emi_invisible_rock_6a5f4a17:

    # hi "Er, she said that she'd forgotten to do something, and so she had to skip out, but she'll see you later today."
    hi "É… ela disse que esqueceu alguma coisa e deixou pra mais tarde, mas que ela vai vê-lo mais tarde."

# game/script-a3-emi.rpy:1718
translate pt_br a3_emi_invisible_rock_9960e747:

    # "The nurse heaves an exasperated sigh."
    "O enfermeiro solta um suspiro aborrecido."

# game/script-a3-emi.rpy:1720
translate pt_br a3_emi_invisible_rock_1fc9f566:

    # nk "Honestly, that girl…"
    nk "Seriamente, aquela garota…"

# game/script-a3-emi.rpy:1722
translate pt_br a3_emi_invisible_rock_34d1d59d:

    # hi "Hmm?"
    hi "Hmm?"

# game/script-a3-emi.rpy:1727
translate pt_br a3_emi_invisible_rock_5688bfcb:

    # nk "She's been avoiding me."
    nk "Ela tem me evitado."

# game/script-a3-emi.rpy:1729
translate pt_br a3_emi_invisible_rock_febad22e:

    # nk "Yesterday she was in and out of here without even taking off her prosthetics. And now this."
    nk "Ontem ela veio e foi sem nem tirar a prótese e agora isso."

# game/script-a3-emi.rpy:1731
translate pt_br a3_emi_invisible_rock_ba0fe8b2:

    # "Well, at least it's not just me Emi doesn't want worrying."
    "Bom, pelo menos não é só a mim que ela não quer preocupar."

# game/script-a3-emi.rpy:1733
translate pt_br a3_emi_invisible_rock_86721cf1:

    # "That's a… comfort, I guess."
    "Isso é… confortante, eu acho."

# game/script-a3-emi.rpy:1735
translate pt_br a3_emi_invisible_rock_805ad0bd:

    # "Still, I feel like I should say something about her leg. I said I'd lie for her, but she really needs to see him."
    "Ainda sim, eu sinto que deveria falar algo sobre a perna dela. Eu disse que mentiria por ela, mas ela realmente precisa vê-lo."

# game/script-a3-emi.rpy:1737
translate pt_br a3_emi_invisible_rock_698345c4:

    # hi "Now that you mention it, she was limping pretty badly today."
    hi "Agora que você mencionou, ela estava mancando bastante hoje."

# game/script-a3-emi.rpy:1739
translate pt_br a3_emi_invisible_rock_72ffa9e6:

    # hi "And last night as well."
    hi "E ontem a noite também."

# game/script-a3-emi.rpy:1744
translate pt_br a3_emi_invisible_rock_005cf11b:

    # "The nurse's eyes narrow at the words 'last night.'"
    
    "Os olhos do enfermeiro estreitam nas palavras “ontem a noite”."

# game/script-a3-emi.rpy:1746
translate pt_br a3_emi_invisible_rock_e0ec98e6:

    # nk "And what exactly were you two doing last night?"
    nk "E o que exatamente vocês dois estavam fazendo ontem a noite?"

# game/script-a3-emi.rpy:1748
translate pt_br a3_emi_invisible_rock_98249085:

    # hi "We were uh, on a date."
    hi "Nós estavamos uh, num encontro."

# game/script-a3-emi.rpy:1753
translate pt_br a3_emi_invisible_rock_b9ff7403:

    # "The nurse raises his eyebrows as if surprised."
    "O enfermeiro levanta a sombrancelha, como que surpreso."

# game/script-a3-emi.rpy:1755
translate pt_br a3_emi_invisible_rock_291e7cdb:

    # nk "Really? Interesting."
    nk "Sério? Interessante."

# game/script-a3-emi.rpy:1757
translate pt_br a3_emi_invisible_rock_0f638bea:

    # hi "Huh?"
    hi "Hã?"

# game/script-a3-emi.rpy:1762
translate pt_br a3_emi_invisible_rock_084c8476:

    # nk "Oh, nothing."
    nk "Ah, nada."

# game/script-a3-emi.rpy:1764
translate pt_br a3_emi_invisible_rock_670e4e02:

    # "His gaze turns thoughtful, and then he grins at me."
    
    "Seu olhar se torna pensativo e ele sorri para mim."

# game/script-a3-emi.rpy:1769
translate pt_br a3_emi_invisible_rock_fbbefeef:

    # nk "You don't think you could use some of that boyfriend charm to get her to come see me today, could you?"
    nk "Você não acha que poderia usar um pouco desse charme de namorado pra fazer com que ela venha aqui hoje, poderia?"

# game/script-a3-emi.rpy:1771
translate pt_br a3_emi_invisible_rock_9aa89fc3:

    # hi "Of course!"
    hi "É claro!"

# game/script-a3-emi.rpy:1773
translate pt_br a3_emi_invisible_rock_53229ca0:

    # hi "I was planning on doing that anyway."
    hi "Eu estava planejando fazer isso de qualquer forma."

# game/script-a3-emi.rpy:1775
translate pt_br a3_emi_invisible_rock_58436db5:

    # hi "I think she's really hurt and just pretending she isn't."
    hi "Eu acho que ela está machucada e está fingindo que não está."

# game/script-a3-emi.rpy:1780
translate pt_br a3_emi_invisible_rock_68110dcc:

    # nk "Hmm, yes. She does that."
    nk "Hmm, é. Ela faz isso."

# game/script-a3-emi.rpy:1782
translate pt_br a3_emi_invisible_rock_d39a1758:

    # nk "Afraid I'll make her stop running."
    nk "Com medo que eu faça ela parar de correr."

# game/script-a3-emi.rpy:1784
translate pt_br a3_emi_invisible_rock_13ff59c8:

    # hi "Will you?"
    hi "Você vai?"

# game/script-a3-emi.rpy:1789
translate pt_br a3_emi_invisible_rock_ee58f0df:

    # nk "I don't like to, but if it's bad enough that she's been limping, well…"
    nk "Eu não quero, mas se é tão mal que faz ela mancar, então…"

# game/script-a3-emi.rpy:1791
translate pt_br a3_emi_invisible_rock_d5e70109:

    # nk "I guess I'll have to see what's wrong for myself before I make that call."
    nk "Eu acho que tenho que ver o que está de errado antes de tomar essa decisão."

# game/script-a3-emi.rpy:1793
translate pt_br a3_emi_invisible_rock_e1f8a5e6:

    # hi "I see."
    hi "Entendo."

# game/script-a3-emi.rpy:1795
translate pt_br a3_emi_invisible_rock_17be382d:

    # "Emi, not allowed to run? Perish the thought."
    "Emi não sendo permitida a correr? Espero que não."

# game/script-a3-emi.rpy:1797
translate pt_br a3_emi_invisible_rock_d638283d:

    # "I don't know if she'd be able to function without running."
    "Eu não sei se ela funcionaria sem poder correr."

# game/script-a3-emi.rpy:1799
translate pt_br a3_emi_invisible_rock_05703add:

    # "No wonder she's reluctant to admit anything's wrong."
    "Não é a toa que ela está relutante em admitir que algo está errado."

# game/script-a3-emi.rpy:1801
translate pt_br a3_emi_invisible_rock_aefacdbb:

    # hi "Well, I'll make sure she sees you."
    hi "Bom, vou fazer com que ela te veja."

# game/script-a3-emi.rpy:1806
translate pt_br a3_emi_invisible_rock_1a83d320:

    # nk "Good. Oh, and before I forget…"
    nk "Ótimo. Ah, e antes que eu me esqueça…"

# game/script-a3-emi.rpy:1811
translate pt_br a3_emi_invisible_rock_11ecfa14:

    # "He grins at me again in what feels like a vaguely threatening manner."
    "Ele sorri pra mim denovo, agora de uma maneira vagamente ameaçadora."

# game/script-a3-emi.rpy:1813
translate pt_br a3_emi_invisible_rock_adb0c5e7:

    # nk "Don't forget that I know what medications you're on."
    nk "Não se esqueça que eu sei quais medicações você usa."

# game/script-a3-emi.rpy:1818
translate pt_br a3_emi_invisible_rock_73a21d81:

    # nk "You be careful around Emi, got it?"
    nk "Você tenha cuidado perto da Emi, entendeu?"

# game/script-a3-emi.rpy:1820
translate pt_br a3_emi_invisible_rock_5dbef0c1:

    # "Wow. He looks serious, too."
    "Uau, ele parece sério também."

# game/script-a3-emi.rpy:1822
translate pt_br a3_emi_invisible_rock_641f55dc:

    # hi "Got it."
    hi "Entendi."

# game/script-a3-emi.rpy:1824
translate pt_br a3_emi_invisible_rock_73920ea6:

    # hi "Don't hurt Emi. Wouldn't dream of it."
    hi "Não machucá-la. Não sonharia com isso."

# game/script-a3-emi.rpy:1829
translate pt_br a3_emi_invisible_rock_60e22ae0:

    # nk "Grand!"
    nk "Show!"

# game/script-a3-emi.rpy:1834
translate pt_br a3_emi_invisible_rock_46925b52:

    # nk "I'd hate for you to be late."
    nk "Eu odiaria que você chegasse atrasado."

# game/script-a3-emi.rpy:1836
translate pt_br a3_emi_invisible_rock_0f638bea_1:

    # hi "Huh?"
    hi "Hein?"

# game/script-a3-emi.rpy:1841
translate pt_br a3_emi_invisible_rock_ce04b9eb:

    # nk "Late, as in the late Hisao Nakai."
    nk "Atrasado para a aula da vida."

# game/script-a3-emi.rpy:1846
translate pt_br a3_emi_invisible_rock_9a0c2b05:

    # "He frowns briefly, dissatisfied."
    "Ele faz uma cara feia, insatisfeito."

# game/script-a3-emi.rpy:1848
translate pt_br a3_emi_invisible_rock_b3d88ff6:

    # nk "Sounded better in my head…"
    nk "Soou melhor na minha cabeça…"

# game/script-a3-emi.rpy:1853
translate pt_br a3_emi_invisible_rock_c1b99db7:

    # nk "Well, at any rate."
    nk "Bom, de qualquer forma."

# game/script-a3-emi.rpy:1858
translate pt_br a3_emi_invisible_rock_4335a79e:

    # nk "Get out of here before you miss your first class!"
    nk "Vá logo antes que você perca sua primeira aula!"

# game/script-a3-emi.rpy:1860
translate pt_br a3_emi_invisible_rock_f9605776:

    # nk "You've got things to do, I'm sure. Shoo!"
    nk "Você tem coisas a fazer, tenho certeza. Xispa!"

# game/script-a3-emi.rpy:1864
translate pt_br a3_emi_invisible_rock_1f20723d:

    # "As I leave, I notice the nurse pulling out his phone and dialing a number."
    "Enquanto eu saio eu percebo o enfermeiro pegando seu telefone e ligando um número."

# game/script-a3-emi.rpy:1869
translate pt_br a3_emi_invisible_rock_6de0fce7:

    # nk "Meiko, your daughter's being a pain in the ass again…"
    nk "Meiko, sua filha está sendo um pé no saco de novo…"

# game/script-a3-emi.rpy:1871
translate pt_br a3_emi_invisible_rock_9e6b0b35:

    # "I'd better head back to my room, or I really will be late."
    "É melhor eu voltar ao meu quarto ou eu vou realmente me atrasar."

# game/script-a3-emi.rpy:1873
translate pt_br a3_emi_invisible_rock_2df2d14a:

    # "Hey, wasn't he supposed to check my heart rate?"
    "Ei, ele não devia ter medido meu batimento cardíaco?"

# game/script-a3-emi.rpy:1884
translate pt_br a3_emi_lunch_and_science_18c45eb9:

    # "The lunch bell sounds, and I bring myself out of the stupor I slipped into during the morning's classes."
    "O sino do almoço toca e eu me recupero da letargia que me atacou durante as aulas da manhã."

# game/script-a3-emi.rpy:1886
translate pt_br a3_emi_lunch_and_science_220064c0:

    # "My lack of sleep last night, coupled with the increased pace of this morning's run, has left me a little exhausted."
    "Minha falta de sono na noite passada, junto com ritmo agitado da corrida matinal me deixaram um pouco exausto."

# game/script-a3-emi.rpy:1894
translate pt_br a3_emi_lunch_and_science_6c38ef20:

    # "Despite that, I find myself skipping stairs up to the roof."
    "Apesar disso eu me pego pulando degraus para o telhado."

# game/script-a3-emi.rpy:1896
translate pt_br a3_emi_lunch_and_science_736a3d00:

    # "There's a thrill of excitement now, in addition to the pleasure one gets from eating lunch with one's friends."
    "Agora tem uma emoção de excitação, em adição do prazer que é almoçar com os amigos."

# game/script-a3-emi.rpy:1904
translate pt_br a3_emi_lunch_and_science_aa3fb5ee:

    # "True, both Emi and Rin are still my friends, but Emi has become more than that now."
    "Verdade, ambas Emi e Rin ainda são minhas amigas, mas a Emi é mais do que isso agora."

# game/script-a3-emi.rpy:1906
translate pt_br a3_emi_lunch_and_science_9dd35d0c:

    # "Rin is back in her usual spot on the roof, almost as if she'd never been absent."
    "Rin está de volta ao seu local de costume no telhado, quase como se ela nunca tivesse saído de lá."

# game/script-a3-emi.rpy:1912
translate pt_br a3_emi_lunch_and_science_2de01dbb:

    # hi "Feeling better, I take it?"
    hi "Sentindo-se melhor, eu presumo?"

# game/script-a3-emi.rpy:1917
translate pt_br a3_emi_lunch_and_science_d5735622:

    # "A raised eyebrow is my reward for speaking."
    "Uma sombrancelha levantada é minha recompensa por falar."

# game/script-a3-emi.rpy:1919
translate pt_br a3_emi_lunch_and_science_c9377f7d:

    # rin "Better than what?"
    rin "Melhor que o quê?"

# game/script-a3-emi.rpy:1923
translate pt_br a3_emi_lunch_and_science_8bf01b97:

    # hi "Er, better than you felt yesterday."
    hi "Eh, melhor do que você se sentia ontem."

# game/script-a3-emi.rpy:1928
translate pt_br a3_emi_lunch_and_science_2d2f7278:

    # "Rin gives my question some serious thought."
    "Rin pensa seriamente na minha pergunta."

# game/script-a3-emi.rpy:1930
translate pt_br a3_emi_lunch_and_science_0efef7a5:

    # rin "I'm not sure."
    rin "Não estou certa."

# game/script-a3-emi.rpy:1932
translate pt_br a3_emi_lunch_and_science_36b8cd8c:

    # rin "I think I might have felt rather good for some of yesterday, but it's all fuzzy."
    rin "Eu acho que me senti um pouco bem ontem, mas está tudo indistinto."

# game/script-a3-emi.rpy:1934
translate pt_br a3_emi_lunch_and_science_83f88214:

    # hi "Too much cold medicine?"
    hi "Muito remédio pra resfriado?"
    

# game/script-a3-emi.rpy:1939
translate pt_br a3_emi_lunch_and_science_c0b826db:

    # rin "Well, I was asleep. And that usually is pretty good."
    rin "Bom, eu estava dormindo. E isso normalmente é bom."

# game/script-a3-emi.rpy:1944
translate pt_br a3_emi_lunch_and_science_a5ec6de1:

    # rin "But I can't remember what it feels like to be asleep, because I'm not conscious for it."
    rin "Mas eu não consigo me lembrar de como é estar dormindo, porque eu não estava consciente pra isso."

# game/script-a3-emi.rpy:1946
translate pt_br a3_emi_lunch_and_science_8130d836:

    # rin "It's a real problem."
    rin "É um problema real."

# game/script-a3-emi.rpy:1951
translate pt_br a3_emi_lunch_and_science_853bfa3f:

    # rin "Then again, if I knew how good it felt I might not sleep any more."
    rin "Mas de novo, se eu soubesse o quão bem eu me senti dormindo, talvez eu não conseguiria dormir mais."

# game/script-a3-emi.rpy:1953
translate pt_br a3_emi_lunch_and_science_74ee5dfe:

    # rin "But this way I keep trying so I guess that's how I can keep from being overtired."
    rin "Mas dessa maneira eu continuo tentando e é assim que eu evito de ficar super cansada."

# game/script-a3-emi.rpy:1955
translate pt_br a3_emi_lunch_and_science_a7fe4f70:

    # hi "An eternal mystery to keep you sleeping at night?"
    hi "Um eterno mistério pra manter você dormindo a noite?"

# game/script-a3-emi.rpy:1960
translate pt_br a3_emi_lunch_and_science_f69117cf:

    # rin "Maybe mystery's the wrong word. Intangibility might be the proper way to describe it."
    rin "Talvez mistério seja a palavra errada. Intangibilidade descreve melhor."

# game/script-a3-emi.rpy:1962
translate pt_br a3_emi_lunch_and_science_e1f8a5e6:

    # hi "I see."
    hi "Entendo."

# game/script-a3-emi.rpy:1964
translate pt_br a3_emi_lunch_and_science_6a0622ec:

    # "No, I don't see at all. I have no idea what she's talking about, but that's okay, since I rarely do."
    "Não, na verdade eu não entendo nada. Eu não tenho ideia do que ela está falando mas tudo bem, já que eu raramente tenho."

# game/script-a3-emi.rpy:1969
translate pt_br a3_emi_lunch_and_science_0a5c1d17:

    # rin "Do you remember what sleeping feels like?"
    rin "Você se lembra de como se sente dormindo?"

# game/script-a3-emi.rpy:1971
translate pt_br a3_emi_lunch_and_science_c068b37f:

    # rin "Like yesterday, do you remember what you felt like sleeping yesterday?"
    rin "Ontem por exemplo, você se lembra de como você se sentiu quando dormiu?"

# game/script-a3-emi.rpy:1973
translate pt_br a3_emi_lunch_and_science_5e4e10fc:

    # hi "Well, I actually didn't get a lot of sleep yesterday."
    hi "Bom, na verdade eu dormi muito ontem."

# game/script-a3-emi.rpy:1978
translate pt_br a3_emi_lunch_and_science_81383cfa:

    # rin "Hmm."
    rin "Hmm."

# game/script-a3-emi.rpy:1980
translate pt_br a3_emi_lunch_and_science_f63e2621:

    # rin "Maybe that's because you remember subconsciously."
    rin "Talvez seja porque você se lembra subconscientemente."

# game/script-a3-emi.rpy:1982
translate pt_br a3_emi_lunch_and_science_99a91115:

    # hi "Actually, I think I was worrying about Emi."
    hi "Na verdade, eu acho que eu estava me preocupando com a Emi."

# game/script-a3-emi.rpy:1987
translate pt_br a3_emi_lunch_and_science_cb5bb5f5:

    # rin "Doesn't Emi worry enough about herself?"
    rin "Mas a Emi não se preocupa o suficiente com ela mesma?"

# game/script-a3-emi.rpy:1989
translate pt_br a3_emi_lunch_and_science_3deea67e:

    # "I hadn't considered that, but it gives me pause."
    "Eu não tinha pensado nisso, mas me faz pensar."

# game/script-a3-emi.rpy:1991
translate pt_br a3_emi_lunch_and_science_2c15b782:

    # hi "True, but would she ask for help if she needed it?"
    hi "Verdade, mas ela pediria ajuda se precisasse?"

# game/script-a3-emi.rpy:1996
translate pt_br a3_emi_lunch_and_science_e6b98c91:

    # "Rin frowns, and I raise an eyebrow. Will I get a proper answer?"
    "Rin franze as sombrancelhas e eu as levanto. Eu terei uma resposta de verdade?"

# game/script-a3-emi.rpy:1998
translate pt_br a3_emi_lunch_and_science_ce9b6a8a:

    # rin "Probably not. Is there something she should be asking for help with?"
    rin "Provavelmente não. Tem algo com o que ela deveria estar pedindo ajuda?"

# game/script-a3-emi.rpy:2000
translate pt_br a3_emi_lunch_and_science_66624620:

    # hi "Her leg, for starters."
    hi "A perna dela, pra início de conversa."

# game/script-a3-emi.rpy:2002
translate pt_br a3_emi_lunch_and_science_be49126a:

    # "This seems to catch Rin's interest."
    "Isso parece interessar a Rin."

# game/script-a3-emi.rpy:2007
translate pt_br a3_emi_lunch_and_science_2bf9a425:

    # rin "Leg?"
    rin "Perna?"

# game/script-a3-emi.rpy:2009
translate pt_br a3_emi_lunch_and_science_71c4e75f:

    # hi "It's hurt, but she won't see the nurse about it."
    hi "Está machucada, mas ela não quer ver o enfermeiro."

# game/script-a3-emi.rpy:2011
translate pt_br a3_emi_lunch_and_science_e68abdb5:

    # "Rin shakes her head in disapproval."
    "Rin balança a cabeça desaprovando."

# game/script-a3-emi.rpy:2016
translate pt_br a3_emi_lunch_and_science_bc6b1019:

    # rin "You have to make her."
    rin "Você tem que forçar ela."

# game/script-a3-emi.rpy:2021
translate pt_br a3_emi_lunch_and_science_9144013e:

    # rin "Like she makes me go to class. For her own good."
    rin "Como ela me força a ir as aulas. Para o bem dela."

# game/script-a3-emi.rpy:2023
translate pt_br a3_emi_lunch_and_science_540af557:

    # rin "Otherwise she could lose her legs again, and that's just too weird."
    rin "Do contrário ela poderia perder as pernas dela de novo, e isso seria muito estranho."

# game/script-a3-emi.rpy:2025
translate pt_br a3_emi_lunch_and_science_4407fc97:

    # rin "Losing things twice."
    rin "Perder as coisas duas vezes."

# game/script-a3-emi.rpy:2030
translate pt_br a3_emi_lunch_and_science_b923619f:

    # rin "Especially if you don't find them again to begin with."
    rin "Especialmente se você não encontrou elas de novo em primeiro lugar."

# game/script-a3-emi.rpy:2032
translate pt_br a3_emi_lunch_and_science_2562663d:

    # rin "Unless prosthetics are the same as finding something."
    rin "A não ser que próteses são o mesmo que encontrar algo."

# game/script-a3-emi.rpy:2037
translate pt_br a3_emi_lunch_and_science_b9772af5:

    # rin "But that's a different kind of lost, isn't it?"
    rin "Mas esse é um tipo diferente de perdido, não é?"

# game/script-a3-emi.rpy:2039
translate pt_br a3_emi_lunch_and_science_d16776d9:

    # hi "I think so."
    hi "Eu acho que sim."

# game/script-a3-emi.rpy:2044
translate pt_br a3_emi_lunch_and_science_ad6ae9c2:

    # rin "Hmm. I wonder…"
    rin "Hmm, eu imagino…"

# game/script-a3-emi.rpy:2051
translate pt_br a3_emi_lunch_and_science_eadfb775:

    # emi "Wonder what?"
    emi "Imagina o que?"

# game/script-a3-emi.rpy:2057
translate pt_br a3_emi_lunch_and_science_c93faa9d:

    # "Emi seems to have snuck up on Rin and me, though Rin doesn't seem especially surprised. Which is itself unsurprising, I suppose."
    "Emi parece ter se aproximado silenciosamente de mim e da Rin, apesar de que a Rin não parece especialmente surpresa. O que não é uma surpresa, eu suponho."

# game/script-a3-emi.rpy:2071
translate pt_br a3_emi_lunch_and_science_1b4134ec:

    # "Rin manages to sit herself upright quite expertly, throwing her upper body forward and using her momentum to right herself."
    "Rin consegue se sentar com uma postura reta com habilidade, jogando o corpo dela pra frente e usando o momento para se endireitar."

# game/script-a3-emi.rpy:2076
translate pt_br a3_emi_lunch_and_science_36aa4b24:

    # hi "Your leg. How's it feel?"
    hi "Sua perna. Como você se sente?"

# game/script-a3-emi.rpy:2082
translate pt_br a3_emi_lunch_and_science_f642633c:

    # "That earns me a frown and a bit of a glare."
    "Isso me ganha uma franzida de sobrancelha e um olhar penetrante."

# game/script-a3-emi.rpy:2084
translate pt_br a3_emi_lunch_and_science_35aa46d7:

    # emi "It's okay, I think."
    emi "Está bem, eu acho."

# game/script-a3-emi.rpy:2089
translate pt_br a3_emi_lunch_and_science_53f4a770:

    # emi "Not worth worrying about."
    emi "Não vale a pena se preocupar."

# game/script-a3-emi.rpy:2094
translate pt_br a3_emi_lunch_and_science_353ecd77:

    # hi "Tell that to the nurse."
    hi "Diga isso ao enfermeiro."

# game/script-a3-emi.rpy:2096
translate pt_br a3_emi_lunch_and_science_20c95936:

    # hi "He's quite insistent that you visit him, you know."
    hi "Ele está insistindo que você vá vê-lo."

# game/script-a3-emi.rpy:2102
translate pt_br a3_emi_lunch_and_science_72abd5b7:

    # "Emi pouts like I've just told her she's been grounded."
    "Emi faz um bico, como se eu tivesse dito que ela está de castigo."

# game/script-a3-emi.rpy:2104
translate pt_br a3_emi_lunch_and_science_051b59b0:

    # emi "He worries too much."
    emi "Ele se preocupa demais."

# game/script-a3-emi.rpy:2109
translate pt_br a3_emi_lunch_and_science_53761694:

    # emi "It's not a big deal, just a little soreness."
    emi "Não é um problema, é só uma dorzinha."

# game/script-a3-emi.rpy:2111
translate pt_br a3_emi_lunch_and_science_77ac14a3:

    # "I try to resist rolling my eyes in exasperation."
    "Eu tento resistir rolar os olhos em irritação."

# game/script-a3-emi.rpy:2116
translate pt_br a3_emi_lunch_and_science_0f0f40ee:

    # hi "If it's nothing, then you should have no problem seeing him, right?"
    hi "Se não é nada você não deveria ter um problema em vê-lo, certo?"

# game/script-a3-emi.rpy:2122
translate pt_br a3_emi_lunch_and_science_4b76edec:

    # "Emi narrows her eyes suspiciously."
    "Emi aperta os olhos, suspeita."

# game/script-a3-emi.rpy:2124
translate pt_br a3_emi_lunch_and_science_be029d42:

    # emi "Did he put you up to this?"
    emi "Ele te colocou nisso?"

# game/script-a3-emi.rpy:2129
translate pt_br a3_emi_lunch_and_science_dc3737ab:

    # hi "Well, maybe. A little."
    hi "Bom, talvez. Um pouco."

# game/script-a3-emi.rpy:2131
translate pt_br a3_emi_lunch_and_science_a866f927:

    # hi "But that's not the point. I would have reminded you to see him anyway."
    hi "Mas isso não é motivo. Eu teria te lembrado de ir vê-lo de qualquer forma."

# game/script-a3-emi.rpy:2133
translate pt_br a3_emi_lunch_and_science_3424a3dc:

    # hi "It would be terrible to see you really hurt and not doing anything about it."
    hi "Seria terrível ver você se machucar e não fazer nada sobre isso."

# game/script-a3-emi.rpy:2135
translate pt_br a3_emi_lunch_and_science_3bc9404f:

    # hi "That would make it worse, and I don't really want to see you hurt, you know?"
    hi "Isso só faria as coisas pior, e eu não quero te ver se machucando sabe?"

# game/script-a3-emi.rpy:2137
translate pt_br a3_emi_lunch_and_science_f1074a87:

    # hi "Call me crazy, but I kinda would prefer to see you happy and healthy."
    hi "Me chame de louco, mas eu acho que preferiria ver você feliz e saudável."

# game/script-a3-emi.rpy:2143
translate pt_br a3_emi_lunch_and_science_978d9142:

    # "With each statement, Emi's frown fades a little more, until eventually she's grinning, albeit a little shyly."
    "Com cada frase, a franzida de Emi some um pouco, até que eventualmente ela está sorrindo, embora com um pouco de vergonha."

# game/script-a3-emi.rpy:2147
translate pt_br a3_emi_lunch_and_science_51deaf76:

    # emi "Well, if you're going to put it that way, then I guess I'll have to see him."
    emi "Bom, se você fala desse jeito, então eu acho que vou ter que ir vê-lo."

# game/script-a3-emi.rpy:2152
translate pt_br a3_emi_lunch_and_science_7d35482f:

    # emi "Otherwise you'll keep worrying, and then I'll never hear the end of it, right?"
    emi "Do contrário você vai continuar se preocupando e eu nunca vou ouvir o fim disso, certo?"

# game/script-a3-emi.rpy:2157
translate pt_br a3_emi_lunch_and_science_371aacb0:

    # hi "That's right. I'll keep bugging you about it, and that might put a damper on our dates."
    hi "Exato, eu vou ficar implicando com você e isso pode acabar com nossos encontros."

# game/script-a3-emi.rpy:2159
translate pt_br a3_emi_lunch_and_science_9a0a32fa:

    # hi "'How's the food, Hisao?' 'Talk to the nurse, Emi.'"
    hi "”Como está a comida, Hisao?” “Fale com o enfermeiro, Emi.”"

# game/script-a3-emi.rpy:2161
translate pt_br a3_emi_lunch_and_science_51810e90:

    # hi "'How was your day, Hisao?' 'Talk to the nurse, Emi.'"
    hi "”Como foi seu dia, Hisao?” “Fale com o enfermeiro, Emi.”"

# game/script-a3-emi.rpy:2163
translate pt_br a3_emi_lunch_and_science_ae00dc1c:

    # hi "'Hisao, I think I'm ready to go all the w—' '{b}Talk to the nurse, Emi.{/b}'"
    hi "”Hisao, acho que estou pronta pra ir até o f…” “{b}Fale com o enfermeiro, Emi.{/b}”"

# game/script-a3-emi.rpy:2165
translate pt_br a3_emi_lunch_and_science_0b653a27:

    # hi "See? It doesn't work that well."
    hi "Viu? Não iria funcionar."

# game/script-a3-emi.rpy:2171
translate pt_br a3_emi_lunch_and_science_28bb042c:

    # "Emi giggles at my high-pitched rendition of her own voice and gives me an affectionate shove."
    "Emi ri numa versão alta do seu tom de voz e me da um empurrão afeiçoado."

# game/script-a3-emi.rpy:2176
translate pt_br a3_emi_lunch_and_science_45de7127:

    # emi "My voice isn't that high, jerk."
    emi "Minha voz não é tão alta, idiota."

# game/script-a3-emi.rpy:2182
translate pt_br a3_emi_lunch_and_science_ced5db4b:

    # rin "I thought it was pretty accurate."
    rin "Eu acho que foi bem preciso."

# game/script-a3-emi.rpy:2186
translate pt_br a3_emi_lunch_and_science_4647c070:

    # "Emi and I stare at Rin for a while before I burst into laughter."
    "Emi e eu encaramos a Rin por um momento antes de gargalharmos."

# game/script-a3-emi.rpy:2192
translate pt_br a3_emi_lunch_and_science_62cae0a9:

    # "Emi crosses her arms and huffs, mock-offended."
    "Emi cruza os braços ofendida, mas não de verdade."

# game/script-a3-emi.rpy:2197
translate pt_br a3_emi_lunch_and_science_fbc12dc6:

    # emi "You're both jerks."
    emi "Vocês são dois idiotas."

# game/script-a3-emi.rpy:2202
translate pt_br a3_emi_lunch_and_science_8dbef685:

    # hi "Such vile calumnies from you, young woman."
    hi "Calúnias perversas você diz, senhorita."

# game/script-a3-emi.rpy:2204
translate pt_br a3_emi_lunch_and_science_e1d8ff1e:

    # hi "I'm stunned that you would call me, of all people, a jerk."
    hi "Estou perplexo que de todas as pessoas você chamaria logo a mim, de idiota."

# game/script-a3-emi.rpy:2206
translate pt_br a3_emi_lunch_and_science_ce320337:

    # hi "Honestly, I just… I don't know what to think."
    hi "Sinceramente, eu só… não sei o que pensar."

# game/script-a3-emi.rpy:2212
translate pt_br a3_emi_lunch_and_science_ec3f0841:

    # "Emi sticks her tongue out at me."
    "Emi mostra a língua."

# game/script-a3-emi.rpy:2214
translate pt_br a3_emi_lunch_and_science_ef3c74ef:

    # emi "You ass."
    emi "Seu babaca."

# game/script-a3-emi.rpy:2219
translate pt_br a3_emi_lunch_and_science_79d22f7a:

    # emi "So Rin, how's the art club these days?"
    emi "Então Rin, como vai o clube de arte?"

# game/script-a3-emi.rpy:2224
translate pt_br a3_emi_lunch_and_science_715072b3:

    # "Rin, seemingly as surprised by this sudden change of topic as I am, takes a minute to think before answering."
    "Rin, parecendo tão surpresa quanto eu com a mudança de assunto, toma um momento para pensar antes de responder."

# game/script-a3-emi.rpy:2229
translate pt_br a3_emi_lunch_and_science_80474c21:

    # rin "I believe it is okay."
    rin "Eu acredito estar bem."

# game/script-a3-emi.rpy:2234
translate pt_br a3_emi_lunch_and_science_95d1778d:

    # rin "Although Nomiya keeps telling me to work harder."
    rin "Apesar de que o Nomiya continua me dizendo para trabalhar mais e mais."

# game/script-a3-emi.rpy:2239
translate pt_br a3_emi_lunch_and_science_3521bde4:

    # rin "But I don't think he understands my methods."
    rin "Mas eu não acho que ele entende meus métodos."

# game/script-a3-emi.rpy:2244
translate pt_br a3_emi_lunch_and_science_5b0327fe:

    # emi "He always struck me as slightly creepy."
    emi "Ele sempre me pareceu um pouco assustador."

# game/script-a3-emi.rpy:2249
translate pt_br a3_emi_lunch_and_science_03c9cfbd:

    # "Rin ponders this statement for a while."
    "Rin considera essa afirmação por um momento."

# game/script-a3-emi.rpy:2254
translate pt_br a3_emi_lunch_and_science_31b4a7e7:

    # rin "I've never really noticed."
    rin "Eu nunca havia percebido."

# game/script-a3-emi.rpy:2259
translate pt_br a3_emi_lunch_and_science_6a83d423:

    # rin "But I don't pay much attention to him most days, so maybe that's why."
    rin "Mas eu não presto muita atenção nele na maioria da vezes, então talvez seja isso."

# game/script-a3-emi.rpy:2261
translate pt_br a3_emi_lunch_and_science_0b167f69:

    # hi "How often do you meet?"
    
    hi "O quão frequentemente vocês se encontram?"

# game/script-a3-emi.rpy:2266
translate pt_br a3_emi_lunch_and_science_35d43b8d:

    # emi "Thinking of joining, Hisao?"
    emi "Pensando em se juntar a eles Hisao?"

# game/script-a3-emi.rpy:2271
translate pt_br a3_emi_lunch_and_science_77010f7a:

    # hi "What? Nah, I've already decided to join a club."
    hi "O quê? Não, eu já decidi me juntar a um clube."

# game/script-a3-emi.rpy:2277
translate pt_br a3_emi_lunch_and_science_301af26b:

    # emi "Really? Which one?"
    emi "Sério? Qual?"

# game/script-a3-emi.rpy:2282
translate pt_br a3_emi_lunch_and_science_45fdb502:

    # hi "Well, it's not really much of a club, to be honest…"
    hi "Bem, não é exatamente um clube, pra ser honesto…"

# game/script-a3-emi.rpy:2288
translate pt_br a3_emi_lunch_and_science_71981731:

    # emi "Oh, you joined the tea club?"
    emi "Oh, então você se juntou ao clube do chá?"

# game/script-a3-emi.rpy:2293
translate pt_br a3_emi_lunch_and_science_c77824a7:

    # hi "No, I uh… joined the science club… I think."
    hi "Não, Eu er… me juntei ao clube de ciências… eu acho."

# game/script-a3-emi.rpy:2299
translate pt_br a3_emi_lunch_and_science_af05e59e:

    # "Emi looks highly confused."
    "Emi parece confusa."

# game/script-a3-emi.rpy:2301
translate pt_br a3_emi_lunch_and_science_6d26b033:

    # emi "We have a science club?"
    emi "Nós temos um clube de ciências?"

# game/script-a3-emi.rpy:2306
translate pt_br a3_emi_lunch_and_science_64500638:

    # hi "Er, not really. It's just me."
    hi "Err, não exatamente. Sou só eu."

# game/script-a3-emi.rpy:2312
translate pt_br a3_emi_lunch_and_science_1c01093a:

    # emi "Hisao, that's not a club. That's sitting in your room reading books."
    emi "Hisao, isso não é um clube. Isso é sentar no seu quarto lendo livros."

# game/script-a3-emi.rpy:2314
translate pt_br a3_emi_lunch_and_science_82665fdb:

    # hi "No, I mean it's just me and Mutou."
    hi "Não, quer dizer, é só eu e o Mutou."

# game/script-a3-emi.rpy:2316
translate pt_br a3_emi_lunch_and_science_2f09f5db:

    # hi "I'm just the only student so far."
    
    hi "Eu sou o único aluno até agora."

# game/script-a3-emi.rpy:2322
translate pt_br a3_emi_lunch_and_science_2c0454a0:

    # emi "Mutou? Really?"
    emi "Mutou? Sério?"

# game/script-a3-emi.rpy:2324
translate pt_br a3_emi_lunch_and_science_45d22bf3:

    # "A thought strikes her."
    "Um pensamento acerta ela."

# game/script-a3-emi.rpy:2329
translate pt_br a3_emi_lunch_and_science_65fca8b8:

    # emi "Oh, is that what you were talking about yesterday? Your meeting with Mutou?"
    
    emi "Oh, então era isso que vocês estavam falando ontem? Você e o Mutou?"

# game/script-a3-emi.rpy:2331
translate pt_br a3_emi_lunch_and_science_9c40978e:

    # hi "Yeah, that was our first meeting, I guess."
    hi "É, foi nossa primeira reunião, eu acho."

# game/script-a3-emi.rpy:2336
translate pt_br a3_emi_lunch_and_science_7af30aaa:

    # "Emi giggles."
    "Emi dá uma risadinha."

# game/script-a3-emi.rpy:2341
translate pt_br a3_emi_lunch_and_science_0e5d260e:

    # emi "Nerd."
    emi "Nerd."

# game/script-a3-emi.rpy:2343
translate pt_br a3_emi_lunch_and_science_516a31fb:

    # hi "Hey, I can't help being clever."
    hi "Ei, não posso fazer nada se eu sou inteligente."

# game/script-a3-emi.rpy:2348
translate pt_br a3_emi_lunch_and_science_59e4a769:

    # emi "You know, I could have used your help years ago."
    emi "Sabe, eu poderia ter usado da sua ajuda anos atrás."

# game/script-a3-emi.rpy:2350
translate pt_br a3_emi_lunch_and_science_0ee33054:

    # emi "You should've had your heart attack earlier in life, Hisao."
    emi "Você deveria ter tido seu ataque cardíaco mais cedo na vida, Hisao."

# game/script-a3-emi.rpy:2352
translate pt_br a3_emi_lunch_and_science_92ea2b3f:

    # "I laugh, and then realize this is probably one of the very rare times I've laughed about my heart attack."
    "Eu rio, e então percebo que foi uma das raras vezes que eu ri sobre o meu ataque cardíaco."

# game/script-a3-emi.rpy:2354
translate pt_br a3_emi_lunch_and_science_c9a5e7a4:

    # hi "Hindsight…"
    hi "Pensando bem…"

# game/script-a3-emi.rpy:2359
translate pt_br a3_emi_lunch_and_science_c711e092:

    # emi "Yeah…"
    emi "É…"

# game/script-a3-emi.rpy:2363
translate pt_br a3_emi_lunch_and_science_81fb92f7:

    # "The ringing of the bell ends our conversation."
    "O soar dos sinos termina nossa conversa."

# game/script-a3-emi.rpy:2365
translate pt_br a3_emi_lunch_and_science_ca4fce7f:

    # hi "Hmm, guess we'd better go."
    hi "Hmm, acho que é melhor irmos."

# game/script-a3-emi.rpy:2370
translate pt_br a3_emi_lunch_and_science_b88352b2:

    # emi "Yeah, I guess so."
    emi "É, acho que sim."

# game/script-a3-emi.rpy:2377
translate pt_br a3_emi_lunch_and_science_01bf50ff:

    # emi "Come on Rin, you too."
    emi "Venha Rin, você também."

# game/script-a3-emi.rpy:2382
translate pt_br a3_emi_lunch_and_science_b30e972c:

    # "Rin has apparently begun to doze off, so Emi gives her a sharp bump."
    "Rin aparentemente tinha cochilado então Emi lhe dá um empurrão."

# game/script-a3-emi.rpy:2387
translate pt_br a3_emi_lunch_and_science_48e45611:

    # rin "I almost had it."
    rin "Eu tava quase lá."

# game/script-a3-emi.rpy:2392
translate pt_br a3_emi_lunch_and_science_07446fe4:

    # emi "Sorry, but you need to go to class."
    emi "Desculpa, mas você precisa ir pra aula."

# game/script-a3-emi.rpy:2397
translate pt_br a3_emi_lunch_and_science_fb4ae925:

    # rin "I disagree, but maybe if I nap in class I'll get it this time."
    rin "Eu discordo, mas talvez se eu cochilar na aula eu vou conseguir dessa vez."

# game/script-a3-emi.rpy:2402
translate pt_br a3_emi_lunch_and_science_05949d42:

    # rin "Changing location is sometimes helpful for that kind of thing."
    rin "Trocar de local as vezes é importante pra esse tipo de coisa."

# game/script-a3-emi.rpy:2404
translate pt_br a3_emi_lunch_and_science_1d0b6747:

    # "Neither Emi or I bother asking what 'it' is."
    "Nem eu e nem Emi nos preocupamos em perguntar sobre o que ela está falando."

# game/script-a3-emi.rpy:2411
translate pt_br a3_emi_lunch_and_science_23a739de:

    # "As we arrive at my classroom, Emi gives me a quick kiss and heads down the hallway, Rin in tow."
    "Quando chegamos na sala de aula, Emi me dá um beijo e desce o corredor com a Rin."

# game/script-a3-emi.rpy:2426
translate pt_br a3_emi_lunch_and_science_cb2eadf0:

    # "I turn to enter the classroom, to be met by the duo of Shizune and Misha."
    "Eu me viro para entrar na sala, e dou de cara com a dupla, Shizune e Misha."

# game/script-a3-emi.rpy:2433
translate pt_br a3_emi_lunch_and_science_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a3-emi.rpy:2435
translate pt_br a3_emi_lunch_and_science_c0ed9402:

    # "Misha seems to be fighting a losing battle to keep from breaking into a fit of giggles while she translates Shizune's latest rant."
    "Misha parece lutar uma batalha perdida ao tentar não rir enquanto traduz as reclamações da Shizune."

# game/script-a3-emi.rpy:2440
translate pt_br a3_emi_lunch_and_science_73443101:

    # mi "While we are pleased, nay thrilled, to see how well you've managed to make new friends and forge relationships - and with such a cutie too, Hicchan~…"
    mi "Apesar de estarmos felizes, não, emocionadas, de ver o quão bem você conseguiu se virar para fazer amigos e ter relações - e com uma lindinha também, Hisaozinho~…"

# game/script-a3-emi.rpy:2442
translate pt_br a3_emi_lunch_and_science_d1accfeb:

    # "I think that last part was probably Misha."
    "Eu acho que essa última parte foi da Misha."

# game/script-a3-emi.rpy:2447
translate pt_br a3_emi_lunch_and_science_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a3-emi.rpy:2452
translate pt_br a3_emi_lunch_and_science_079c0b5d:

    # mi "We nevertheless feel compelled to politely remind you that public displays of affection are strictly forbidden - really? That's disappointing, Shicchan - by section eight of the code of conduct laid out in the student handbook."
    mi "Nós apesar disso nos sentimos obrigadas a educadamente lembrá-lo que exibições de afeto público são estritamente proibidas - sério? Isso é decepcionante, Shizunezinha - pela seção oito do código de conduta previsto na escola."

# game/script-a3-emi.rpy:2457
translate pt_br a3_emi_lunch_and_science_ef2b123c_2:

    # shi "…"
    shi "…"

# game/script-a3-emi.rpy:2462
translate pt_br a3_emi_lunch_and_science_5c024ff3:

    # mi "In this case, however, ignorance of the law may be your excuse, as we are feeling lenient…"
    mi "Nesse caso, porém, ignorância da lei pode ser sua desculpa, já que estamos nos sentindo clementes."

# game/script-a3-emi.rpy:2467
translate pt_br a3_emi_lunch_and_science_ef2b123c_3:

    # shi "…"
    shi "…"

# game/script-a3-emi.rpy:2472
translate pt_br a3_emi_lunch_and_science_d2f8011b:

    # mi "…and the paperwork required to punish the both of you would only add to the already mountainous volume of work which confronts us, the sole members of the Student Council - and besides, you two are adorable together~!"
    mi "…e a papelada necessária para punir ambos apenas adicionaria mais a nossa já montanhosa carga de trabalho, os únicos membros do Conselho Estudantil - além do mais, vocês dois são adoráveis juntos~!"

# game/script-a3-emi.rpy:2477
translate pt_br a3_emi_lunch_and_science_ef2b123c_4:

    # shi "…"
    shi "…"

# game/script-a3-emi.rpy:2482
translate pt_br a3_emi_lunch_and_science_9b7ea9ad:

    # mi "Therefore consider this a formal warning, and please refrain from such displays in the future. At least when Shizune can see you, Hicchan~!"
    mi "Então considere isso um aviso formal, e por favor evite tais exibições no futuro. Pelo menos quando a Shizune conseguir te ver, Hisaozinho~!"

# game/script-a3-emi.rpy:2484
translate pt_br a3_emi_lunch_and_science_b0463726:

    # "This whole spiel is so patently ridiculous that I can't help but reply in the same pompous manner."
    "Toda essa lenga-lenga é tão notoriamente ridícula que eu não consigo evitar de responder da mesma maneira pomposa."

# game/script-a3-emi.rpy:2486
translate pt_br a3_emi_lunch_and_science_01c0e5d0:

    # hi "Well, I for one feel enlightened."
    hi "Bem, eu mesmo me sinto iluminado agora."

# game/script-a3-emi.rpy:2488
translate pt_br a3_emi_lunch_and_science_33f4e90f:

    # hi "I apologize profusely for my rash actions and will strive to contain my baser impulses which, I fear, impel me toward such inappropriate displays of public affection."
    hi "Eu peço perdão pelas minhas ações imprudentes e vou ambicionar conter meus impulsos base, dos quais eu temo, me impelem tais inapropriadas exibições de afeto público."

# game/script-a3-emi.rpy:2490
translate pt_br a3_emi_lunch_and_science_152bada1:

    # hi "It is hardly my wish to burden an already overworked Student Council with such petty matters, and will do my best to make your lives easier in this matter in the future."
    hi "É difícilmente meu desejo fardar mais um Conselho Estudantil já cheio de trabalho com tais problemas triviais e vou fazer o meu melhor para facilitar a vida de vocês no futuro."

# game/script-a3-emi.rpy:2492
translate pt_br a3_emi_lunch_and_science_75512ce3:

    # hi "At least, when Shizune's watching."
    hi "Pelo menos, quando a Shizune estiver vendo."

# game/script-a3-emi.rpy:2494
translate pt_br a3_emi_lunch_and_science_a60ddf0f:

    # "This last line is delivered with a wink to Misha, who finally loses control of her laughter."
    "Essa última frase é dada com uma piscada de olho pra Misha, que finalmente perde o controle da risada."

# game/script-a3-emi.rpy:2499
translate pt_br a3_emi_lunch_and_science_e39fcd2d:

    # mi "Wahaha~!"
    mi "Wahaha~!"

# game/script-a3-emi.rpy:2504
translate pt_br a3_emi_lunch_and_science_3978c3f8:

    # mi "Well said, Hicchan~!"
    mi "Bem dito, Hisaozinho~!"

# game/script-a3-emi.rpy:2506
translate pt_br a3_emi_lunch_and_science_e1dab0c0:

    # "Chuckling a little myself, we enter the classroom."
    "Rindo um pouco eu mesmo, nós entramos na sala de aula."

# game/script-a3-emi.rpy:2512
translate pt_br a3_emi_lunch_and_science_e831e126:

    # "Class is uneventful, and after the final bell rings, I find myself alone with Mutou again."
    "A aula prossegue sem eventos, e quando o sinal toca eu me encontro sozinho com o Mutou novamente."

# game/script-a3-emi.rpy:2517
translate pt_br a3_emi_lunch_and_science_291fa12c:

    # mu "So, it looks like we've all assembled for the second meeting of the Science Club."
    mu "Então, parece que já estamos prontos para uma segunda reunião do Clube de Ciência."

# game/script-a3-emi.rpy:2523
translate pt_br a3_emi_lunch_and_science_072cd73e:

    # mu "Or is it the first? What do you think, should we count yesterday as a meeting?"
    mu "Ou é a primeira? O que você acha, ontem pode contar como uma reunião?"

# game/script-a3-emi.rpy:2525
translate pt_br a3_emi_lunch_and_science_11579085:

    # hi "Well, we did form the club yesterday, didn't we?"
    hi "Bom, nós formamos o clube ontem não é mesmo?"

# game/script-a3-emi.rpy:2527
translate pt_br a3_emi_lunch_and_science_1f820112:

    # hi "That seems like club business, so we can safely call yesterday a meeting."
    hi "Me pareceu atividade de clube, então podemos dizer que ontem foi uma reunião."

# game/script-a3-emi.rpy:2532
translate pt_br a3_emi_lunch_and_science_a4296f0b:

    # "Mutou smiles in his usual stilted and awkward way. I wonder if the muscles in his face are just not shaped correctly to let him smile naturally."
    "Mutou sorri de sua maneira comumente estranha. Eu imagino se os músculos na cara dele não são apenas de formatos estranhos que não o deixam sorrir naturalmente."

# game/script-a3-emi.rpy:2534
translate pt_br a3_emi_lunch_and_science_a69070b4:

    # mu "You really do have a knack for this, I think. Logical thought processes, that is."
    mu "Você realmente tem jeito para isso, eu acho. Isso sendo, processo de pensamento lógico."

# game/script-a3-emi.rpy:2536
translate pt_br a3_emi_lunch_and_science_38fa48f6:

    # hi "I guess so?"
    hi "Eu acho?"

# game/script-a3-emi.rpy:2541
translate pt_br a3_emi_lunch_and_science_557cbd21:

    # mu "A scientist speaks with authority, Hisao. The answer here is 'Yes, I do.'"
    mu "Um cientista fala com autoridade, Hisao. A resposta é “Sim, eu tenho”."

# game/script-a3-emi.rpy:2543
translate pt_br a3_emi_lunch_and_science_d40f499f:

    # mu "When the world wants to know how it works, we tell it. Even if all we've got is a decent hypothesis."
    mu "Quando o mundo quer saber como aquilo funciona, nós dizemos. Mesmo se tudo que temos são hipóteses decentes."

# game/script-a3-emi.rpy:2548
translate pt_br a3_emi_lunch_and_science_4a07af6a:

    # mu "But we must sound certain anyway, because we're the authorities on the subject, right?"
    mu "Mas temos que parecer termos certeza, porque somos a autoridade no assunto, certo?"

# game/script-a3-emi.rpy:2550
translate pt_br a3_emi_lunch_and_science_5e089a2c:

    # "He chuckles, to go along with his awkward smile at his awkward joke. I'm doing my best not to grimace, but I don't think I'm being too successful."
    "Ele ri, pra combinar com seu sorriso estranho e sua piada sem graça. Estou fazendo o meu melhor pra não fazer careta, mas não acho que estou sendo muito bem sucedido."

# game/script-a3-emi.rpy:2555
translate pt_br a3_emi_lunch_and_science_0d74b4e3:

    # mu "That's entirely false, of course."
    mu "Isso é inteiramente falso, é claro."

# game/script-a3-emi.rpy:2557
translate pt_br a3_emi_lunch_and_science_f1eb0b77:

    # mu "We know a lot, sure, but nobody's an expert on how the world works, if only because nobody can be sure. With no certainty, there are no experts."
    mu "Nós sabemos muito, claro, mas ninguém é um expert em como o mundo funciona, mas só podemos ser com certeza. Sem certeza, não há experts."

# game/script-a3-emi.rpy:2559
translate pt_br a3_emi_lunch_and_science_7b49fe21:

    # mu "But we like to pretend, sometimes."
    mu "Apesar de que gostamos de fingir, às vezes."

# game/script-a3-emi.rpy:2561
translate pt_br a3_emi_lunch_and_science_2035d2c3:

    # hi "There's some things we can be certain of, right?"
    
    hi "Há coisas das quais podemos ter certaza, certo?"

# game/script-a3-emi.rpy:2563
translate pt_br a3_emi_lunch_and_science_738ce96d:

    # mu "Yes… but no."
    mu "Sim… mas não."

# game/script-a3-emi.rpy:2565
translate pt_br a3_emi_lunch_and_science_da989aa2:

    # mu "We know gravity's there, for example."
    mu "Nós sabemos que a gravidade está aqui, por exemplo."

# game/script-a3-emi.rpy:2567
translate pt_br a3_emi_lunch_and_science_9fb46c72:

    # "To illustrate, Mutou picks up a pencil and drops it."
    "Para ilustrar, Mutou pega um lápis e deixa cair."

# game/script-a3-emi.rpy:2569
translate pt_br a3_emi_lunch_and_science_39deda6c:

    # mu "See? Still there. But it's good to check every once in a while."
    
    mu "Viu? Ainda está aqui. Mas é bom checar isso de vez em quando."

# game/script-a3-emi.rpy:2571
translate pt_br a3_emi_lunch_and_science_18e27b07:

    # mu "That's why you'll still see researchers mucking about with gravity."
    mu "Por isso que você ainda vê pesquisadores mexendo com gravidade."

# game/script-a3-emi.rpy:2576
translate pt_br a3_emi_lunch_and_science_6b768a7a:

    # mu "We're pretty sure we know how it works, but there's always a chance that something isn't how we think it is."
    mu "Nós temos certeza de que sabemos como funciona, mas sempre há a chance de que algo não é como nós pensamos que seja."

# game/script-a3-emi.rpy:2578
translate pt_br a3_emi_lunch_and_science_bc2adbbc:

    # mu "So you check, and check, and check. That's science in a nutshell, Hisao."
    mu "Então você checa, e checa e checa. Isso é um resumo do que é ciência, Hisao."

# game/script-a3-emi.rpy:2580
translate pt_br a3_emi_lunch_and_science_511b3722:

    # "The whole time I've listened feeling rather spellbound. Mutou seems to really be passionate about this stuff… I think. It's hard to tell, sometimes."
    "Durante todo o tempo que eu o escutei, eu estava me sentindo encantado de certa forma. Mutou faz transparecer sua paixão pelo assunto… eu acho. É difícil dizer, às vezes."

# game/script-a3-emi.rpy:2582
translate pt_br a3_emi_lunch_and_science_74ea04e9:

    # "How the world works…"
    "Como o mundo funciona…"
    

# game/script-a3-emi.rpy:2584
translate pt_br a3_emi_lunch_and_science_65fabe47:

    # "How humans work."
    "Como humanos funcionam."

# game/script-a3-emi.rpy:2586
translate pt_br a3_emi_lunch_and_science_d98c7895:

    # "How the universe works."
    "Como o Universo funciona."

# game/script-a3-emi.rpy:2588
translate pt_br a3_emi_lunch_and_science_a3ad946a:

    # "All these questions to be answered."
    "Todas essas perguntas a serem respondidas."

# game/script-a3-emi.rpy:2590
translate pt_br a3_emi_lunch_and_science_3252cd69:

    # "And, depending on what I go into, maybe I could even figure out a way to fix my heart. That said, I don't think that's a real priority for me."
    "E, dependendo do ramo que eu seguir, talvez eu arranje uma maneira de consertar o meu coração. Dito isso, eu não acho que esta seja uma prioridade pra mim."

# game/script-a3-emi.rpy:2592
translate pt_br a3_emi_lunch_and_science_29ecac11:

    # "Besides, as we start discussing the book he gave me yesterday, I find myself more and more interested in that than my heart condition."
    "Além do que, conforme começamos a discutir o livro que ele me deu ontem, eu me encontro mais e mais interessado nisso do que no meu problema de coração."

# game/script-a3-emi.rpy:2597
translate pt_br a3_emi_lunch_and_science_7d7b286b:

    # "Before we even realize it, an hour's gone by."
    "Antes de percebermos, se passou uma hora."

# game/script-a3-emi.rpy:2599
translate pt_br a3_emi_lunch_and_science_5c890fc6:

    # mu "Well, let's call this meeting over for now, okay?"
    mu "Vamos terminar a reunião por aqui, tudo bem?"

# game/script-a3-emi.rpy:2601
translate pt_br a3_emi_lunch_and_science_0e87bc90:

    # mu "We'll have another meeting… tomorrow, or uh… the day after."
    mu "Teremos outra reunião… amanhã, ou er… no dia depois de amanhã."

# game/script-a3-emi.rpy:2603
translate pt_br a3_emi_lunch_and_science_8529385d:

    # "He considers this for a moment."
    "Ele considera isso por um momento."

# game/script-a3-emi.rpy:2605
translate pt_br a3_emi_lunch_and_science_46d767c2:

    # mu "Call it the day after. I've got a lot of grading to do."
    mu "Deixe para depois de amanhã. Eu tenho algumas notas a dar."

# game/script-a3-emi.rpy:2607
translate pt_br a3_emi_lunch_and_science_18f6c519:

    # hi "Okay. See you then."
    hi "Ok, até mais."

# game/script-a3-emi.rpy:2614
translate pt_br a3_emi_lunch_and_science_7fb92804:

    # "As I exit the classroom, I realize that I don't really have anything to do tonight."
    "Saindo da sala de aula, eu percebo que não tenho nada para fazer hoje a noite."

# game/script-a3-emi.rpy:2616
translate pt_br a3_emi_lunch_and_science_afdb6e99:

    # "Emi and I didn't make plans, so…"
    "Emi e eu não fizemos planos, então…"

# game/script-a3-emi.rpy:2618
translate pt_br a3_emi_lunch_and_science_1af65376:

    # "I guess I'll go to the library. It beats doing homework in my room, anyway."
    "Acho que vou para a biblioteca, é melhor que ficar no meu quarto fazendo dever de casa de qualquer forma."

# game/script-a3-emi.rpy:2631
translate pt_br a3_emi_up_down_and_up_again_5f961ec5:

    # "The library always seems cooler than the rest of the building."
    "A biblioteca sempre parece mais fresca que o resto do prédio."

# game/script-a3-emi.rpy:2633
translate pt_br a3_emi_up_down_and_up_again_55ce66bb:

    # "Probably to keep the books from getting damaged by excessive heat and humidity."
    "Provavelmente para impedir que os livros se danifiquem por excesso de calor e umidade."

# game/script-a3-emi.rpy:2635
translate pt_br a3_emi_up_down_and_up_again_43c7ec40:

    # "Books are sturdy objects, but if you want to keep them in good condition it takes a little effort."
    "Livros são bem resistentes, mas se você quiser mantê-los em boas condições é preciso um pouco de esforço."

# game/script-a3-emi.rpy:2637
translate pt_br a3_emi_up_down_and_up_again_de27fee6:

    # "I've got several books that are so well-worn the pages are barely clinging to the spine."
    "Eu tenho vários livros que estão tão desgastados que as páginas quase não estão mais presas."

# game/script-a3-emi.rpy:2639
translate pt_br a3_emi_up_down_and_up_again_e98ac8bd:

    # "It seems impossible for them to still be usable, but if you handle them with care…"
    "Parece impossível de serem usados, mas se você os manejar com cuidado…"

# game/script-a3-emi.rpy:2641
translate pt_br a3_emi_up_down_and_up_again_1a935ea8:

    # "I make my way to the main desk, where I spot Yuuko busying herself with something or another."
    "Eu vou até a mesa principal, onde eu vejo Yuuko se ocupando com algo aqui ou ali."

# game/script-a3-emi.rpy:2646
translate pt_br a3_emi_up_down_and_up_again_626a644c:

    # "She smiles at me as I enter and waves."
    "Ela sorri quando eu entro e acena."

# game/script-a3-emi.rpy:2651
translate pt_br a3_emi_up_down_and_up_again_56bd504b:

    # yu "Hello, Hisao."
    yu "Olá, Hisao."

# game/script-a3-emi.rpy:2656
translate pt_br a3_emi_up_down_and_up_again_060f7c77:

    # yu "Good to see you again! What are you looking for this time?"
    yu "Bom te ver de novo. O que você está procurando hoje?"

# game/script-a3-emi.rpy:2658
translate pt_br a3_emi_up_down_and_up_again_f444bec9:

    # hi "Nothing in particular, I guess. I just didn't really feel like going back to my room, is all."
    hi "Nada em particular eu acho. Eu só não estava muito afim de voltar para o meu quarto, só isso."

# game/script-a3-emi.rpy:2663
translate pt_br a3_emi_up_down_and_up_again_2b4678bf:

    # "Yuuko nods."
    "Yuuko balança a cabeça."

# game/script-a3-emi.rpy:2668
translate pt_br a3_emi_up_down_and_up_again_cee22333:

    # yu "Well, if you're unoccupied, maybe you could help me look for something?"
    yu "Bem, se você está desocupado, você poderia me ajudar a procurar por algo?"

# game/script-a3-emi.rpy:2670
translate pt_br a3_emi_up_down_and_up_again_44dac545:

    # hi "Sure, what do you need?"
    hi "Claro, o que é?"

# game/script-a3-emi.rpy:2677
translate pt_br a3_emi_up_down_and_up_again_80cb4d04:

    # "Yuuko brings a finger to her lips and looks around furtively."
    "Yuuko leva um dedo aos lábios e olha ao seu redor furtivamente."

# game/script-a3-emi.rpy:2679
translate pt_br a3_emi_up_down_and_up_again_50c87fed:

    # "She seems to be looking for eavesdroppers."
    
    "Ela parece estar procurando por pessoas que possam estar escutando."

# game/script-a3-emi.rpy:2681
translate pt_br a3_emi_up_down_and_up_again_321f3d99:

    # yu "Come closer."
    yu "Chegue mais perto."

# game/script-a3-emi.rpy:2686
translate pt_br a3_emi_up_down_and_up_again_e4f6dd11:

    # "I take a few hesitant steps forward while feeling distinctly unnerved."
    "Eu dou alguns passos a frente me sentindo distintamente nervoso."

# game/script-a3-emi.rpy:2688
translate pt_br a3_emi_up_down_and_up_again_596eb3dd:

    # "Yuuko lowers her voice to a confidential whisper."
    "Yuuko abaixa a voz a nível de um sussurro confidencial."

# game/script-a3-emi.rpy:2693
translate pt_br a3_emi_up_down_and_up_again_5b382376:

    # yu "I'm on the trail of the Yamaku Cat Burglar."
    yu "Estou procurando pelo Gatuno da Yamaku."

# game/script-a3-emi.rpy:2697
translate pt_br a3_emi_up_down_and_up_again_a7d6fb56:

    # hi "The what?"
    hi "O quê?"

# game/script-a3-emi.rpy:2702
translate pt_br a3_emi_up_down_and_up_again_4485dacd:

    # yu "Shh! The walls have ears, Hisao!"
    yu "Shh! As paredes tem ouvidos, Hisao!"

# game/script-a3-emi.rpy:2704
translate pt_br a3_emi_up_down_and_up_again_82e2f54b:

    # yu "Or they might."
    yu "Ou elas podem ter."

# game/script-a3-emi.rpy:2709
translate pt_br a3_emi_up_down_and_up_again_04017c4c:

    # yu "But listen! Those missing books, remember them?"
    yu "Mas escute! Aqueles livros sumidos, lembra?"

# game/script-a3-emi.rpy:2711
translate pt_br a3_emi_up_down_and_up_again_5f71bc52:

    # hi "Er, yeah?"
    hi "Er, sim?"

# game/script-a3-emi.rpy:2716
translate pt_br a3_emi_up_down_and_up_again_480cf535:

    # yu "Well, they weren't missing! They were stolen!"
    
    yu "Bem, eles não estavam sumidos! Eles foram roubados!"

# game/script-a3-emi.rpy:2718
translate pt_br a3_emi_up_down_and_up_again_0472c156:

    # yu "I'm convinced of it!"
    yu "Eu estou certa disso!"

# game/script-a3-emi.rpy:2720
translate pt_br a3_emi_up_down_and_up_again_023b44dc:

    # hi "I remember you saying something of the sort earlier, but how do you know?"
    hi "Eu me lembro de você dizendo algo do tipo. Mas como você sabe?"

# game/script-a3-emi.rpy:2722
translate pt_br a3_emi_up_down_and_up_again_3b291e19:

    # "Yuuko leans in closer and, if possible, whispers even lower."
    "Yuuko se aproxima mais, se é que é possível, e sussura ainda mais baixo."

# game/script-a3-emi.rpy:2727
translate pt_br a3_emi_up_down_and_up_again_9be36150:

    # yu "Because I found one of his hiding places!"
    
    yu "Porque eu encontrei um dos seus esconderijos!"

# game/script-a3-emi.rpy:2729
translate pt_br a3_emi_up_down_and_up_again_167efa4b:

    # hi "You did what?"
    hi "Você o quê?"

# game/script-a3-emi.rpy:2731
translate pt_br a3_emi_up_down_and_up_again_9bd867eb:

    # "Yuuko looks triumphant."
    "Yuuko parece triunfante."

# game/script-a3-emi.rpy:2736
translate pt_br a3_emi_up_down_and_up_again_d9418d9c:

    # yu "Found one of his stashes! It was under one of the stairwells in the boy's dorm!"
    yu "Eu achei um de seus armazéns! Era embaixo de uma das escadas no dormitório masculino."

# game/script-a3-emi.rpy:2738
translate pt_br a3_emi_up_down_and_up_again_a153032d:

    # yu "Three books I'd been looking for, all there!"
    yu "Três livros que eu estava procurando, todos lá!"

# game/script-a3-emi.rpy:2743
translate pt_br a3_emi_up_down_and_up_again_7fd0012a:

    # yu "I'd suspected a thief before, but this proves it!"
    yu "Eu suspeitava de um ladrão antes, mas isso é a prova!"

# game/script-a3-emi.rpy:2745
translate pt_br a3_emi_up_down_and_up_again_2c4f463e:

    # hi "So did you take back the books?"
    hi "Então, você pegou os livros de volta?"

# game/script-a3-emi.rpy:2750
translate pt_br a3_emi_up_down_and_up_again_b8489dd9:

    # "Yuuko looks as if I've just suggested she walk around naked."
    "Yuuko me olha como se eu tivesse sugerido que ela andasse nua em público."

# game/script-a3-emi.rpy:2752
translate pt_br a3_emi_up_down_and_up_again_6241567a:

    # yu "Are you nuts?"
    yu "Você está louco?"

# game/script-a3-emi.rpy:2757
translate pt_br a3_emi_up_down_and_up_again_4125826c:

    # yu "He can't know I'm on to him! He might go to ground and evade capture!"
    yu "Ele não pode saber que estou atrás dele! Ele pode fugir e eu não vou conseguir capturá-lo."

# game/script-a3-emi.rpy:2759
translate pt_br a3_emi_up_down_and_up_again_1e332c0c:

    # hi "Uh… huh. So what do you need my help with, then?"
    hi "A… ham. Então com o que você precisa da minha ajuda?"

# game/script-a3-emi.rpy:2761
translate pt_br a3_emi_up_down_and_up_again_dc57b6a1:

    # "Yuuko casts another glance around the library and leans in closer."
    "Yuuko olha mais uma vez em volta e chega mais perto."

# game/script-a3-emi.rpy:2766
translate pt_br a3_emi_up_down_and_up_again_95a25071:

    # yu "You've got to spy for me."
    yu "Você tem que espionar por mim."

# game/script-a3-emi.rpy:2768
translate pt_br a3_emi_up_down_and_up_again_349104a9:

    # hi "Spy?"
    hi "Espionar?"

# game/script-a3-emi.rpy:2770
translate pt_br a3_emi_up_down_and_up_again_948e16ab:

    # yu "Yeah, like when you're in the dorms, you know."
    
    yu "É, quando você estiver no dormitório, sabe."

# game/script-a3-emi.rpy:2775
translate pt_br a3_emi_up_down_and_up_again_4c481194:

    # yu "Keep an eye out for suspicious activity."
    yu "Fique de olho aberto para atividades suspeitas."

# game/script-a3-emi.rpy:2777
translate pt_br a3_emi_up_down_and_up_again_3b99d883:

    # "What constitutes suspicious, anyway?"
    "O que constitui suspeito, de qualquer forma?"

# game/script-a3-emi.rpy:2779
translate pt_br a3_emi_up_down_and_up_again_19e51202:

    # "I mean Kenji's a pretty suspicious dude, but I'll wager he barely goes to class, much less sneaks into the library to pilfer books."
    "Quer dizer, o Kenji é um cara suspeito, mas eu aposto que ele mal vai as aulas, muito menos entrar escondido na biblioteca para furtar livros."

# game/script-a3-emi.rpy:2781
translate pt_br a3_emi_up_down_and_up_again_4057f6e5:

    # "Still, what's the harm in saying yes? At the least it'll get me out of this weird conversation."
    "Ainda sim, qual o problema em concordar? Pelo menos vai me tirar dessa conversa esquisita."

# game/script-a3-emi.rpy:2783
translate pt_br a3_emi_up_down_and_up_again_44cab39a:

    # hi "Yeah, I can do that. No problem."
    hi "Claro, eu posso fazer isso. Sem problemas."

# game/script-a3-emi.rpy:2788
translate pt_br a3_emi_up_down_and_up_again_b6c633ae:

    # "Yuuko straightens up and claps excitedly."
    "Yuuko se endireita e aplaude com fervor."

# game/script-a3-emi.rpy:2790
translate pt_br a3_emi_up_down_and_up_again_6fe05fee:

    # yu "Great!"
    yu "Ótimo!"

# game/script-a3-emi.rpy:2795
translate pt_br a3_emi_up_down_and_up_again_fb2d785a:

    # yu "Now, hurry up and talk about something else in case someone comes in!"
    yu "Agora, rápido, fale sobre outra coisa, caso alguém entre!"

# game/script-a3-emi.rpy:2802
translate pt_br a3_emi_up_down_and_up_again_caf16bd4:

    # yu "How's the school treating you?"
    yu "Como anda a escola?"

# game/script-a3-emi.rpy:2804
translate pt_br a3_emi_up_down_and_up_again_2fe6c1c4:

    # hi "Er, pretty well, actually."
    hi "Er, bem, na verdade."

# game/script-a3-emi.rpy:2806
translate pt_br a3_emi_up_down_and_up_again_6d19ae65:

    # hi "I've been running in the mornings with—"
    
    hi "Eu tenho corrida pelas manhãs com-"

# game/script-a3-emi.rpy:2811
translate pt_br a3_emi_up_down_and_up_again_449125d7:

    # yu "Emi Ibarazaki, right?"
    yu "Emi Ibarazaki, certo?"

# game/script-a3-emi.rpy:2815
translate pt_br a3_emi_up_down_and_up_again_2d3cf25d:

    # hi "Uh, yeah."
    hi "Er, é."

# game/script-a3-emi.rpy:2817
translate pt_br a3_emi_up_down_and_up_again_da2bccd9:

    # hi "How'd you know?"
    hi "Como você sabe?"

# game/script-a3-emi.rpy:2822
translate pt_br a3_emi_up_down_and_up_again_e7d8e8e7:

    # yu "I served you two in the teahouse, remember?"
    yu "Eu servi vocês dois na casa de chá, lembra?"

# game/script-a3-emi.rpy:2827
translate pt_br a3_emi_up_down_and_up_again_08db766c:

    # yu "I deduced that if you were going to run with anyone, it would probably be her."
    yu "Deduzi que se você fosse estar correndo com alguém, seria ela."

# game/script-a3-emi.rpy:2829
translate pt_br a3_emi_up_down_and_up_again_f6ab9b8c:

    # "She looks pleased with herself."
    "Ela parece satisfeita consigo mesma."

# game/script-a3-emi.rpy:2831
translate pt_br a3_emi_up_down_and_up_again_05823cbc:

    # hi "Impressive."
    hi "Impressionante."

# game/script-a3-emi.rpy:2833
translate pt_br a3_emi_up_down_and_up_again_7371112f:

    # hi "Anyway, yes. We've been running in the mornings."
    
    hi "De qualquer forma, sim. Eu tenho corrido de manhã."
    

# game/script-a3-emi.rpy:2835
translate pt_br a3_emi_up_down_and_up_again_f9f7e4ff:

    # hi "And uh, we kinda started dating."
    
    hi "E, é, nós meio que acabamos namorando."

# game/script-a3-emi.rpy:2840
translate pt_br a3_emi_up_down_and_up_again_3b22f75a:

    # "Yuuko claps her hands together excitedly."
    "Yuuko bate palmas com fervor novamente."

# game/script-a3-emi.rpy:2842
translate pt_br a3_emi_up_down_and_up_again_723ae3be:

    # yu "Really? That's great!"
    yu "Sério? Isso é ótimo!"

# game/script-a3-emi.rpy:2844
translate pt_br a3_emi_up_down_and_up_again_b8a7502d:

    # yu "I'll bet you two are great together!"
    yu "Eu aposto que vocês dois são ótimos juntos!"

# game/script-a3-emi.rpy:2849
translate pt_br a3_emi_up_down_and_up_again_f657a023:

    # yu "I love seeing people find one another like that, you know?"
    yu "Eu amo ver as pessoas se encontrarem dessa forma, sabe?"

# game/script-a3-emi.rpy:2851
translate pt_br a3_emi_up_down_and_up_again_4fcbfa89:

    # yu "I even thought to myself when you walked into the Shanghai that one time, 'I wonder if that kid will wind up with one of those girls.'"
    yu "Eu até pensei aquele dia quando vocês foram no Xangai, “eu imagino se ele vai acabar ficando com uma das garotas”."

# game/script-a3-emi.rpy:2853
translate pt_br a3_emi_up_down_and_up_again_9456f068:

    # hi "…Really?"
    hi "…Sério?"

# game/script-a3-emi.rpy:2855
translate pt_br a3_emi_up_down_and_up_again_fb2b7134:

    # "Yuuko doesn't seem to notice my somewhat weirded out tone and nods affirmatively."
    "Yuuko não percebe pelo meu tom que eu achei estranho o que ela falou, e apenas balança a cabeça veemente."

# game/script-a3-emi.rpy:2860
translate pt_br a3_emi_up_down_and_up_again_00ac9931:

    # yu "Yup! I could tell that you'd wind up with one of them, you know."
    
    yu "Aham! Eu sabia que você ficaria com uma delas, sabe."

# game/script-a3-emi.rpy:2865
translate pt_br a3_emi_up_down_and_up_again_fabbb612:

    # yu "I've got an eye for that sort of thing."
    yu "Eu tenho um olho para esse tipo de coisa."

# game/script-a3-emi.rpy:2870
translate pt_br a3_emi_up_down_and_up_again_fc547a64:

    # yu "Of course…"
    
    yu "Claro…"

# game/script-a3-emi.rpy:2872
translate pt_br a3_emi_up_down_and_up_again_39e41517:

    # "Her expression droops slightly."
    "Ela parece se abater um pouco."

# game/script-a3-emi.rpy:2874
translate pt_br a3_emi_up_down_and_up_again_5715a674:

    # yu "I'm not so good at it myself."
    yu "Eu não sou tão boa com isso eu mesma."

# game/script-a3-emi.rpy:2876
translate pt_br a3_emi_up_down_and_up_again_54264c5d:

    # hi "Aw, I'm sure that's not true."
    
    hi "Aw, eu tenho certeza que isso não é verdade."

# game/script-a3-emi.rpy:2881
translate pt_br a3_emi_up_down_and_up_again_127e7dfd:

    # yu "Oh, it's true."
    yu "Oh, é verdade."

# game/script-a3-emi.rpy:2883
translate pt_br a3_emi_up_down_and_up_again_89eaedb3:

    # yu "I met this guy once…"
    yu "Eu conheci um cara…"

# game/script-a3-emi.rpy:2888
translate pt_br a3_emi_up_down_and_up_again_db47b7ec:

    # yu "We got along really great, but it turned out he was younger than me."
    yu "Nós nos davamos muito bem, mas acabou que ele era mais novo que eu."

# game/script-a3-emi.rpy:2893
translate pt_br a3_emi_up_down_and_up_again_15fb4b26:

    # yu "And that was kinda weird, but not terribly so."
    yu "E isso é um pouco estranho, mas nem tanto."

# game/script-a3-emi.rpy:2895
translate pt_br a3_emi_up_down_and_up_again_7b0067a0:

    # yu "What was really weird was that he disappeared one day, and I've not seen him since then."
    yu "O que foi estranho é que ele desapareceu um dia e eu nunca mais o vi."

# game/script-a3-emi.rpy:2897
translate pt_br a3_emi_up_down_and_up_again_2f18048b:

    # hi "Huh. That does seem kind of odd."
    hi "Hmm. Isso parece sim meio estranho."

# game/script-a3-emi.rpy:2902
translate pt_br a3_emi_up_down_and_up_again_7773c4ef:

    # yu "Doesn't it?"
    yu "Não parece?"

# game/script-a3-emi.rpy:2907
translate pt_br a3_emi_up_down_and_up_again_553af8a3:

    # yu "I hope it wasn't something I did…"
    yu "Espero que não tenha sido algo que eu fiz…"

# game/script-a3-emi.rpy:2909
translate pt_br a3_emi_up_down_and_up_again_7c0b7cb1:

    # "I feel compelled to reassure her."
    "Eu me sinto obrigado a consolá-la."

# game/script-a3-emi.rpy:2911
translate pt_br a3_emi_up_down_and_up_again_3c90741a:

    # hi "I'm sure it wasn't."
    hi "Tenho certeza que não foi."

# game/script-a3-emi.rpy:2920
translate pt_br a3_emi_up_down_and_up_again_c3c50419:

    # "I intend to try and calm her down further, but the both of us jump in surprise at the ringing suddenly coming from my pocket."
    "Eu tinha a intenção de acalmá-la totalmente, mas nós dois pulamos surpresos com o som que sai do meu bolso."

# game/script-a3-emi.rpy:2925
translate pt_br a3_emi_up_down_and_up_again_225cae1f:

    # "Yuuko sighs to steady herself as I pull the phone from my pocket. I feel a little sheepish for indirectly causing the incident."
    "Yuuko expira pra se acalmar enquanto eu puxo o telefone do bolso. Eu me sinto um pouco culpado por ter causado o incidente."

# game/script-a3-emi.rpy:2935
translate pt_br a3_emi_up_down_and_up_again_58c69509:

    # hi "Emi? What's up?"
    hi "Emi? E aí?"

# game/script-a3-emi.rpy:2937
translate pt_br a3_emi_up_down_and_up_again_a08228e1:

    # emi "Oh thank God I haven't called your phone before so I didn't know if this number would work or whether you would pick up and I can't—"
    emi "Oh graças a Deus eu não tinha te ligado nesse número antes então eu não sabia se esse número iria funcionar ou se você iria atender e eu não posso—"

# game/script-a3-emi.rpy:2942
translate pt_br a3_emi_up_down_and_up_again_354ab1d0:

    # hi "Woah there Emi, slow down."
    hi "Calma aí Emi, mais devagar."

# game/script-a3-emi.rpy:2944
translate pt_br a3_emi_up_down_and_up_again_2331cad8:

    # hi "What's wrong?"
    
    hi "O que houve?"
    

# game/script-a3-emi.rpy:2946
translate pt_br a3_emi_up_down_and_up_again_ab5d124e:

    # "There's a pause on the other side of the line, during which I can hear Emi trying to control her breathing in order to calm down."
    "Há uma pausa no outro lado da linha, durante a qual eu consigo ouvir a Emi tentando controlar sua respiração para se acalmar."

# game/script-a3-emi.rpy:2948
translate pt_br a3_emi_up_down_and_up_again_6355dcf2:

    # "Something's got her terribly agitated, and it's starting to agitate me."
    "Algo a deixou terrivelmente agitada, e está começando a me agitar também."

# game/script-a3-emi.rpy:2950
translate pt_br a3_emi_up_down_and_up_again_9282edca:

    # emi "Can you just…"
    emi "Você pode só…"

# game/script-a3-emi.rpy:2952
translate pt_br a3_emi_up_down_and_up_again_1c75e1c7:

    # emi "Can you stop by?"
    emi "Pode vir aqui?"

# game/script-a3-emi.rpy:2954
translate pt_br a3_emi_up_down_and_up_again_54cadd34:

    # emi "Like, now? Or shortly after now?"
    emi "Tipo, agora? Ou daqui a pouco?"

# game/script-a3-emi.rpy:2956
translate pt_br a3_emi_up_down_and_up_again_74556757:

    # emi "I really, really need to talk to you."
    emi "Eu tenho muito, muito que falar com você."

# game/script-a3-emi.rpy:2958
translate pt_br a3_emi_up_down_and_up_again_5f247174:

    # "There's a tone of pleading in the last sentence that I don't think I've ever heard from her."
    "Tem um tom de súplica nessa última frase que eu acho que nunca tinha ouvido dela."

# game/script-a3-emi.rpy:2960
translate pt_br a3_emi_up_down_and_up_again_e6a9e9f2:

    # hi "Of course, I'll be right there."
    hi "É claro, já chego aí."

# game/script-a3-emi.rpy:2962
translate pt_br a3_emi_up_down_and_up_again_d8776315:

    # hi "Hold steady, okay?"
    hi "Aguenta firme, tá bem?"

# game/script-a3-emi.rpy:2964
translate pt_br a3_emi_up_down_and_up_again_5fc7ae54:

    # "In my increasingly agitated state I've apparently started saying things that don't quite make sense."
    "No meu estado agitado eu aparentemente comecei a falar coisas que não fazem muito sentido."

# game/script-a3-emi.rpy:2966
translate pt_br a3_emi_up_down_and_up_again_26a89abd:

    # emi "Okay. I'll be okay."
    emi "Ok, eu vou ficar bem."

# game/script-a3-emi.rpy:2968
translate pt_br a3_emi_up_down_and_up_again_6482a22f:

    # hi "See you soon."
    hi "Te vejo logo."

# game/script-a3-emi.rpy:2986
translate pt_br a3_emi_up_down_and_up_again_7c8735bd:

    # "I press the button to end the call before slipping the phone back into my pocket, apologize to Yuuko for running off, and run off."
    "Eu aperto o botão que termina a chamada, coloco o telefone de volta no meu bolso, desculpo-me com a Yuuko por sair de repente, e saio."

# game/script-a3-emi.rpy:2991
translate pt_br a3_emi_up_down_and_up_again_862cd951:

    # "Perhaps at some point I would have stopped to think about the time, or how suspicious it looks for a guy to enter the girls' dorm at this hour."
    "Talvez em algum momento eu teria parado para pensar na hora, ou o quão suspeito é para um cara entrar no dormitório das garotas a esta hora."

# game/script-a3-emi.rpy:2993
translate pt_br a3_emi_up_down_and_up_again_0d2e1ca9:

    # "Except right now I'm just concerned with getting to Emi and finding out what's wrong and how I can help her."
    "Mas neste momento eu só estou preocupado com chegar até a Emi e descobrir o que há de errado com ela e como eu posso ajudá-la."

# game/script-a3-emi.rpy:2997
translate pt_br a3_emi_up_down_and_up_again_19e19650:

    # "I knock on the door and am greeted with a subdued 'Come in.'"
    
    "Eu bato na porta e ouço um vencido “pode entrar”."

# game/script-a3-emi.rpy:3002
translate pt_br a3_emi_up_down_and_up_again_e83f36b7:

    # "Something is very wrong as I stare at the scene before me."
    "Algo está muito errado com a cena que vejo diante de mim."

# game/script-a3-emi.rpy:3004
translate pt_br a3_emi_up_down_and_up_again_1df8148b:

    # "Emi's there, yes."
    "Emi está lá, sim."

# game/script-a3-emi.rpy:3006
translate pt_br a3_emi_up_down_and_up_again_7f3269a5:

    # "But she's in a wheelchair."
    "Mas em uma cadeira de rodas."

# game/script-a3-emi.rpy:3008
translate pt_br a3_emi_up_down_and_up_again_c096bfdd:

    # "And her legs are missing. I glance around the room and see them sitting in a corner, looking like they've been thrown there."
    "E suas pernas não estão lá. Eu olho pelo quarto e as vejo em um canto, como se tivessem sido jogadas."

# game/script-a3-emi.rpy:3013
translate pt_br a3_emi_up_down_and_up_again_04fb99bc:

    # "Emi responds to my entrance with a lopsided grin that is both pleased to see me and completely, utterly heartbroken."
    "Emi responde a minha entrada com um sorriso que parece tanto de coração partido, quanto de feliz por me ver."

# game/script-a3-emi.rpy:3015
translate pt_br a3_emi_up_down_and_up_again_61b0a565:

    # emi "Hi, Hisao."
    
    emi "Oi, Hisao."

# game/script-a3-emi.rpy:3017
translate pt_br a3_emi_up_down_and_up_again_2e17aadc:

    # "It looks like she's been crying, but if she was, she's stopped now."
    
    "Parece que ela estava chorando, mas se estava, já parou agora."

# game/script-a3-emi.rpy:3019
translate pt_br a3_emi_up_down_and_up_again_313bfa8b:

    # "I notice that I'm a little out of breath, having taken the stairs two at a time in order to get here."
    "Eu percebo que estou um pouco sem ar, tendo subido as escadas de dois em dois degraus para chegar aqui."

# game/script-a3-emi.rpy:3021
translate pt_br a3_emi_up_down_and_up_again_a1e7bbdd:

    # "My heart doesn't seem to mind the strain, though. I file this happy fact away for later consideration."
    "Meu coração parece não se importar com o esforço. Eu arquivo isso em um “fatos felizes” para considerações mais tarde."

# game/script-a3-emi.rpy:3023
translate pt_br a3_emi_up_down_and_up_again_73c68489:

    # "Like when I am not staring somewhat dumbstruck at my girlfriend in a wheelchair."
    
    "Tipo para quando eu não estiver encarando como um idiota a minha namorada em uma cadeira de rodas."

# game/script-a3-emi.rpy:3025
translate pt_br a3_emi_up_down_and_up_again_ae88f535:

    # "Realizing I've still not responded to her greeting, my brain lurches into gear."
    "Vendo que eu ainda não a respondi, meu cérebro volta a funcionar."

# game/script-a3-emi.rpy:3027
translate pt_br a3_emi_up_down_and_up_again_0886498e:

    # hi "Emi? What happened?"
    
    hi "Emi? O que aconteceu?"
    

# game/script-a3-emi.rpy:3032
translate pt_br a3_emi_up_down_and_up_again_912043c9:

    # emi "Guess I should've listened to you, Hisao."
    emi "Acho que eu devia ter escutado você, Hisao."

# game/script-a3-emi.rpy:3037
translate pt_br a3_emi_up_down_and_up_again_643c5b95:

    # emi "My leg's got a nasty infection. I'm not allowed to run on it for at least a couple of weeks."
    emi "Minhas pernas contraíram uma infecção. Eu não posso correr nelas pelo menos por algumas semanas."

# game/script-a3-emi.rpy:3039
translate pt_br a3_emi_up_down_and_up_again_623fe27f:

    # "She gives a bitter laugh that shouldn't be coming from her."
    "Ela dá uma risada amarga que não é típico dela."

# game/script-a3-emi.rpy:3044
translate pt_br a3_emi_up_down_and_up_again_7fd644de:

    # emi "Heh, I can't even walk on it."
    emi "Heh, eu não posso nem andar nela."

# game/script-a3-emi.rpy:3046
translate pt_br a3_emi_up_down_and_up_again_fb111d79:

    # emi "I could have used a crutch and kept one of my legs, but I didn't see the point."
    emi "Eu poderia ter usado uma bengala e ficado com uma delas, mas não tem porquê fazer isso."

# game/script-a3-emi.rpy:3051
translate pt_br a3_emi_up_down_and_up_again_d07732f2:

    # emi "Why hop? You can't run on one leg."
    emi "Por que saltitar? Você não pode correr com uma perna."

# game/script-a3-emi.rpy:3056
translate pt_br a3_emi_up_down_and_up_again_4e339765:

    # emi "At least this way I can still, I dunno, roll fast or something."
    emi "Desse jeito eu posso pelo menos, sei lá, rolar rápido, ou algo assim."

# game/script-a3-emi.rpy:3058
translate pt_br a3_emi_up_down_and_up_again_1324f439:

    # hi "Y-yeah, that's good, right?"
    
    hi "É-É, que bom, né?"

# game/script-a3-emi.rpy:3060
translate pt_br a3_emi_up_down_and_up_again_2886ce29:

    # "My awkward attempt to look on the bright side seems appreciated, but not really effective."
    "Minha inábil maneira de tentar ver pelo lado bom parece apreciada, mas ineficiente."
    

# game/script-a3-emi.rpy:3062
translate pt_br a3_emi_up_down_and_up_again_a29e2378:

    # "Emi shrugs again."
    "Emi encolhe os ombros de novo."

# game/script-a3-emi.rpy:3067
translate pt_br a3_emi_up_down_and_up_again_4c3645e5:

    # emi "It's just… kind of a nuisance."
    emi "Só é meio que… um incômodo."

# game/script-a3-emi.rpy:3072
translate pt_br a3_emi_up_down_and_up_again_8478c5fa:

    # emi "I mean, we can't even eat up on the roof now. No wheelchair access."
    emi "Quer dizer, nem podemos mais comer no telhado. Não podemos levar cadeira de rodas lá."

# game/script-a3-emi.rpy:3074
translate pt_br a3_emi_up_down_and_up_again_cb952baf:

    # hi "Yeah, but that's not a big deal, right?"
    hi "É, mas isso não é um grande problema, né?"

# game/script-a3-emi.rpy:3076
translate pt_br a3_emi_up_down_and_up_again_595e0f07:

    # hi "I mean we can still eat together, and that's the important thing."
    hi "Quer dizer, ainda podemos comer juntos, e isso que é importante né."

# game/script-a3-emi.rpy:3081
translate pt_br a3_emi_up_down_and_up_again_786ac2e7:

    # "That lopsided grin again. It hurts to look at."
    "Aquela risada amarga de novo. Machuca de ver."

# game/script-a3-emi.rpy:3083
translate pt_br a3_emi_up_down_and_up_again_ebdc6fd1:

    # emi "I suppose so, yeah."
    emi "Eu acho que sim, é."

# game/script-a3-emi.rpy:3088
translate pt_br a3_emi_up_down_and_up_again_56bff2ff:

    # emi "But like I said, it's a nuisance."
    
    emi "Mas como eu disse, é um incômodo."

# game/script-a3-emi.rpy:3093
translate pt_br a3_emi_up_down_and_up_again_36be3a30:

    # emi "I mean, I haven't really used a wheelchair in…"
    emi "Quer dizer, eu não uso uma cadeira de rodas desde…"

# game/script-a3-emi.rpy:3097
translate pt_br a3_emi_up_down_and_up_again_ca92b07c:

    # "She thinks for a minute."
    "Ela pensa por um minuto."

# game/script-a3-emi.rpy:3102
translate pt_br a3_emi_up_down_and_up_again_80041d64:

    # emi "Maybe seven years? Something like that, anyway."
    emi "Talvez sete anos? É, algo assim."

# game/script-a3-emi.rpy:3104
translate pt_br a3_emi_up_down_and_up_again_5b1bee7b:

    # emi "A long time."
    emi "Muito tempo."

# game/script-a3-emi.rpy:3109
translate pt_br a3_emi_up_down_and_up_again_5bca6df3:

    # emi "I'm afraid I'm a bit out of practice."
    emi "Acho que estou um pouco sem prática."

# game/script-a3-emi.rpy:3111
translate pt_br a3_emi_up_down_and_up_again_a6c7d5e8:

    # hi "Well, fortunately it's only temporary, right?"
    hi "Bem, por sorte é apenas temporário, né?"

# game/script-a3-emi.rpy:3113
translate pt_br a3_emi_up_down_and_up_again_61cabdac:

    # "Emi nods."
    "Emi balança a cabeça."

# game/script-a3-emi.rpy:3118
translate pt_br a3_emi_up_down_and_up_again_5602bd8f:

    # emi "Oh yeah, of course."
    emi "Ah sim, é claro."

# game/script-a3-emi.rpy:3120
translate pt_br a3_emi_up_down_and_up_again_3f683ac8:

    # emi "It's not like I've lost 'em permanently."
    emi "Não é como se eu as tivesse perdido permanentemente."

# game/script-a3-emi.rpy:3125
translate pt_br a3_emi_up_down_and_up_again_22b6e828:

    # emi "But it's a pain in the ass all the same."
    emi "Mas é um pé no saco de qualquer forma."

# game/script-a3-emi.rpy:3127
translate pt_br a3_emi_up_down_and_up_again_9e4b9fb6:

    # "I nod sympathetically."
    "Eu balanço a cabeça, em simpatia."

# game/script-a3-emi.rpy:3129
translate pt_br a3_emi_up_down_and_up_again_7198b845:

    # "There's not much else I can do, after all."
    "Não há nada que eu possa fazer, afinal."

# game/script-a3-emi.rpy:3131
translate pt_br a3_emi_up_down_and_up_again_725bb9e9:

    # "What am I gonna do, say 'I told you so?'"
    "O que eu vou fazer, dizer “eu te disse”?"

# game/script-a3-emi.rpy:3133
translate pt_br a3_emi_up_down_and_up_again_152cb06b:

    # "Although I {b}did{/b} tell her to get that leg looked at."
    
    "Apesar que eu {b}disse{/b} de fato para ela ir ver essa perna."

# game/script-a3-emi.rpy:3135
translate pt_br a3_emi_up_down_and_up_again_b07c63d4:

    # "But by the time I noticed, it was too late anyway."
    "Mas quando eu percebi já era tarde demais."

# game/script-a3-emi.rpy:3137
translate pt_br a3_emi_up_down_and_up_again_a699921a:

    # hi "Do you need help with anything?"
    hi "Você precisa de ajuda com alguma coisa?"

# game/script-a3-emi.rpy:3139
translate pt_br a3_emi_up_down_and_up_again_eb8b0b0c:

    # hi "Er, that is, can I help with anything?"
    
    hi "Er, quer dizer, posso ajudar com algo?"
    

# game/script-a3-emi.rpy:3144
translate pt_br a3_emi_up_down_and_up_again_f0a24398:

    # "Emi shakes her head and there's a bit of her usual grin back."
    "Emi balança a cabeça negativamente e tem um pouco do seu sorriso de volta."

# game/script-a3-emi.rpy:3146
translate pt_br a3_emi_up_down_and_up_again_0b2bf549:

    # emi "Nah, I can manage fine by myself."
    emi "Não, eu consigo me virar sozinha."

# game/script-a3-emi.rpy:3151
translate pt_br a3_emi_up_down_and_up_again_0b3c19ed:

    # emi "Although if you want to help me over to my bed, it would save me the trouble of rolling over there myself."
    emi "Apesar que, se você quiser me ajudar chegar até minha cama, me salvaria o trabalho de rolar até ela eu mesma."

# game/script-a3-emi.rpy:3153
translate pt_br a3_emi_up_down_and_up_again_43500873:

    # "I blush, in spite of myself."
    "Eu coro, em despeito a mim mesmo."

# game/script-a3-emi.rpy:3155
translate pt_br a3_emi_up_down_and_up_again_7af30aaa:

    # "Emi giggles."
    "Emi ri."

# game/script-a3-emi.rpy:3162
translate pt_br a3_emi_up_down_and_up_again_8f5d9fb9:

    # emi "You're such a prude, Hisao."
    emi "Você é tão puritano, Hisao."

# game/script-a3-emi.rpy:3164
translate pt_br a3_emi_up_down_and_up_again_85dcbb34:

    # hi "I'm not a prude! I just wouldn't want to take advantage of a young woman such as yourself."
    hi "Eu não sou puritano! Eu só não gostaria de tirar vantagem de uma jovem mulher como você."

# game/script-a3-emi.rpy:3166
translate pt_br a3_emi_up_down_and_up_again_6c3fea9b:

    # hi "It's ungentlemanly."
    hi "Eu não seria cavalheiro."

# game/script-a3-emi.rpy:3174
translate pt_br a3_emi_up_down_and_up_again_1903eb2e:

    # "I wheel Emi's chair to her bed, and easily scoop her up and deposit her there. She quickly sorts herself out and sits on the side."
    "Eu rodo a cadeira de rodas até a cama e facilmente a levanto e coloco na cama. Ela rápidamente se ajeita e senta no lado."

# game/script-a3-emi.rpy:3185
translate pt_br a3_emi_up_down_and_up_again_f36e85d9:

    # "She's actually a little heavier than she looks. It would be rude of me to observe this aloud, of course."
    "Ela é um pouco mais pesada do que parece. Seria tudo da minha parte observar isso em voz alta, é claro."

# game/script-a3-emi.rpy:3187
translate pt_br a3_emi_up_down_and_up_again_da9afd7e:

    # hi "Man, you're kind of heavy."
    hi "Você é meio pesada."

# game/script-a3-emi.rpy:3201
translate pt_br a3_emi_up_down_and_up_again_172369cb:

    # "Emi hits me with a pillow."
    "Emi me acerta com um travesseiro."

# game/script-a3-emi.rpy:3206
translate pt_br a3_emi_up_down_and_up_again_da07edab:

    # emi "Ass."
    emi "Babaca."

# game/script-a3-emi.rpy:3208
translate pt_br a3_emi_up_down_and_up_again_9a5576ff:

    # hi "Just sayin', is all."
    hi "Só dizendo."

# game/script-a3-emi.rpy:3210
translate pt_br a3_emi_up_down_and_up_again_2a757153:

    # hi "Must be all that running."
    hi "Devem ser todas essas corridas."

# game/script-a3-emi.rpy:3215
translate pt_br a3_emi_up_down_and_up_again_834c68f7:

    # "At the mention of running Emi's grin falters slightly."
    "Ao mencionar as corridas o sorriso da Emi falha um pouco."

# game/script-a3-emi.rpy:3220
translate pt_br a3_emi_up_down_and_up_again_bb6e20d8:

    # emi "Heh, well I guess I won't have to worry about that for a bit, huh?"
    emi "Heh, bem, acho que não vou ter que me preocupar com isso por um tempo, né?"

# game/script-a3-emi.rpy:3225
translate pt_br a3_emi_up_down_and_up_again_2ac88e1c:

    # emi "Maybe I'll lose some weight."
    
    emi "Quem sabe eu não perco um peso."
    
    

# game/script-a3-emi.rpy:3227
translate pt_br a3_emi_up_down_and_up_again_47f78638:

    # hi "That's what you do to lose weight, right? Cease physical activity?"
    hi "É isso que você faz pra perder peso não é? Parar com as atividades físicas?"

# game/script-a3-emi.rpy:3232
translate pt_br a3_emi_up_down_and_up_again_e6ca5e7a:

    # emi "I'm pretty sure that's what the nurse would recommend."
    emi "Acho que é isso que o enfermeiro recomendaria."

# game/script-a3-emi.rpy:3234
translate pt_br a3_emi_up_down_and_up_again_fd636600:

    # hi "Speaking of which, are you going to still be showing up in the mornings?"
    hi "Falando nisso, você ainda vai estar indo lá de manhã?"

# game/script-a3-emi.rpy:3236
translate pt_br a3_emi_up_down_and_up_again_e1cab925:

    # hi "I'd hate to run alo—"
    hi "Eu odiaria correr soz-"

# game/script-a3-emi.rpy:3241
translate pt_br a3_emi_up_down_and_up_again_37db3ebc:

    # emi "Ah, shit…"
    emi "Ah, merda…"

# game/script-a3-emi.rpy:3243
translate pt_br a3_emi_up_down_and_up_again_754a249f:

    # "Emi's sudden interjection, more a disquieted muttering than anything too profane, causes me to look over in shock."
    "A repentina interjeição de Emi, mais uma balbuciada discreta do que algo profano, me deixa em choque."

# game/script-a3-emi.rpy:3245
translate pt_br a3_emi_up_down_and_up_again_f5964946:

    # "She's leaning forward, trying to cover the fact that she's crying by covering her eyes with a hand."
    "Ela está se apoiando, tentando acobertar o fato de que está chorando, cobrindo os olhos com uma mão."

# game/script-a3-emi.rpy:3247
translate pt_br a3_emi_up_down_and_up_again_d7f53b59:

    # "Of course, the subdued sobbing makes it pretty obvious that she's crying."
    "Claro, seu soluço faz ficar bem claro que ela está chorando."

# game/script-a3-emi.rpy:3249
translate pt_br a3_emi_up_down_and_up_again_308a9253:

    # hi "Hey, I'm sorry."
    hi "Ei, me desculpa."

# game/script-a3-emi.rpy:3251
translate pt_br a3_emi_up_down_and_up_again_a3e8814d:

    # hi "Forget I said anything, okay?"
    hi "Esquece o que eu disse, tá bom?"

# game/script-a3-emi.rpy:3256
translate pt_br a3_emi_up_down_and_up_again_a083cbe2:

    # "I place a hand gingerly around her and pull her close."
    "Eu coloco a mão em volta dela cautelosamente e puxo ela para perto."

# game/script-a3-emi.rpy:3258
translate pt_br a3_emi_up_down_and_up_again_a0eda459:

    # "I can think of nothing else to say or do. How do you comfort someone who's just lost their legs again?"
    "Eu não consigo pensar em nada a dizer ou fazer. Como você consola alguém que acaba de perder suas pernas de novo?"

# game/script-a3-emi.rpy:3263
translate pt_br a3_emi_up_down_and_up_again_1242f0b5:

    # "Emi wraps me in a hug and stays that way for a while."
    "Emi se enrola em mim em um abraço e fica assim por um tempo."

# game/script-a3-emi.rpy:3265
translate pt_br a3_emi_up_down_and_up_again_eab1722c:

    # hi "Sorry."
    hi "Desculpa."

# game/script-a3-emi.rpy:3267
translate pt_br a3_emi_up_down_and_up_again_3ed8826c:

    # hi "I'm pretty bad at this whole comforting thing, I guess."
    hi "Eu sou bem ruim nesse negócio de consolar, eu acho."

# game/script-a3-emi.rpy:3269
translate pt_br a3_emi_up_down_and_up_again_8407207d:

    # emi "Don't say that."
    emi "Não diga isso."

# game/script-a3-emi.rpy:3271
translate pt_br a3_emi_up_down_and_up_again_dfb5c13b:

    # emi "I'm fine, really."
    emi "Eu estou bem, sério."

# game/script-a3-emi.rpy:3273
translate pt_br a3_emi_up_down_and_up_again_d0fd81a6:

    # "Her voice is slightly muffled by my chest. I pat her head reassuringly."
    "Sua voz é abafada em meu peito, eu acaricio sua cabeça de maneira confortante."

# game/script-a3-emi.rpy:3275
translate pt_br a3_emi_up_down_and_up_again_379787d6:

    # hi "That's the spirit, right?"
    hi "Essa é a ideia, né?"

# game/script-a3-emi.rpy:3277
translate pt_br a3_emi_up_down_and_up_again_55eae125:

    # hi "You'll get through this fine, I know it."
    hi "Você vai passar por isso tranquila, eu tenho certeza."

# game/script-a3-emi.rpy:3279
translate pt_br a3_emi_up_down_and_up_again_6b118916:

    # hi "Besides, I'm here to help you, remember?"
    hi "Ainda porque, eu estou aqui para te ajudar, lembra?"

# game/script-a3-emi.rpy:3284
translate pt_br a3_emi_up_down_and_up_again_70c13975:

    # "Emi lifts her head and stares at me with tear-stained eyes."
    
    "Emi levanta a cabeça e me encara com olhos cheio de lágrimas."

# game/script-a3-emi.rpy:3289
translate pt_br a3_emi_up_down_and_up_again_0bafb5fd:

    # emi "Can you? Can you really?"
    emi "Você pode? Você pode mesmo?"

# game/script-a3-emi.rpy:3291
translate pt_br a3_emi_up_down_and_up_again_f73cde47:

    # "She's grinning lopsidedly, and something sparkles in her gaze."
    "Ela está rindo com um sorriso torto, e algo brilha no seu olhar."

# game/script-a3-emi.rpy:3293
translate pt_br a3_emi_up_down_and_up_again_325a3b55:

    # "I can't tell if I'm being mocked or not."
    
    
    "Eu não consigo dizer se estou sendo caçoado ou não."

# game/script-a3-emi.rpy:3295
translate pt_br a3_emi_up_down_and_up_again_b3f25bd3:

    # hi "Of course. I mean sure, you're a bit heavy, but -{w=0.5}{nw}"
    hi "É claro, quer dizer, você é um pouco pesada mas— {w=0.5}{nw}"
    

# game/script-a3-emi.rpy:3302
translate pt_br a3_emi_up_down_and_up_again_3f555334:

    # extend " mmph!"
    extend "Mmph!"

# game/script-a3-emi.rpy:3304
translate pt_br a3_emi_up_down_and_up_again_c37dfd9b:

    # "My witty comment is cut off by the sudden press of Emi's lips on mine. I'm caught off guard, and am rewarded by hitting my head on the wall behind her bed."
    "Meu gracioso comentário é cortado por uma repentina pressionada dos lábios da Emi nos meus. Eu sou pego de surpresa, e recompensado batendo minha cabeça na parede atrás da cama dela."

# game/script-a3-emi.rpy:3306
translate pt_br a3_emi_up_down_and_up_again_3b159a51:

    # hi "Ow."
    hi "Ai."

# game/script-a3-emi.rpy:3311
translate pt_br a3_emi_up_down_and_up_again_e4868734:

    # "Emi pulls back, trying to look concerned rather than like she's about to laugh."
    "Emi se afasta, tentando parecer preocupada ao invés de estar quase gargalhando."

# game/script-a3-emi.rpy:3313
translate pt_br a3_emi_up_down_and_up_again_f8744be2:

    # emi "Are you okay?"
    emi "Você tá bem?"

# game/script-a3-emi.rpy:3318
translate pt_br a3_emi_up_down_and_up_again_2b702141:

    # emi "Sorry!"
    emi "Desculpa!"
    

# game/script-a3-emi.rpy:3320
translate pt_br a3_emi_up_down_and_up_again_a12a61c9:

    # "I rub my head ruefully and grin back at her."
    "Eu esfrego a cabeça com pesar e rio de volta para ela."

# game/script-a3-emi.rpy:3322
translate pt_br a3_emi_up_down_and_up_again_b5b043a3:

    # hi "Caught me off guard, there."
    hi "Me pegou de surpresa."

# game/script-a3-emi.rpy:3324
translate pt_br a3_emi_up_down_and_up_again_91d2a934:

    # hi "Is that going to become a habit? Am I going to be lectured by Shizune and Misha more?"
    hi "Isso vai se tornar um hábito? Terei que ser repreendido mais pela Shizune e a Misha?"

# game/script-a3-emi.rpy:3326
translate pt_br a3_emi_up_down_and_up_again_b035ac35:

    # "At the mention of the duo, Emi giggles."
    
    "Ao mencionar a dupla, Emi ri."
    

# game/script-a3-emi.rpy:3331
translate pt_br a3_emi_up_down_and_up_again_8874a93a:

    # emi "Honestly, those two…"
    emi "Sério, aquelas duas…"

# game/script-a3-emi.rpy:3336
translate pt_br a3_emi_up_down_and_up_again_1df67718:

    # emi "If I didn't know why, I'd be utterly confused as to why she hangs around with someone so bossy."
    emi "Se eu não soubesse o motivo eu ficaria confusa do porquê ela fica perto de alguém tão mandona."

# game/script-a3-emi.rpy:3338
translate pt_br a3_emi_up_down_and_up_again_5cbfab81:

    # hi "Which one are we talking about?"
    
    hi "De qual das duas estamos falando?"
    

# game/script-a3-emi.rpy:3343
translate pt_br a3_emi_up_down_and_up_again_ab088914:

    # emi "You know exactly which one, Hisao. Misha's hardly bossy."
    emi "Você sabe exatamente de quem Hisao. A Misha é dificilmente mandona."

# game/script-a3-emi.rpy:3345
translate pt_br a3_emi_up_down_and_up_again_cd3b68a6:

    # hi "So what's the reason, then?"
    hi "Qual o motivo então?"

# game/script-a3-emi.rpy:3350
translate pt_br a3_emi_up_down_and_up_again_d5e5048f:

    # emi "Huh?"
    emi "Hein?"

# game/script-a3-emi.rpy:3352
translate pt_br a3_emi_up_down_and_up_again_27f9b373:

    # hi "The reason why Misha hangs around Shizune."
    hi "O motivo pelo qual a Misha passa tanto tempo com a Shizune."

# game/script-a3-emi.rpy:3357
translate pt_br a3_emi_up_down_and_up_again_7e1f9b4e:

    # "Emi waves my question off with a smile."
    "Emi desfaz da minha pergunta com um sorriso."

# game/script-a3-emi.rpy:3359
translate pt_br a3_emi_up_down_and_up_again_ab9a83a6:

    # emi "No idea."
    emi "Nem faço ideia."

# game/script-a3-emi.rpy:3361
translate pt_br a3_emi_up_down_and_up_again_e1f8a5e6:

    # hi "I see."
    hi "Aham."

# game/script-a3-emi.rpy:3366
translate pt_br a3_emi_up_down_and_up_again_b1367cf6:

    # emi "Anyway, you seem to be forgetting the original question, don't you?"
    emi "De qualquer forma, você parece estar esquecendo da pergunta original, não?"

# game/script-a3-emi.rpy:3368
translate pt_br a3_emi_up_down_and_up_again_7592e090:

    # hi "Oh yeah, I guess I am."
    hi "É verdade, acho que estou."

# game/script-a3-emi.rpy:3370
translate pt_br a3_emi_up_down_and_up_again_b3059c80:

    # hi "You wouldn't mind giving a guy a little warning, would you?"
    hi "Você não se importaria de me dar um aviso, se importaria?"

# game/script-a3-emi.rpy:3372
translate pt_br a3_emi_up_down_and_up_again_3d4a1bf1:

    # hi "Otherwise I'm liable to wind up with a concussion."
    
    hi "Do contrário vou acabar tendo uma contusão."

# game/script-a3-emi.rpy:3374
translate pt_br a3_emi_up_down_and_up_again_9578240e:

    # "I emphasize the point by rubbing at the back of my head."
    "Eu enfatizo a ideia esfregando a nuca."

# game/script-a3-emi.rpy:3379
translate pt_br a3_emi_up_down_and_up_again_f58d04f2:

    # "Emi giggles madly."
    "Emi ri loucamente."

# game/script-a3-emi.rpy:3381
translate pt_br a3_emi_up_down_and_up_again_a725e695:

    # emi "You could wear a helmet."
    emi "Você poderia usar um capacete."

# game/script-a3-emi.rpy:3386
translate pt_br a3_emi_up_down_and_up_again_0ff15731:

    # emi "Some kids here do, you know."
    emi "Algumas crianças aqui usam, sabia."

# game/script-a3-emi.rpy:3390
translate pt_br a3_emi_up_down_and_up_again_092670d8:

    # hi "Or I could just take revenge!"
    hi "Ou eu poderia só me vingar."

# game/script-a3-emi.rpy:3397
translate pt_br a3_emi_up_down_and_up_again_7669e4fc:

    # "I grab a pillow from beside me and whack Emi over the head."
    "Eu pego um travesseiro do meu lado e bato na cabeça da Emi com ele."

# game/script-a3-emi.rpy:3416
translate pt_br a3_emi_up_down_and_up_again_c470ef6d:

    # "Emi topples off the bed and lands on the floor with a thump."
    "Emi se desequilibra da cama e cai no chão com o som de uma pancada."

# game/script-a3-emi.rpy:3424
translate pt_br a3_emi_up_down_and_up_again_644d14b5:

    # "Her arms promptly reappear on the bed, and she manages to pull herself back up."
    "Seus braços aparecem na cama, e ela consegue se puxar para cima."

# game/script-a3-emi.rpy:3426
translate pt_br a3_emi_up_down_and_up_again_f05aeb67:

    # "She really has a surprising amount of strength in that little body."
    
    "Ela tem uma surpreendente força naquele pequeno corpo."

# game/script-a3-emi.rpy:3428
translate pt_br a3_emi_up_down_and_up_again_64eb1e86:

    # "Her face is turned downwards and away from mine, making me think I might have accidentally hurt her."
    "Sua cara está pra baixo e virada de lado, me fazendo pensar que eu possa ter a machucado."

# game/script-a3-emi.rpy:3430
translate pt_br a3_emi_up_down_and_up_again_9fd0eaa0:

    # hi "Emi? You okay?"
    hi "Emi? Você está bem?"

# game/script-a3-emi.rpy:3432
translate pt_br a3_emi_up_down_and_up_again_2721129b:

    # hi "You didn't hit your—{w=0.3}{nw}"
    hi "Você não acertou sua—{w=0.3}{nw}"

# game/script-a3-emi.rpy:3437
translate pt_br a3_emi_up_down_and_up_again_dc0cfcde:

    # "A hand shoots up and grabs my collar. She pulls me in with a sharp tug, her face now barely an inch away from mine as she grins cheekily."
    "Uma mão puxa minha gola. Ela me dá um puxão forte, sua face agora está quase colada com a minha enquanto ela ri corajosamente."

# game/script-a3-emi.rpy:3439
translate pt_br a3_emi_up_down_and_up_again_4932c45f:

    # hi "Emi…?"
    hi "Emi…?"

# game/script-a3-emi.rpy:3452
translate pt_br a3_emi_up_down_and_up_again_1023b7e6:

    # "She gives me a sharp headbutt, our foreheads making quite a loud thud."
    "Ela me dá uma forte cabeçada, nossas testas fazendo um barulho alto."

# game/script-a3-emi.rpy:3458
translate pt_br a3_emi_up_down_and_up_again_5ef367cb:

    # "I sit back and rub my now sore head as Emi smirks victoriously."
    "Eu sento e esfrego minha agora dolorida testa enquanto a Emi sorri vitoriosamente."

# game/script-a3-emi.rpy:3463
translate pt_br a3_emi_up_down_and_up_again_598e6989:

    # emi "How's {b}that{/b} for revenge?"
    
    emi "Que tal {b}isso{/b} como vingança?"

# game/script-a3-emi.rpy:3467
translate pt_br a3_emi_up_down_and_up_again_53fc202d:

    # hi "No fair!"
    hi "Não é justo!"

# game/script-a3-emi.rpy:3469
translate pt_br a3_emi_up_down_and_up_again_7ee18cae:

    # hi "You can't take revenge for revenge!"
    
    hi "Você não pode se vingar da minha vingança!"

# game/script-a3-emi.rpy:3471
translate pt_br a3_emi_up_down_and_up_again_dda94b2d:

    # "For someone missing most of her legs, Emi's surprisingly agile."
    "Para alguém que não tem grande parte das pernas, Emi é surpreendentemente ágil."

# game/script-a3-emi.rpy:3484
translate pt_br a3_emi_up_down_and_up_again_bbb1a491:

    # "I swipe at her, but she deftly rolls out of the way and lands a hit with her pillow."
    "Eu tento acertá-la, mas ela habilmente rola pra fora e me acerta com seu travesseiro."

# game/script-a3-emi.rpy:3486
translate pt_br a3_emi_up_down_and_up_again_0e757448:

    # "Of course, the odds are against her. I can stand up, for starters."
    "É claro que eu tenho a vantagem. Eu posso ficar de pé, por exemplo."

# game/script-a3-emi.rpy:3491
translate pt_br a3_emi_up_down_and_up_again_aae32818:

    # "Oof!"
    "Oof!"

# game/script-a3-emi.rpy:3500
translate pt_br a3_emi_up_down_and_up_again_e27b1f19:

    # "Guess I can't, after all. Emi seems to have effectively tripped me up, and is now sitting primly astride me as I lay on my back. I'm not even sure how she managed it."
    "Acho que não. Emi parece ter efetivamente me tropeçado, e agora esta precisamente montada em mim enquanto estou de costas. Eu não tenho certeza de como ela conseguiu."

# game/script-a3-emi.rpy:3502
translate pt_br a3_emi_up_down_and_up_again_57acfbbb:

    # emi "I win!"
    emi "Eu venci!"

# game/script-a3-emi.rpy:3504
translate pt_br a3_emi_up_down_and_up_again_67e6431b:

    # "Her eyes twinkle mischievously. I've been thoroughly defeated, and by a girl that's a fraction of my size, at that."
    "Seus olhos brilham com malícia. Eu fui completamente derrotado, e por uma garota que é uma fração do meu tamanho."

# game/script-a3-emi.rpy:3506
translate pt_br a3_emi_up_down_and_up_again_bd674f9b:

    # "Then again, being defeated doesn't seem quite so bad. Emi being positioned over my waist isn't something that I, or my body, can ignore easily."
    
    "Então, ser derrotado não parece tão ruim. Emi posicionada na minha cintura não é algo que eu, ou o meu corpo, pode facilmente ignorar."

# game/script-a3-emi.rpy:3511
translate pt_br a3_emi_up_down_and_up_again_f06f210d:

    # "I open my lips to speak, but Emi's head darts downwards before I can get so much as a word out. I give no resistance as she presses her mouth to mine, not that I'd want to."
