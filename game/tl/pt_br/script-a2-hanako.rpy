# game/script-a2-hanako.rpy:16
translate pt_br a2_hanako_to_town_to_town_d34b3dc7:

    # "My alarm blares into my ears, only to be swiftly silenced by my fist."
    "Meu alarme dispara nos meus ouvidos, apenas para ser rapidamente silenciado pelo meu punho."

# game/script-a2-hanako.rpy:21
translate pt_br a2_hanako_to_town_to_town_3db1ac03:

    # "My body switches into auto-mode, carrying my subconscious self out of bed and into my uniform."
    "Meu corpo entra em piloto automático, carregando meu eu subconsciente para fora da cama e para dentro do meu uniforme."

# game/script-a2-hanako.rpy:23
translate pt_br a2_hanako_to_town_to_town_2b3ffa6b:

    # "As always, my bottles of pills sit on my desk patiently, waiting for me to take them and pick out my daily dosage of medicine; seventeen pills a day."
    "Como sempre, meus frascos de pílulas se encontram pacientemente em minha escrivaninha, me esperando pegá-los e tomar minha dose diária de remédios; dezessete pílulas por dia."

# game/script-a2-hanako.rpy:28
translate pt_br a2_hanako_to_town_to_town_a5cc44de:

    # "Before I know it, I'm opening the door to class 3-3, glad to see that I'm not the only one who seems to be a little hung-over from festival week."
    "Antes de perceber, estou abrindo a porta da classe 3-3, feliz ao ver que não sou o único um pouco acabado por causa da semana do festival."

# game/script-a2-hanako.rpy:30
translate pt_br a2_hanako_to_town_to_town_4abd7b7a:

    # "Every face in the classroom looks gaunt. With the festival now over, it's as if everyone's life dreams have been achieved."
    "Todos os rostos da sala parecem desolados. Com o festival encerrado, é como se os sonhos das vidas de todos tivessem sido alcançados."

# game/script-a2-hanako.rpy:32
translate pt_br a2_hanako_to_town_to_town_4a4c290b:

    # "With nothing left to live for, the students have relied on instincts alone to guide them to class."
    "Com nada mais pelo que viver, os estudantes confiaram somente em seus instintos para guiá-los até a aula."

# game/script-a2-hanako.rpy:34
translate pt_br a2_hanako_to_town_to_town_e960e014:

    # "Or maybe I'm just reading too much into it."
    "Ou talvez eu esteja apenas pensando muito sobre isso."

# game/script-a2-hanako.rpy:36
translate pt_br a2_hanako_to_town_to_town_3d74beca:

    # "I slowly make my way to my seat, and it's only then that I realize why the room is so peaceful."
    "Eu lentamente me dirijo ao meu lugar, e só então entendo porque a sala está tão calma."

# game/script-a2-hanako.rpy:38
translate pt_br a2_hanako_to_town_to_town_c94787db:

    # "The seats beside mine are blissfully empty; the world's loudest interpreter for the deaf has yet to arrive."
    "Os assentos atrás de mim estão alegremente vazios; a intérprete de mudos mais barulhenta do mundo ainda está por chegar."

# game/script-a2-hanako.rpy:50
translate pt_br a2_hanako_to_town_to_town_d1d3ccce:

    # "Just as I am about to sit down, the door flies open, revealing a resplendent Misha; drills bobbing from the dramatic entrance and arms stretched towards the sky."
    "Assim que estou prestes a sentar, a porta abre bruscamente, revelando uma Misha resplandecente; suas “brocas” balançando por causa de sua entrada dramática e seus braços estendidos em direção ao céu."

# game/script-a2-hanako.rpy:55
translate pt_br a2_hanako_to_town_to_town_6660b1d8:

    # mi "Ya-hooo~! It's all over!"
    mi "Ya-hooo~! Está tudo acabado!"

# game/script-a2-hanako.rpy:57
translate pt_br a2_hanako_to_town_to_town_da93f82d:

    # "It would appear that not everyone is affected by the post-festival depression."
    "Parece que nem todo mundo é afetado pela depressão pós-festival."

# game/script-a2-hanako.rpy:59
translate pt_br a2_hanako_to_town_to_town_b5183643:

    # "The rest of the class glare at her, obviously thinking the same thing I am."
    "O resto da sala olha fixamente para ela, provavelmente pensando a mesma coisa que eu."

# game/script-a2-hanako.rpy:64
translate pt_br a2_hanako_to_town_to_town_70b33264:

    # "Misha, still frozen in the doorway with her arms still in the air, nervously looks around."
    "Misha, ainda congelada na entrada com seus braços imóveis no ar, olha em volta nervosamente."

# game/script-a2-hanako.rpy:66
translate pt_br a2_hanako_to_town_to_town_127010a0:

    # "It's obvious that she senses the foul mood, but can't work out exactly what to do."
    "É óbvio que ela percebe o clima marasmado, mas não consegue planejar exatamente o que fazer."

# game/script-a2-hanako.rpy:71
translate pt_br a2_hanako_to_town_to_town_5007ba21:

    # "Suddenly, she jerks forward."
    "Repentinamente, ela se lança para frente."

# game/script-a2-hanako.rpy:76
translate pt_br a2_hanako_to_town_to_town_4ed09e68:

    # mi "Hey!"
    mi "Ei!"

# game/script-a2-hanako.rpy:86
translate pt_br a2_hanako_to_town_to_town_cdd50267:

    # "As she stumbles into the classroom, she reveals Shizune, arm still extended from where she shoved Misha."
    "Quando ela tropeça para dentro da sala de aula, revela Shizune, com os braços ainda estendidos de ter empurrado a Misha."

# game/script-a2-hanako.rpy:91
translate pt_br a2_hanako_to_town_to_town_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:93
translate pt_br a2_hanako_to_town_to_town_42ea6a1a:

    # hi "Thanks for the entertainment, but shouldn't you two take your seats?"
    hi "Valeu pelo espetáculo, mas vocês duas não deveriam ir aos seus lugares?"

# game/script-a2-hanako.rpy:98
translate pt_br a2_hanako_to_town_to_town_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:100
translate pt_br a2_hanako_to_town_to_town_f761e4a5:

    # "Still slightly embarrassed, Misha takes a few seconds to realize she has to translate."
    "Ainda um pouco envergonhada, Misha demora alguns segundos para perceber que tem que traduzir."

# game/script-a2-hanako.rpy:105
translate pt_br a2_hanako_to_town_to_town_7c4aaea2:

    # mi "Oh! Yeah! Shicchan says she's not happy with you ditching us last week."
    mi "Ah! Sim! A Shizunezinha disse que ela não está feliz com você ter abandonado a gente semana passada."

# game/script-a2-hanako.rpy:110
translate pt_br a2_hanako_to_town_to_town_aee22e6f:

    # mi "We were really busy!"
    mi "Estávamos muito ocupadas!"

# game/script-a2-hanako.rpy:112
translate pt_br a2_hanako_to_town_to_town_b6ed210a:

    # hi "Is that so? What about the stuff I already did for you two?"
    hi "Ah, é assim? E as coisas que eu já fiz pra vocês?"

# game/script-a2-hanako.rpy:117
translate pt_br a2_hanako_to_town_to_town_ef2b123c_2:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:122
translate pt_br a2_hanako_to_town_to_town_0886efc2:

    # mi "She says that only counts for council members. Since you declined, she doesn’t owe you anything."
    mi "Ela disse que isso só conta para membros do Conselho. Já que você rejeitou, ela não te deve nada."

# game/script-a2-hanako.rpy:127
translate pt_br a2_hanako_to_town_to_town_5113a755:

    # "Misha leans closer, and whispers conspiratorially into my ear."
    "Misha se inclina para perto de mim e cochicha conspiratoriamente em meu ouvido."

# game/script-a2-hanako.rpy:129
translate pt_br a2_hanako_to_town_to_town_3ac3ec9b:

    # mi "Actually, I think she's just a little sore that you didn’t spend the day with her."
    mi "Na verdade, acho que ela só está um pouco magoada por você não ter passado o dia com ela."

# game/script-a2-hanako.rpy:134
translate pt_br a2_hanako_to_town_to_town_31997731:

    # mi "She's really thankful for your work last week though."
    mi "Ela está agradecida a beça pelo seu trabalho semana passada."

# game/script-a2-hanako.rpy:139
translate pt_br a2_hanako_to_town_to_town_ff8ca9e8:

    # "Sensing that she is being talked about, Shizune lightly raps her fingers on her desk until Misha turns around to face her."
    "Percebendo que estamos falando sobre ela, Shizune bate seus dedos levemente em sua carteira até a Misha virar para ela."

# game/script-a2-hanako.rpy:153
translate pt_br a2_hanako_to_town_to_town_e15ea550:

    # "I can't understand any of the fast-paced signing that's going on, but from Shizune's slightly embarrassed expression, and Misha's poorly contained laughter, I can guess."
    "Não consigo entender nada dos sinais acelerados sendo feitos, mas pela expressão meio constrangida da Shizune, e a risada insuficientemente contida da Misha, posso adivinhar."

# game/script-a2-hanako.rpy:157
translate pt_br a2_hanako_to_town_to_town_7765f059:

    # "While this exchange is happening, the door opens once again, but this time at a much more reasonable pace."
    "Enquanto essa interação está acontecendo, a porta se abre novamente, mas num ritmo mais razoável dessa vez."

# game/script-a2-hanako.rpy:170
translate pt_br a2_hanako_to_town_to_town_67536029:

    # "Hanako quietly enters the room, and pulls the door closed behind her."
    "Hanako entra na sala silenciosamente, e fecha a porta atrás dela."

# game/script-a2-hanako.rpy:175
translate pt_br a2_hanako_to_town_to_town_403e96ca:

    # "Peering out from under her hair, she quickly scans the classroom."
    "Espiando por debaixo de seu cabelo, ela examina a sala velozmente."

# game/script-a2-hanako.rpy:177
translate pt_br a2_hanako_to_town_to_town_96a6932e:

    # "Our eyes meet, and she suddenly stiffens. She closes her eyes, takes a deep breath, and then walks over to my desk."
    "Nossos olhos se encontram, e ela repentinamente se enrijece. Ela fecha seus olhos, respira fundo, e então caminha até minha carteira."

# game/script-a2-hanako.rpy:182
translate pt_br a2_hanako_to_town_to_town_a2f9183d:

    # ha "G… good morning Hisao."
    ha "B… bom dia, Hisao."

# game/script-a2-hanako.rpy:184
translate pt_br a2_hanako_to_town_to_town_5b914455:

    # hi "Morning Hanako. You're a little late, aren't you?"
    hi "Bom dia, Hanako. Está um pouco atrasada, não?"

# game/script-a2-hanako.rpy:189
translate pt_br a2_hanako_to_town_to_town_8c4f89fb:

    # ha "I… was talking to Lilly."
    
    ha "E… eu estava falando com a Lilly."

# game/script-a2-hanako.rpy:194
translate pt_br a2_hanako_to_town_to_town_2cee45b2:

    # ha "A-about today."
    ha "S-sobre hoje."

# game/script-a2-hanako.rpy:196
translate pt_br a2_hanako_to_town_to_town_5fbba3d5:

    # hi "Ah, so you've got her list then? We can leave straight after classes in that case."
    hi "Ah, então você pegou a lista dela? Podemos ir direto assim que a aula acabar nesse caso."

# game/script-a2-hanako.rpy:201
translate pt_br a2_hanako_to_town_to_town_ff70d1cd:

    # ha "S-sure."
    ha "S-sim."

# game/script-a2-hanako.rpy:203
translate pt_br a2_hanako_to_town_to_town_81d7ddc4:

    # hi "I'm looking forward to it."
    hi "Mal posso esperar."

# game/script-a2-hanako.rpy:205
translate pt_br a2_hanako_to_town_to_town_8c16f8fe:

    # "Hanako briefly flashes her embarrassed smile at me then hurries off to her seat."
    "O sorriso envergonhado da Hanako me é mostrado por apenas um segundo e ela então se apressa de volta à sua carteira."

# game/script-a2-hanako.rpy:212
translate pt_br a2_hanako_to_town_to_town_49e513b4:

    # "During classes, it becomes apparent that it's not only the students that are a little despondent after the festival."
    "Durante as aulas, torna-se aparente que não são só os estudantes que estão abatidos após o festival."

# game/script-a2-hanako.rpy:214
translate pt_br a2_hanako_to_town_to_town_ec20446d:

    # "Mutou simply gives us a list of exercises from the textbook and then sits behind his desk."
    "Mutou simplesmente nos dá uma lista de exercícios do livro e senta atrás de sua mesa."

# game/script-a2-hanako.rpy:216
translate pt_br a2_hanako_to_town_to_town_036dbbfd:

    # "I totally forget about the brief lunch period for a moment, such is the banality of the day."
    "Me esqueço completamente do breve intervalo de almoço por um momento, tamanha a banalidade do dia."

# game/script-a2-hanako.rpy:220
translate pt_br a2_hanako_to_town_to_town_85f18f01:

    # "It's mind-numbing, and everyone seems surprised when the bells signal the end of the lessons."
    "É cansativo, e todos parecem surpresos quando o sinal anuncia o fim das aulas."

# game/script-a2-hanako.rpy:226
translate pt_br a2_hanako_to_town_to_town_70afce89:

    # "As I am packing up my bags, Shizune and Misha flank and entrap me."
    "Enquanto arrumo minhas coisas, Shizune e Misha me flanqueiam para me bloquear."

# game/script-a2-hanako.rpy:231
translate pt_br a2_hanako_to_town_to_town_30516337:

    # mi "Say, Hicchan, it's still not too late to join up. There's a lot of post-festival paperwork for us to complete…"
    mi "Sabe, Hisaozinho, não é tarde demais para se juntar ao Conselho. Tem um monte de papelada pós-festival para completarmos…"

# game/script-a2-hanako.rpy:233
translate pt_br a2_hanako_to_town_to_town_945cd433:

    # hi "Er, sorry Misha, I've… got plans…"
    hi "Bom, desculpe, Misha. Eu… já tenho planos …"

# game/script-a2-hanako.rpy:246
translate pt_br a2_hanako_to_town_to_town_85efd206:

    # "As if sensing the cue, Hanako appears behind me, holding a small bag, and trying to avoid eye contact with the outside world."
    "Como que captando a deixa, Hanako aparece atrás de mim, segurando uma pequena bolsa, e tentando evitar contado visual com o mundo de fora."

# game/script-a2-hanako.rpy:251
translate pt_br a2_hanako_to_town_to_town_ae439be9:

    # "Misha's eyes open wide, then she bursts into laughter."
    "Os olhos da Misha se arregalam, e ela então estoura numa gargalhada."

# game/script-a2-hanako.rpy:253
translate pt_br a2_hanako_to_town_to_town_99e7d9a4:

    # mi "BWAHAHA! You move fast, don't you Hicchan~? We won't disturb your date any further! Bwahahaha!"
    mi "BWAHAHA! Você é bem rápido, hein, Hisaozinho~? Não vamos mais atrapalhar seu encontro! Bwahahaha!"

# game/script-a2-hanako.rpy:258
translate pt_br a2_hanako_to_town_to_town_ed875abf:

    # "Behind the roaring Misha, I see Shizune taking far too little interest in the scene. I might be taking this the wrong way, but I think she's deliberately ignoring me."
    "Por trás da Misha atroadora, vejo a Shizune se interessando bem pouco pela cena. Eu posso estar entendendo errado, mas acho que ela está deliberadamente me ignorando."

# game/script-a2-hanako.rpy:263
translate pt_br a2_hanako_to_town_to_town_3ba2957a:

    # "I feel a gentle tug on my shirt, and turn to see Hanako's eyes fixed firmly on the floor."
    "Sinto um puxão suave em minha camisa, e viro para ver os olhos da Hanako fixados firmemente em direção ao chão."

# game/script-a2-hanako.rpy:268
translate pt_br a2_hanako_to_town_to_town_41de7974:

    # ha "L… let's…"
    ha "V… vamos…"

# game/script-a2-hanako.rpy:270
translate pt_br a2_hanako_to_town_to_town_9c2637a9:

    # hi "Got ya. Shizune, Misha, I'll see you later."
    hi "Certo. Shizune, Misha, vejo vocês depois."

# game/script-a2-hanako.rpy:272
translate pt_br a2_hanako_to_town_to_town_283a2529:

    # hi "And I'm still not interested in the council."
    hi "E ainda não estou interessado no Conselho."

# game/script-a2-hanako.rpy:277
translate pt_br a2_hanako_to_town_to_town_a6d0047f:

    # mi "Spoilsport."
    mi "Estraga-prazer."

# game/script-a2-hanako.rpy:289
translate pt_br a2_hanako_to_town_to_town_8ac4355e:

    # "Misha and Shizune retreat into the hallway, happily signing to each other."
    "Misha e Shizune vão para o corredor, fazendo sinais alegremente entre si."

# game/script-a2-hanako.rpy:291
translate pt_br a2_hanako_to_town_to_town_2f3459cb:

    # hi "Got all your stuff? Let's head off."
    hi "Pegou todas as suas coisas? Vamos embora."

# game/script-a2-hanako.rpy:298
translate pt_br a2_hanako_to_town_to_town_411c47d4:

    # "Floods of students pour out of the school gates and onto the road into town."
    "Enxurradas de estudantes transbordam dos portões da escola em direção à estrada para a cidade."

# game/script-a2-hanako.rpy:300
translate pt_br a2_hanako_to_town_to_town_8957b27b:

    # "It's a little weird. It's almost a scene from any other high school, but the illusion fades because of the occasional wheelchair or missing limb."
    "É um pouco estranho. É uma quase uma cena colegial como qualquer outra, mas a ilusão se dissipa por causa da ocasional cadeira de rodas ou braço ou perna faltando."

# game/script-a2-hanako.rpy:302
translate pt_br a2_hanako_to_town_to_town_e5617b90:

    # "One thing I do notice is that nobody is alone."
    "Uma coisa que eu percebo é que ninguém está sozinho."

# game/script-a2-hanako.rpy:310
translate pt_br a2_hanako_to_town_to_town_d1edea69:

    # "And, as Hanako and I pass through the gates, I notice that she closes the distance between us."
    "E, assim que a Hanako e eu passamos pelos portões, percebo que ela chega mais perto de mim."

# game/script-a2-hanako.rpy:312
translate pt_br a2_hanako_to_town_to_town_fda84fd1:

    # "Not enough to be considered 'close', but she certainly isn't at her usual just-a-little-far position."
    "Não o suficiente para ser considerado “perto”, mas ela certamente não está mais na sua posição normal, um pouco afastada."

# game/script-a2-hanako.rpy:314
translate pt_br a2_hanako_to_town_to_town_f6e4d131:

    # "I guess we're not familiar enough for her to get as close as she does with Lilly."
    "Creio que não sejamos íntimos o suficiente para ela ficar tão perto de mim como fica da Lilly."

# game/script-a2-hanako.rpy:316
translate pt_br a2_hanako_to_town_to_town_381fc1d0:

    # "However, even though she has moved a little closer to me physically, mentally she seems to have traveled a mile."
    "Contudo, apesar dela ter se aproximado de mim fisicamente, mentalmente ela parece ter viajado um quilômetro."

# game/script-a2-hanako.rpy:318
translate pt_br a2_hanako_to_town_to_town_2629b5e4:

    # "Her hands clutched around the leather straps of her bag to the point of whitening her knuckles, her head down and her mouth pursed closed."
    "Suas mãos apertadas ao redor das alças de couro da sua bolsa ao ponto de esbranquiçar seus nós dos dedos, sua cabeça abaixada e sua boca franzida de tão fechada."

# game/script-a2-hanako.rpy:320
translate pt_br a2_hanako_to_town_to_town_ac1e1bbc:

    # "She almost looks like she's being walked to the Principal's office for the first time."
    "Quase parece que ela está sendo levada ao escritório do diretor pela primeira vez."

# game/script-a2-hanako.rpy:322
translate pt_br a2_hanako_to_town_to_town_6faefa45:

    # "I try to stifle a giggle at the thought, but it is futile."
    "Eu tento reprimir uma risada ao pensar isso, mas é inútil."

# game/script-a2-hanako.rpy:327
translate pt_br a2_hanako_to_town_to_town_f84a0570:

    # ha "W-what's the matter…?"
    ha "Q-qual é o problema…?"

# game/script-a2-hanako.rpy:329
translate pt_br a2_hanako_to_town_to_town_38ca3a9b:

    # "I guess there's no point in hiding it…"
    "Acho que não há porquê esconder isso…"

# game/script-a2-hanako.rpy:331
translate pt_br a2_hanako_to_town_to_town_c7694a4e:

    # hi "Sorry. For a second there it looked like you were getting in trouble."
    hi "Perdão. Por um segundo parecia que você estava se metendo em encrenca."

# game/script-a2-hanako.rpy:336
translate pt_br a2_hanako_to_town_to_town_4022a22c:

    # ha "W-w-what do you mean?"
    ha "C-c-como assim?"

# game/script-a2-hanako.rpy:338
translate pt_br a2_hanako_to_town_to_town_d6240147:

    # hi "I think you need to relax a little. We're not going too far, and it's only students around, right?"
    hi "Acho que você precisa relaxar um pouco. Não estamos indo muito longe, e só há estudantes por aqui, não é?"

# game/script-a2-hanako.rpy:343
translate pt_br a2_hanako_to_town_to_town_40ca9b49:

    # ha "R-right."
    ha "É-é."

# game/script-a2-hanako.rpy:345
translate pt_br a2_hanako_to_town_to_town_f0b09cf8:

    # "It bothers me a little to see Hanako so worked up."
    "Ver a Hanako tão tensa me incomoda um pouco."

# game/script-a2-hanako.rpy:347
translate pt_br a2_hanako_to_town_to_town_fe6a1ad1:

    # hi "And you do this every week, don't you?"
    hi "E você faz isso toda semana, certo?"

# game/script-a2-hanako.rpy:352
translate pt_br a2_hanako_to_town_to_town_8e898ada:

    # ha "Y-yes. With Lilly."
    ha "S-sim. Com a Lilly."

# game/script-a2-hanako.rpy:354
translate pt_br a2_hanako_to_town_to_town_fb1f122d:

    # "Of course. 'With Lilly.' I wonder, has she ever left the school without her?"
    "É claro. “Com a Lilly.” Me pergunto se ela sequer já saiu da escola sem ela…"

# game/script-a2-hanako.rpy:356
translate pt_br a2_hanako_to_town_to_town_dd8eb15b:

    # "It doesn't seem like much at first glance, but Hanako's dependence on Lilly is absurdly heavy."
    "Não parece tanto à primeira vista, mas a dependência da Hanako em relação à Lilly é absurdamente intensa."

# game/script-a2-hanako.rpy:358
translate pt_br a2_hanako_to_town_to_town_51304730:

    # "If she can't even handle leaving the school without her, how would she have managed to survive if the two had never met?"
    "Se ela não consegue nem sair da escola sem ela, como ela se viraria caso as duas nunca tivessem se conhecido?"

# game/script-a2-hanako.rpy:360
translate pt_br a2_hanako_to_town_to_town_6473c3eb:

    # "Would she have found someone else to latch on to? And what drew her to Lilly?"
    "Arranjaria ela outra pessoa a quem se agarrar? E o que a atraiu para perto da Lilly?"

# game/script-a2-hanako.rpy:362
translate pt_br a2_hanako_to_town_to_town_16335268:

    # "Was it her lack of eyesight, or was Lilly just kind enough to lend a hand?"
    "Será que foi o fato dela não enxergar, ou será que a Lilly apenas foi gentil o suficiente para auxiliá-la?"

# game/script-a2-hanako.rpy:364
translate pt_br a2_hanako_to_town_to_town_c640fc5d:

    # "I wonder if anyone would have fit the bill."
    "Me pergunto se qualquer um teria servido para a tarefa."

# game/script-a2-hanako.rpy:366
translate pt_br a2_hanako_to_town_to_town_74edf894:

    # hi "Well, I'm here. Besides, we're not going far. It'll be over before you know it."
    hi "Bem, estou aqui. Além do mais, não estamos indo longe. Tudo acabará antes que possamos perceber."

# game/script-a2-hanako.rpy:371
translate pt_br a2_hanako_to_town_to_town_e56341d7:

    # "Hanako's knuckles slowly regain their color as she tries to hide a small smile, but the effort of that seems to prevent further conversation."
    "Os nós dos dedos da Hanako lentamente recuperam sua cor quando ela tenta esconder um pequeno sorriso, mas o esforço envolvido nisso parece previnir qualquer conversa adicional."

# game/script-a2-hanako.rpy:373
translate pt_br a2_hanako_to_town_to_town_be891b4e:

    # "We travel, side by side, down the winding road towards the town. The crowd of students thins as we continue along the sidewalk."
    "Caminhamos lado a lado pela estrada tortuosa até a cidade. A multidão de estudantes vai se dissipando quanto mais avançamos junto à calçada."

# game/script-a2-hanako.rpy:375
translate pt_br a2_hanako_to_town_to_town_a5b1b7ba:

    # "Faster students rush ahead, and the less mobile ones fall behind, rarefying the crowd into nothingness."
    "Os mais rápidos se apressam à frente, e os menos móveis ficam para trás, rarefazendo a multidão até um nada."

# game/script-a2-hanako.rpy:380
translate pt_br a2_hanako_to_town_to_town_10c37307:

    # "By the time we reach the convenience store we are practically alone."
    "No instante em que chegamos à loja de convenência, estamos praticamente sozinhos."

# game/script-a2-hanako.rpy:385
translate pt_br a2_hanako_to_town_to_town_61eb7fc0:

    # "Using me as a shield between herself and the attendant, Hanako moves through the narrow aisles, adding an assortment of items to her basket."
    "Me usando como escudo entre ela e a atendente, Hanako se move por entre os corredores estreitos, adicionando um sortimento de itens à sua cesta."

# game/script-a2-hanako.rpy:387
translate pt_br a2_hanako_to_town_to_town_d0ae944a:

    # "Bread, milk, tea… thyme?"
    "Pão, leite, chá… tomilho?"

# game/script-a2-hanako.rpy:389
translate pt_br a2_hanako_to_town_to_town_b57613d1:

    # "What kind of convenience store sells herbs?"
    "Que tipo de loja de conveniência vende ervas?"

# game/script-a2-hanako.rpy:393
translate pt_br a2_hanako_to_town_to_town_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:397
translate pt_br a2_hanako_to_town_to_town_69982a8b:

    # n "{vspace=60}Then again, nothing about this town seems normal, which may not be such a bad thing in retrospect."
    n "{vspace=60}Mas pensando bem, nada nessa cidade parece normal, o que talvez nem seja uma coisa tão ruim em retrospecto."

# game/script-a2-hanako.rpy:399
translate pt_br a2_hanako_to_town_to_town_d0237add:

    # n "Everything is so different and uncomfortable; dwelling on such matters isn't really an option."
    n "Tudo é tão diferente e desconfortável; ficar muito tempo pensando nisso vai dar em nada."

# game/script-a2-hanako.rpy:401
translate pt_br a2_hanako_to_town_to_town_145e9169:

    # n "When I think about that, it reminds me of Hanako."
    n "Quando penso nisso, me lembro da Hanako."

# game/script-a2-hanako.rpy:403
translate pt_br a2_hanako_to_town_to_town_b691319e:

    # n "No matter how much you try, you can't escape her scars; they still interrupt my train of thought when I see them."
    n "Não importa o quanto você tente, você não consegue escapar das suas cicatrizes; elas ainda interrompem minha linha de pensamento quando as vejo."

# game/script-a2-hanako.rpy:405
translate pt_br a2_hanako_to_town_to_town_461b57c4:

    # n "As much as I don't want to admit it to myself, I think I'm forcing myself to try to ignore them."
    n "Por mais que não queira admitir a mim mesmo, acho que estou me forçando a tentar ignorá-las."

# game/script-a2-hanako.rpy:407
translate pt_br a2_hanako_to_town_to_town_2c78ea94:

    # n "Not that I am scar-free myself. The jagged line down my sternum will never completely fade away."
    n "Não que eu não possua nenhuma cicatriz também. A linha dentilhada que corta meu peitoral nunca vai desaparecer completamente."

# game/script-a2-hanako.rpy:409
translate pt_br a2_hanako_to_town_to_town_7db0e9ae:

    # n "I just have the luxury of being able to hide it easily."
    n "Eu apenas disponho do luxo de poder escondê-la facilmente."

# game/script-a2-hanako.rpy:411
translate pt_br a2_hanako_to_town_to_town_2be61d50:

    # n "{vspace=30}But, in a way, both of our scars remind me that we're all in this place for a reason."
    n "{vspace=30}Mas, de certa maneira, ambas cicatrizes nos lembram que estamos neste lugar por uma razão."

# game/script-a2-hanako.rpy:416
translate pt_br a2_hanako_to_town_to_town_00e4ae06:

    # nvl clear
    # "…"
    nvl clear
    "…"

# game/script-a2-hanako.rpy:420
translate pt_br a2_hanako_to_town_to_town_d820fab6:

    # "Hanako throws one last item into her basket then sheepishly holds it out to me, along with a few bank notes."
    "Hanako joga um último item em sua cesta e então se segura a mim timidamente, portando algumas cédulas para pagar."

# game/script-a2-hanako.rpy:425
translate pt_br a2_hanako_to_town_to_town_065a8266:

    # ha "C-c-could you p-please…"
    ha "V-v-você poderia p-por favor…"

# game/script-a2-hanako.rpy:427
translate pt_br a2_hanako_to_town_to_town_310f0eb4:

    # "It takes me a second to understand what she's trying to say."
    "Leva um segundo para eu entender o que ela quer dizer."

# game/script-a2-hanako.rpy:429
translate pt_br a2_hanako_to_town_to_town_e8a86c24:

    # hi "Oh, you want me to pay for this?"
    hi "Ah, quer que eu pague por isso?"

# game/script-a2-hanako.rpy:434
translate pt_br a2_hanako_to_town_to_town_b5a726a4:

    # "She nods, but doesn't look up."
    "Ela acena positivamente com a cabeça, mas não olha para cima."

# game/script-a2-hanako.rpy:436
translate pt_br a2_hanako_to_town_to_town_ba3929f3:

    # "I guess this task falls to Lilly on the usual occasions."
    "Acredito que esta tarefa recaia sobre a Lilly nas ocasiões usuais."

# game/script-a2-hanako.rpy:438
translate pt_br a2_hanako_to_town_to_town_75a6f24a:

    # hi "Sure. Lemme just grab a couple of things…"
    hi "Beleza. Deixa só eu pegar mais algumas coisas…"

# game/script-a2-hanako.rpy:440
translate pt_br a2_hanako_to_town_to_town_38b24da6:

    # "Hastily I grab a few essential items for myself and head for the counter with Hanako in close tow."
    "Eu rapidamente pego alguns itens essenciais para mim e me dirijo ao balcão com a Hanako logo atrás."

# game/script-a2-hanako.rpy:442
translate pt_br a2_hanako_to_town_to_town_66d7256e:

    # "The attendant gives me an indifferent nod as he scans in the items."
    "A atendente acena a cabeça indiferentemente para mim enquanto escaneia os itens."

# game/script-a2-hanako.rpy:444
translate pt_br a2_hanako_to_town_to_town_fa2bc676:

    # "I suppose just ignoring us is one way to deal with the anomalies of Yamaku; they must get a lot of students here, being the closest store to the school."
    "Presumo que simplesmente nos ignorar seja uma maneira de lidar com as anormalidades da Yamaku; eles devem receber um monte de estudantes aqui, tendo em vista que é a loja mais perto da escola."

# game/script-a2-hanako.rpy:446
translate pt_br a2_hanako_to_town_to_town_64ed741c:

    # "The staff must all have their own way of dealing with us. Or maybe they don't; maybe it's only me who thinks twice about my unique schoolmates."
    "Os funcionários devem todos ter seus próprios jeitos de lidar conosco. Ou talvez não tenham; talvez eu só pense demais sobre meus peculiares colegas."

# game/script-a2-hanako.rpy:453
translate pt_br a2_hanako_to_town_to_town_ddc60390:

    # "Our transaction complete, Hanako and I head back out onto the street."
    "Assim que terminamos as compras, Hanako e eu nos dirigimos de volta à rua."

# game/script-a2-hanako.rpy:460
translate pt_br a2_hanako_to_town_to_town_21cc1ef3:

    # "The road is pretty much abandoned now. The students that were heading out have already left, and nobody has started returning just yet."
    "A estrada está praticamente deserta agora. Os estudantes que estavam vindo para cá já passaram, e ninguém está retornando ainda."

# game/script-a2-hanako.rpy:462
translate pt_br a2_hanako_to_town_to_town_1ecddf6b:

    # "And, with only the school ahead on the road, there doesn't seem to be anyone else around."
    "E, somente com a escola à nossa frente na estrada, não parecer haver mais ninguém por aqui."

# game/script-a2-hanako.rpy:467
translate pt_br a2_hanako_to_town_to_town_2aee6244:

    # "The emptiness certainly reflects on Hanako; her arms by her sides each carrying a bag, her head no longer bowed, and back to the upright position…"
    "A ausência de pessoas certamente reflete na Hanako; seus braços estendidos, cada um carregando uma bolsa, sua cabeça não mais abaixada, de novo em posição normal…"

# game/script-a2-hanako.rpy:469
translate pt_br a2_hanako_to_town_to_town_4a638b2d:

    # "It's almost as if she were enjoying this walk."
    "É quase como se ela estivesse apreciando esta caminhada."

# game/script-a2-hanako.rpy:471
translate pt_br a2_hanako_to_town_to_town_4a7474ba:

    # hi "So, why all these weird things? Mixed Spice? Why would you need that in school?"
    hi "Por que todas essas coisas estranhas? Especiarias mistas? Por que você precisaria disso na escola?"

# game/script-a2-hanako.rpy:476
translate pt_br a2_hanako_to_town_to_town_b172874e:

    # ha "I… sometimes… like to m-make food."
    ha "Eu… às vezes… gosto de f-fazer comida."

# game/script-a2-hanako.rpy:478
translate pt_br a2_hanako_to_town_to_town_7dd42bab:

    # hi "Well, yeah, so do I but… spices?"
    hi "Certo, eu também, mas… especiarias?"

# game/script-a2-hanako.rpy:480
translate pt_br a2_hanako_to_town_to_town_09a56195:

    # hi "That's a little more advanced, don't you think?"
    hi "Isso é um pouco mais avançado, não acha?"

# game/script-a2-hanako.rpy:485
translate pt_br a2_hanako_to_town_to_town_0f82ed62:

    # ha "N-not really."
    ha "N-não muito."

# game/script-a2-hanako.rpy:487
translate pt_br a2_hanako_to_town_to_town_02488693:

    # hi "Well, I think it's cool. You'll have to teach me one day."
    hi "Bem, eu acho legal. Você tem que me ensinar um dia desses."

# game/script-a2-hanako.rpy:492
translate pt_br a2_hanako_to_town_to_town_ff70d1cd_1:

    # ha "S-sure."
    ha "T-tá bom."

# game/script-a2-hanako.rpy:494
translate pt_br a2_hanako_to_town_to_town_feef7a46:

    # "She doesn't seem all that sure, but pushing the point doesn't seem all that wise."
    "Ela não parece realmente certa disso, mas insistir nesse assunto não parece ser a melhor escolha."

# game/script-a2-hanako.rpy:496
translate pt_br a2_hanako_to_town_to_town_c5cf4bff:

    # "At the very least, she seems a great deal happier than she did on the walk down here."
    "Na pior das hipóteses, ela ao menos parece bem mais feliz do que parecia na vinda para cá."

# game/script-a2-hanako.rpy:498
translate pt_br a2_hanako_to_town_to_town_19c6c214:

    # "That alone makes me a little happier."
    "Isso por si só me faz um pouco mais feliz."

# game/script-a2-hanako.rpy:506
translate pt_br a2_hanako_to_town_to_town_03fd12ef:

    # "Outside the girls' dorm, Hanako and I sort out the grocery bags with our respective purchases."
    "Do lado de fora do dormitório feminino, Hanako e eu organizamos as sacolas para separarmos nossas respectivas compras."

# game/script-a2-hanako.rpy:508
translate pt_br a2_hanako_to_town_to_town_dfcad5a0:

    # "In comparison, my things look positively plain."
    "Em comparação, minhas coisas parecem categoricamente simples."

# game/script-a2-hanako.rpy:510
translate pt_br a2_hanako_to_town_to_town_226c4572:

    # hi "I tell you, you're putting me to shame here…"
    hi "Vou te dizer, você está me humilhando aqui…"

# game/script-a2-hanako.rpy:515
translate pt_br a2_hanako_to_town_to_town_e199c186:

    # ha "N-no I'm not… I just…"
    ha "N-não, eu não… eu só…"

# game/script-a2-hanako.rpy:517
translate pt_br a2_hanako_to_town_to_town_057626e7:

    # hi "I'm only joking."
    hi "Foi brincadeira."

# game/script-a2-hanako.rpy:522
translate pt_br a2_hanako_to_town_to_town_04ccf85e:

    # hi "I have a stack of homework that I skipped last week, so I must leave now."
    hi "Eu tenho uma pilha de dever de casa que eu deixei de fazer semana passada, então preciso ir agora."

# game/script-a2-hanako.rpy:524
translate pt_br a2_hanako_to_town_to_town_22199bc7:

    # hi "Will you be all right getting that to your room?"
    hi "Você vai ficar bem levando isso até seu quarto?"

# game/script-a2-hanako.rpy:529
translate pt_br a2_hanako_to_town_to_town_3959e7b8:

    # ha "Y-yeah."
    ha "A-aham."

# game/script-a2-hanako.rpy:531
translate pt_br a2_hanako_to_town_to_town_5a69b387:

    # hi "Sure? Okay then. I'll see you tomorrow."
    hi "Certeza? Ok, então. Nos vemos amanhã."

# game/script-a2-hanako.rpy:536
translate pt_br a2_hanako_to_town_to_town_78c8f662:

    # ha "B-bye."
    ha "T-tchau."

# game/script-a2-hanako.rpy:543
translate pt_br a2_hanako_to_town_to_town_5ef52fb6:

    # "We part ways, and I return to my room."
    "Nos separamos, e volto para meu quarto."

# game/script-a2-hanako.rpy:548
translate pt_br a2_hanako_to_town_to_town_47418ef9:

    # "Piles of papers sit upon my desk, begging to be completed. With the entire ruckus of the last week, I've barely had any time to catch up."
    "Montes de papéis repousam sobre minha escrivaninha, implorando para serem completados. Com toda a confusão da última semana, eu mal tive tempo de me atualizar na matéria."

# game/script-a2-hanako.rpy:550
translate pt_br a2_hanako_to_town_to_town_3b4cf5ec:

    # "I tried to keep up with my studies while I was in the hospital, but some of this stuff I've never seen before, even back in my old school."
    "Eu tentei manter meus estudos em dia no hospital, mas nunca vi a maioria destas coisas antes, nem mesmo na minha antiga escola."

# game/script-a2-hanako.rpy:552
translate pt_br a2_hanako_to_town_to_town_3ea7e3fc:

    # "Totally unprepared, I pop the top on a can of drink, and get to work."
    "Totalmente despreparado, eu abro abro uma lata de bebida e começo o trabalho."

# game/script-a2-hanako.rpy:570
translate pt_br a2_hanako_tea_leaves_d79de2cd:

    # "The days are really starting to heat up."
    "Os dias estão realmente começando a esquentar."

# game/script-a2-hanako.rpy:572
translate pt_br a2_hanako_tea_leaves_fe194ba3:

    # "This morning, I awoke covered in sweat."
    "Essa manhã, acordei coberto de suor."

# game/script-a2-hanako.rpy:574
translate pt_br a2_hanako_tea_leaves_802d36a2:

    # "By the time the student body starts leaving their dorms for breakfast and morning duties, the sun has taken full effect; oddly, that puts me in high spirits."
    "Na hora em que o corpo estudantil começa a deixar os dormitórios para tomar café e começar as atividades da manhã, o sol já está imponente levantado; estranhamente, isso coloca meu astral lá em cima."

# game/script-a2-hanako.rpy:576
translate pt_br a2_hanako_tea_leaves_74bcb9ff:

    # "It's not even eight, yet I feel that this day is going to be one of those pleasant, tranquil, warm ones."
    "Não são nem oito horas ainda, mas sinto que o dia de hoje será um daqueles dias agradáveis, calmos e cálidos."

# game/script-a2-hanako.rpy:578
translate pt_br a2_hanako_tea_leaves_8ea58980:

    # "If I weren't at a school that considered every absence from class as a sign of a life-threatening situation, I'd consider skipping the whole day and just relaxing in the school gardens."
    "Se eu não estivesse numa escola que considera cada falta como uma situação de perigo de vida, eu consideraria cabular todas as aulas de hoje e apenas relaxar nos jardins da escola."

# game/script-a2-hanako.rpy:580
translate pt_br a2_hanako_tea_leaves_e38c3d07:

    # "Yes, today will be a genuinely lazy day."
    "Sim, hoje será um dia genuinamente preguiçoso."

# game/script-a2-hanako.rpy:582
translate pt_br a2_hanako_tea_leaves_7464266b:

    # "For a second, I stop in mid-stretch, and consider the nurse's warning about exercise. Maybe I should have kept up those morning jogs."
    "Por um segundo, eu paro enquanto estou me esticando e considero o aviso do enfermeiro sobre exercícios. Talvez eu devesse ter mantido aquelas corridas matinais."

# game/script-a2-hanako.rpy:584
translate pt_br a2_hanako_tea_leaves_28d35147:

    # "Running with someone like Emi might have been a little testing, but if I worked at my own pace…"
    "Correr com alguém como a Emi poderia ter sido um pouco desafiador, mas se eu tivesse me mantido no meu próprio passo…"

# game/script-a2-hanako.rpy:586
translate pt_br a2_hanako_tea_leaves_2b77d856:

    # "Ah, who am I kidding? I couldn't stick to something like that without some kind of motivation."
    "Ah, quem eu estou tentando enganar? Eu não conseguiria me manter em algo assim sem algum tipo de motivação."

# game/script-a2-hanako.rpy:588
translate pt_br a2_hanako_tea_leaves_9fd9121e:

    # "It's not like I sit around all day. The walk to and from the convenience store counts as exercise, right? Especially the walk back up the hill…"
    "Eu não fico sentado o dia todo. A caminhada de ida e volta até a loja de conveniência conta como exercício, certo? Especialmente a subida de volta pela colina…"

# game/script-a2-hanako.rpy:590
translate pt_br a2_hanako_tea_leaves_58cd49dc:

    # "Yeah, it's no big deal. Compared to months lying in a hospital bed I'm getting plenty exercise."
    "É, não tem importância. Comparando com os meses que fiquei deitado em uma cama de hospital, estou me exercitando bastante."

# game/script-a2-hanako.rpy:595
translate pt_br a2_hanako_tea_leaves_7d07848a:

    # "It seems that I'm not alone in my appreciation of the day."
    "Parece que não estou sozinho em minha apreciação pelo dia de hoje."

# game/script-a2-hanako.rpy:597
translate pt_br a2_hanako_tea_leaves_0e426bd5:

    # "Nearly every member of the class is glancing through the window and into the tantalizing sky."
    "Quase todos os membros da turma estão olhando pela janela e olhando para o céu tentador."

# game/script-a2-hanako.rpy:599
translate pt_br a2_hanako_tea_leaves_b9d5d43e:

    # "Even the steadfast Shizune seems to lack her usual vigor for schoolwork."
    "Até a inabalável Shizune parece destituída de seu usual vigor para trabalhos escolares."

# game/script-a2-hanako.rpy:601
translate pt_br a2_hanako_tea_leaves_39535cf4:

    # "Misha, as brazen as ever, has even unbuttoned the top buttons of her shirt and is fanning herself with a note book."
    "Misha, descarada como sempre, até desabotoou os botões de cima de sua blusa e está se abanando com um caderno."

# game/script-a2-hanako.rpy:603
translate pt_br a2_hanako_tea_leaves_f1c4b14d:

    # "I must have been staring, as she's now sticking her tongue out at me."
    "Eu devo ter olhado demais, pois ela está agora mostrando a língua para mim."

# game/script-a2-hanako.rpy:605
translate pt_br a2_hanako_tea_leaves_f5ccf72c:

    # "However, she shows no signs of halting her efforts, nor is she trying to hide the fact."
    "Contudo, ela não mostra nenhum sinal de que vai parar com seus esforços, nem está tentando esconder o fato."

# game/script-a2-hanako.rpy:609
translate pt_br a2_hanako_tea_leaves_750865fe:

    # "The lunch bells seem to catch everyone by surprise, and the class empties at a much slower pace than usual."
    "O sinal do almoço parece pegar todos de surpresa, e minha sala se esvazia de forma mais lenta que o normal."

# game/script-a2-hanako.rpy:611
translate pt_br a2_hanako_tea_leaves_d7a6c350:

    # "The heat seems to be draining the need to rush from everyone."
    "O calor parece estar drenando a necessidade de todos de serem apressados."

# game/script-a2-hanako.rpy:615
translate pt_br a2_hanako_tea_leaves_157892b3:

    # "Well, almost everyone."
    "Bem, quase todo mundo."

# game/script-a2-hanako.rpy:620
translate pt_br a2_hanako_tea_leaves_eae2a53e:

    # ha "H… Hisao?"
    ha "H… Hisao?"

# game/script-a2-hanako.rpy:622
translate pt_br a2_hanako_tea_leaves_3a260c25:

    # hi "Hey there Hanako, what can I do for you today?"
    hi "Olá, Hanako, o que posso fazer por você hoje?"

# game/script-a2-hanako.rpy:624
translate pt_br a2_hanako_tea_leaves_91d2ef49:

    # "Hanako already has a lunch bag in hand."
    "Hanako já está com uma lancheira nas mãos."

# game/script-a2-hanako.rpy:626
translate pt_br a2_hanako_tea_leaves_c4d155c9:

    # "I don't have to be a detective to work out where this is going."
    "Não preciso ser um detetive para descobrir onde isso vai acabar."

# game/script-a2-hanako.rpy:631
translate pt_br a2_hanako_tea_leaves_fdad5312:

    # ha "Um… would you like to have lunch with us again?"
    ha "Hm… quer almoçar com a gente de novo?"

# game/script-a2-hanako.rpy:636
translate pt_br a2_hanako_tea_leaves_56c24a4b:

    # ha "I… I brought enough for everyone…"
    ha "Eu… eu trouxe o suficiente para todos nós…"

# game/script-a2-hanako.rpy:638
translate pt_br a2_hanako_tea_leaves_b1520968:

    # hi "Awesome. You don't have to be so stiff about it though."
    hi "Impressionante. Mas você não precisa ser tão rigorosa com isso."

# game/script-a2-hanako.rpy:643
translate pt_br a2_hanako_tea_leaves_63539c2e:

    # ha "Ah… right."
    ha "Ah… está bem."

# game/script-a2-hanako.rpy:645
translate pt_br a2_hanako_tea_leaves_d1e8fa95:

    # hi "I take it we're going to the tea room?"
    hi "Presumo que iremos para a sala de chá?"

# game/script-a2-hanako.rpy:650
translate pt_br a2_hanako_tea_leaves_913ee39d:

    # ha "P… please."
    ha "P… por favor."

# game/script-a2-hanako.rpy:655
translate pt_br a2_hanako_tea_leaves_32770c6a:

    # ha "Lilly said she'll meet us in there, so we should… should…"
    ha "Lilly disse que nos encontraria lá, então deveríamos… deveríamos…"

# game/script-a2-hanako.rpy:657
translate pt_br a2_hanako_tea_leaves_b0b0ea97:

    # hi "Should?"
    hi "Deveríamos?"

# game/script-a2-hanako.rpy:662
translate pt_br a2_hanako_tea_leaves_e363999a:

    # ha "…should go ahead together…"
    ha "…ir lá juntos…"

# game/script-a2-hanako.rpy:664
translate pt_br a2_hanako_tea_leaves_f8846f9d:

    # hi "Sounds like a plan. This heat has made me pretty hungry."
    hi "Parece uma boa ideia. Esse calor me deixou com bastante fome."

# game/script-a2-hanako.rpy:666
translate pt_br a2_hanako_tea_leaves_1e6b4ddd:

    # "Hanako breathes a sigh of relief, and I gather my things together."
    "Hanako suspira aliviada, e eu pego minhas coisas."

# game/script-a2-hanako.rpy:673
translate pt_br a2_hanako_tea_leaves_e079fafe:

    # "As usual, the aura of the tea room is refreshing, feeling isolated from the rest of the world."
    "Como sempre, a aura da sala de chá é refrescante, com um sentimento de isolamento do resto do mundo."

# game/script-a2-hanako.rpy:675
translate pt_br a2_hanako_tea_leaves_1d3c58cb:

    # "Then again, the usual din of the school seems to be a bit subdued; most likely from laziness promoted by heat exhaustion."
    "O ruído da escola parece mais suave do que de costume; provavelmente devido à preguiça causada pela exaustão do calor."

# game/script-a2-hanako.rpy:677
translate pt_br a2_hanako_tea_leaves_cc23e121:

    # "Hanako slowly spreads her food on the table, intently focusing on every little movement, as if she's trying to keep her mind off other thoughts."
    "Hanako espalha e organiza sua comida pela mesa, se focando atentamente em cada pequeno movimento, como se estivesse tentando manter sua mente longe de outros pensamentos."

# game/script-a2-hanako.rpy:679
translate pt_br a2_hanako_tea_leaves_10b8774d:

    # "It's not much, but I can tell from her demeanor that she has prepared everything with utmost care."
    "Não é muita coisa, mas posso dizer por seu comportamento que ela preparou tudo com muito carinho."

# game/script-a2-hanako.rpy:681
translate pt_br a2_hanako_tea_leaves_54723c24:

    # hi "I guess Lilly isn't here yet. Should we start without her?"
    hi "Acho que Lilly não veio ainda. Devemos começar sem ela?"

# game/script-a2-hanako.rpy:688
translate pt_br a2_hanako_tea_leaves_8ad775e7:

    # ha "S-she'll be here soon…"
    ha "E-ela vai chegar logo…"

# game/script-a2-hanako.rpy:693
translate pt_br a2_hanako_tea_leaves_ad3f78d5:

    # "Hanako struggles with the lid of the container of rice."
    "Hanako tem dificuldade com a tampa do pote de arroz."

# game/script-a2-hanako.rpy:695
translate pt_br a2_hanako_tea_leaves_fdd97525:

    # hi "Here, let me help with that…"
    hi "Vem cá, deixa eu te ajudar com isso…"

# game/script-a2-hanako.rpy:697
translate pt_br a2_hanako_tea_leaves_a714ccbd:

    # "I take the container from Hanako's hands, and try to force open the lid."
    "Eu pego o pote das mãos da Hanako, e tento abrir a tampa com força."

# game/script-a2-hanako.rpy:699
translate pt_br a2_hanako_tea_leaves_a207837a:

    # "Try as I might, it seems wedged shut."
    "Por mais que eu tente, parece completamente emperrado."

# game/script-a2-hanako.rpy:701
translate pt_br a2_hanako_tea_leaves_7bb3d935:

    # hi "Let me guess, did you put this in while the rice was still hot?"
    hi "Deixa eu adivinhar, você colocou o arroz aí dentro enquanto ainda estava quente?"

# game/script-a2-hanako.rpy:706
translate pt_br a2_hanako_tea_leaves_d5c541be:

    # ha "Y-yes. I was in a rush…"
    ha "S-sim. Eu estava com pressa…"

# game/script-a2-hanako.rpy:708
translate pt_br a2_hanako_tea_leaves_0b68056b:

    # "I put the container on the table between us."
    "Eu coloco o pote na mesa entre nós dois."

# game/script-a2-hanako.rpy:710
translate pt_br a2_hanako_tea_leaves_ea9d6eb8:

    # hi "I thought so. It looks like this is wedged shut. We'll need some hot water to get it open."
    hi "Foi o que pensei. Parece estar entalado. Vamos precisar de um pouco de água quente para abrir."

# game/script-a2-hanako.rpy:712
translate pt_br a2_hanako_tea_leaves_04877fa6:

    # hi "But that could be a pain in here. We'd get water everywhere."
    hi "Mas isso seria ruim aqui, iria molhar tudo."

# game/script-a2-hanako.rpy:714
translate pt_br a2_hanako_tea_leaves_262dc552:

    # li "Well, in that case, how about I contribute to today's meal?"
    li "Bem, nesse caso, que tal eu contribuir para a refeição de hoje?"

# game/script-a2-hanako.rpy:726
translate pt_br a2_hanako_tea_leaves_fdcddff6:

    # "At the door, Lilly smiles while holding up a bag stocked with various buns and bread rolls. I can't help but do the same."
    "Na porta, Lilly sorri segurando uma sacola cheia de vários tipos de pães e enroladinhos. Não consigo evitar de sorrir também."

# game/script-a2-hanako.rpy:731
translate pt_br a2_hanako_tea_leaves_404768e6:

    # li "Since you two had a change of plans because of me, I thought I would bring a little something."
    li "Já que vocês dois mudaram seus planos por minha causa, pensei em trazer umas coisinhas."

# game/script-a2-hanako.rpy:733
translate pt_br a2_hanako_tea_leaves_c7d1e465:

    # hi "Thanks, Lilly. Here, let me get that for you…"
    hi "Obrigado, Lilly. Aqui, deixa eu pegar isso pra você…"

# game/script-a2-hanako.rpy:739
translate pt_br a2_hanako_tea_leaves_e986c8d0:

    # "With a little guidance, Lilly's bread assortment joins Hanako's rice-less platter. I hastily make some tea to complete the picture."
    "Com um pouco de orientação, a seleção de pães da Lilly se junta ao prato sem arroz da Hanako. Eu faço um pouco de chá rapidamente para completar o conjunto."

# game/script-a2-hanako.rpy:741
translate pt_br a2_hanako_tea_leaves_a6d37fd9:

    # hi "Well, I'm looking forward to this."
    hi "Hm, estou ansioso por isso."

# game/script-a2-hanako.rpy:746
translate pt_br a2_hanako_tea_leaves_a56ec980:

    # "As I take a bite, I notice Hanako trying her hardest to not look like she is looking at me."
    "Quando mordo minha comida, percebo a Hanako se esforçando muito para parecer não estar olhando para mim."

# game/script-a2-hanako.rpy:748
translate pt_br a2_hanako_tea_leaves_4ad1cd68:

    # "It's nothing special, but then again I can't really complain. I'm pretty lazy when it comes to cooking for myself."
    "Não é nada de especial, mas eu não posso realmente reclamar. Sou bem preguiçoso quando se trata de cozinhar para mim mesmo."

# game/script-a2-hanako.rpy:750
translate pt_br a2_hanako_tea_leaves_305b12e5:

    # hi "Not bad, I guess this is made with the stuff you bought yesterday?"
    hi "Nada mal, presumo que tenha feito isso com as coisas que comprou ontem?"

# game/script-a2-hanako.rpy:755
translate pt_br a2_hanako_tea_leaves_13b7ab07:

    # ha "Y-yes."
    ha "S-sim."

# game/script-a2-hanako.rpy:757
translate pt_br a2_hanako_tea_leaves_d68dd63c:

    # "Hanako's eyes shout at me, begging for some kind of feedback."
    "Os olhos da Hanako se lançam em minha direção, clamando pelo meu parecer."

# game/script-a2-hanako.rpy:759
translate pt_br a2_hanako_tea_leaves_df4640b6:

    # hi "Well it was clearly worth it. Thanks, Hanako."
    hi "Realmente valeu a pena. Obrigado, Hanako."

# game/script-a2-hanako.rpy:764
translate pt_br a2_hanako_tea_leaves_f67761ee:

    # ha "I… I wanted to show you this… after yesterday…"
    ha "E… eu queria te mostrar isto… depois de ontem…"

# game/script-a2-hanako.rpy:766
translate pt_br a2_hanako_tea_leaves_26851b0f:

    # hi "It's okay. I was just a little surprised at the stuff you were buying."
    hi "Está tudo bem. Eu só estava um pouco surpreso com as coisas que você estava comprando."

# game/script-a2-hanako.rpy:771
translate pt_br a2_hanako_tea_leaves_1473ba3b:

    # li "Hanako's always liked to experiment when it comes to food. I think it's good… most… of the time."
    li "Hanako sempre gostou de experimentar quando se trata de comida. Acho que isso é bom… na… maioria das vezes."

# game/script-a2-hanako.rpy:773
translate pt_br a2_hanako_tea_leaves_e47b5ede:

    # "While Lilly's smile doesn't waver, the slight change in her tone tells me that things have not gone so well in the past."
    "Embora o sorriso de Lilly não oscile, a leve mudança em seu tom de voz me diz que que as coisas não deram tão certo no passado."

# game/script-a2-hanako.rpy:775
translate pt_br a2_hanako_tea_leaves_ee3b6710:

    # "And it's not like Hanako has many people to sample her cooking…"
    "E não parece que a Hanako tem muita gente para experimentar o que ela cozinha…"

# game/script-a2-hanako.rpy:779
translate pt_br a2_hanako_tea_leaves_2dbc629a:

    # "Hang on… was Lilly waiting for me to go first? She didn't start eating until after I said it was all right…"
    "Espere aí… Lilly estava esperando eu ir primeiro? Ela não começou a comer até eu dizer que estava bom…"

# game/script-a2-hanako.rpy:781
translate pt_br a2_hanako_tea_leaves_aebaf96f:

    # "Her cheeky grin tells me that this was a deliberate action on her part. I'll have to try and work out how to get one over her in the future, to make up for this."
    "Seu sorriso irônico e irreverente me diz que essa ação foi deliberada da parte dela. Tenho que pensar numa forma de pegá-la no futuro, para compensar por isso."

# game/script-a2-hanako.rpy:783
translate pt_br a2_hanako_tea_leaves_14edd9ad:

    # hi "Well, it's good, and that's all that counts, right?"
    hi "Bem, está bom, e é isso que conta, né?"

# game/script-a2-hanako.rpy:788
translate pt_br a2_hanako_tea_leaves_40ca9b49:

    # ha "R-right."
    ha "É-é."

# game/script-a2-hanako.rpy:793
translate pt_br a2_hanako_tea_leaves_6d42d438:

    # "Lilly, satisfied at not being the first to sample Hanako's creation, begins to consume the food in front of her."
    "Lilly, satisfeita por não ter sido a primeira a provar a criação da Hanako, começa a comer a comida à sua frente."

# game/script-a2-hanako.rpy:795
translate pt_br a2_hanako_tea_leaves_959dd891:

    # "I find myself staring as I watch her chopsticks gently touch the plate, their tips delicately poking and tracing to quickly ascertain the positions of the food as she dexterously picks it up."
    "Me pego olhando fixamente quando assisto aos seus hashis tocarem suavemente o prato, e as pontas de seus dedos delicadamente tocando e rastreando as posições da comida enquanto ela habilmente as pega."

# game/script-a2-hanako.rpy:797
translate pt_br a2_hanako_tea_leaves_2e53826d:

    # "One might think she were a child playing with her food if not for the situation, though she does it with such care and thoughtlessness that it's obvious this is simply how she eats this kind of meal."
    "Alguém poderia pensar que ela seria uma criança brincando com a comida se não fosse pela situação, mas ela faz isso com tanto cuidado e naturalidade que é óbvio que esse é simplesmente o jeito com o qual ela come esse tipo de refeição."

# game/script-a2-hanako.rpy:799
translate pt_br a2_hanako_tea_leaves_5dbf722b:

    # "Not wanting to miss out, I start filling up myself."
    "Sem querer ficar para trás, começo a atacar meu prato também."

# game/script-a2-hanako.rpy:804
translate pt_br a2_hanako_tea_leaves_94829a7c:

    # "Hanako takes a different approach, waiting until Lilly and I have our hands clear before quickly snatching up her share."
    "Hanako assume uma abordagem diferente, esperando até que a Lilly e eu estejamos de mãos vazias antes de arrebatar agilmente sua parte."

# game/script-a2-hanako.rpy:811
translate pt_br a2_hanako_tea_leaves_b72570f2:

    # "Before long the containers are empty, save for the still-shut rice container."
    "Em não muito tempo, os potes estão vazios; com a exceção do de arroz, ainda emperrado."

# game/script-a2-hanako.rpy:816
translate pt_br a2_hanako_tea_leaves_59b45e71:

    # li "Thank you Hanako, that was filling."
    li "Obrigado, Hanako, estou satisfeita."

# game/script-a2-hanako.rpy:821
translate pt_br a2_hanako_tea_leaves_6dde9eb9:

    # ha "N-no… thank you for the bread…"
    ha "N-não… obrigada pelo pão…"

# game/script-a2-hanako.rpy:823
translate pt_br a2_hanako_tea_leaves_b68f1c55:

    # hi "Yes, it would have been a disaster if not for that."
    hi "Sim, teria sido um desastre se não fosse por isso."

# game/script-a2-hanako.rpy:828
translate pt_br a2_hanako_tea_leaves_d1a80f84:

    # li "You're both welcome."
    li "Disponham."

# game/script-a2-hanako.rpy:833
translate pt_br a2_hanako_tea_leaves_d05c3672:

    # li "But now, I must be getting back. It's far too easy to be late after eating here."
    li "Mas agora, eu tenho que voltar. É muito fácil se atrasar depois de comer aqui."

# game/script-a2-hanako.rpy:835
translate pt_br a2_hanako_tea_leaves_f7569242:

    # hi "Yeah, I see what you mean. I think we'll just clean up here and then head off."
    hi "Verdade, entendo o que quer dizer. Acho que devemos apenas limpar as coisas aqui e ir embora."

# game/script-a2-hanako.rpy:840
translate pt_br a2_hanako_tea_leaves_2db9ae35:

    # li "Well then, good day."
    li "Muito bem, então. Tenham um bom dia."

# game/script-a2-hanako.rpy:851
translate pt_br a2_hanako_tea_leaves_91f65439:

    # "Lilly leaves, her cane tapping away down the quiet hallway."
    "Lilly sai, com sua bengala batendo levemente pelo corredor quieto."

# game/script-a2-hanako.rpy:853
translate pt_br a2_hanako_tea_leaves_12f6d2bc:

    # "Hanako and I quickly pack our things and stay seated, waiting for the bell."
    "Hanako e eu arrumamos nossas coisas depressa e continuamos sentados, esperando pelo sinal."

# game/script-a2-hanako.rpy:862
translate pt_br a2_hanako_tea_leaves_5de14c10:

    # "Together, we stare out the window and into the endless azure sky."
    "Juntos, olhamos a vastidão azulada do céu."

# game/script-a2-hanako.rpy:866
translate pt_br a2_hanako_tea_leaves_4b942b3a:

    # "If it weren't for the pealing of the bells, I would have sworn that time had stopped."
    "Se não fosse pelo ressoo dos sinos, eu poderia jurar que o tempo tinha parado."

# game/script-a2-hanako.rpy:868
translate pt_br a2_hanako_tea_leaves_1ad2c5e5:

    # "The urge to skip class rises in my gut."
    "A ânsia de matar aula permeia meu ser."

# game/script-a2-hanako.rpy:870
translate pt_br a2_hanako_tea_leaves_7d7d9118:

    # "I shoot a glance at Hanako, who shows no signs of moving either."
    "Dou uma olhada para a Hanako, que também não mostra sinais de se mover."

# game/script-a2-hanako.rpy:872
translate pt_br a2_hanako_tea_leaves_450101e2:

    # ha "Not… just yet…"
    ha "Não… ainda não…"

# game/script-a2-hanako.rpy:882
translate pt_br a2_hanako_tea_leaves_b55f1ccc:

    # "The interval between the warning bells and the end of lunch bells passes in the blink of an eye."
    "O intervalo entre o sinal de aviso e o sinal do fim do almoço passa num piscar de olhos."

# game/script-a2-hanako.rpy:884
translate pt_br a2_hanako_tea_leaves_6a91e7ab:

    # hi "We really should go… people will freak out and start a search party if we skip…"
    hi "Realmente deveríamos ir… O pessoal vai se preocupar e organizar um grupo de busca se matarmos a aula…"

# game/script-a2-hanako.rpy:889
translate pt_br a2_hanako_tea_leaves_82710fcb:

    # "Hanako sighs."
    "Hanako suspira."

# game/script-a2-hanako.rpy:894
translate pt_br a2_hanako_tea_leaves_e3554cc0:

    # ha "You're right."
    ha "Tem razão."

# game/script-a2-hanako.rpy:899
translate pt_br a2_hanako_tea_leaves_56dbcd7d:

    # "Slowly, she rises to her feet, and I follow suit."
    "Lentamente, ela se põe de pé, e eu a sigo."

# game/script-a2-hanako.rpy:904
translate pt_br a2_hanako_tea_leaves_ee16115e:

    # "Silently, we make our way up the old stairs to the third floor and then to our classroom."
    "Percorremos silenciosamente nosso caminho subindo as antigas escadas para o terceiro andar, e então para nossa sala."

# game/script-a2-hanako.rpy:911
translate pt_br a2_hanako_tea_leaves_c74e1be1:

    # "At the door, I take point and open the door ahead of Hanako, bowing my head down in apology in advance."
    "Na porta, eu assumo a dianteira e abro a porta à frente de Hanako, curvando-me antecipadamente em desculpa pelo atraso."

# game/script-a2-hanako.rpy:918
translate pt_br a2_hanako_tea_leaves_a5ce169e:

    # hi "I'm sorry we're late, teacher."
    hi "Desculpe por estarmos atrasados, professor."

# game/script-a2-hanako.rpy:922
translate pt_br a2_hanako_tea_leaves_8a946aea:

    # "I am greeted not by stern words, nor by an angered instruction to take my seat, but simply by the silence created by fifteen or so students trying not to laugh."
    "Não sou cumprimentado por palavras severas, ou por instruções enfurecidas para me sentar, mas simplesmente pelo silêncio causado pelos mais ou menos quinze alunos tentando não rir."

# game/script-a2-hanako.rpy:924
translate pt_br a2_hanako_tea_leaves_ab711778:

    # "Mutou, ever tardy, has yet to arrive. However, the fact that Hanako and I have arrived together is blatantly obvious."
    "Mutou, sempre tardio, ainda está para chegar. Entretanto, o fato de Hanako e eu chegarmos juntos é flagrantemente óbvio."

# game/script-a2-hanako.rpy:929
translate pt_br a2_hanako_tea_leaves_9766aa67:

    # mi "Pff… pffwa…"
    mi "Pff… pffha…"

# game/script-a2-hanako.rpy:931
translate pt_br a2_hanako_tea_leaves_456a618c:

    # "Make that about fourteen students trying, and one student failing."
    "Diminua para cerca de quatorze alunos tentando, e um falhando."

# game/script-a2-hanako.rpy:938
translate pt_br a2_hanako_tea_leaves_99545ec2:

    # mi "Pft-bwahahaha! The lovers return~!"
    mi "Pff-bhahahaha! O casal de namorados voltou~!"

# game/script-a2-hanako.rpy:943
translate pt_br a2_hanako_tea_leaves_097f05a0:

    # mi "WAHAHAHA~!"
    mi "WAHAHAHA~!"

# game/script-a2-hanako.rpy:945
translate pt_br a2_hanako_tea_leaves_5a3a6a91:

    # hi "Yeah, thanks. You can calm down now."
    hi "Sim, obrigado. Você pode se acalmar agora."

# game/script-a2-hanako.rpy:958
translate pt_br a2_hanako_tea_leaves_a7fb9029:

    # "I step through the door, and realize that Hanako is firmly pressed against my back, hiding herself from the class."
    "Passo pela porta, e percebo que a Hanako está firmemente prensada contra minhas costas, se escondendo da classe."

# game/script-a2-hanako.rpy:967
translate pt_br a2_hanako_tea_leaves_9e63a96e:

    # "With my steps coming closer to my desk, she eventually breaks from me and stiffly walks to her own. Her efforts to mentally block everyone's presence from her mind are written fairly clearly on her face."
    "Com meus passos se aproximando da minha carteira, ela eventualmente se separa de mim e anda de forma tensa para a sua. Seus esforços para bloquear a presença de todos de sua mente estão escritos claramente no seu rosto."

# game/script-a2-hanako.rpy:972
translate pt_br a2_hanako_tea_leaves_533e7eeb:

    # "Quickly checking the door for any signs of the teacher's arrival, I make a trip to Hanako's desk and whisper in her ear."
    "Checando brevemente a porta a procura de quaisquer sinais da chegada do professor, faço uma jornada até a carteira da Hanako e sussurro em seu ouvido."

# game/script-a2-hanako.rpy:974
translate pt_br a2_hanako_tea_leaves_e4de6562:

    # hi "Don't worry about Misha, she's always like this. I enjoyed myself today. Don't sweat it, okay?"
    hi "Não se preocupe com a Misha, ela é sempre assim. Eu me diverti hoje. Não ligue para isso, ok?"

# game/script-a2-hanako.rpy:976
translate pt_br a2_hanako_tea_leaves_6fd4fef2:

    # "Hanako nods her head behind her folded arms, but still doesn't show her face."
    "Hanako acena positivamente com a cabeça por detrás de seus braços cruzados, mas ainda não mostra seu rosto."

# game/script-a2-hanako.rpy:990
translate pt_br a2_hanako_tea_leaves_e86aca05:

    # "I yearn to stay and console her more, but Mutou picks this exact moment to enter the class, halfway through his lecture, as if he started it in the hallway."
    "Eu sinto vontade de ficar e consolá-la mais, mas Mutou escolhe este exato momento para adentrar a sala, no meio de sua explicação, como se já a tivesse começado no corredor."

# game/script-a2-hanako.rpy:995
translate pt_br a2_hanako_tea_leaves_5d2876e1:

    # mu "…which, of course, is directly proportional to the charge but inversely proportionally to the square of the distance…"
    mu "…a qual, naturalmente, é diretamente proporcional à carga, mas inversamente proporcional ao quadrado da distância…"

# game/script-a2-hanako.rpy:1002
translate pt_br a2_hanako_tea_leaves_6d868831:

    # "He's so engrossed in his speech that he doesn't even notice me sneaking back into my seat from Hanako's desk."
    "Ele está tão absorto em seu discurso que nem me percebe esgueirando da carteira da Hanako de volta à minha."

# game/script-a2-hanako.rpy:1004
translate pt_br a2_hanako_tea_leaves_01944858:

    # "While Mutou's spiel rambles on, Misha leans over to me."
    "Enquanto a lengalenga do Mutou continua, Misha se inclina em minha direção."

# game/script-a2-hanako.rpy:1016
translate pt_br a2_hanako_tea_leaves_f21fa221:

    # mi "The teacher may not have noticed your tardiness, but I did."
    mi "O professor pode não ter percebido seu atraso, mas eu percebi."

# game/script-a2-hanako.rpy:1018
translate pt_br a2_hanako_tea_leaves_346b6496:

    # "That much is obvious from the show you just put on."
    "Isso é óbvio pelo show que você deu."

# game/script-a2-hanako.rpy:1023
translate pt_br a2_hanako_tea_leaves_671bcaf7:

    # mi "I have been instructed to let you off the hook for today, but only on one condition."
    mi "Fui instruída a deixar você se safar por hoje, mas apenas com uma condição."

# game/script-a2-hanako.rpy:1025
translate pt_br a2_hanako_tea_leaves_52b091f1:

    # hi "Oh? And what would that be?"
    hi "Oh? E qual seria?"

# game/script-a2-hanako.rpy:1030
translate pt_br a2_hanako_tea_leaves_a4a172ca:

    # mi "You have to help us this afternoon~!"
    mi "Você tem que nos ajudar essa tarde~!"

# game/script-a2-hanako.rpy:1032
translate pt_br a2_hanako_tea_leaves_922e8834:

    # "I crane my neck to look over Misha's shoulder."
    "Eu estico meu pescoço para olhar sobre o ombro da Misha."

# game/script-a2-hanako.rpy:1034
translate pt_br a2_hanako_tea_leaves_0a4b77bd:

    # "Shizune is conveniently not making eye contact with me."
    "Shizune, convenientemente, não está fazendo contato visual comigo."

# game/script-a2-hanako.rpy:1036
translate pt_br a2_hanako_tea_leaves_aa78da23:

    # hi "Fine. Just for today."
    hi "Tudo bem. Só por hoje."

# game/script-a2-hanako.rpy:1038
translate pt_br a2_hanako_tea_leaves_ae1dd96c:

    # hi "I've already told you I'm not joining the council, remember?"
    hi "Já falei para vocês que não vou entrar no Conselho, lembra?"

# game/script-a2-hanako.rpy:1043
translate pt_br a2_hanako_tea_leaves_80420c9b:

    # mi "Of course! Doing so could be considered… um, considered…"
    mi "É claro! Fazer isso seria considerado… hm, considerado…"

# game/script-a2-hanako.rpy:1048
translate pt_br a2_hanako_tea_leaves_96f58dc2:

    # "She looks down at her notebook, obviously looking for her place in her script."
    "Ela olha para seu caderno, obviamente procurando por sua fala no roteiro."

# game/script-a2-hanako.rpy:1053
translate pt_br a2_hanako_tea_leaves_6979903f:

    # mi "…under duress and hence would be against regulations."
    mi "…sob coação, e portanto seria contra os regulamentos."

# game/script-a2-hanako.rpy:1055
translate pt_br a2_hanako_tea_leaves_0a5b7502:

    # hi "How very strange of you to be considerate of the regulations now."
    hi "Que estranho que você esteja considerando os regulamentos agora."

# game/script-a2-hanako.rpy:1060
translate pt_br a2_hanako_tea_leaves_d5ecf66d:

    # mi "Things should be done by the book!"
    mi "As coisas devem ser feitas conforme as regras!"

# game/script-a2-hanako.rpy:1065
translate pt_br a2_hanako_tea_leaves_921d7f42:

    # mi "It's just that the book hasn't been written for every situation, so there are times when it can be ignored."
    mi "Só que as regras não foram feitas para todas as situações, então tem vezes nas quais podem ser ignoradas."

# game/script-a2-hanako.rpy:1067
translate pt_br a2_hanako_tea_leaves_b444b045:

    # hi "And yet, you two wonder why no one else wants to be in the Student Council…"
    hi "E vocês ainda se perguntam por que ninguém quer se afiliar ao Conselho Estudantil…"

# game/script-a2-hanako.rpy:1083
translate pt_br a2_hanako_tea_leaves_02e82071:

    # "After poking her tongue out at me, Misha returns to her workbook, and we battle our way through the latter half of the school day."
    "Após esticar a língua para mim, Misha retorna para seu caderno, e batalhamos nosso caminho através da segunda metade do dia escolar."

# game/script-a2-hanako.rpy:1097
translate pt_br a2_hanako_tea_leaves_2b074432:

    # "Before I can even stand up, Misha and Shizune have placed their hands on both my shoulders."
    "Antes mesmo que eu possa me levantar, Misha e Shizune já colocaram suas mãos cada uma em um de meus ombros."

# game/script-a2-hanako.rpy:1099
translate pt_br a2_hanako_tea_leaves_a71cf44c:

    # hi "Hey, I said I'd help out, damn…"
    hi "Ei, eu disse que ajudaria, droga…"

# game/script-a2-hanako.rpy:1106
translate pt_br a2_hanako_tea_leaves_b44d2576:

    # mi "This is just insurance, Hisao, insurance~!"
    mi "É só por garantia, Hisao, garantia~!"

# game/script-a2-hanako.rpy:1120
translate pt_br a2_hanako_tea_leaves_f3decb73:

    # ha "H-Hisao?"
    ha "H-Hisao?"

# game/script-a2-hanako.rpy:1122
translate pt_br a2_hanako_tea_leaves_a65f3f71:

    # "Hanako timidly tries to leave the room by circling around us and I suddenly realize that this may be my one chance to escape."
    "Hanako tenta timidamente deixar a sala nos circulando, e eu repentinamente percebo que essa pode ser minha única chance de escapar."

# game/script-a2-hanako.rpy:1124
translate pt_br a2_hanako_tea_leaves_1f4e2443:

    # hi "Oh hey Hanako. What's up?"
    hi "Ah, ei, Hanako. E aí?"

# game/script-a2-hanako.rpy:1129
translate pt_br a2_hanako_tea_leaves_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1134
translate pt_br a2_hanako_tea_leaves_17c19b5d:

    # mi "Hey, what makes you think you've got time to chat?"
    mi "Ei, o que o faz pensar que você tem tempo para papear?"

# game/script-a2-hanako.rpy:1136
translate pt_br a2_hanako_tea_leaves_8f1a017d:

    # hi "Oh relax, this won't take long… sorry Hanako, you were saying?"
    hi "Relaxe, isso não vai demorar… desculpe, Hanako, você estava dizendo?"

# game/script-a2-hanako.rpy:1141
translate pt_br a2_hanako_tea_leaves_8fb9f6f8:

    # ha "I… I was going to go to the library, and… and I thought…"
    ha "E… eu estava indo para a biblioteca, e… e eu pensei…"

# game/script-a2-hanako.rpy:1143
translate pt_br a2_hanako_tea_leaves_cbcc77e7:

    # "Hanako's thumbs dance around each other and her eyes flit around the room, looking everywhere but at us."
    "Os polegares da Hanako dançam um em volta do outro e seu olhar se move rapidamente pela sala, olhando para todos os lugares menos para nós."

# game/script-a2-hanako.rpy:1148
translate pt_br a2_hanako_tea_leaves_a8d28f1a:

    # mi "Sorry Hanako, but Hisao has to come with us. He's got work to do."
    mi "Desculpa, Hanako, mas o Hisao tem que vir com a gente. Ele tem trabalho a fazer."

# game/script-a2-hanako.rpy:1153
translate pt_br a2_hanako_tea_leaves_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1158
translate pt_br a2_hanako_tea_leaves_4ba21152:

    # mi "Oh! But you can help too if you'd like."
    mi "Ah! Mas você pode ajudar também se quiser."

# game/script-a2-hanako.rpy:1163
translate pt_br a2_hanako_tea_leaves_a5709550:

    # ha "Um…"
    ha "Hm…"

# game/script-a2-hanako.rpy:1170
translate pt_br a2_hanako_tea_leaves_aecacf86:

    # mi "So, how about it, Hisao?" nointeract
    mi "Então, que tal isso, Hisao?" nointeract

# game/script-a2-hanako.rpy:1187
translate pt_br a2_hanako_office_confessional_35e835c2:

    # hi "What do you say, Hanako? If we all help it shouldn't take long at all."
    hi "O que me diz, Hanako? Se todos ajudarmos, não deve demorar muito."

# game/script-a2-hanako.rpy:1192
translate pt_br a2_hanako_office_confessional_92611110:

    # "Hanako's fidgeting answers my question before she can even form the words."
    "A inquietação da Hanako responde minha pergunta antes que mesmo que ela forme qualquer palavra."

# game/script-a2-hanako.rpy:1197
translate pt_br a2_hanako_office_confessional_854c9bd1:

    # ha "I… I really need to go…"
    ha "Eu… realmente preciso ir…"

# game/script-a2-hanako.rpy:1199
translate pt_br a2_hanako_office_confessional_11048bf8:

    # "Well, that was to be expected. Looks like it's just me and the council girls again."
    "Bem, era de se esperar. Parece que somos apenas eu e as garotas do Conselho de novo."

# game/script-a2-hanako.rpy:1201
translate pt_br a2_hanako_office_confessional_ffe75f53:

    # "It's easier to resign myself to another afternoon's work in the small council office."
    "É mais fácil eu me resignar a mais uma tarde de trabalho no pequeno escritório do Conselho."

# game/script-a2-hanako.rpy:1203
translate pt_br a2_hanako_office_confessional_cee49811:

    # hi "I'll catch up with you later, okay?"
    hi "Me encontro com você depois, ok?"

# game/script-a2-hanako.rpy:1208
translate pt_br a2_hanako_office_confessional_57db572d:

    # ha "O-okay."
    ha "O-ok."

# game/script-a2-hanako.rpy:1223
translate pt_br a2_hanako_office_confessional_ce8c911c:

    # mi "Right! Now that the farewells are over, it's work time!"
    mi "Certo! Agora que as despedidas acabaram, é hora do trabalho!"

# game/script-a2-hanako.rpy:1228
translate pt_br a2_hanako_office_confessional_88226440:

    # "Misha and Shizune frog-march me to the student council office, never once letting go of my shoulders."
    "Misha e Shizune me escoltam até o escritório do Conselho Estudantil, não largando meus ombros nem ao menos uma vez."

# game/script-a2-hanako.rpy:1230
translate pt_br a2_hanako_office_confessional_683cf824:

    # "I feel a little bad for ditching Hanako like this, but if this is the price of getting Misha off her back, so be it."
    "Me sinto mal por abandonar a Hanako assim, mas se este é o preço para tirar a Misha da cola dela, que seja."

# game/script-a2-hanako.rpy:1235
translate pt_br a2_hanako_office_confessional_f84fba54:

    # hi "So then, what are we up to today?"
    hi "E então, o que faremos hoje?"

# game/script-a2-hanako.rpy:1242
translate pt_br a2_hanako_office_confessional_655e6ecc:

    # mi "Debrief!"
    mi "Relatório!"

# game/script-a2-hanako.rpy:1244
translate pt_br a2_hanako_office_confessional_44966046:

    # hi "Huh? Isn't that supposed to happen after something?"
    hi "Hã? Isso não é para ser feito depois de termos feito algo?"

# game/script-a2-hanako.rpy:1249
translate pt_br a2_hanako_office_confessional_66701b4e:

    # mi "Yup! We have to collate all of the information from the festival so that Shicchan can debrief the teachers."
    mi "Aham! Temos que arranjar toda a informação do festival para que a Shizunezinha possa fazer o relatório com os professores."

# game/script-a2-hanako.rpy:1258
translate pt_br a2_hanako_office_confessional_90266d02:

    # "Shizune drops a large pile of paperwork on the desk in front of me, and smiles succinctly."
    "Shizune coloca uma grande pilha de papelada na escrivaninha à minha frente, e sorri de forma sucinta."

# game/script-a2-hanako.rpy:1263
translate pt_br a2_hanako_office_confessional_bce21edc:

    # mi "You need to sort those out into two piles."
    mi "Você tem que organizar estes em duas pilhas."

# game/script-a2-hanako.rpy:1268
translate pt_br a2_hanako_office_confessional_45734771:

    # mi "One for financial stuff, like receipts, one for feedback, one for positive feedback, maybe one for things that look like they could be problems next year, one for problems that probably won't be able to be fixed…"
    mi "Uma para coisas financeiras, como recibos, uma para feedback, uma para feedback positivo, talvez uma para coisas que parecem poder causar problemas ano que vem, uma para problemas que provavelmente não serão resolvidos…"

# game/script-a2-hanako.rpy:1270
translate pt_br a2_hanako_office_confessional_50436f3b:

    # hi "That's a few more than two piles…"
    hi "Isso é um pouco mais que duas pilhas…"

# game/script-a2-hanako.rpy:1275
translate pt_br a2_hanako_office_confessional_779c8f72:

    # mi "Huh? Oh, right. Yeah I thought it would be only two piles. My bad."
    mi "Hã? Oh, certo. É, eu pensei que seriam só duas pilhas. Foi mal."

# game/script-a2-hanako.rpy:1277
translate pt_br a2_hanako_office_confessional_ff669e88:

    # hi "Right. While I'm doing this, what will you two be doing?"
    hi "Certo. Enquanto eu faço isso, o que vocês duas vão fazer?"

# game/script-a2-hanako.rpy:1283
translate pt_br a2_hanako_office_confessional_90e910ac:

    # mi "Well, we missed lunch because we were collecting all of these reports, so we're going to go get some food!"
    mi "Bem, nós perdemos o almoço porque estávamos coletando todas esses relatórios, então vamos pegar alguma comida!"

# game/script-a2-hanako.rpy:1285
translate pt_br a2_hanako_office_confessional_03dbca20:

    # "Why didn't you just sort them out while you were collecting them…"
    "Por que vocês não organizaram eles enquanto estavam coletando…"

# game/script-a2-hanako.rpy:1287
translate pt_br a2_hanako_office_confessional_1f73cf9c:

    # "Thankfully my self-defense mechanism kicks in and prevents me from opening my mouth and further worsening my situation."
    "Por sorte, meu mecanismo de autodefesa entra em ação e me impede de abrir minha boca para falar mais e piorar minha situação."

# game/script-a2-hanako.rpy:1292
translate pt_br a2_hanako_office_confessional_dec9bd86:

    # mi "Eh?!"
    mi "Hã?!"

# game/script-a2-hanako.rpy:1297
translate pt_br a2_hanako_office_confessional_f30488c1:

    # mi "How is that fair?"
    mi "Que justiça há nisso?"

# game/script-a2-hanako.rpy:1302
translate pt_br a2_hanako_office_confessional_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1304
translate pt_br a2_hanako_office_confessional_68872e00:

    # "I was fretting over the unfair distribution of work so much that I didn't notice that Shizune had kept on signing."
    "Eu estava reclamando tanto sobre a distribuição injusta do trabalho que não percebi que a Shizune continuou fazendo sinais."

# game/script-a2-hanako.rpy:1306
translate pt_br a2_hanako_office_confessional_b0720ed0:

    # "If it weren't for Misha's outburst, I probably wouldn't have noticed at all."
    "Se não fosse pelo ataque da Misha, eu provavelmente nem teria percebido."

# game/script-a2-hanako.rpy:1317
translate pt_br a2_hanako_office_confessional_b38922dc:

    # "Shizune seems to be delivering a fairly long string of commands to Misha, and none of them look pleasant."
    "Shizune parece estar passando uma longa série de comandos para Misha, e nenhum deles parece agradável."

# game/script-a2-hanako.rpy:1329
translate pt_br a2_hanako_office_confessional_7f68a7cb:

    # "Reaching a conclusion, Misha signs briefly back to Shizune, and then sits down at the desk next to me."
    "Chegando a uma conclusão, Misha sinaliza brevemente de volta para a Shizune, e então se senta em frente à mesa ao lado da minha."

# game/script-a2-hanako.rpy:1342
translate pt_br a2_hanako_office_confessional_38366f84:

    # "Shizune waves to the both of us before disappearing out the door."
    "Shizune acena para nós dois antes de desaparecer pela porta."

# game/script-a2-hanako.rpy:1344
translate pt_br a2_hanako_office_confessional_12c3279e:

    # hi "What was all that about?"
    hi "Sobre o que foi tudo isso?"

# game/script-a2-hanako.rpy:1349
translate pt_br a2_hanako_office_confessional_182710b7:

    # mi "Shicchan was worried that you'd get it all wrong unless you were supervised."
    mi "Shizunezinha estava preocupada sobre você fazer tudo errado a menos que fosse supervisionado."

# game/script-a2-hanako.rpy:1354
translate pt_br a2_hanako_office_confessional_fd5e98ee:

    # mi "And since she can't tell you how you are messing things up, she's making me stay. Awww… bummer, I wanted to go with Shicchan!"
    mi "E já que ela não poderia te falar o que você está fazendo de errado, ela está me fazendo ficar. Ahhh… que pena, eu queria ir com a Shizunezinha!"

# game/script-a2-hanako.rpy:1359
translate pt_br a2_hanako_office_confessional_65a276d7:

    # mi "But she is going to bring us back some food~!"
    mi "Mas ela trará comida pra gente~!"

# game/script-a2-hanako.rpy:1364
translate pt_br a2_hanako_office_confessional_1625412e:

    # mi "How good is that!"
    mi "Que tal isso!"

# game/script-a2-hanako.rpy:1366
translate pt_br a2_hanako_office_confessional_b3bb0e4d:

    # "Misha's flippancy is out of this world. From down in the dumps to on top of the world over some calories."
    "A superficialidade de Misha é fora de série. De deprimida ao topo do mundo por causa de algumas calorias."

# game/script-a2-hanako.rpy:1368
translate pt_br a2_hanako_office_confessional_7aab42f1:

    # "It's hard to imagine how anyone could operate at that level."
    "É difícil imaginar como alguém consegue operar nesse nível."

# game/script-a2-hanako.rpy:1370
translate pt_br a2_hanako_office_confessional_3965f6a1:

    # hi "Well, it could have been worse."
    hi "Bem, podia ter sido pior."

# game/script-a2-hanako.rpy:1372
translate pt_br a2_hanako_office_confessional_1ff25175:

    # hi "So what are we supposed to be doing?"
    hi "Então, o que devemos fazer?"

# game/script-a2-hanako.rpy:1377
translate pt_br a2_hanako_office_confessional_b46f70cd:

    # mi "Collation."
    mi "Colação."

# game/script-a2-hanako.rpy:1379
translate pt_br a2_hanako_office_confessional_4e649191:

    # hi "I gathered that."
    hi "Reuni isso aqui."

# game/script-a2-hanako.rpy:1384
translate pt_br a2_hanako_office_confessional_ca7ccf0f:

    # mi "Well, let's just start making piles. We'll work out what the piles mean later."
    mi "Muito bem, vamos começar só fazendo as pilhas. A gente vê o que as pilhas representam depois."

# game/script-a2-hanako.rpy:1386
translate pt_br a2_hanako_office_confessional_b74f9e7d:

    # hi "Right…"
    hi "Certo…"

# game/script-a2-hanako.rpy:1391
translate pt_br a2_hanako_office_confessional_e7ad2a8d:

    # "We start to separate all of the papers into increasingly complex piles."
    "Começamos a separar os papéis em pilhas cada vez mais complexas."

# game/script-a2-hanako.rpy:1393
translate pt_br a2_hanako_office_confessional_29aa5c51:

    # "At first it's just simple categories; financial, feedback, incident reports…"
    "Primeiro são apenas as categorias simples; financeiro, feedback, relatórios de incidentes…"

# game/script-a2-hanako.rpy:1395
translate pt_br a2_hanako_office_confessional_d36b8d86:

    # "Then they split apart into the good and bad reports, and further still, until it starts to look like we've just thrown the papers onto the desk."
    "Eles então se separaram entre relatórios bons e ruins, e mais ainda, até começar a parecer que apenas jogamos os papéis sobre a mesa."

# game/script-a2-hanako.rpy:1397
translate pt_br a2_hanako_office_confessional_c0c3b426:

    # hi "This is hopeless."
    hi "Isso não vai a lugar nenhum."

# game/script-a2-hanako.rpy:1402
translate pt_br a2_hanako_office_confessional_70951ebf:

    # mi "Huh? Why? We're doing what we were told, right?"
    mi "Hein? Por quê? Estamos fazendo o que nos foi mandando, certo?"

# game/script-a2-hanako.rpy:1404
translate pt_br a2_hanako_office_confessional_33546fbf:

    # hi "Yes, but it looks like we're just making a mess."
    hi "Sim, mas parece que estamos apenas fazendo uma bagunça."

# game/script-a2-hanako.rpy:1409
translate pt_br a2_hanako_office_confessional_f6ecce50:

    # mi "No, I think we got a lot done. Shicchan will be able to work out the rest from here."
    mi "Não, acho que já fizemos muita coisa. A Shizunezinha vai continuar daqui."

# game/script-a2-hanako.rpy:1414
translate pt_br a2_hanako_office_confessional_f6aae81b:

    # mi "So I think we can stop about here then."
    mi "Então acho que já podemos encerrar."

# game/script-a2-hanako.rpy:1416
translate pt_br a2_hanako_office_confessional_4d8ad7cd:

    # "It's almost as if Misha's common sense left the room with Shizune."
    "Quase parece que o bom senso da Misha saiu da sala com a Shizune."

# game/script-a2-hanako.rpy:1418
translate pt_br a2_hanako_office_confessional_85854635:

    # "Still, there's no point in arguing."
    "Ainda assim, não há porque discutir."

# game/script-a2-hanako.rpy:1423
translate pt_br a2_hanako_office_confessional_80090940:

    # mi "Anyway…"
    mi "Enfim…"

# game/script-a2-hanako.rpy:1428
translate pt_br a2_hanako_office_confessional_d046eaa9:

    # mi "What's the deal with you and Hanako?"
    mi "Qual é o negócio entre você e a Hanako?"

# game/script-a2-hanako.rpy:1430
translate pt_br a2_hanako_office_confessional_c4c69de9:

    # hi "Deal?"
    hi "Negócio?"

# game/script-a2-hanako.rpy:1435
translate pt_br a2_hanako_office_confessional_0b860f1f:

    # mi "You were hanging out with her today, weren't you~?"
    mi "Você estava curtindo por aí com ela hoje, não estava~?"

# game/script-a2-hanako.rpy:1440
translate pt_br a2_hanako_office_confessional_d5797188:

    # mi "Have there been any fireworks? Any gossip that you're withholding from me~?"
    mi "Aconteceu alguma coisa? Alguma fofoca que você esteja me escondendo~?"

# game/script-a2-hanako.rpy:1442
translate pt_br a2_hanako_office_confessional_32028d64:

    # hi "If I told you about my own circumstances, it wouldn’t be gossip, would it?"
    hi "Se eu te contasse sobre minhas próprias coisas, não seria fofoca, não é?"

# game/script-a2-hanako.rpy:1447
translate pt_br a2_hanako_office_confessional_146b66f4:

    # mi "I guess not…"
    mi "Acho que não…"

# game/script-a2-hanako.rpy:1449
translate pt_br a2_hanako_office_confessional_1fc1c5e6:

    # hi "We're just friends, I guess."
    hi "Somos apenas amigos, acho."

# game/script-a2-hanako.rpy:1451
translate pt_br a2_hanako_office_confessional_4e5a7f40:

    # hi "Why are you so interested? I thought you and Shizune didn't like her…"
    hi "Por que você está tão interessada? Pensei que você e a Shizune não gostassem dela…"

# game/script-a2-hanako.rpy:1456
translate pt_br a2_hanako_office_confessional_da73ef7b:

    # mi "It's not really like that. You know Shicchan and Lilly don't get along well."
    mi "Não é bem assim. Você sabe que a Shizunezinha e a Lilly não se dão bem."

# game/script-a2-hanako.rpy:1458
translate pt_br a2_hanako_office_confessional_7caac522:

    # mi "And since you can't really get Hanako away from Lilly, we don't talk to her much."
    mi "E já que não dá para separar a Hanako da Lilly, não falamos muito com ela."

# game/script-a2-hanako.rpy:1463
translate pt_br a2_hanako_office_confessional_0c02231f:

    # mi "But that doesn't mean that I can't be concerned for her."
    mi "Mas isso não significa que eu não possa me preocupar com ela."

# game/script-a2-hanako.rpy:1465
translate pt_br a2_hanako_office_confessional_b2bc5141:

    # hi "What is there to be concerned about?"
    hi "E o que há para se preocupar?"

# game/script-a2-hanako.rpy:1470
translate pt_br a2_hanako_office_confessional_0e9584c2:

    # mi "Well, she never hangs out with anyone else, right? It's no good, Hicchan!"
    mi "Bem, ela nunca anda com mais ninguém, né? Isso não é bom, Hisaozinho!"

# game/script-a2-hanako.rpy:1472
translate pt_br a2_hanako_office_confessional_ceee4967:

    # "If Shizune and Lilly dislike each other because 'their personalities are different' then I hate to think how Misha and Hanako would get along…"
    "Se a Shizune e a Lilly não gostam uma da outra porque “suas personalidades são diferentes,” então odeio imaginar como a Misha e a Hanako se dariam…"

# game/script-a2-hanako.rpy:1477
translate pt_br a2_hanako_office_confessional_e16987a6:

    # mi "I mean, in one way or the other, we're all in the same boat here, right~?"
    mi "Quero dizer, de um jeito ou de outro, estamos todos no mesmo barco aqui, certo~?"

# game/script-a2-hanako.rpy:1479
translate pt_br a2_hanako_office_confessional_29f171d3:

    # hi "Well, I guess."
    hi "É, acho que sim."

# game/script-a2-hanako.rpy:1484
translate pt_br a2_hanako_office_confessional_1550e607:

    # mi "This one time, when she left class halfway through, Shicchan went to the teacher and asked what was going to be done about it."
    mi "Teve uma vez que ela saiu da sala na metade da aula e a Shizunezinha foi até ao professor perguntar o que ele estaria fazendo sobre isso."

# game/script-a2-hanako.rpy:1489
translate pt_br a2_hanako_office_confessional_8d5d4975:

    # mi "He said that every student here has special needs, and that Shicchan shouldn't worry herself about it."
    mi "Ele disse que todos os estudantes aqui tem necessidades especiais, e que a Shizunezinha não deveria se preocupar com isso."

# game/script-a2-hanako.rpy:1494
translate pt_br a2_hanako_office_confessional_792f768d:

    # mi "Hanako never does any group work; she just runs off."
    mi "A Hanako nunca faz nenhum trabalho em grupo; ela simplesmente vai embora."

# game/script-a2-hanako.rpy:1496
translate pt_br a2_hanako_office_confessional_da5ad839:

    # mi "Isn't that enough to be concerned about?"
    mi "Isso não é o suficiente para se preocupar?"

# game/script-a2-hanako.rpy:1498
translate pt_br a2_hanako_office_confessional_df3c9971:

    # hi "I guess you're right. She still hardly says a word when we're talking."
    hi "Acho que você tem razão. Ela ainda mal fala quando nós conversamos."

# game/script-a2-hanako.rpy:1503
translate pt_br a2_hanako_office_confessional_9c06efd1:

    # mi "Well, that's more than I have been able to do. Shicchan and I both tried when she started, but she got scared and ran off."
    mi "Bem, isso é mais do que eu jamais consegui fazer. Shizunezinha e eu tentamos quando ela começou aqui, mas ela se assustou e fugiu."

# game/script-a2-hanako.rpy:1505
translate pt_br a2_hanako_office_confessional_f4412218:

    # "I consider telling Misha that exactly the same thing happened with me, but she seems caught up in thought."
    "Eu considero falar para a Misha que o mesmo ocorreu comigo, mas ela parece absorta em sua fala."

# game/script-a2-hanako.rpy:1507
translate pt_br a2_hanako_office_confessional_0ff585fc:

    # "Listening to Misha without Shizune's influence is… interesting."
    "Escutar a Misha sem a influência da Shizune é… interessante."

# game/script-a2-hanako.rpy:1512
translate pt_br a2_hanako_office_confessional_d45bd06d:

    # mi "I think she needs to realize that people here don't care what she looks like, and that she can trust us."
    mi "Acho que ela precisa perceber que as pessoas aqui não se importam com a aparência dela, e que ela pode confiar em nós."

# game/script-a2-hanako.rpy:1517
translate pt_br a2_hanako_office_confessional_7fe248ec:

    # mi "If she could, I'd feel a lot better about her."
    mi "Se ela pudesse, eu me sentiria bem melhor sobre ela."

# game/script-a2-hanako.rpy:1519
translate pt_br a2_hanako_office_confessional_373150f5:

    # "I think this is the longest I have watched Misha without seeing her sign."
    "Acho que essa foi a vez que vi a Misha por mais tempo sem sinalizar."

# game/script-a2-hanako.rpy:1521
translate pt_br a2_hanako_office_confessional_6a997708:

    # "When she's with Shizune, she is constantly waving her hands about, explaining the world to Shizune."
    "Quando ela está com a Shizune, ela está constantemente agitando as mãos, explicando o mundo à Shizune."

# game/script-a2-hanako.rpy:1523
translate pt_br a2_hanako_office_confessional_847c37fc:

    # "That amount of effort probably places a strain even on an agile mind."
    "Todo esse esforço é provavelmente demais até para uma mente ágil."

# game/script-a2-hanako.rpy:1525
translate pt_br a2_hanako_office_confessional_d70abca6:

    # "And let's face it; Misha isn't the world's brightest spark."
    "E falemos a verdade; a Misha não é a mente mais brilhante do mundo."

# game/script-a2-hanako.rpy:1527
translate pt_br a2_hanako_office_confessional_482f0482:

    # hi "Well, I'll keep an eye on her for you."
    hi "Bem, vou manter um olho nela pra você."

# game/script-a2-hanako.rpy:1529
translate pt_br a2_hanako_office_confessional_981c405b:

    # hi "But you should probably apologize for earlier. I don't think Hanako is cut out for that kind of joke."
    hi "Mas você deveria se desculpar por hoje. Não acho que a Hanako seja do tipo que gosta daquele tipo de brincadeira."

# game/script-a2-hanako.rpy:1534
translate pt_br a2_hanako_office_confessional_52309b36:

    # mi "Oh? Oh~!"
    mi "Ah? Ah~!"

# game/script-a2-hanako.rpy:1539
translate pt_br a2_hanako_office_confessional_73d6dd20:

    # mi "I didn't even notice. Sorry."
    mi "Eu nem percebi. Desculpa."

# game/script-a2-hanako.rpy:1541
translate pt_br a2_hanako_office_confessional_3bc4f41d:

    # hi "Don't say it to me, just mention it to her."
    hi "Não diga isso pra mim, apenas mencione a ela."

# game/script-a2-hanako.rpy:1546
translate pt_br a2_hanako_office_confessional_1ced0beb:

    # mi "All right. First thing tomorrow, I'll speak to her."
    mi "Certo. Vai ser a primeira coisa que farei amanhã."

# game/script-a2-hanako.rpy:1548
translate pt_br a2_hanako_office_confessional_c71898a4:

    # hi "Good."
    hi "Bom."

# game/script-a2-hanako.rpy:1553
translate pt_br a2_hanako_office_confessional_d7bfe8e2:

    # "A cacophony from the door heralds the return of Shizune."
    "Uma série de ruídos da porta anuncia o retorno da Shizune."

# game/script-a2-hanako.rpy:1555
translate pt_br a2_hanako_office_confessional_dd04e09c:

    # "I guess she can't really tell how much noise she is making."
    "Acho que ela não consegue perceber quanto barulho está fazendo."

# game/script-a2-hanako.rpy:1560
translate pt_br a2_hanako_office_confessional_7835761b:

    # mi "Oh, Shicchan! You're back!"
    mi "Ah, Shizunezinha Você voltou!"

# game/script-a2-hanako.rpy:1573
translate pt_br a2_hanako_office_confessional_56815d1b:

    # "Shizune appears, completely laden with goods from the convenience store."
    "Shizune aparece, completamente carregada com artigos da loja de conveniência."

# game/script-a2-hanako.rpy:1578
translate pt_br a2_hanako_office_confessional_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1583
translate pt_br a2_hanako_office_confessional_61ab1cd7:

    # mi "There was some surplus left from the festival. Since this is officially festival business, I've splurged a little."
    mi "Teve um pouco de superávit sobrando do festival. Já que isto são negócios do festival, gastei um pouco."

# game/script-a2-hanako.rpy:1588
translate pt_br a2_hanako_office_confessional_1851ac7f:

    # mi "Nice idea Shicchan, ten points."
    mi "Ótima ideia, Shizunezinha, dez pontos."

# game/script-a2-hanako.rpy:1590
translate pt_br a2_hanako_office_confessional_78f06e0c:

    # hi "Is that really allowed?"
    hi "Isso é realmente permitido?"

# game/script-a2-hanako.rpy:1595
translate pt_br a2_hanako_office_confessional_ef2b123c_2:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1600
translate pt_br a2_hanako_office_confessional_12e1ee83:

    # mi "For someone who refuses to join us, you seem to take an unhealthy interest in the politics of this council."
    mi "Para alguém que se recusa a ingressar, você parece exageradamente interessado nas políticas deste Conselho."

# game/script-a2-hanako.rpy:1606
translate pt_br a2_hanako_office_confessional_fe99fe77:

    # mi "I shall punish your insolence by rationing your portion of the feast."
    mi "Devo punir sua insolência racionando sua porção do banquete."

# game/script-a2-hanako.rpy:1608
translate pt_br a2_hanako_office_confessional_16c9516d:

    # hi "Fine, fine, I get it."
    hi "Beleza, beleza, já entendi."

# game/script-a2-hanako.rpy:1615
translate pt_br a2_hanako_office_confessional_dc0f00ad:

    # "Misha slides the multiple stacks of paper to one side to make room for the avalanche of food Shizune is spreading out."
    "Misha empurra as múltiplas pilhas de papel para o lado para dar espaço à avalanche de comida que a Shizune está espalhando."

# game/script-a2-hanako.rpy:1617
translate pt_br a2_hanako_office_confessional_205e4391:

    # "As I watch my hard yet misdirected work become wasted, I realize that it's little wonder why these two need help."
    "Assistindo meu duro porém mal dirigido trabalho sendo perdido, eu percebo que não é de se estranhar que essas duas precisem de ajuda."

# game/script-a2-hanako.rpy:1619
translate pt_br a2_hanako_office_confessional_204fa05a:

    # "The convenience store meal isn't overly tasty, but at the very least it's filling."
    "A comida da loja de conveniência não é muito saborosa, mas pelo menos enche bem."

# game/script-a2-hanako.rpy:1624
translate pt_br a2_hanako_office_confessional_ef2b123c_3:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1629
translate pt_br a2_hanako_office_confessional_347d46dd:

    # mi "Thanks for helping today. Most of the time we just make up the reports for the staff."
    mi "Obrigado por ajudar hoje. A maior parte do tempo, apenas fazemos relatórios para os funcionários."

# game/script-a2-hanako.rpy:1634
translate pt_br a2_hanako_office_confessional_e6bb266f:

    # mi "This year we can at least make up some relevant headings on the debrief."
    mi "Este ano podemos ao menos fazer uns cabeçalhos relevantes para os relatórios."

# game/script-a2-hanako.rpy:1636
translate pt_br a2_hanako_office_confessional_6459194e:

    # hi "Are you sure this isn't a corrupt organization?"
    hi "Vocês tem certeza que esta não é uma organização corrupta?"

# game/script-a2-hanako.rpy:1641
translate pt_br a2_hanako_office_confessional_12e2d68d:

    # mi "Not at all, not at all. We're by the book. It's not our fault if the book isn't specific enough."
    mi "De jeito nenhum, de jeito nenhum. Estamos seguindo à risca. Não é nossa culpa se as regras não são específicas o bastante."

# game/script-a2-hanako.rpy:1643
translate pt_br a2_hanako_office_confessional_487669db:

    # hi "I thought that was the definition of corruption…"
    hi "Pensei que essa era a definição de corrupção…"

# game/script-a2-hanako.rpy:1648
translate pt_br a2_hanako_office_confessional_b9c451e0:

    # mi "You think too much~!"
    mi "Você pensa demais~!"

# game/script-a2-hanako.rpy:1650
translate pt_br a2_hanako_office_confessional_3112c944:

    # hi "You know what? You're probably right."
    hi "Sabe do que mais? Você provavelmente tem razão."

# game/script-a2-hanako.rpy:1652
translate pt_br a2_hanako_office_confessional_ffccc655:

    # hi "Anyway, I must be off…"
    hi "Enfim, preciso ir…"

# game/script-a2-hanako.rpy:1654
translate pt_br a2_hanako_office_confessional_3295eace:

    # hi "…that is, if I'm allowed to leave."
    hi "…quer dizer, se me for permitido."

# game/script-a2-hanako.rpy:1659
translate pt_br a2_hanako_office_confessional_ef2b123c_4:

    # shi "…"
    shi "…"

# game/script-a2-hanako.rpy:1664
translate pt_br a2_hanako_office_confessional_379aa510:

    # mi "Your work has been deemed sufficient. You may leave."
    mi "Seu trabalho foi julgado suficiente. Você pode ir."

# game/script-a2-hanako.rpy:1666
translate pt_br a2_hanako_office_confessional_8d59115b:

    # hi "Well, thank you."
    hi "Bem, obrigado."

# game/script-a2-hanako.rpy:1668
translate pt_br a2_hanako_office_confessional_d7f9fe28:

    # hi "You know, if you stressed the 'free meal' side of things over the 'endless workload' side, you'd probably end up with more recruits."
    hi "Sabe, se vocês salientassem a parte da “refeição grátis” acima da “pilhas de trabalho infinitas”, vocês provavelmente acabariam com mais recrutas."

# game/script-a2-hanako.rpy:1678
translate pt_br a2_hanako_office_confessional_335486cb:

    # mi "You might just have a point."
    mi "Faz algum sentido."

# game/script-a2-hanako.rpy:1680
translate pt_br a2_hanako_office_confessional_7a4cba29:

    # hi "Well, think about it."
    hi "Pense sobre isso."

# game/script-a2-hanako.rpy:1682
translate pt_br a2_hanako_office_confessional_3e9e6a14:

    # hi "And think about what we talked about… you don't have to tell that to Shizune if you don't want."
    hi "E pense sobre o que conversamos… você não precisa contar à Shizune se não quiser."

# game/script-a2-hanako.rpy:1687
translate pt_br a2_hanako_office_confessional_a44c1641:

    # mi "What? Oh, right. I'll try to see her tomorrow."
    mi "O quê? Ah, sim. Vou tentar vê-la amanhã."

# game/script-a2-hanako.rpy:1692
translate pt_br a2_hanako_office_confessional_d28e2228:

    # mi "G'night, Hicchan."
    mi "Boa noite, Hisaozinho."

# game/script-a2-hanako.rpy:1694
translate pt_br a2_hanako_office_confessional_18a0dcca:

    # hi "Night Misha, Shizune."
    hi "Boa noite, Misha, Shizune."

# game/script-a2-hanako.rpy:1711
translate pt_br a2_hanako_chess_and_slides_444a09e5:

    # hi "Hey, Shizune. I know I said I'd help, but I forgot I'd already made plans. Besides, I helped out more than my fair share last week, didn't I?"
    hi "Ei, Shizune. Eu sei que disse que ajudaria, mas esqueci que já tinha feito planos. Além disso, já fiz mais do que minha parte semana passada, não foi?"

# game/script-a2-hanako.rpy:1713
translate pt_br a2_hanako_chess_and_slides_7aecd9d3:

    # hi "I promise I'll make it up to you some other time."
    hi "Prometo que vou compensar por isso numa outra oportunidade."

# game/script-a2-hanako.rpy:1727
translate pt_br a2_hanako_chess_and_slides_35d80ebb:

    # "Shizune and Misha release their grip on me and have a long, deep, and silent conversation."
    "Shizune e Misha me liberam do seu aperto e tem uma longa, profunda e silenciosa conversa."

# game/script-a2-hanako.rpy:1732
translate pt_br a2_hanako_chess_and_slides_e965de2c:

    # mi "Well, you have a point there. To be honest, we were only going to spend the rest of the budget on cakes."
    mi "Bem, você tem alguma razão. Pra ser honesta, iríamos apenas gastar o resto do orçamento em bolos."

# game/script-a2-hanako.rpy:1737
translate pt_br a2_hanako_chess_and_slides_889c04bd:

    # mi "So, if you're not there, it works out better. More cake for us. Wahahaha~!"
    mi "Então, se você não for, melhor. Mais bolo para nós. Wahahaha~!"

# game/script-a2-hanako.rpy:1750
translate pt_br a2_hanako_chess_and_slides_17b98826:

    # "Shizune about-faces and marches out the door, and Misha skips out after her."
    "Shizune dá meia volta e marcha pela porta, e Misha salta atrás dela."

# game/script-a2-hanako.rpy:1752
translate pt_br a2_hanako_chess_and_slides_aa9e09d2:

    # hi "Well, that was a lot easier than I thought it was going to be. Last week those two were like bloodhounds. Or prison guards."
    hi "Bem, isso foi muito mais fácil do que pensei que seria. Semana passada essas duas estavam como cães de caça. Ou guardas de prisão."

# game/script-a2-hanako.rpy:1754
translate pt_br a2_hanako_chess_and_slides_2a6e78bf:

    # hi "Or maybe prison guards bred from bloodhounds…"
    hi "Ou talvez guardas de prisão gerados por cães de caça…"

# game/script-a2-hanako.rpy:1756
translate pt_br a2_hanako_chess_and_slides_e8ab1114:

    # "I can't believe I just thought that, let alone saying it out loud. I think I need to move away from Kenji."
    "Não acredito que disse isso, quanto mais que falei isso em voz alta. Acho que preciso me afastar do Kenji."

# game/script-a2-hanako.rpy:1758
translate pt_br a2_hanako_chess_and_slides_89423cc5:

    # hi "…Never mind. Anyway, should we go to the library?"
    hi "…Deixa pra lá. Enfim, vamos à biblioteca?"

# game/script-a2-hanako.rpy:1763
translate pt_br a2_hanako_chess_and_slides_ff70d1cd:

    # ha "S-sure."
    ha "V-vamos."

# game/script-a2-hanako.rpy:1771
translate pt_br a2_hanako_chess_and_slides_b0b636f6:

    # "Hanako follows me through the still-crowded halls to the library, using me as a shield."
    "Hanako me segue através dos corredores ainda lotados até a biblioteca, me usando como escudo."

# game/script-a2-hanako.rpy:1784
translate pt_br a2_hanako_chess_and_slides_ac990948:

    # "As soon as we are through the door, Hanako bolts for the counter, where Yuuko is stacking books."
    "Assim que passamos pela porta, Hanako dispara até o balcão, onde a Yuuko está empilhando livros."

# game/script-a2-hanako.rpy:1789
translate pt_br a2_hanako_chess_and_slides_e4fdd64f:

    # "Before I can catch up, Hanako has whispered something to her."
    "Antes que eu possa alcançá-la, a Hanako já cochichou algo para ela."

# game/script-a2-hanako.rpy:1794
translate pt_br a2_hanako_chess_and_slides_bce8c889:

    # yu "Um, you'd find that in non-fiction, but I don't know where, exactly. If you want I can look it up…"
    yu "Hm, você pode achar isso na parte de não-ficção, mas não sei exatamente onde. Se você quiser posso procurar…"

# game/script-a2-hanako.rpy:1799
translate pt_br a2_hanako_chess_and_slides_22b7fec0:

    # ha "N-never mind."
    ha "D-deixa pra lá."

# game/script-a2-hanako.rpy:1801
translate pt_br a2_hanako_chess_and_slides_228fbb81:

    # hi "Hey Yuuko, what's all this about?"
    hi "Ei, Yuuko, sobre o que é tudo isso?"

# game/script-a2-hanako.rpy:1806
translate pt_br a2_hanako_chess_and_slides_1a474a3c:

    # yu "Oh, Hisao… Hanako was just looking for a book on…"
    yu "Oh, Hisao… A Hanako estava apenas buscando um livro sobre…"

# game/script-a2-hanako.rpy:1811
translate pt_br a2_hanako_chess_and_slides_631a96af:

    # ha "N-nothing…"
    ha "N-nada…"

# game/script-a2-hanako.rpy:1813
translate pt_br a2_hanako_chess_and_slides_554acfd2:

    # hi "A book on nothing? In the non-fiction section?"
    hi "Um livro sobre nada? Na seção de não-ficção?"

# game/script-a2-hanako.rpy:1818
translate pt_br a2_hanako_chess_and_slides_b85036dd:

    # ha "I… I was just…"
    ha "Eu… eu estava apenas…"

# game/script-a2-hanako.rpy:1823
translate pt_br a2_hanako_chess_and_slides_8c153558:

    # "I shoot a glance at Yuuko. She looks like she's about to burst from the pressure of keeping Hanako's request secret."
    "Eu atiro um olhar para a Yuuko. Ela parece estar a ponto de explodir sob a pressão de manter o pedido da Hanako secreto."

# game/script-a2-hanako.rpy:1825
translate pt_br a2_hanako_chess_and_slides_a1444200:

    # hi "Yuuko, what did…"
    hi "Yuuko, o que…"

# game/script-a2-hanako.rpy:1830
translate pt_br a2_hanako_chess_and_slides_a35342ac:

    # yu "Chess! She's looking for a chess book!"
    yu "Xadrez! Ela está procurando por um livro sobre xadrez!"

# game/script-a2-hanako.rpy:1832
translate pt_br a2_hanako_chess_and_slides_d080932a:

    # "I make a mental note to never entrust Yuuko with any important information."
    "Eu faço uma nota mental para nunca confiar nenhuma informação importante à Yuuko."

# game/script-a2-hanako.rpy:1837
translate pt_br a2_hanako_chess_and_slides_14302e29:

    # ha "Y-Yuuko…"
    ha "Y-Yuuko…"

# game/script-a2-hanako.rpy:1842
translate pt_br a2_hanako_chess_and_slides_220c1d79:

    # yu "I'm sorry Hanako… it just slipped out…"
    yu "Desculpa, Hanako… me escapou…"

# game/script-a2-hanako.rpy:1844
translate pt_br a2_hanako_chess_and_slides_98e346fb:

    # hi "Well, it's not a secret any more. Come on, I'll give you a hand. I should really brush up on my skills, too."
    hi "Bem, não é mais segredo. Venha, te dou uma ajuda. Eu também preciso melhorar minhas habilidades."

# game/script-a2-hanako.rpy:1849
translate pt_br a2_hanako_chess_and_slides_c6454212:

    # ha "O… okay."
    ha "O… ok."

# game/script-a2-hanako.rpy:1858
translate pt_br a2_hanako_chess_and_slides_68a2319b:

    # "Yuuko disappears behind the counter in shame as Hanako and I wander into the depths of the non-fiction section."
    "Yuuko desaparece atrás do balcão de vergonha enquanto a Hanako e eu vagamos pelas profundezas da seção de não-ficção."

# game/script-a2-hanako.rpy:1860
translate pt_br a2_hanako_chess_and_slides_e96ba036:

    # "I know there is supposed to be a system for categorizing these books, but I don't see how anyone can decipher it without spending half of their life researching it."
    "Eu sei que deveria haver um sistema para categorizar esses livros, mas não consigo imaginar como alguém poderia decifrá-lo sem gastar metade da sua minha vida nele."

# game/script-a2-hanako.rpy:1862
translate pt_br a2_hanako_chess_and_slides_059633e4:

    # "That's probably why all the librarians I know are neurotic."
    "Deve ser por isso que todos os bibliotecários que conheço são neuróticos."

# game/script-a2-hanako.rpy:1864
translate pt_br a2_hanako_chess_and_slides_562360bb:

    # "Towards the end of the aisle, between a book on card tricks and some book on kid's games, stands a single book bearing the title 'Chess Tactics for Champions'."
    "Perto do fim do corredor, entre um livro sobre truques com cartas e um sobre jogos infantis, está um livro que carrega o título de “Táticas de Xadrez para Campeões”."

# game/script-a2-hanako.rpy:1869
translate pt_br a2_hanako_chess_and_slides_30cddeef:

    # "Before I can reach for it, Hanako has the book in her hands, clutching it to her chest."
    "Antes que eu possa estender a mão para pegá-lo, Hanako já o tem em mãos, apertando-o contra o peito."

# game/script-a2-hanako.rpy:1871
translate pt_br a2_hanako_chess_and_slides_b2a4f0f7:

    # hi "Well, I guess that's yours then. Mind if I borrow it when you're finished?"
    hi "É, acho que é seu então. Se importa se eu pegar emprestado quando você terminar?"

# game/script-a2-hanako.rpy:1876
translate pt_br a2_hanako_chess_and_slides_9c6b1660:

    # ha "S-sure. I… I just haven't really played against anyone but L-Lilly before, so I thought…"
    ha "N-não. É que… eu não tinha jogado contra ninguém além da L-Lilly antes, então pensei…"

# game/script-a2-hanako.rpy:1878
translate pt_br a2_hanako_chess_and_slides_40c9f34e:

    # "Damn. It's not like I was trying to beat Hanako deliberately or anything, but she seems to have taken it to heart."
    "Droga. Eu nem estava tentando vencer a Hanako deliberadamente ou nada do tipo, mas parece que isso realmente a marcou."

# game/script-a2-hanako.rpy:1880
translate pt_br a2_hanako_chess_and_slides_56d62937:

    # "Then again, at least this means she wants to play me again. That's a plus, right?"
    "Em todo caso, pelo menos isso quer dizer que ela quer jogar contra mim de novo. Isso é bom, certo?"

# game/script-a2-hanako.rpy:1882
translate pt_br a2_hanako_chess_and_slides_bc8460eb:

    # hi "Ha, well it's not like I'm a master or anything; I just played a bit before…"
    hi "Ha, não sou nenhum mestre nem nada; só já tinha jogado um pouco antes do…"

# game/script-a2-hanako.rpy:1884
translate pt_br a2_hanako_chess_and_slides_31f5d59b:

    # "It occurs to me that I haven't told Hanako about my condition. I falter for a second, deciding to cover my tracks. That is a conversation for another day."
    "Me ocorre que ainda não contei à Hanako sobre minha condição. Eu vacilo por um instante, decidindo não dar bandeira. Essa é uma conversa para um outro dia."

# game/script-a2-hanako.rpy:1886
translate pt_br a2_hanako_chess_and_slides_c5b87b56:

    # hi "…before I came here."
    hi "…antes de eu vir para cá."

# game/script-a2-hanako.rpy:1893
translate pt_br a2_hanako_chess_and_slides_ad5d9a65:

    # ha "Are… are you all right?"
    ha "T… tá tudo bem?"

# game/script-a2-hanako.rpy:1895
translate pt_br a2_hanako_chess_and_slides_3e727585:

    # hi "Yeah, I was just remembering something…"
    hi "Sim, só estava lembrando algo…"

# game/script-a2-hanako.rpy:1897
translate pt_br a2_hanako_chess_and_slides_d7b2012f:

    # "When I think about it, I shouldn't be afraid to tell Hanako about my condition and my time in the hospital. Judging by her scars, she probably spent a fair amount of time in a hospital bed."
    "Pensando bem, eu não deveria ter medo de contar sobre a minha condição e a minha permanência no hospital para a Hanako. Julgando pelas cicatrizes dela, ela provavelmente passou um bom tempo em uma cama de hospital."

# game/script-a2-hanako.rpy:1899
translate pt_br a2_hanako_chess_and_slides_4f50a563:

    # "But, for some reason, I can't bring it up. At least not today, and not on short notice."
    "Mas, por alguma razão, não consigo falar sobre isso. Pelo menos não hoje, e não assim, do nada."

# game/script-a2-hanako.rpy:1901
translate pt_br a2_hanako_chess_and_slides_87bb079e:

    # "Eager to break off the conversation, I grab a random book from the shelf."
    "Ansioso para encerrar a conversa, agarro um livro qualquer da estante."

# game/script-a2-hanako.rpy:1903
translate pt_br a2_hanako_chess_and_slides_c71dd0ea:

    # "It's some book on the world's fastest roller coasters…"
    "É um livro sobre as montanhas-russas mais rápidas do mundo…"

# game/script-a2-hanako.rpy:1905
translate pt_br a2_hanako_chess_and_slides_5a3ae132:

    # "…published in 1982. Well, not very up to date, but it should at least be interesting."
    "…publicado em 1982. Bem, não muito atualizado, mas deve ser interessante."

# game/script-a2-hanako.rpy:1907
translate pt_br a2_hanako_chess_and_slides_44ae7593:

    # hi "Well, we both got books now, should we go sit down?"
    hi "Nós dois temos livros agora, vamos nos sentar?"

# game/script-a2-hanako.rpy:1912
translate pt_br a2_hanako_chess_and_slides_605a276e:

    # "Hanako seems to accept my bluff, and we head to the reading nook in the back of the library."
    "Hanako parece aceitar meu blefe, e nos dirigimos para o recanto de leitura na parte de trás da biblioteca."

# game/script-a2-hanako.rpy:1917
translate pt_br a2_hanako_chess_and_slides_6ffa268a:

    # "Neither of us says a word; we simply open our books and start reading."
    "Nenhum de nós diz uma palavra; simplesmente abrimos nossos livros e começamos a ler."

# game/script-a2-hanako.rpy:1919
translate pt_br a2_hanako_chess_and_slides_39a89710:

    # "I try to read my book, but it would seem that in 1982 roller coasters weren't nearly as large as the ones built in the decades since."
    "Eu tento ler meu livro, mas parece que em 1982 as montanhas russas não eram tão grandes quanto as que foram construídas desde então."

# game/script-a2-hanako.rpy:1921
translate pt_br a2_hanako_chess_and_slides_080cedd7:

    # "Most of the ones listed are made of wood. Something about that doesn't seem safe to me."
    "A maioria das listadas são feitas de madeira. Algo que não perece seguro para mim."

# game/script-a2-hanako.rpy:1923
translate pt_br a2_hanako_chess_and_slides_c8c332f3:

    # "If I'm going to ride on something potentially dangerous, I want it to be made out of steel, or some kind of space-age alloy that has big words like 'Titanium' and 'Ruthenium'."
    "Se eu vou andar em algo potencialmente perigoso, quero que seja feito de aço, ou algum tipo de liga da era espacial que tenha palavras imponentes como “titânio” e “rutênio”."

# game/script-a2-hanako.rpy:1925
translate pt_br a2_hanako_chess_and_slides_2fd33234:

    # "I quickly lose interest, and my eyes wander across the reading area to rest on Hanako."
    "Perco rapidamente o interesse e meus olhos vagam pela área de leitura para repousar na Hanako."

# game/script-a2-hanako.rpy:1932
translate pt_br a2_hanako_chess_and_slides_40108196:

    # "Hanako seems absorbed in her book, flicking back and forth through the pages, as if confirming what she just read."
    "Hanako parece absorvida em seu livro, indo de um lado para o outro através das páginas, como se confirmando o que acabou de ler."

# game/script-a2-hanako.rpy:1934
translate pt_br a2_hanako_chess_and_slides_ef1195ee:

    # "I wonder if that's actually effective, or if she's just overloading herself."
    "Me pergunto se isso é realmente efetivo, ou se ela está apenas se sobrecarregando."

# game/script-a2-hanako.rpy:1936
translate pt_br a2_hanako_chess_and_slides_9d0ed266:

    # "She unconsciously brushes her hair from her face, temporarily revealing her scar tissue."
    "Sem dar por si, ela arruma o cabelo para fora do rosto, temporariamente revelando seu tecido cicatricial."

# game/script-a2-hanako.rpy:1938
translate pt_br a2_hanako_chess_and_slides_799f961a:

    # "I'm still not sure about the protocol here. Is it right to ask her about her scars? Or her past? How long was she in the hospital? Does she still visit the doctor?"
    "Ainda não tenho certeza sobre o protocolo aqui. É correto perguntar a ela sobre suas cicatrizes? Ou seu passado? Quanto tempo ela ficou no hospital? Ela ainda visita o médico?"

# game/script-a2-hanako.rpy:1940
translate pt_br a2_hanako_chess_and_slides_321f234a:

    # "These all seem like the questions that you'd ask someone who just transferred to your school, translated into the local language."
    "Todas essas parecem questões que você faria para alguém que acabou de ser transferido para sua escola, traduzindo para a linguagem local."

# game/script-a2-hanako.rpy:1942
translate pt_br a2_hanako_chess_and_slides_e8b533cb:

    # "But, to date, no one has directly asked me any of them. Well, except Rin, but I don't think I should use her as a guide to proper social behavior."
    "Mas, até agora, ninguém me perguntou diretamente sobre nenhuma delas. Bem, menos a Rin, mas não acho que eu deveria usá-la como guia de comportamento social adequado."

# game/script-a2-hanako.rpy:1944
translate pt_br a2_hanako_chess_and_slides_61faf26e:

    # "For the time being, I'll just keep my mouth shut. If someone wants you to know something, then they'll tell you. Trying to force the issue might drive Hanako back into herself."
    "Por enquanto, apenas me manterei calado. Se alguém quiser que você saiba de algo, te dirá. Tentar forçar essa questão pode fazer a Hanako recuar de novo."

# game/script-a2-hanako.rpy:1950
translate pt_br a2_hanako_chess_and_slides_c9548257:

    # yu "Um… sorry to interrupt, but I have to close the library now."
    yu "Ahn… desculpe interromper, mas preciso fechar a biblioteca agora."

# game/script-a2-hanako.rpy:1954
translate pt_br a2_hanako_chess_and_slides_1020d84c:

    # hi "Already?"
    hi "Já?"

# game/script-a2-hanako.rpy:1956
translate pt_br a2_hanako_chess_and_slides_9b0f671d:

    # "I check my watch. Somehow, as I was lost in thought, nearly two hours have passed."
    "Eu checo meu relógio. De algum modo, enquanto eu estava imerso em pensamentos, quase duas horas passaram."

# game/script-a2-hanako.rpy:1961
translate pt_br a2_hanako_chess_and_slides_289bc7c5:

    # yu "Do you want to check out those books? I can do it on the way out…"
    yu "Querem levar esses livros? Posso checá-los na saída…"

# game/script-a2-hanako.rpy:1977
translate pt_br a2_hanako_chess_and_slides_d3e20edf:

    # ha "P-please."
    ha "P-por favor."

# game/script-a2-hanako.rpy:1979
translate pt_br a2_hanako_chess_and_slides_01d2e274:

    # hi "I'm done. I'll drop this one back on the way through. It wasn't as interesting as I first thought."
    hi "Eu já terminei. Vou colocar este de volta. Não era tão interessante quanto pensei."

# game/script-a2-hanako.rpy:1984
translate pt_br a2_hanako_chess_and_slides_7d2666f6:

    # "Hanako marks her place with a slip of paper and stands up. The girls head to the counter and I return my book to what I think is the right shelf."
    "Hanako marca sua leitura com um pedaço de papel e se levanta. As garotas se dirigem ao balcão e eu devolvo meu livro para o que acredito ser sua estante certa."

# game/script-a2-hanako.rpy:1989
translate pt_br a2_hanako_chess_and_slides_f1753953:

    # "Yuuko scans Hanako's book with practiced precision, yet still manages to fumble it."
    "Yuuko escaneia o livro da Hanako com precisão praticada, mas ainda assim consegue se atrapalhar um pouco."

# game/script-a2-hanako.rpy:1994
translate pt_br a2_hanako_chess_and_slides_8fb26f12:

    # yu "Oh… there we go. Third time lucky. Since this is a non-fiction book, you can only have it for a week."
    yu "Ah… aqui vamos nós. Melhor sorte na próxima. Já que é um livro de não-ficção, você só pode ficar com ele por uma semana."

# game/script-a2-hanako.rpy:1999
translate pt_br a2_hanako_chess_and_slides_cf84b514:

    # ha "T-that's okay."
    ha "T-tá bem."

# game/script-a2-hanako.rpy:2004
translate pt_br a2_hanako_chess_and_slides_824a78b4:

    # "Yuuko shuts down the library's computer and herds us out the door."
    "Yuuko sai do computador da biblioteca e nos leva até a porta."

# game/script-a2-hanako.rpy:2010
translate pt_br a2_hanako_chess_and_slides_19536bae:

    # yu "Argh! I didn't think it was this late already…!"
    yu "Argh! Não sabia que já estava tão tarde…!"

# game/script-a2-hanako.rpy:2012
translate pt_br a2_hanako_chess_and_slides_2e2644cf:

    # hi "But you're the one that told us you had to close…"
    hi "Mas foi você que nos disse que precisava fechar…"

# game/script-a2-hanako.rpy:2017
translate pt_br a2_hanako_chess_and_slides_d8a6afb8:

    # yu "Yes but, I know but, that was before I looked at the time!"
    yu "Sim, mas… eu sei, mas, aquilo foi antes de eu ver que horas são!"

# game/script-a2-hanako.rpy:2022
translate pt_br a2_hanako_chess_and_slides_d1ddae7a:

    # yu "I'll see you later."
    yu "Vejo vocês depois."

# game/script-a2-hanako.rpy:2029
translate pt_br a2_hanako_chess_and_slides_dfef6bc2:

    # "Yuuko bolts down the hall, her handbag trailing behind her like an awkward streamer."
    "Yuuko dispara pelo corredor, com sua bolsa balançando atrás dela como uma bandeirola desajeitada."

# game/script-a2-hanako.rpy:2035
translate pt_br a2_hanako_chess_and_slides_a9510b03:

    # hi "I guess all librarians really are neurotic."
    hi "Acho que todos os bibliotecários são mesmo neuróticos."

# game/script-a2-hanako.rpy:2040
translate pt_br a2_hanako_chess_and_slides_0aeaefef:

    # ha "Huh?"
    ha "Hã?"

# game/script-a2-hanako.rpy:2042
translate pt_br a2_hanako_chess_and_slides_3249095e:

    # hi "Ah, never mind. I was just thinking that I've never met a librarian that can organize their time, no matter how good they are with their books."
    hi "Ah, esquece. Estava apenas pensando em como nunca encontrei um bibliotecário que conseguisse organizar seu tempo, não importa o quão bons sejam com os livros."

# game/script-a2-hanako.rpy:2047
translate pt_br a2_hanako_chess_and_slides_97c4e29b:

    # ha "Oh… I k-know what you mean…"
    hi "Ah, esquece. Estava apenas pensando em como nunca encontrei um bibliotecário que conseguisse organizar seu tempo, não importa o quão bons sejam com os livros."

# game/script-a2-hanako.rpy:2049
translate pt_br a2_hanako_chess_and_slides_215b5fdb:

    # "Hanako smiles in amusement. It wasn't meant to be a joke, but I must have reminded her of some other librarian… or something…"
    "Hanako sorri divertidamente. Não era para ser uma piada, mas acho que isso deve tê-la lembrado de algum outro bibliotecario ou algo do tipo…"

# game/script-a2-hanako.rpy:2054
translate pt_br a2_hanako_chess_and_slides_6da4aa5c:

    # ha "I… I have to get back."
    ha "E… eu preciso ir voltando."

# game/script-a2-hanako.rpy:2056
translate pt_br a2_hanako_chess_and_slides_cba86884:

    # hi "Yeah, me too. I didn't realize it was this late. Thanks for letting me hang out with you."
    hi "É, eu também. Não percebi que já estava tão tarde. Obrigado por me deixar te fazer companhia."

# game/script-a2-hanako.rpy:2061
translate pt_br a2_hanako_chess_and_slides_fc223126:

    # ha "N-no problem."
    ha "S-sem problemas."

# game/script-a2-hanako.rpy:2063
translate pt_br a2_hanako_chess_and_slides_3c0c25b1:

    # hi "I'm going to my dormitory room now anyway, so do you mind if I tag along?"
    hi "Estou indo para o meu dormitório também, então se importa se eu for andando com você?"

# game/script-a2-hanako.rpy:2068
translate pt_br a2_hanako_chess_and_slides_57db572d:

    # ha "O-okay."
    ha "O-ok."

# game/script-a2-hanako.rpy:2073
translate pt_br a2_hanako_chess_and_slides_db742ec9:

    # "Hanako sets off ahead of me, and I need to jog a little to reach her side."
    "Hanako parte antes de mim, e eu preciso dar uma corrida para alcançar o seu lado."

# game/script-a2-hanako.rpy:2081
translate pt_br a2_hanako_chess_and_slides_615fb524:

    # "We walk through the gardens, eventually arriving in front of the dorm buildings."
    "Andamos pelos jardins, eventualmente chegando em frente aos dormitórios."

# game/script-a2-hanako.rpy:2083
translate pt_br a2_hanako_chess_and_slides_9cbd5aef:

    # hi "Man, you walk pretty fast. I used to play in a soccer club, and you manage to outpace me."
    hi "Cara, você anda muito rápido. Eu costumava fazer parte de um clube de futebol, e você conseguiu me ultrapassar."

# game/script-a2-hanako.rpy:2090
translate pt_br a2_hanako_chess_and_slides_b10ce9d3:

    # "I kinda regret saying that. It has less to do with her pace than with the fact that my condition has significantly worsened my fitness."
    "Eu me arrependo um pouco de ter dito isso. Tem menos a ver com o passo dela do que com o fato de que a minha condição piorou significativamente minha aptidão física."

# game/script-a2-hanako.rpy:2092
translate pt_br a2_hanako_chess_and_slides_9ca065d7:

    # "Hanako's reaction is odd. I expected an awkward attempt to downplay her walking speed, but she just blushes while looking at her feet and smiling."
    "A reação da Hanako é estranha. Eu esperava uma tentativa sem jeito de menosprezar sua própria velocidade, mas ela apenas fica vermelha enquanto olha para os pés e sorri."

# game/script-a2-hanako.rpy:2094
translate pt_br a2_hanako_chess_and_slides_eb0bf453:

    # "Silence hangs in the air between us. That happens often around Hanako, but feels slightly different than usual this time. After a few seconds, I try to break the silence."
    "Silêncio paira no ar entre nós. Acontece muito com a Hanako, mas parece um pouco diferente do normal desta vez. Depois de alguns segundos, tento quebrar o silêncio."

# game/script-a2-hanako.rpy:2096
translate pt_br a2_hanako_chess_and_slides_76803acd:

    # hi "Here you go. See you in class tomorrow?"
    hi "Aqui estamos. Te vejo na aula amanhã?"

# game/script-a2-hanako.rpy:2101
translate pt_br a2_hanako_chess_and_slides_ff70d1cd_1:

    # ha "S-sure."
    ha "S-sim."

# game/script-a2-hanako.rpy:2106
translate pt_br a2_hanako_chess_and_slides_e23cd0e9:

    # "Hanako waves a short goodbye before pushing her way through the dorm's doors. I stand and look at them for a while, before making my way to my own dormitory room."
    "Hanako acena brevemente em despedida antes de completar seu caminho através da porta do dormitório. Eu fico parado olhando para ela por um tempo, antes de seguir para meu quarto também."

# game/script-a2-hanako.rpy:2120
translate pt_br a2_hanako_rise_and_shine_d60ddb48:

    # "Chirping birds."
    "Pássaros cantando."

# game/script-a2-hanako.rpy:2122
translate pt_br a2_hanako_rise_and_shine_a2ff3ede:

    # "Normally, this would be a good time to reflect upon the beauty of nature."
    "Normalmente, esta seria uma boa hora para refletir sobre a beleza da natureza."

# game/script-a2-hanako.rpy:2124
translate pt_br a2_hanako_rise_and_shine_ff95a64f:

    # "But it is 6 AM."
    "Mas são 6:00 da manhã."

# game/script-a2-hanako.rpy:2131
translate pt_br a2_hanako_rise_and_shine_0b1b56cb:

    # "Covering my head with the pillow, I slam my face into the mattress, hoping that the impact will send me instantly back to sleep."
    "Cobrindo minha cabeça com o travesseiro, eu bato meu rosto contra o colchão, esperando que o impacto me mande de volta ao meu sono de forma instantânea."

# game/script-a2-hanako.rpy:2133
translate pt_br a2_hanako_rise_and_shine_e44a4dce:

    # "Futile."
    "Em vão."

# game/script-a2-hanako.rpy:2135
translate pt_br a2_hanako_rise_and_shine_241c2ca6:

    # "I toss and turn, but sleep simply won't return to me."
    "Me agito e me viro, mas o sono simplesmente não vai voltar."

# game/script-a2-hanako.rpy:2142
translate pt_br a2_hanako_rise_and_shine_5eed0909:

    # "All right nature, you've won. See? I'm getting up now…"
    "Ok, natureza, você venceu. Está vendo? Estou me levantando agora…"

# game/script-a2-hanako.rpy:2144
translate pt_br a2_hanako_rise_and_shine_e5e3f390:

    # "The lack of sleep weighs my mind down, and there's only one remedy for this; a nice, hearty breakfast."
    "A falta de sono pesa em minha cabeça, e só há um remédio para isso: um café da manhã bom e sustentável."

# game/script-a2-hanako.rpy:2152
translate pt_br a2_hanako_rise_and_shine_112ff660:

    # "It would be nice to be the first person here."
    "Seria legal ser a primeira pessoa aqui."

# game/script-a2-hanako.rpy:2154
translate pt_br a2_hanako_rise_and_shine_d84a63c1:

    # "To be the first to dig into a piping hot pile of food, to sit wherever I desire…"
    "Ser o primeiro a se empanturrar com uma pilha de comida quentinha, sentar onde eu quiser…"

# game/script-a2-hanako.rpy:2156
translate pt_br a2_hanako_rise_and_shine_bf8fed3a:

    # "It would have been nice."
    "Teria sido legal."

# game/script-a2-hanako.rpy:2158
translate pt_br a2_hanako_rise_and_shine_c0ce7b7d:

    # "But even my exceptionally early start has put me behind the most diligent students."
    "Mas até mesmo meu despertar excepcionalmente cedo me deixou para trás em relação aos estudantes mais diligentes."

# game/script-a2-hanako.rpy:2160
translate pt_br a2_hanako_rise_and_shine_3a176f34:

    # "I guess there are quite a few people that have early starts here, for one reason or another."
    "Acho que há muita gente que acorda cedo por aqui, seja por uma razão ou outra."

# game/script-a2-hanako.rpy:2162
translate pt_br a2_hanako_rise_and_shine_ddf49169:

    # "A group of students in sports clothes huddle around one table, eagerly discussing game plans inbetween inhaling great gulps of food."
    "Um grupo de estudantes em roupas esportivas se amontoa em volta de uma mesa, revezando entre discutir ardentemente planos de jogo e engolir grandes quantidades de comida."

# game/script-a2-hanako.rpy:2164
translate pt_br a2_hanako_rise_and_shine_da6bf91e:

    # "Scattered around the hall are a number of bleary-eyed students, probably suffering from the same ailment as myself - noisy birds."
    "Dispersos pelo corredor estão alguns estudantes de olhares cansados, provavelmente padecendo do mesmo mal que eu - pássaros barulhentos."

# game/script-a2-hanako.rpy:2166
translate pt_br a2_hanako_rise_and_shine_22937685:

    # "And, of course, there are the people that actually enjoy getting up this early, the ones with their bags stuffed with textbooks and completed homework."
    "E, é claro, tem as pessoas que de fato gostam de acordar cedo assim, aqueles com suas mochilas abarrotadas de livros e deveres de casa prontos."

# game/script-a2-hanako.rpy:2168
translate pt_br a2_hanako_rise_and_shine_bbabe8df:

    # "It's hard not to despise people like that, even more so when you're tired yourself."
    "É difícil não desprezar pessoas assim, especialmente quando se está cansado."

# game/script-a2-hanako.rpy:2170
translate pt_br a2_hanako_rise_and_shine_bf892ab7:

    # "Picking out a familiar face from the thin crowd, I head towards the nearest table."
    "Encontrando um rosto familiar na pequena multidão, vou até a mesa mais próxima."

# game/script-a2-hanako.rpy:2172
translate pt_br a2_hanako_rise_and_shine_91cee339:

    # "Lilly sits alone, delicately feeling her way around a small plate of eggs with her fork."
    "Lilly senta sozinha, delicadamente sentindo seu caminho pelo pequeno prato de ovos com seu garfo."

# game/script-a2-hanako.rpy:2174
translate pt_br a2_hanako_rise_and_shine_062a62f3:

    # "It's almost a shame to interrupt her and her clockwork movements."
    "É quase uma vergonha interromper ela e seus movimentos mecânicos."

# game/script-a2-hanako.rpy:2176
translate pt_br a2_hanako_rise_and_shine_e28ca64d:

    # "I wonder, is this how a blind person zones out? Simply moving in pre-determined patterns learned over the years, just like how a sighted person would eat while reading a newspaper."
    "Será que é assim que uma pessoa cega limpa a mente? Simplesmente se movendo de modos pré-determinados aprendidos ao longo dos anos, assim como uma pessoa com visão comeria enquanto lê um jornal?"

# game/script-a2-hanako.rpy:2178
translate pt_br a2_hanako_rise_and_shine_973e7a5f:

    # hi "Good morning, Lilly. I didn't expect you to be here this early."
    hi "Bom dia, Lilly. Não esperava te encontrar aqui tão cedo."

# game/script-a2-hanako.rpy:2185
translate pt_br a2_hanako_rise_and_shine_8fc8ed6e:

    # li "Oh, Hisao, you startled me. I didn't know you took breakfast this early."
    li "Oh, Hisao, você me surpreendeu. Não sabia que você tomava café da manhã neste horário."

# game/script-a2-hanako.rpy:2187
translate pt_br a2_hanako_rise_and_shine_463bfda1:

    # hi "I don't. This is an exception to the rule. I'd greatly prefer to be late to school than early to breakfast."
    hi "Não tomo. Hoje é uma exceção à regra. Prefiro muito mais me atrasar para a escola do que chegar cedo para o café."

# game/script-a2-hanako.rpy:2192
translate pt_br a2_hanako_rise_and_shine_2cb74284:

    # "Lilly gives a small sigh at my admitted tardiness as I begin eating my food."
    "Lilly suspira discretamente pela minha confissão enquanto começo a comer."

# game/script-a2-hanako.rpy:2194
translate pt_br a2_hanako_rise_and_shine_b4c173d1:

    # "It doesn't take long for her to lapse back into her previous mindless nibbling."
    "Não demora muito para ela voltar a mordiscar de forma absorta."

# game/script-a2-hanako.rpy:2196
translate pt_br a2_hanako_rise_and_shine_cb84d6cc:

    # "Each short motion lacks energy. I suppose this is similar to letting your eyes wander while performing any ordinary chore."
    "Cada pequeno movimento carece de energia. Suponho que isso seja o equivalente a deixar seus olhos vagarem enquanto faz uma pequena tarefa."

# game/script-a2-hanako.rpy:2198
translate pt_br a2_hanako_rise_and_shine_982e9ac1:

    # "But after a few repetitions of the find food/eat food cycle, Lilly puts down her fork and dabs her lips with a napkin."
    "Mas depois de algumas repetições de seu ciclo de achar comida/comer comida, Lilly abaixa o garfo e limpa os lábios com um guardanapo."

# game/script-a2-hanako.rpy:2206
translate pt_br a2_hanako_rise_and_shine_bdc0904d:

    # li "Hisao, do you mind if I ask you a question?"
    li "Hisao, se importa se eu te fizer uma pergunta?"

# game/script-a2-hanako.rpy:2208
translate pt_br a2_hanako_rise_and_shine_70effd09:

    # "Damn. All I want is a little food and about four hours of sleep. And nobody says 'can I ask you a question' for a simple question."
    "Droga. Tudo que eu queria era um pouco de comida e umas quatro horas de sono. E ninguém diz “posso te fazer uma pergunta” por causa de uma pergunta simples."

# game/script-a2-hanako.rpy:2210
translate pt_br a2_hanako_rise_and_shine_21ce94c5:

    # hi "Sure."
    hi "Pode fazer."

# game/script-a2-hanako.rpy:2215
translate pt_br a2_hanako_rise_and_shine_cdb69970:

    # li "Do you think of Hanako as a friend?"
    li "Você pensa na Hanako como uma amiga?"

# game/script-a2-hanako.rpy:2217
translate pt_br a2_hanako_rise_and_shine_20d7c42c:

    # "Huh, this seems like a leading question."
    "Huh, essa pergunta parece uma pegadinha."

# game/script-a2-hanako.rpy:2219
translate pt_br a2_hanako_rise_and_shine_6a0a81de:

    # hi "I… guess so. Why do you ask?"
    hi "Eu… creio que sim. Por que a pergunta?"

# game/script-a2-hanako.rpy:2224
translate pt_br a2_hanako_rise_and_shine_fd981080:

    # li "No real reason."
    li "Nenhuma razão específica."

# game/script-a2-hanako.rpy:2231
translate pt_br a2_hanako_rise_and_shine_e6c2f3c7:

    # li "I do have another question though. Why is it that you think of her as a friend?"
    li "Porém, eu tenho outra pergunta. Por que você pensa nela como uma amiga?"

# game/script-a2-hanako.rpy:2233
translate pt_br a2_hanako_rise_and_shine_cf13f7ad:

    # "This is well above my level. What is she expecting from me?"
    "Isso está acima do meu nível. O que ela espera de mim?"

# game/script-a2-hanako.rpy:2235
translate pt_br a2_hanako_rise_and_shine_92dd9db0:

    # hi "I'm not really sure. I guess it's because she's a little different in the way she deals with people…"
    hi "Não tenho certeza. Acho que é porque ela é um pouco diferente na maneira em que lida com as pessoas…"

# game/script-a2-hanako.rpy:2240
translate pt_br a2_hanako_rise_and_shine_246959c2:

    # li "Hmm. Since I've known her, she hasn't really connected with anyone."
    li "Hmm. Desde que a conheço, ela nunca se conectou com alguém de verdade."

# game/script-a2-hanako.rpy:2245
translate pt_br a2_hanako_rise_and_shine_a4434515:

    # li "She doesn't seem interested in other people, and I think people are a little scared off by her appearance."
    li "Ela não parece interessada em outras pessoas, e acho que as pessoas se afugentam um pouco por causa da aparência dela."

# game/script-a2-hanako.rpy:2247
translate pt_br a2_hanako_rise_and_shine_2fd3b41c:

    # hi "Really? I thought that kind of thing was, well, discouraged here. Discriminating and such."
    hi "Sério? Pensei que esse tipo de coisa era desencorajada por aqui. Discriminação e coisas do tipo."

# game/script-a2-hanako.rpy:2252
translate pt_br a2_hanako_rise_and_shine_33a8db27:

    # li "Hmm, if I were to put it one way…"
    li "Hmm, se eu fosse colocar isso de um modo…"

# game/script-a2-hanako.rpy:2254
translate pt_br a2_hanako_rise_and_shine_20db8d7c:

    # "She furrows her brow in thought, a move which makes me slightly anxious as to what she's plucking from her mind."
    "Ela franze as sobrancelhas enquanto pensa, uma ação que me deixa um pouco ansioso sobre o que ela está puxando da mente."

# game/script-a2-hanako.rpy:2259
translate pt_br a2_hanako_rise_and_shine_cdfdc1b1:

    # li "I'd say that you're a little naive."
    li "Diria que você é um pouco ingênuo."

# game/script-a2-hanako.rpy:2261
translate pt_br a2_hanako_rise_and_shine_4059062f:

    # "Naive? I'd be insulted if not for the slightly cynical grin on her face."
    "Ingênuo? Eu me sentiria insultado se não fosse pelo pequeno sorriso cínico no rosto dela."

# game/script-a2-hanako.rpy:2263
translate pt_br a2_hanako_rise_and_shine_5715c902:

    # hi "I… see."
    hi "Eu… entendo."

# game/script-a2-hanako.rpy:2268
translate pt_br a2_hanako_rise_and_shine_7c277df3:

    # li "While Yamaku has a stronger sense of community compared to other schools, it's far from being free of conflict."
    li "Por mais que a Yamaku tenha um senso de comunidade mais forte que outras escolas, está longe de estar livre de conflitos."

# game/script-a2-hanako.rpy:2273
translate pt_br a2_hanako_rise_and_shine_6b1c4549:

    # li "Rules cannot remove human nature, after all, only suppress it."
    li "As regras não podem remover a natureza humana, no fim das contas. Apenas suprimí-la."

# game/script-a2-hanako.rpy:2275
translate pt_br a2_hanako_rise_and_shine_67796def:

    # "That's something I've noticed, actually."
    "Isso é algo que notei, na verdade."

# game/script-a2-hanako.rpy:2277
translate pt_br a2_hanako_rise_and_shine_47643aa8:

    # "Just little things, like how certain people and cliques avoid each other in the hallways. It's no different than my old school, really."
    "Apenas pequenas coisas, como a forma com que algumas pessoas e panelinhas se evitam nos corredores. Não é muito diferente da minha antiga escola, pensando bem."

# game/script-a2-hanako.rpy:2279
translate pt_br a2_hanako_rise_and_shine_773ae041:

    # "Even Lilly and Shizune could be considered bitter rivals, even though they both seem like fairly accepting people."
    "Até mesmo a Lilly e a Shizune podem ser consideradas rivais implacáveis, mesmo que as duas pareçam ser pessoas bem sensatas."

# game/script-a2-hanako.rpy:2281
translate pt_br a2_hanako_rise_and_shine_b803bd26:

    # "Well, at least the Misha-tinted Shizune does; who knows what actually goes on with her fingers and behind her glasses."
    "Bem, pelo menos a Shizune colorida da Misha é assim; quem sabe o que de fato acontece com seus dedos e por trás de seus óculos."

# game/script-a2-hanako.rpy:2283
translate pt_br a2_hanako_rise_and_shine_2714796b:

    # hi "I guess you're right. But when I first came here, everything was a bit of a shock."
    hi "Acho que tem razão. Mas quando eu cheguei aqui, tudo foi um pouco chocante."

# game/script-a2-hanako.rpy:2285
translate pt_br a2_hanako_rise_and_shine_312fa566:

    # hi "I kept on making mistakes, or at least thinking I was making mistakes. Like when we first met, and I said 'I see' to you."
    hi "Eu não parei de cometer erros, ou ao menos pensar estar os cometendo. Como quando nos conhecemos, e eu disse “estou vendo” para você."

# game/script-a2-hanako.rpy:2287
translate pt_br a2_hanako_rise_and_shine_58145d5f:

    # hi "I didn't know if that was considered rude or anything, so I tried to just put it in the back of my mind. Treating people any differently and that kinda thing."
    hi "Não sabia se isso era considerado uma regra ou algo do tipo, então tentei esquecer isso. Tratar as pessoas de alguma forma diferente ou algo assim."

# game/script-a2-hanako.rpy:2289
translate pt_br a2_hanako_rise_and_shine_897bb7cf:

    # hi "So I didn't. I told myself that Hanako and you and everyone else was just normal, and I tried to ignore the obvious."
    hi "Então não fiz isso. Disse a mim mesmo que a Hanako, você e todos os outros eram totalmente normais, e tentei ignorar o óbvio."

# game/script-a2-hanako.rpy:2291
translate pt_br a2_hanako_rise_and_shine_682f6b66:

    # hi "I talked to Hanako as if she were any other person, and so we became friends."
    hi "Falei com a Hanako como se fosse qualquer outra pessoa, então nos tornamos amigos."

# game/script-a2-hanako.rpy:2293
translate pt_br a2_hanako_rise_and_shine_2e31660f:

    # hi "At least, that's how I think it happened."
    hi "Pelo menos é assim que eu acho que aconteceu."

# game/script-a2-hanako.rpy:2295
translate pt_br a2_hanako_rise_and_shine_dab58a3f:

    # hi "But you know, I feel guilty just from saying something like that aloud. As if it took extra effort to think of Hanako, or you, or anyone here as normal people. I don't think that's right."
    hi "Mas sabe, me sinto culpado por dizer algo assim abertamente. Como se pensar na Hanako, ou em você, ou qualquer um aqui como gente normal requirisse algum esforço extra. Não acho que isso seja certo."

# game/script-a2-hanako.rpy:2300
translate pt_br a2_hanako_rise_and_shine_4e2734f2:

    # li "Hisao, I think you are naive, but I also think that you are a good person. It is perhaps one of your better traits."
    li "Hisao, eu acho que você é ingênuo, mas também acho que você é uma boa pessoa. Talvez essa seja uma de suas melhores características."

# game/script-a2-hanako.rpy:2302
translate pt_br a2_hanako_rise_and_shine_84c6a8f8:

    # hi "I… suppose… I can take that as a compliment…"
    hi "Eu… acho… que posso levar isso como elogio…"

# game/script-a2-hanako.rpy:2307
translate pt_br a2_hanako_rise_and_shine_00147a71:

    # li "Tell me, are you free tonight?"
    li "Me diga, está livre hoje a noite?"

# game/script-a2-hanako.rpy:2309
translate pt_br a2_hanako_rise_and_shine_7197e293:

    # hi "If you don't count homework, then I'm as free as the breeze."
    hi "Se você não contar com o dever de casa, então estou livre como um pássaro."

# game/script-a2-hanako.rpy:2314
translate pt_br a2_hanako_rise_and_shine_dd8c3158:

    # li "In that case, would you care to join myself and Hanako for tea?"
    li "Nesse caso, gostaria de se juntar a Hanako e eu para tomar chá?"

# game/script-a2-hanako.rpy:2316
translate pt_br a2_hanako_rise_and_shine_9a2e9250:

    # hi "Er, I don't really have that much money at the moment, so going out isn't really…"
    hi "Err, não estou com muito dinheiro no momento, então sair não é muito…"

# game/script-a2-hanako.rpy:2321
translate pt_br a2_hanako_rise_and_shine_328f7a1c:

    # li "Oh, I didn't mean going out. Just here, this evening."
    li "Oh, não me referi a sair. Aqui mesmo, no final da tarde."

# game/script-a2-hanako.rpy:2323
translate pt_br a2_hanako_rise_and_shine_8d831ddd:

    # hi "You can access the classrooms in the evening here?"
    hi "Você pode ter acesso às salas de aula no final da tarde aqui?"

# game/script-a2-hanako.rpy:2328
translate pt_br a2_hanako_rise_and_shine_f0328798:

    # li "No, that's not what I meant. Hanako and I often use my room for tea parties together. Please feel free to drop by after dusk."
    li "Não, não é isso. A Hanako e eu frequentemente usamos meu quarto para as festas de chá juntas. Por favor, esteja à vontade para aparecer depois que escurecer."

# game/script-a2-hanako.rpy:2330
translate pt_br a2_hanako_rise_and_shine_2347b5f7:

    # hi "Sure, I see no problem with that. What's your room number?"
    hi "Sem problemas. Qual o número do seu quarto?"

# game/script-a2-hanako.rpy:2335
translate pt_br a2_hanako_rise_and_shine_1372d309:

    # li "225; Room 25 on the second floor."
    li "225; quarto 25 no segundo andar."

# game/script-a2-hanako.rpy:2337
translate pt_br a2_hanako_rise_and_shine_c8e7b156:

    # hi "Okay, sure."
    hi "Ok, certo."

# game/script-a2-hanako.rpy:2342
translate pt_br a2_hanako_rise_and_shine_955b32eb:

    # li "Well then, I had best be off. I have class representative duties to attend to, after all."
    li "Muito bem então. Melhor eu ir andando, tenho tarefas de repressentante de classe para fazer."

# game/script-a2-hanako.rpy:2347
translate pt_br a2_hanako_rise_and_shine_0640266a:

    # li "Until this evening, Hisao."
    li "Até mais tarde, Hisao."

# game/script-a2-hanako.rpy:2349
translate pt_br a2_hanako_rise_and_shine_9cba87c8:

    # hi "Yeah, catch you later."
    hi "Até, te vejo depois."

# game/script-a2-hanako.rpy:2356
translate pt_br a2_hanako_rise_and_shine_51634f83:

    # "Hang on… was I just invited to a girl's room after hours? Is that even allowed?"
    "Espera aí… acabei de ser convidado para o quarto de uma garota depois de escurecer? Isso é sequer permitido?"

# game/script-a2-hanako.rpy:2358
translate pt_br a2_hanako_rise_and_shine_9bdcce00:

    # "There is the curfew here, but I've never heard any rules about visitors in the dorm rooms."
    "Temos o toque de recolher aqui, mas nunca ouvi falar de nenhuma regra sobre visitantes nos dormitórios."

# game/script-a2-hanako.rpy:2360
translate pt_br a2_hanako_rise_and_shine_b87d2674:

    # "Even still, this is enough to get my sleep-deprived brain jump-started."
    "De qualquer forma, isso é o suficiente para fazer meu cérebro privado de sono pegar no tranco."

# game/script-a2-hanako.rpy:2362
translate pt_br a2_hanako_rise_and_shine_6bab9e2d:

    # "Add that to a lukewarm breakfast and you have one hell of a pick-me-up."
    "Adicione isso ao café da manhã reforçado que tomei e você tem um belo de um revigorante."

# game/script-a2-hanako.rpy:2367
translate pt_br a2_hanako_rise_and_shine_20e9e2f4:

    # "I grudgingly go to class, still a little excited at the prospect of breaking the rules."
    "Vou à aula de má vontade, ainda um pouco animado pelo prospecto de quebrar as regras."

# game/script-a2-hanako.rpy:2369
translate pt_br a2_hanako_rise_and_shine_c7f330e4:

    # "I feel a little like a kid planning to sneak out of his window at night."
    "Me sinto como uma criançinha planejando fugir pela janela à noite."

# game/script-a2-hanako.rpy:2371
translate pt_br a2_hanako_rise_and_shine_f668619e:

    # "Well, maybe that's going a little too far, but when you compare an invitation to a party to six or so hours of lectures, I know which one wins."
    "Bem, talvez isso seja ir um pouco longe demais, mas quando você compara um convite a uma festa a mais ou menos seis horas de lições, eu sei qual ganha."

# game/script-a2-hanako.rpy:2373
translate pt_br a2_hanako_rise_and_shine_e519caf4:

    # "Misha and Shizune do little to relieve my boredom either. For once, they seem determined to actually complete Mutou's assignments."
    "Misha e Shizune também não fazem muito para diminuir meu tédio. Uma vez na vida, elas parecem determinadas a completar as tarefas dadas pelo Mutou."

# game/script-a2-hanako.rpy:2380
translate pt_br a2_hanako_rise_and_shine_4aa6f748:

    # "Nevertheless, the day eventually winds to a close."
    "Todavia, o dia de aula eventualmente se encerra."

# game/script-a2-hanako.rpy:2385
translate pt_br a2_hanako_rise_and_shine_2788ddae:

    # "I hurry back to my room to wash up and comb my hair. Thankfully I don't run into Kenji."
    "Me apresso até meu quarto para tomar banho e pentear meu cabelo. Por sorte, não passo pelo Kenji."

# game/script-a2-hanako.rpy:2390
translate pt_br a2_hanako_rise_and_shine_ff586a6c:

    # "Before long I am leaving the boys' dorm."
    "Em não muito tempo estou deixando o dormitório."

# game/script-a2-hanako.rpy:2401
translate pt_br a2_hanako_mad_hatter_f8ecda95:

    # "I nervously rap on the door marked 225, checking my watch once again."
    "Eu bato nervosamente na porta marcada como 225, checando meu relógio mais uma vez."

# game/script-a2-hanako.rpy:2403
translate pt_br a2_hanako_mad_hatter_e3819a87:

    # li "Is that you, Hisao? The door is open, you can come in."
    li "É você, Hisao? A porta está aberta, pode entrar."

# game/script-a2-hanako.rpy:2405
translate pt_br a2_hanako_mad_hatter_25499b30:

    # "Lilly's voice lilts through the door and soothes my nerves."
    "A voz da Lilly ressoa melodicamente através da porta e acalma meus nervos."

# game/script-a2-hanako.rpy:2407
translate pt_br a2_hanako_mad_hatter_4070c4d4:

    # "This is the first time I've been invited to a girl's room after dark."
    "Esta é a primeira vez que sou convidado a um quarto de garota depois de escurecer."

# game/script-a2-hanako.rpy:2409
translate pt_br a2_hanako_mad_hatter_ec61a358:

    # "Even though I know there is no ulterior motive behind this invitation, it doesn't stop my mind running wild with possibilities."
    "Mesmo sabendo que não há motivos maiores por trás desse convite, isso não impede minha mente de fervilhar de possibilidades."

# game/script-a2-hanako.rpy:2411
translate pt_br a2_hanako_mad_hatter_f0877089:

    # "One guy. Two girls. In a dorm room. With a tea set."
    "Um cara. Duas garotas. Num quarto de dormitório. Com um jogo de chá."

# game/script-a2-hanako.rpy:2413
translate pt_br a2_hanako_mad_hatter_588c2faa:

    # "When I put it like that, it sounds a little dodgy."
    "Quando coloco dessa forma, soa um pouco desonesto."

# game/script-a2-hanako.rpy:2415
translate pt_br a2_hanako_mad_hatter_8338d8e6:

    # "Giving a small sigh to steady myself, I gingerly put my hand on the handle and open the door, craning my head to see inside."
    "Dando um pequeno suspiro, coloco cautelosamente a mão na maçaneta e abro a porta, inclinando a cabeça para ver dentro."

# game/script-a2-hanako.rpy:2432
translate pt_br a2_hanako_mad_hatter_f9d49294:

    # "The door opens completely and I catch my first glimpse of Lilly's room."
    "A porta se abre por completo e eu tenho minha primeira visão do quarto da Lilly."

# game/script-a2-hanako.rpy:2434
translate pt_br a2_hanako_mad_hatter_6c9ec6b5:

    # "Her furniture looks almost antique, but the bare walls and flat surfaces are barely decorated at all. In the center of the room sits a low table, where I see a small tea set at rest."
    "Sua mobília parece quase clássica, mas as paredes nuas e superfícies estão praticamente sem nenhuma decoração. No centro do quarto há uma mesa, onde posso ver um pequeno jogo de chá."

# game/script-a2-hanako.rpy:2436
translate pt_br a2_hanako_mad_hatter_23dac982:

    # "It seems that everything in this room has its place, possibly excepting the several piles of books stacked up against the wall."
    "Parece que tudo nesse quarto tem seu lugar, com a possível exceção da montoeira de livros empilhados contra a parede."

# game/script-a2-hanako.rpy:2438
translate pt_br a2_hanako_mad_hatter_4d3afb09:

    # "My sense of vision isn't the only one to be stimulated; the faint smell of something can be picked up on the air. Nail polish, perfume, makeup… it's hard to describe in any way other than 'girly'."
    "Meu sentido da visão não é o único a ser estimulado; o sutil odor de algo pode ser sentido no ar. Esmalte, perfume, maquiagem… é difícil descrever em qualquer maneira além de “feminino”."

# game/script-a2-hanako.rpy:2440
translate pt_br a2_hanako_mad_hatter_e49ed0d4:

    # "My eyes finish their quick sweep of the room, before returning their position onto the girls."
    "Meus olhos terminam sua breve varredura do quarto, antes de retornar à sua posição sobre as garotas."

# game/script-a2-hanako.rpy:2447
translate pt_br a2_hanako_mad_hatter_a83fb251:

    # "Lilly sits next to the small table, wearing very dark blue pajamas. Dark blue pajamas with shorts that show off plenty of her alluring pale legs."
    "Lilly senta-se em frente à pequena mesa, vestindo pijamas azuis bem escuros. Pijamas azuis bem escuros com shorts que mostram bastante de suas sedutoras pernas pálidas."

# game/script-a2-hanako.rpy:2453
translate pt_br a2_hanako_mad_hatter_8e4dba43:

    # "Opposite her, Hanako sits adorned in a conservative light pink gown."
    "No lado oposto, Hanako senta-se adornada em um conservador vestido rosa-claro."

# game/script-a2-hanako.rpy:2455
translate pt_br a2_hanako_mad_hatter_f6aaab68:

    # "Her hands are firmly fixed between her legs, her shoulders forward, and her head down, as if trying to hide herself in it."
    "Suas mãos estão firmemente fixadas entre as pernas, seus ombros para frente, e sua cabeça abaixada, como se tentando se esconder dentro do vestido."

# game/script-a2-hanako.rpy:2457
translate pt_br a2_hanako_mad_hatter_389cedc0:

    # "It would be easy for her to do; it looks about two sizes too big for her."
    "Seria fácil fazê-lo; ele parece uns dois números grande demais para ela."

# game/script-a2-hanako.rpy:2459
translate pt_br a2_hanako_mad_hatter_7a2d6326:

    # "Waves of flannel flow from her frame, making her look like a child playing dress-up in her parents' clothes."
    "Ondas de flanela caem por suas formas, tornando-a parecida com uma criança brincando com as roupas dos pais."

# game/script-a2-hanako.rpy:2461
translate pt_br a2_hanako_mad_hatter_68cb210b:

    # "She looks up to confirm my identity, and the beginnings of a thin smile creep across her face, before vanishing so fast that I can't be sure they ever were there."
    "Ela olha para cima para confirmar minha identidade, e então um começo de pequeno sorriso aflora em seu rosto, antes de desaparecer tão rápido que não se tem certeza se ele sequer existiu um dia."

# game/script-a2-hanako.rpy:2466
translate pt_br a2_hanako_mad_hatter_6ddb36dc:

    # li "There's no point in you standing in the doorway, Hisao."
    li "Não há motivo para ficar parado na entrada, Hisao."

# game/script-a2-hanako.rpy:2480
translate pt_br a2_hanako_mad_hatter_d5e9055e:

    # "I take a step into the room, closing the door behind me."
    "Eu adentro o quarto, fechando a porta atrás de mim."

# game/script-a2-hanako.rpy:2485
translate pt_br a2_hanako_mad_hatter_29bc9ba1:

    # li "My my, I'm afraid this really is a small room for the three of us. Would you like to take a seat?"
    li "Minha nossa, temo que este quarto seja de fato muito pequeno para nós três. Gostaria de se sentar?"

# game/script-a2-hanako.rpy:2487
translate pt_br a2_hanako_mad_hatter_269fba85:

    # "I slowly walk to the table and sit down, trying my hardest not to disturb anything along the way."
    "Eu ando devagar até a mesa e me sento, me esforçando o máximo para não interferir em nada no caminho."

# game/script-a2-hanako.rpy:2489
translate pt_br a2_hanako_mad_hatter_5ad7baeb:

    # "I also can't help but steal a quick glance into Lilly's top as I sit."
    "Além disso, não consigo evitar de dar uma espiadela por cima da Lilly enquanto sento."

# game/script-a2-hanako.rpy:2491
translate pt_br a2_hanako_mad_hatter_ad1a067a:

    # "To be robbed of sight would be a most terrible fate."
    "Ser privado de visão seria o destino mais terrível."

# game/script-a2-hanako.rpy:2496
translate pt_br a2_hanako_mad_hatter_116bb0b2:

    # li "Well now, how about some tea. Hanako, could you please pour?"
    li "Bem, agora, que tal um pouco de chá? Hanako, poderia servir?"

# game/script-a2-hanako.rpy:2501
translate pt_br a2_hanako_mad_hatter_60ab94be:

    # ha "S… sure. Hi… sao… would…"
    ha "C… claro. Hi… sao… você…"

# game/script-a2-hanako.rpy:2506
translate pt_br a2_hanako_mad_hatter_99fbe8fb:

    # ha "…would you…"
    ha "…você gostaria…"

# game/script-a2-hanako.rpy:2511
translate pt_br a2_hanako_mad_hatter_d8d7c5a7:

    # ha "…would you like…"
    ha "…você gostaria de…"

# game/script-a2-hanako.rpy:2513
translate pt_br a2_hanako_mad_hatter_3906f248:

    # hi "I would love some tea. Do you need a hand?"
    hi "Eu adoraria um pouco de chá. Quer ajuda?"

# game/script-a2-hanako.rpy:2518
translate pt_br a2_hanako_mad_hatter_1e8c396a:

    # ha "N… no, I'm fine…"
    ha "N… não, estou bem…"

# game/script-a2-hanako.rpy:2523
translate pt_br a2_hanako_mad_hatter_c4efd2c3:

    # ha "Thank you…"
    ha "Obrigada…"

# game/script-a2-hanako.rpy:2530
translate pt_br a2_hanako_mad_hatter_7e39b933:

    # "Lilly finds it difficult to resist a smile at her companion's nervousness, something I can't really blame her for."
    "Lilly tem dificuldades em resistir um sorriso em vista do nervosismo de sua companheira, algo pelo qual não posso culpá-la."

# game/script-a2-hanako.rpy:2535
translate pt_br a2_hanako_mad_hatter_7912c95d:

    # hi "Been a tiring day?"
    
    hi "Foi um dia cansativo?"

# game/script-a2-hanako.rpy:2540
translate pt_br a2_hanako_mad_hatter_8c015a3e:

    # ha "Y… yeah."
    ha "S… sim."

# game/script-a2-hanako.rpy:2545
translate pt_br a2_hanako_mad_hatter_5af4c442:

    # "I relax at my place, opposite of the cabinet."
    "Relaxo em meu lugar, oposto ao armário."

# game/script-a2-hanako.rpy:2547
translate pt_br a2_hanako_mad_hatter_d318ed41:

    # "To my left is the blue-clad Lilly and to my right sits the pink Hanako."
    "À minha esquerda está a Lilly vestida de azul, e à minha direita, a Hanako rosada."

# game/script-a2-hanako.rpy:2557
translate pt_br a2_hanako_mad_hatter_340d6e16:

    # "The tea set on the table looks cute as well as practical; painted red with a floral motif."
    "O jogo de chá sobre a mesa parece bonitinho e prático; pintado de vermelho com um motivo floral."

# game/script-a2-hanako.rpy:2559
translate pt_br a2_hanako_mad_hatter_6ce7a5bc:

    # "It looks odd when contrasted with Lilly's plain but generally sophisticated-looking furniture, which leads me to think that Hanako might have picked it out."
    "É estranho contrastá-lo com os móveis simples porém de aparência sofisticada de Lilly, o que me leva a pensar que Hanako deve tê-lo escolhido."

# game/script-a2-hanako.rpy:2561
translate pt_br a2_hanako_mad_hatter_24c6cf02:

    # "There is a slight 'ting' when Hanako accidentally clips the teapot on a cup as she is pouring."
    "Ouve-se um pequeno “plim” quando Hanako acidentalmente trava o bule em uma xícara enquanto serve."

# game/script-a2-hanako.rpy:2573
translate pt_br a2_hanako_mad_hatter_f284263d:

    # "She breathes in sharply; she must be really nervous, as it's not the kind of thing anyone would worry about."
    "Ela respira bruscamente; ela deve estar bem nervosa, pois esse não é o tipo de coisa com o qual alguém se preocuparia."

# game/script-a2-hanako.rpy:2578
translate pt_br a2_hanako_mad_hatter_6d723c60:

    # "Hanako quivers at her mistake."
    "Hanako estremece por seu equívoco."

# game/script-a2-hanako.rpy:2583
translate pt_br a2_hanako_mad_hatter_319ec7d0:

    # li "It's okay, Hanako. There's no need to be nervous."
    li "Está tudo bem, Hanako. Não há razão para ficar nervosa."

# game/script-a2-hanako.rpy:2588
translate pt_br a2_hanako_mad_hatter_89e418b1:

    # "Hanako seems to find some confidence in Lilly's reassuringly soft-spoken words and deftly pours the next two cups."
    "Hanako aparenta encontrar um pouco de confiança nas palavras tranquilizadoras e suaves da Lilly, servindo as duas próximas xícaras habilmente."

# game/script-a2-hanako.rpy:2593
translate pt_br a2_hanako_mad_hatter_1b504d01:

    # ha "Here you are, Hisao… Lilly."
    ha "Aqui está, Hisao… Lilly."

# game/script-a2-hanako.rpy:2595
translate pt_br a2_hanako_mad_hatter_62d57335:

    # "Hanako carefully places a cup and saucer in front of Lilly and myself. I could get used to service like this."
    "Hanako cuidadosamente coloca uma xícara e um pires em frente a Lilly e a mim. Eu poderia me acostumar a serviços assim."

# game/script-a2-hanako.rpy:2600
translate pt_br a2_hanako_mad_hatter_23ce2f9d:

    # li "Thank you, Hanako."
    li "Obrigada, Hanako."

# game/script-a2-hanako.rpy:2602
translate pt_br a2_hanako_mad_hatter_25f4a6b6:

    # hi "Yeah, thanks."
    hi "Obrigado."

# game/script-a2-hanako.rpy:2607
translate pt_br a2_hanako_mad_hatter_a23af8ea:

    # ha "Y-you're welcome."
    ha "D-de nada."

# game/script-a2-hanako.rpy:2612
translate pt_br a2_hanako_mad_hatter_f98cf146:

    # "Lilly searches for her cup, and upon finding it, sips delicately."
    "Lilly procura por sua xícara, e após achá-la, bebe o chá delicadamente."

# game/script-a2-hanako.rpy:2614
translate pt_br a2_hanako_mad_hatter_fff5a883:

    # "I do the same. This tea tastes somewhat better than the tea we usually have at school."
    "Faço o mesmo. Este chá é um pouco melhor que o que a gente normalmente bebe na escola."

# game/script-a2-hanako.rpy:2616
translate pt_br a2_hanako_mad_hatter_7e6d14a4:

    # hi "This is nice, it's so different from any tea I had before…"
    hi "Este chá é bom, diferente de todos que eu já tinha bebido antes…"

# game/script-a2-hanako.rpy:2622
translate pt_br a2_hanako_mad_hatter_a8a0fc2e:

    # li "Looks like you picked the right one, Hanako."
    li "Parece que você escolheu o certo, Hanako."

# game/script-a2-hanako.rpy:2627
translate pt_br a2_hanako_mad_hatter_dab7c8e6:

    # li "You've done well, even if it was a bold move."
    li "Você foi bem, mesmo com um movimento arriscado."

# game/script-a2-hanako.rpy:2632
translate pt_br a2_hanako_mad_hatter_38f80c6e:

    # "Hanako's smile returns, redoubled."
    "O sorriso da Hanako retorna, redobrado."

# game/script-a2-hanako.rpy:2634
translate pt_br a2_hanako_mad_hatter_391a6f7e:

    # "Even with her blighted face, her shy smile couldn't be called anything but 'cute'."
    "Mesmo com seu rosto manchado, seu sorriso não poderia ser chamado de nada além de “bonitinho”."

# game/script-a2-hanako.rpy:2639
translate pt_br a2_hanako_mad_hatter_ff8b709c:

    # ha "I'm glad you like it…"
    ha "Estou feliz que tenham gostado…"

# game/script-a2-hanako.rpy:2641
translate pt_br a2_hanako_mad_hatter_1d2664be:

    # "Hanako, finally beginning to relax, sips from her cup."
    "Hanako, finalmente começando a relaxar, bebe de sua xícara."

# game/script-a2-hanako.rpy:2646
translate pt_br a2_hanako_mad_hatter_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:2649
translate pt_br a2_hanako_mad_hatter_dd6c1788:

    # n "I think back to my chat with Misha the other day."
    n "Me lembro de minha conversa com a Misha outro dia."

# game/script-a2-hanako.rpy:2651
translate pt_br a2_hanako_mad_hatter_5fe1268c:

    # n "Is Hanako's behavior something to be concerned about, or is she just shy?"
    n "Será que o comportamento da Hanako é algo sobre o que se preocupar, ou ela é apenas tímida?"

# game/script-a2-hanako.rpy:2653
translate pt_br a2_hanako_mad_hatter_e6c818ac:

    # n "And then there was Lilly earlier this morning."
    n "E então teve a Lilly hoje mais cedo."

# game/script-a2-hanako.rpy:2655
translate pt_br a2_hanako_mad_hatter_b2b0aa22:

    # n "The concern from both of them seemed to be genuine, and they know the situation better than I."
    n "A preocupação das duas parecia genuína, e elas conhecem a situação melhor que eu."

# game/script-a2-hanako.rpy:2657
translate pt_br a2_hanako_mad_hatter_f893aad3:

    # n "But, really, how could I possibly help?"
    n "Mas de verdade, como eu poderia ajudar?"

# game/script-a2-hanako.rpy:2659
translate pt_br a2_hanako_mad_hatter_7919f76d:

    # n "I'm no plastic surgeon, so I can't really help her appearance. Nor am I a psychologist who can make her more sociable."
    n "Não sou um cirurgião plástico, então não posso ajudá-la com sua aparência. Nem sou um psicólogo que pode fazê-la mais sociável."

# game/script-a2-hanako.rpy:2661
translate pt_br a2_hanako_mad_hatter_6b966374:

    # n "So what the hell do Lilly and Misha want me to do?"
    n "Então o que diabos a Lilly e a Misha querem que eu faça?"

# game/script-a2-hanako.rpy:2663
translate pt_br a2_hanako_mad_hatter_ca2bdec6:

    # n "It's frustrating. Hanako and I are quickly becoming friends on our own accord, and because of that, it's like everyone wants me to solve all her problems."
    n "É frustrante. Hanako e eu estamos rapidamente nos tornando amigos por anuência nossa, e por causa disso, é como se todos quisessem que eu resolvesse todos os problemas dela."

# game/script-a2-hanako.rpy:2665
translate pt_br a2_hanako_mad_hatter_06c75d2a:

    # n "And I have no idea how to do that."
    n "E eu não tenho ideia de como fazer isso."

# game/script-a2-hanako.rpy:2667
translate pt_br a2_hanako_mad_hatter_55e6685b:

    # n "No one can cure my heart, nor Lilly's eyes, nor anyone who is here, in this school."
    n "Ninguém pode curar meu coração, ou os olhos da Lilly, ou qualquer outra pessoa que esteja aqui, nesta escola."

# game/script-a2-hanako.rpy:2669
translate pt_br a2_hanako_mad_hatter_f57eaa86:

    # n "However, I see no harm in becoming better friends with Hanako. Now that she's warming up to me I kind of enjoy hanging out with her."
    n "Entretanto, não vejo problema em fortalecer minha amizade com a Hanako. Agora que ela está se acostumando comigo, eu gosto de estar perto dela."

# game/script-a2-hanako.rpy:2672
translate pt_br a2_hanako_mad_hatter_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:2677
translate pt_br a2_hanako_mad_hatter_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:2680
translate pt_br a2_hanako_mad_hatter_00bbcaa4:

    # n "{vspace=120}Something about this makes me think about Lilly's question at breakfast."
    n "{vspace=120}Algo sobre isso me faz pensar na pergunta da Lilly durante o café da manhã."

# game/script-a2-hanako.rpy:2682
translate pt_br a2_hanako_mad_hatter_8e1b1645:

    # n "Why am I friends with Hanako?"
    n "Por que eu sou amigo da Hanako?"

# game/script-a2-hanako.rpy:2684
translate pt_br a2_hanako_mad_hatter_268a5761:

    # n "Lilly seems genuinely concerned for Hanako's well being, but it's not like I can do anything to help her."
    n "Lilly parece genuinamente preocupada com o bem-estar da Hanako, mas não é como se eu pudesse fazer qualquer coisa para ajudá-la."

# game/script-a2-hanako.rpy:2686
translate pt_br a2_hanako_mad_hatter_cc918a55:

    # n "As far as I can tell, her scars don't hold her back physically, and everyone I've met seems to have overcome their disabilities to some extent."
    n "Pelo que eu sei, suas cicatrizes não têm qualquer efeito em sua aptidão física, e todos que eu conheci aqui parecem ter superado suas deficiências em algum nível."

# game/script-a2-hanako.rpy:2688
translate pt_br a2_hanako_mad_hatter_16bc7f3a:

    # n "I don't have any ulterior motives to hang out with Hanako, we just share similar interests."
    n "Eu não tenho motivos maiores para andar com a Hanako, nós apenas compartilhamos de interesses similares."

# game/script-a2-hanako.rpy:2690
translate pt_br a2_hanako_mad_hatter_384a99ca:

    # n "{vspace=30}Isn't that enough?"
    n "{vspace=30}Não é o suficiente?"

# game/script-a2-hanako.rpy:2693
translate pt_br a2_hanako_mad_hatter_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:2699
translate pt_br a2_hanako_mad_hatter_481c50c2:

    # li "So, Hisao, are you enjoying yourself?"
    li "Então, Hisao, está apreciando estar aqui?"

# game/script-a2-hanako.rpy:2701
translate pt_br a2_hanako_mad_hatter_74a703c9:

    # "Lilly's words break me out of my reverie, and I take a second to reconsider where I am."
    "As palavras da Lilly me tiram de meu devaneio, e levo um segundo para rever onde estou."

# game/script-a2-hanako.rpy:2703
translate pt_br a2_hanako_mad_hatter_ae16d3cd:

    # "I'm in a room with two girls in their bedclothes. This is something to be enjoyed."
    "Estou em um quarto com duas garotas em suas roupas de cama. Isso é algo a ser apreciado."

# game/script-a2-hanako.rpy:2705
translate pt_br a2_hanako_mad_hatter_2a2dc2c5:

    # hi "Yeah, it's relaxing. Almost like I'm not in the school any more. Do you do this often?"
    hi "Sim, é relaxante. Quase como se eu não estivesse mais na escola. Vocês fazem isto sempre?"

# game/script-a2-hanako.rpy:2710
translate pt_br a2_hanako_mad_hatter_5e493ced:

    # li "Quite often, but not as often as we take tea in the school building."
    li "Quase sempre, mas não tanto quanto tomamos chá no prédio da escola mesmo."

# game/script-a2-hanako.rpy:2712
translate pt_br a2_hanako_mad_hatter_37a9ee7a:

    # "Considering they do that nearly every day, that's not a big surprise."
    "Considerando que elas fazem isso quase todo dia, não é uma grande surpresa."

# game/script-a2-hanako.rpy:2714
translate pt_br a2_hanako_mad_hatter_fd62a08a:

    # "As I move to take another sip from my teacup, I find it sadly empty."
    "Quando me movo para dar mais um gole de minha xícara, a encontro tristemente vazia."

# game/script-a2-hanako.rpy:2716
translate pt_br a2_hanako_mad_hatter_65e60fd2:

    # hi "That was delicious. Thank you Hanako, Lilly."
    hi "Estava delicioso. Obrigado, Hanako, Lilly."

# game/script-a2-hanako.rpy:2721
translate pt_br a2_hanako_mad_hatter_eb14f811:

    # ha "You're welcome."
    ha "De nada."

# game/script-a2-hanako.rpy:2726
translate pt_br a2_hanako_mad_hatter_8c7bed9e:

    # li "Yes, you're most welcome Hisao. It's nice to have a third person here."
    li "Sim, você é muito bem-vindo, Hisao. É legal ter uma terceira pessoa aqui."

# game/script-a2-hanako.rpy:2728
translate pt_br a2_hanako_mad_hatter_3edce04d:

    # hi "Well, any time you need someone to fill that position, I'm always available. Always."
    hi "Bem, quando precisarem de alguém para assumir essa posição, estou sempre disponível. Sempre."

# game/script-a2-hanako.rpy:2730
translate pt_br a2_hanako_mad_hatter_1aad795e:

    # "One must be sure to get one's point across in these circumstances."
    "Deve-se ter certeza de passar bem a parte principal da mensagem nessas circunstâncias."

# game/script-a2-hanako.rpy:2736
translate pt_br a2_hanako_mad_hatter_01a88cb9:

    # "Lilly lets loose a yawn, which she unsuccessfully hides with her hand."
    "Lilly deixa escapar um bocejo, que ela esconde de forma mal-sucedida com sua mão."

# game/script-a2-hanako.rpy:2741
translate pt_br a2_hanako_mad_hatter_df62ad4d:

    # li "Pardon me, I think I'm a little tired."
    li "Perdão, acho que estou um pouco cansada."

# game/script-a2-hanako.rpy:2746
translate pt_br a2_hanako_mad_hatter_656ff99b:

    # ha "I think we're all a little tired…"
    ha "Acho que estamos todos um pouco cansados…"

# game/script-a2-hanako.rpy:2751
translate pt_br a2_hanako_mad_hatter_3de06da5:

    # li "My my, how astute we are tonight, Hanako."
    li "Minha nossa, como estamos astutos esta noite, Hanako."

# game/script-a2-hanako.rpy:2756
translate pt_br a2_hanako_mad_hatter_18bf72c9:

    # li "We really should head to bed; we all have class tomorrow."
    li "Nós realmente deveríamos ir dormir; todos temos aula amanhã."

# game/script-a2-hanako.rpy:2758
translate pt_br a2_hanako_mad_hatter_874537c4:

    # hi "Yeah… I should go."
    hi "Sim… vou indo."

# game/script-a2-hanako.rpy:2763
translate pt_br a2_hanako_mad_hatter_5622699f:

    # li "Thank you for your presence, Hisao."
    li "Obrigada por sua presença, Hisao."

# game/script-a2-hanako.rpy:2768
translate pt_br a2_hanako_mad_hatter_b90df44e:

    # ha "Th… thanks. You'll come again?"
    ha "Ob… obrigada. Você virá outra vez?"

# game/script-a2-hanako.rpy:2770
translate pt_br a2_hanako_mad_hatter_927ea77b:

    # hi "Not even a whole army could stop me."
    hi "Nem mesmo um exército poderia me deter."

# game/script-a2-hanako.rpy:2775
translate pt_br a2_hanako_mad_hatter_df338e79:

    # li "I'm impressed by your determination, Hisao."
    li "Estou impressionada com sua determinação, Hisao."

# game/script-a2-hanako.rpy:2777
translate pt_br a2_hanako_mad_hatter_2af7bba8:

    # hi "Either way, you're right. We'd best get going."
    hi "De qualquer forma, vocês têm razão. Melhor irmos dormir."

# game/script-a2-hanako.rpy:2779
translate pt_br a2_hanako_mad_hatter_c4789be2:

    # "I stand up, and make for the door."
    "Eu levanto, e vou até a porta."

# game/script-a2-hanako.rpy:2784
translate pt_br a2_hanako_mad_hatter_5e7d84cf:

    # "Hanako gingerly stands up behind me."
    "Hanako cautelosamente se levanta atrás de mim."

# game/script-a2-hanako.rpy:2786
translate pt_br a2_hanako_mad_hatter_5f031343:

    # "I stop and face her."
    "Eu paro e viro."

# game/script-a2-hanako.rpy:2788
translate pt_br a2_hanako_mad_hatter_f3b42fd8:

    # hi "Are you coming with me?"
    hi "Você vem comigo?"

# game/script-a2-hanako.rpy:2795
translate pt_br a2_hanako_mad_hatter_8085a3c1:

    # "Hanako instantly blossoms into full blush."
    "Hanako instantaneamente floresce num rubor completo."

# game/script-a2-hanako.rpy:2800
translate pt_br a2_hanako_mad_hatter_e45f7741:

    # ha "No… I… not… this room… isn't…"
    ha "Não… eu… não… este quarto… não é…"

# game/script-a2-hanako.rpy:2802
translate pt_br a2_hanako_mad_hatter_48ff747d:

    # hi "It's okay, I was only joking."
    hi "Tudo bem, eu estava só brincando."

# game/script-a2-hanako.rpy:2807
translate pt_br a2_hanako_mad_hatter_5ad8a756:

    # ha "Oh… okay… good night…"
    ha "Oh… ok… boa noite…"

# game/script-a2-hanako.rpy:2812
translate pt_br a2_hanako_mad_hatter_7e7c816d:

    # li "Good night, Hanako. Good night, Hisao."
    li "Boa noite, Hanako. Boa noite, Hisao."
    

# game/script-a2-hanako.rpy:2814
translate pt_br a2_hanako_mad_hatter_67158daf:

    # hi "Night all."
    hi "Boa noite."

# game/script-a2-hanako.rpy:2816
translate pt_br a2_hanako_mad_hatter_6de05866:

    # "And with that, our tea party finishes."
    "E com isso, nossa festa termina."

# game/script-a2-hanako.rpy:2821
translate pt_br a2_hanako_mad_hatter_7891cde9:

    # "I'm still not sure what it is that Lilly wants me to do for Hanako, but I don't want to let her down."
    "Ainda não tenho certeza do que a Lilly quer que eu faça pela Hanako, mas não quero decepcioná-la."

# game/script-a2-hanako.rpy:2823
translate pt_br a2_hanako_mad_hatter_a5404c5c:

    # "I wait until the door has closed behind us before turning to Hanako."
    "Espero até que a porta atrás de nós se feche para virar para a Hanako."

# game/script-a2-hanako.rpy:2828
translate pt_br a2_hanako_mad_hatter_c6b2c385:

    # hi "Hey, Hanako, you know, you don't have to be nervous around me or anything."
    hi "Ei Hanako, sabe, você não precisa ficar nervosa perto de mim nem nada do tipo."

# game/script-a2-hanako.rpy:2830
translate pt_br a2_hanako_mad_hatter_432fb44c:

    # hi "I mean, we're friends, right?"
    hi "Quero dizer, somos amigos, certo?"

# game/script-a2-hanako.rpy:2835
translate pt_br a2_hanako_mad_hatter_dc9ff3a5:

    # ha "R-right. We're… friends."
    ha "C-certo. Somos… amigos."

# game/script-a2-hanako.rpy:2837
translate pt_br a2_hanako_mad_hatter_9e235b22:

    # hi "If you ever want to hang out or anything, just let me know. We still need to have that chess rematch, remember?"
    hi "Sempre que você quiser fazer algo, apenas me fale. Ainda precisamos ter aquela revanche no xadrez, lembra?"

# game/script-a2-hanako.rpy:2842
translate pt_br a2_hanako_mad_hatter_74d620de:

    # ha "S-sure…"
    ha "V-verdade…"

# game/script-a2-hanako.rpy:2847
translate pt_br a2_hanako_mad_hatter_a86606d5:

    # ha "B-but I don't think you'll win…"
    ha "Mas não acho que você vá vencer…"

# game/script-a2-hanako.rpy:2849
translate pt_br a2_hanako_mad_hatter_eed198ca:

    # hi "It wouldn't be any fun if it was easy."
    hi "Não teria graça se fosse fácil."

# game/script-a2-hanako.rpy:2854
translate pt_br a2_hanako_mad_hatter_81831ea4:

    # "Hanako seems to give a muted laugh, but she could have just as easily been exhaling."
    "Hanako parece dar uma risada muda, mas ela podia muito bem estar apenas exalando."

# game/script-a2-hanako.rpy:2856
translate pt_br a2_hanako_mad_hatter_9ddb4683:

    # ha "G-good night Hisao…"
    ha "B-boa noite, Hisao…"

# game/script-a2-hanako.rpy:2867
translate pt_br a2_hanako_mad_hatter_094aae14:

    # "With that, Hanako quickly retreats into her room, located next to Lilly's."
    "Com isso, Hanako rapidamente recua até seu quarto, localizado ao lado do da Lilly."

# game/script-a2-hanako.rpy:2869
translate pt_br a2_hanako_mad_hatter_446a4a22:

    # "I start to walk back to my dorm, but the simple act of walking seems to drain me of my energy."
    "Começo a andar de volta até meu quarto, mas o simples ato de andar parece drenar minha energia."

# game/script-a2-hanako.rpy:2874
translate pt_br a2_hanako_mad_hatter_9f4b3a07:

    # "I barely make it to my room before I am hit by a wave of exhaustion."
    "Mal chego até meu quarto antes de ser atingido por uma onda de exaustão."

# game/script-a2-hanako.rpy:2881
translate pt_br a2_hanako_mad_hatter_6b5aa2ed:

    # "I kick off my shoes, fall into bed and fall asleep by the time my head hits the pillow."
    "Eu tiro meus sapatos, caio na cama e pego no sono no momento em que minha cabeça atinge o travesseiro."

# game/script-a2-hanako.rpy:2895
translate pt_br a2_hanako_small_change_414460c8:

    # "I pull my door closed, ready for another day of classes."
    "Fecho minha porta, pronto para mais um dia de aula."

# game/script-a2-hanako.rpy:2905
translate pt_br a2_hanako_small_change_4ba5b253:

    # ke "Sleep well?"
    ke "Dormiu bem?"

# game/script-a2-hanako.rpy:2909
translate pt_br a2_hanako_small_change_00e9df53:

    # "Kenji's sudden arrival makes me jump, and I narrowly avoid butting heads with him."
    "A chegada repentina do Kenji me faz pular, e por pouco evito bater minha cabeça com a dele."

# game/script-a2-hanako.rpy:2911
translate pt_br a2_hanako_small_change_67f74c55:

    # "I know he has poor eyesight, but he knows who I am now. Does he still have to stand this close?"
    "Eu sei que ele tem uma má visão, mas ele sabe quem eu sou agora. Ele ainda tem que ficar tão perto?"

# game/script-a2-hanako.rpy:2916
translate pt_br a2_hanako_small_change_20f63de6:

    # hi "Oh. Yeah. Like a baby."
    hi "Oh. Sim. Como um bebê."

# game/script-a2-hanako.rpy:2921
translate pt_br a2_hanako_small_change_7ef7182e:

    # ke "Damn, why do people say that? Have you ever heard a baby sleep?"
    ke "Droga, por que as pessoas falam isso? Você já ouviu um bebê dormindo?"

# game/script-a2-hanako.rpy:2923
translate pt_br a2_hanako_small_change_0fd006f7:

    # ke "They scream. All night. Every night. Babies don't sleep well, ever."
    ke "Eles gritam. A noite toda. Toda noite. Bebês nunca dormem bem."

# game/script-a2-hanako.rpy:2925
translate pt_br a2_hanako_small_change_c2bbf865:

    # "Well, there goes my restful state. I have to remember to never use figures of speech with Kenji."
    "Bem, lá se vai meu sossego. Tenho que me lembrar de nunca usar figuras de linguagem com o Kenji."

# game/script-a2-hanako.rpy:2927
translate pt_br a2_hanako_small_change_8bd4126a:

    # hi "All right, I get your point. It was a figure of speech."
    hi "Certo, entendi o que quer dizer. Foi uma figura de linguagem."

# game/script-a2-hanako.rpy:2932
translate pt_br a2_hanako_small_change_18739701:

    # ke "Yeah, sure, whatever. Where were you last night? I had a favor to ask but you weren't around."
    ke "É, claro, tanto faz. Onde você estava ontem à noite? Eu tinha um favor pra te pedir mas você não estava por perto."

# game/script-a2-hanako.rpy:2934
translate pt_br a2_hanako_small_change_c7b163d4:

    # "For a split second I consider telling Kenji the truth; that I was spending time with Hanako and Lilly."
    "Por uma fração de segundo considero falar a verdade ao Kenji; que eu estava com a Hanako e a Lilly."

# game/script-a2-hanako.rpy:2936
translate pt_br a2_hanako_small_change_165818f1:

    # "Thankfully, that split second passes as soon as it came."
    "Agradecidamente, essa fração de segundo passa tão rápido quanto veio."

# game/script-a2-hanako.rpy:2938
translate pt_br a2_hanako_small_change_fbaeb729:

    # hi "I was just out. Checking out the local area and stuff. You know, recon."
    hi "Estava apenas fora. Checando a área daqui e tal. Você sabe, reconhecimento."

# game/script-a2-hanako.rpy:2943
translate pt_br a2_hanako_small_change_1055dda8:

    # ke "Good man, good. I knew you were the type to plan ahead…"
    ke "Boa, cara, boa. Sabia que você era do tipo que planeja com antecedência…"

# game/script-a2-hanako.rpy:2945
translate pt_br a2_hanako_small_change_b30f047b:

    # hi "Anyway, what was this favor you wanted?"
    hi "Enfim, qual era o favor que você queria?"

# game/script-a2-hanako.rpy:2950
translate pt_br a2_hanako_small_change_3c9a2998:

    # ke "I was going to get some take-out, but I needed change."
    ke "Eu ia pedir algo para comer, mas precisava de trocados."

# game/script-a2-hanako.rpy:2952
translate pt_br a2_hanako_small_change_1e70c0bb:

    # hi "Wait, what? I gave you money last week and you still haven't paid me back!"
    hi "Espera aí, o quê? Eu te dei dinheiro semana passada e você ainda não me pagou!"

# game/script-a2-hanako.rpy:2957
translate pt_br a2_hanako_small_change_2d15fe9e:

    # ke "Tch, and I was starting to think you were cool."
    ke "Tsc, e eu que estava começando a pensar que você era legal."

# game/script-a2-hanako.rpy:2959
translate pt_br a2_hanako_small_change_051e9fee:

    # "Kenji fishes around in his pocket and produces his wallet."
    "Kenji pesca sua carteira do bolso."

# game/script-a2-hanako.rpy:2961
translate pt_br a2_hanako_small_change_f8765421:

    # "As he counts out the 400 yen he owes me, I can clearly see at least two 10,000 yen notes."
    "Enquanto ele conta os 400 ienes que me deve, posso claramente ver duas notas de 10,000."

# game/script-a2-hanako.rpy:2963
translate pt_br a2_hanako_small_change_33b2e1d9:

    # hi "Hey, what the hell? Why are you borrowing money off me when you've got that much cash?"
    hi "Ei, que droga é essa? Por que você fica pedindo dinheiro emprestado de mim quando tem tudo isso?"

# game/script-a2-hanako.rpy:2965
translate pt_br a2_hanako_small_change_d12370b9:

    # "Kenji hisses a little, realizing that he's been had."
    "Kenji trava um pouco, percebendo que foi pego."

# game/script-a2-hanako.rpy:2967
translate pt_br a2_hanako_small_change_810df696:

    # ke "Get off my case, man. It's bad luck to break a big note for anything less than half its value. It's the tycoon's rule."
    ke "Sai do meu pé, cara. Traz má sorte trocar uma nota grande por qualquer coisa que não valha pelo menos metade do seu valor. É a regra do magnata."

# game/script-a2-hanako.rpy:2969
translate pt_br a2_hanako_small_change_f6977ad0:

    # ke "Last night's dinner is going to cost me seven years of bad luck. Seven years!"
    ke "O jantar de ontem à noite vai me custar sete anos de má sorte. Sete anos!"

# game/script-a2-hanako.rpy:2974
translate pt_br a2_hanako_small_change_b324007c:

    # ke "Don't you think that's enough cause to help someone out? I'd get a shorter sentence if I just stole the stuff."
    ke "Você não acha que isso é motivo o suficiente para ajudar alguém? Eu pegaria uma sentença menor se tive simplesmente roubado a parada."

# game/script-a2-hanako.rpy:2976
translate pt_br a2_hanako_small_change_9cade674:

    # "My common sense screams at me to say something to him, but thankfully I restrain myself."
    "Meu senso comum me grita para responder algo a ele, mas por sorte, me contenho."

# game/script-a2-hanako.rpy:2978
translate pt_br a2_hanako_small_change_133c5cd9:

    # "Arguing a point like this with Kenji will just lead to further and more complicated discussions."
    "Discutir sobre algum ponto com o Kenji irá apenas levar a mais discussões, e mais complicadas."

# game/script-a2-hanako.rpy:2980
translate pt_br a2_hanako_small_change_983456a8:

    # hi "Yeah, I guess you're right. Maybe you should plan these things a little better?"
    hi "É, acho que tem razão. Talvez você devesse planejar essas coisas um pouco melhor."

# game/script-a2-hanako.rpy:2985
translate pt_br a2_hanako_small_change_a2e7404e:

    # ke "Yeah man, I know. But I've just got so much stuff to do, it's hard. And you're never around any more so I'm on my own."
    ke "É, cara, eu sei. Mas eu tenho tanta coisa pra fazer, é difícil. E você nunca mais está por perto então fico por minha conta."

# game/script-a2-hanako.rpy:2987
translate pt_br a2_hanako_small_change_05c4b193:

    # ke "We're supposed to be brothers in brotherhood, remember?"
    ke "Deveríamos ser irmãos em irmandade, lembra?"

# game/script-a2-hanako.rpy:2989
translate pt_br a2_hanako_small_change_fbd10166:

    # hi "Yeah yeah, I get you. Global conspiracy and such. I'll keep my ear to the ground."
    hi "Sim, sim, entendo. Conspiração global e tudo mais. Vou me manter atento."

# game/script-a2-hanako.rpy:2994
translate pt_br a2_hanako_small_change_e506da83:

    # "Kenji draws close enough for me to get a clear whiff of his garlic-tainted breath."
    "Kenji chega perto o suficiente para que eu sinta uma baforada de seu hálito de alho."

# game/script-a2-hanako.rpy:2999
translate pt_br a2_hanako_small_change_7b669498:

    # ke "You'd better, man. You're already spending less time here. That's the first thing they do."
    ke "Melhor, cara. Você já está passando menos tempo aqui. Essa é a primeira coisa que eles fazem."

# game/script-a2-hanako.rpy:3001
translate pt_br a2_hanako_small_change_170906f1:

    # ke "They'll try to split us up. Divide and conquer. Sun Tzu said that."
    ke "Eles vão tentar nos separar. Dividir e conquistar. Sun Tzu disse isso."

# game/script-a2-hanako.rpy:3003
translate pt_br a2_hanako_small_change_142214b4:

    # hi "Roger that. Now, I've got to be going. I've got classes. You coming?"
    hi "Entendido. Agora tenho que ir andando. Tenho aula. Você vem?"

# game/script-a2-hanako.rpy:3008
translate pt_br a2_hanako_small_change_23061b4f:

    # ke "Nah, I'm tired. I stayed up all night just to make sure nothing was going to happen after splitting that note."
    ke "Nah, estou cansado. Fiquei acordado a noite toda para ter certeza que nada aconteceria depois de ter trocado aquela nota."

# game/script-a2-hanako.rpy:3010
translate pt_br a2_hanako_small_change_df06d837:

    # hi "As rational as ever, I see."
    hi "Racional como sempre, estou vendo."

# game/script-a2-hanako.rpy:3015
translate pt_br a2_hanako_small_change_bf3b976c:

    # ke "Whatever. Night."
    ke "Tanto faz. Boa noite."

# game/script-a2-hanako.rpy:3026
translate pt_br a2_hanako_small_change_5e8bf7f4:

    # "Kenji scurries back into his room, and I hear him throwing his locks as I walk down the hallway."
    "Kenji debanda de volta para seu quarto, e eu ouço ele trancando seus cadeados enquanto desço o corredor."

# game/script-a2-hanako.rpy:3040
translate pt_br a2_hanako_absenteeism_a5ef963c:

    # mu "…that is why some people can't roll their tongue, or why their second toe is longer than their big toe."
    mu "…é por isso que algumas pessoas não conseguem enrolar a língua, ou têm o segundo dedo do pé maior que o dedão."

# game/script-a2-hanako.rpy:3042
translate pt_br a2_hanako_absenteeism_2d0d59fd:

    # "Mutou beams a half-moon smile at us, obviously proud of his explanation of recessive genes."
    "Mutou irradia um enorme sorriso em nossa direção, obviamente orgulhoso de sua explicação sobre genes recessivos."

# game/script-a2-hanako.rpy:3044
translate pt_br a2_hanako_absenteeism_86a5f305:

    # "However, no matter how impressed he is at the science that defines who we are, the classroom seems to be reduced to a stupor."
    "Contudo, não importa o quanto ele se impressione com a ciência que define quem somos, a sala de aula parece reduzida a um estupor."

# game/script-a2-hanako.rpy:3046
translate pt_br a2_hanako_absenteeism_70e4914a:

    # "Why is it that a bad explanation can make even the most interesting thing seem worthless?"
    "Por que será que uma explicação ruim pode fazer até as coisas mais interessantes parecerem inúteis?"

# game/script-a2-hanako.rpy:3051
translate pt_br a2_hanako_absenteeism_b9f79c47:

    # "I can see Mutou deflate as he realizes that nothing he's said in the past half hour has sunk in."
    "Posso ver o Mutou se esvaziar enquanto percebe que nada do que ele falou na última meia hora foi absorvido."

# game/script-a2-hanako.rpy:3056
translate pt_br a2_hanako_absenteeism_92d824a6:

    # "Whispered conversations start to break the silence, and like an avalanche, the noise level in the class starts to rise."
    "Conversas em sussurros começam a quebram o silêncio, e como uma avalanche, o nível de barulho na sala começa a aumentar."

# game/script-a2-hanako.rpy:3061
translate pt_br a2_hanako_absenteeism_ff265982:

    # "Defeated, Mutou identifies some questions from the text book and sets to clearing off the blackboard."
    "Derrotado, Mutou identifica algumas questões do livro e começa a limpar o quadro negro."

# game/script-a2-hanako.rpy:3066
translate pt_br a2_hanako_absenteeism_88d11e22:

    # "Almost as if expected, Hanako packs up her things and leaves as soon as people start talking and laughing among themselves."
    "Quase como o esperado, Hanako arruma suas coisas e sai assim que as pessoas começam a conversar e rir entre si."

# game/script-a2-hanako.rpy:3068
translate pt_br a2_hanako_absenteeism_c6e110d8:

    # "The initial shock of seeing someone play so blatantly truant has started to fade, but it doesn't stop me from wondering."
    "O choque inicial de ver alguém tão descaradamente cabulador de aula já começou a passar, mas isso não me impede de refletir."

# game/script-a2-hanako.rpy:3070
translate pt_br a2_hanako_absenteeism_f039a358:

    # "Is she leaving because she doesn't want people to speak to her? Or is it just the thought of people around her shattering her peace?"
    "Ela está indo embora por que não quer que as pessoas falem com ela? Ou é apenas o fato das pessoas ao redor dela estarem tirando sua paz?"

# game/script-a2-hanako.rpy:3075
translate pt_br a2_hanako_absenteeism_4637668b:

    # "Before I can think about the topic any further, the lunch bells ring. I wonder if she was simply taking the opportunity to leave early."
    "Antes que eu possa pensar mais no assunto, o sinal de almoço toca. Me pergunto se ela simplesmente aproveitou para sair mais cedo."

# game/script-a2-hanako.rpy:3077
translate pt_br a2_hanako_absenteeism_67505965:

    # "The usual clamor of students exchanging books for lunch reverberates around the room, and while Misha is distracted, I grab my lunch and head out the door."
    "O clamor usual de estudantes trocando livros por seus almoços reverbera pela sala, e enquanto Misha está distraída, eu pego meu almoço e saio."

# game/script-a2-hanako.rpy:3087
translate pt_br a2_hanako_absenteeism_13e977ed:

    # "Lilly already sits in the tea room, setting out her lunch alone."
    "Lilly já está sentada na sala de chá, desempacotando seu almoço sozinha."

# game/script-a2-hanako.rpy:3089
translate pt_br a2_hanako_absenteeism_f27359ae:

    # hi "So, Hanako's not here then?"
    hi "Então a Hanako não está aqui?"

# game/script-a2-hanako.rpy:3094
translate pt_br a2_hanako_absenteeism_c18236b6:

    # li "Oh, Hisao, how are you? I haven't met Hanako since this morning, I'm afraid."
    li "Oh, Hisao, como você está? Não me encontro com a Hanako desde essa manhã."

# game/script-a2-hanako.rpy:3096
translate pt_br a2_hanako_absenteeism_ac291dd0:

    # "That's right, Hanako and Lilly live next to each other."
    "É verdade, os quartos da Hanako e da Lilly são vizinhos."

# game/script-a2-hanako.rpy:3098
translate pt_br a2_hanako_absenteeism_a7fdd4ca:

    # "Somehow I think their morning conversations are slightly more grounded than Kenji's ramblings."
    "Algo me diz que suas conversas matinais são um pouco mais fundamentadas do que os papos desconexos do Kenji."

# game/script-a2-hanako.rpy:3100
translate pt_br a2_hanako_absenteeism_4a4a0911:

    # hi "That's strange. She left class early, so I figured that she'd come here."
    hi "É estranho. Ela saiu mais cedo da aula, então pensei que tinha vindo aqui."

# game/script-a2-hanako.rpy:3105
translate pt_br a2_hanako_absenteeism_b6cb230a:

    # li "So she's still leaving class early…"
    li "Então ela ainda está saindo mais cedo da aula…"

# game/script-a2-hanako.rpy:3107
translate pt_br a2_hanako_absenteeism_febb31e4:

    # hi "Huh? Yeah, I've seen her do it a few times."
    hi "Hã? Sim, vi ela fazendo isso algumas vezes."

# game/script-a2-hanako.rpy:3114
translate pt_br a2_hanako_absenteeism_72d51a90:

    # "Lilly drops her head a little, and her tone of voice is notably depressed. It's very reminiscent of someone who is used to hearing bad news."
    "Lilly abaixa a cabeça um pouco, e seu tom de voz está notavelmente deprimido. Faz lembrar o de alguém já acostumado a ouvir notícias ruins."

# game/script-a2-hanako.rpy:3116
translate pt_br a2_hanako_absenteeism_2d4a5daa:

    # li "I was so sure that she'd stop doing that once you two became friends."
    li "Eu tinha tanta certeza de que ela pararia de fazer isso depois que vocês viraram amigos."

# game/script-a2-hanako.rpy:3121
translate pt_br a2_hanako_absenteeism_9ebd35ba:

    # li "Everyone has their own pace, I suppose."
    li "Todos tem seu tempo, eu suponho."

# game/script-a2-hanako.rpy:3123
translate pt_br a2_hanako_absenteeism_eb348c7b:

    # hi "Well, I was wondering about just that today. Why exactly does she leave?"
    hi "Bem, eu estava pensando sobre isso agora pouco. Por que exatamente ela sai?"

# game/script-a2-hanako.rpy:3128
translate pt_br a2_hanako_absenteeism_8d8c209e:

    # li "I'm not entirely sure myself. I personally think it's because she doesn't want to be put in a situation where she has to answer someone."
    li "Também não tenho certeza. Eu pessoalmente acho que é porque ela não quer se colocar numa situação onde tenha que responder a alguém."

# game/script-a2-hanako.rpy:3130
translate pt_br a2_hanako_absenteeism_18509307:

    # "I have a flashback of my first meeting with her, when I thought she looked like a cornered animal. Maybe I wasn't far from the truth."
    "Tenho um flashback do meu primeiro encontro com ela, quando eu pensei que ela se parecia com um animal acuado. Talvez eu não tenha me enganado muito."

# game/script-a2-hanako.rpy:3132
translate pt_br a2_hanako_absenteeism_376a7ec2:

    # hi "But she seems fine with talking to you, and with me… a bit…"
    hi "Mas ela parece bem quando fala com você, e comigo… um pouco…"

# game/script-a2-hanako.rpy:3137
translate pt_br a2_hanako_absenteeism_027f0015:

    # li "It's a little more complex than that. I imagine that the first thing most people ask her about is her scars, and what happened."
    li "É um pouco mais complexo que isso. Eu imagino que a primeira coisa que as pessoas perguntem a ela seja sobre suas cicatrizes, e o que aconteceu."

# game/script-a2-hanako.rpy:3139
translate pt_br a2_hanako_absenteeism_2e968ca2:

    # li "She rarely talks about it with me, but I can tell that she doesn't like to remember whatever happened back then."
    li "Ela raramente fala sobre isso comigo, mas percebo que ela não gosta de lembrar o que aconteceu."

# game/script-a2-hanako.rpy:3144
translate pt_br a2_hanako_absenteeism_feee00ed:

    # li "Leaving class and running away from discussions is her preemptive strike, if you will."
    li "Sair da aula e fugir das discussões é sua manobra preemptiva, colocando de outra forma."

# game/script-a2-hanako.rpy:3146
translate pt_br a2_hanako_absenteeism_cb207f84:

    # hi "Huh… so then how does that explain her talking to me?"
    hi "Hm… então como isso explica ela falando comigo?"

# game/script-a2-hanako.rpy:3151
translate pt_br a2_hanako_absenteeism_8a0498bf:

    # li "You said it yourself yesterday at breakfast; you tried to ignore her scars. Once she saw that you weren't going to ask her about that, she opened herself up to you."
    li "Você mesmo disse ontem no café da manhã; você tentou ignorar as cicatrizes dela. Uma vez que ela viu que você não ia perguntar sobre isso, ela se abriu para você."

# game/script-a2-hanako.rpy:3153
translate pt_br a2_hanako_absenteeism_653ef7f0:

    # hi "Hrm, I guess you're right. Maybe. I dunno. You know her better than I, so I'll take your word for it."
    hi "Hmm, acho que tem razão. Talvez. Não sei. Você sabe melhor que eu, então vou confiar em sua palavra."

# game/script-a2-hanako.rpy:3160
translate pt_br a2_hanako_absenteeism_e0b5d357:

    # li "I wouldn't worry about that. I'm sure you'll come to know her as well as I do soon enough."
    li "Eu não me preocuparia com isso. Tenho certeza que você irá conhecer ela tão bem quanto eu em breve."

# game/script-a2-hanako.rpy:3165
translate pt_br a2_hanako_absenteeism_80d87810:

    # li "I welcome the prospect of her having a new friend, and the two of you have such similar interests…"
    li "Fico feliz com o prospecto dela ter um novo amigo, e vocês dois tem interesses bem similares…"

# game/script-a2-hanako.rpy:3167
translate pt_br a2_hanako_absenteeism_c800c091:

    # hi "Well, I hardly count reading as a team sport. It is good to have company, though."
    hi "Bem, eu não contaria ler como um esporte em equipe. Mas é bom ter companhia."

# game/script-a2-hanako.rpy:3172
translate pt_br a2_hanako_absenteeism_f8905f40:

    # li "That's my point. Hanako is still an average person at heart. She also wants company at times like that."
    li "Esse é meu ponto. A Hanako ainda é uma pessoa como qualquer outra por dentro. Ela também quer companhia em momentos assim."

# game/script-a2-hanako.rpy:3174
translate pt_br a2_hanako_absenteeism_c9c67089:

    # hi "Huh, I see. I think. To be honest, both of you still confuse me a little."
    hi "Uhum, entendo. Acho. Pra ser honesto, vocês duas ainda me confundem um pouco."

# game/script-a2-hanako.rpy:3179
translate pt_br a2_hanako_absenteeism_37c38658:

    # li "That's only natural, Hisao. We've only known each other for a little while; it's unreasonable to expect you to understand us, just as we can't understand you."
    li "É algo natural, Hisao. Nos conhecemos apenas há pouco; é irracional esperar que você nos entenda, da mesma forma que nós não entendemos a você."

# game/script-a2-hanako.rpy:3184
translate pt_br a2_hanako_absenteeism_2fcfb65b:

    # li "But that is half the fun of becoming friends, right?"
    li "Mas isso é metade da graça de nos tornamos amigos, certo?"

# game/script-a2-hanako.rpy:3186
translate pt_br a2_hanako_absenteeism_00cdd77f:

    # hi "Yes, yes it is."
    hi "Sim, é mesmo."

# game/script-a2-hanako.rpy:3191
translate pt_br a2_hanako_absenteeism_666b085a:

    # li "Although… I suppose there is the matter of us being opposite genders. Men and women do seem to confuse each other quite often."
    li "Embora… suponho que haja a questão de sermos de gêneros opostos. Homens e mulheres parecem confundir um ao outro bem frequentemente."

# game/script-a2-hanako.rpy:3193
translate pt_br a2_hanako_absenteeism_b6ee6083:

    # "She says this with a light giggle, finding amusement at the odd little details of life."
    "Ela diz isso com uma risadinha, achando graça dos pequenos detalhes estranhos da vida."

# game/script-a2-hanako.rpy:3198
translate pt_br a2_hanako_absenteeism_6d0a7ee4:

    # li "I hope you don't mind, but I'm going to start eating."
    li "Espero que não se importe, mas vou começar a comer."

# game/script-a2-hanako.rpy:3200
translate pt_br a2_hanako_absenteeism_b30cddcd:

    # hi "No, go ahead, I think I'll eat something too. I've got some books I want to drop back at the library before classes start, so I'd better get a move on."
    hi "Não, vá em frente, acho que vou comer alguma coisa também. Tenho que devolver alguns livros à biblioteca antes que as aulas recomecem, então melhor eu começar logo."

# game/script-a2-hanako.rpy:3205
translate pt_br a2_hanako_absenteeism_8788f0b1:

    # li "You'll probably find Hanako there as well. If you do see her, can you tell her to stop by my room later tonight? I'd like to talk to her."
    li "Você provavelmente achará a Hanako lá também. Se for o caso, pode dizer para ela ir ao meu quarto hoje à noite? Gostaria de falar com ela."

# game/script-a2-hanako.rpy:3207
translate pt_br a2_hanako_absenteeism_db0c25a0:

    # hi "You're not coming?"
    hi "Você não vem?"

# game/script-a2-hanako.rpy:3212
translate pt_br a2_hanako_absenteeism_c3ad30ae:

    # li "Unfortunately I have a class representatives' meeting later, so I'll be gone as soon as I've finished my lunch."
    li "Infelizmente tenho uma reunião dos representantes de classe, então vou ter que ir andando assim que acabar de almoçar."

# game/script-a2-hanako.rpy:3214
translate pt_br a2_hanako_absenteeism_94008d93:

    # hi "Okay then, if I don't see her in the library then I'll tell her in class. I'm sure she'll be back after lunch."
    hi "Ok, então, se eu não a vir na biblioteca digo a ela na sala mesmo. Tenho certeza que ela voltará depois do almoço."

# game/script-a2-hanako.rpy:3216
translate pt_br a2_hanako_absenteeism_0ee52a58:

    # "We fall silent as we start to eat, and I take a second to reflect on our conversation."
    "Nos silenciamos enquanto começamos a comer, e eu paro para refletir sobre nossa conversa um segundo."

# game/script-a2-hanako.rpy:3218
translate pt_br a2_hanako_absenteeism_6740b049:

    # "I've always thought that Hanako's shyness was simply due to her being self-conscious of her scars."
    "Sempre pensei que a timidez da Hanako se desse simplesmente por ela sentir vergonha por causa de suas cicatrizes."

# game/script-a2-hanako.rpy:3220
translate pt_br a2_hanako_absenteeism_d2fe5666:

    # "But that is a pretty superficial way of looking at her."
    "Mas esta é uma maneira bem superficial de olhar para ela."

# game/script-a2-hanako.rpy:3222
translate pt_br a2_hanako_absenteeism_ca1b8f85:

    # "Just when I thought I was able to see through the fog of Lilly and Hanako, I realize that I'm more lost than when I started."
    "Bem quando eu pensei que poderia ver através do nevoeiro da Lilly e da Hanako, percebo estar mais perdido do que quando comecei."

# game/script-a2-hanako.rpy:3224
translate pt_br a2_hanako_absenteeism_f2ef4006:

    # "Lilly quickly finishes her lunch, acutely aware of her meeting. I don't blame her."
    "Lilly termina rapidamente seu almoço, agudamente ciente de sua reunião. Não a culpo."

# game/script-a2-hanako.rpy:3226
translate pt_br a2_hanako_absenteeism_dfa74fe6:

    # "Shizune is most likely going to be there, and I doubt she wants to give her the satisfaction of another argument."
    "Shizune muito provavelmente estará lá, e duvido que ela queira dar a ela a satisfação de ter o que apontar."

# game/script-a2-hanako.rpy:3231
translate pt_br a2_hanako_absenteeism_cffbe383:

    # li "I must be off. Same time tomorrow?"
    li "Preciso ir. Mesma hora amanhã?"

# game/script-a2-hanako.rpy:3233
translate pt_br a2_hanako_absenteeism_55189750:

    # hi "Same time, same channel. I'd better head off too; I don't want to risk being late."
    hi "Mesma hora, mesmo canal. Melhor eu ir também; não quero arriscar me atrasar."

# game/script-a2-hanako.rpy:3243
translate pt_br a2_hanako_absenteeism_9e97d45e:

    # "Lilly smiles gently, picks up her cane and walks out into the hall."
    "Lilly sorri suavemente, pega sua bengala e vai embora pelo corredor."

# game/script-a2-hanako.rpy:3252
translate pt_br a2_hanako_equivalent_exchange_5c2dc0ea:

    # "I turn my back on Lilly as we head in opposite directions. For some reason I find myself hoping she doesn't get into another fight with Shizune."
    "Viro minhas costas para a Lilly enquanto vamos em direções opostas. Por alguma razão me pego desejando que ela não entre em outra briga com a Shizune."

# game/script-a2-hanako.rpy:3254
translate pt_br a2_hanako_equivalent_exchange_8df37b47:

    # "As much as I like Lilly, Shizune and Misha have been pretty instrumental in helping me adjust, even if half of our conversations are thinly-veiled recruitment attempts."
    "Por mais que eu goste da Lilly, Shizune e Misha contribuíram muito para minha adaptação, mesmo que metade de nossas conversas sejam tentativas de me recrutar mal disfarçadas."

# game/script-a2-hanako.rpy:3256
translate pt_br a2_hanako_equivalent_exchange_d2d4462e:

    # "Then again, I barely know either of them. Maybe they were previously leaders of some kind of secret society, but their love for each other drove them apart…"
    "Porém, mal conheço elas. Talvez elas tenham sido antigas líderes de algum tipo de sociedade secreta, mas seu amor uma pela outra as separou…"

# game/script-a2-hanako.rpy:3258
translate pt_br a2_hanako_equivalent_exchange_da6bfc95:

    # "Man, I need to stop reading cheap fiction. It's rotting my brain. Either that or I've got to move away from Kenji and his bad influence."
    "Cara, preciso parar de ler ficção barata. Está apodrecendo meu cérebro. Ou isso ou tenho que me afastar do Kenji e sua influência ruim."

# game/script-a2-hanako.rpy:3260
translate pt_br a2_hanako_equivalent_exchange_11a6205a:

    # "It's sad that I can't tell the two apart any more."
    "É triste que eu não saiba mais diferenciar entre esses dois."

# game/script-a2-hanako.rpy:3267
translate pt_br a2_hanako_equivalent_exchange_cc6423aa:

    # "I slide my books down the return chute and they crash into the cart with a pleasant thud."
    "Escorrego meus livros pela calha de devolução e eles batem no carrinho provocando um ruído agradável."

# game/script-a2-hanako.rpy:3274
translate pt_br a2_hanako_equivalent_exchange_ba97ce0e:

    # "Yuuko, however, doesn't seem as impressed as I."
    "Yuuko, contudo, não parece tão impressionada como eu."

# game/script-a2-hanako.rpy:3276
translate pt_br a2_hanako_equivalent_exchange_2692f86d:

    # yu "H-Hisao! You scared me!"
    yu "H-Hisao! Você me assustou!"

# game/script-a2-hanako.rpy:3278
translate pt_br a2_hanako_equivalent_exchange_bcb4e532:

    # hi "Sorry, I thought you would be used to that by now. Or is the literacy level here so low that nobody borrows any books?"
    hi "Desculpe, pensei que você já estivesse acostumada com isso. Ou será que o nível de alfabetização aqui é tão baixo que ninguém pega nenhum livro?"

# game/script-a2-hanako.rpy:3283
translate pt_br a2_hanako_equivalent_exchange_a83143dc:

    # yu "Huh? No I think everyone here can read fine…"
    yu "Hum? Não, acho que todos aqui sabem ler sem problemas…"

# game/script-a2-hanako.rpy:3285
translate pt_br a2_hanako_equivalent_exchange_e99e2a3c:

    # hi "Yeah… never mind."
    hi "É… deixa pra lá."

# game/script-a2-hanako.rpy:3287
translate pt_br a2_hanako_equivalent_exchange_6c4c9be3:

    # "There are some battles that you can never win. Trying to explain jokes is one of them. My Dad taught me that the hard way."
    "Há batalhas que você não pode vencer. Tentar explicar piadas é uma delas. Meu pai me ensinou isso do modo difícil."

# game/script-a2-hanako.rpy:3289
translate pt_br a2_hanako_equivalent_exchange_674d9c65:

    # hi "Say, Yuuko, have you seen Hanako about? She left class early but she wasn't in her usual hiding place."
    hi "Ei, Yuuko, viu a Hanako por aí? Ela saiu da aula mais cedo mas não estava em seu esconderijo usual."

# game/script-a2-hanako.rpy:3294
translate pt_br a2_hanako_equivalent_exchange_9a1b83cd:

    # yu "I think I saw her sneak in before lunch…"
    yu "Acho que vi ela entrando antes do almoço…"

# game/script-a2-hanako.rpy:3299
translate pt_br a2_hanako_equivalent_exchange_5e531f24:

    # yu "Oh! But I'm not supposed to tell anyone that!"
    yu "Ah! Mas não era para eu contar isso para ninguém!"

# game/script-a2-hanako.rpy:3301
translate pt_br a2_hanako_equivalent_exchange_6cac9a59:

    # hi "I just told you that I saw her leave, no need to stress out…"
    hi "Eu acabei de te falar que vi ela indo embora, não precisa se estressar…"

# game/script-a2-hanako.rpy:3306
translate pt_br a2_hanako_equivalent_exchange_0bc10676:

    # yu "Oh… of course. She's probably in the back."
    yu "Oh… claro. Ela provavelmente está lá atrás."

# game/script-a2-hanako.rpy:3308
translate pt_br a2_hanako_equivalent_exchange_23326cfe:

    # hi "Thanks. Get any new books in recently?"
    hi "Obrigado. Chegou algum livro recentemente?"

# game/script-a2-hanako.rpy:3313
translate pt_br a2_hanako_equivalent_exchange_575cb9c9:

    # yu "No, sorry. I'll let you know when we do, though."
    yu "Não, sinto muito. Mas te informo quando chegar algum."

# game/script-a2-hanako.rpy:3315
translate pt_br a2_hanako_equivalent_exchange_16a7dec2:

    # hi "Okay."
    hi "Ok."

# game/script-a2-hanako.rpy:3317
translate pt_br a2_hanako_equivalent_exchange_2d2554e6:

    # "If there's one thing I know about librarians, part-time or otherwise, it's that they appreciate people who take a genuine interest in their work."
    "Se tem uma coisa que eu sei sobre bibliotecários, de meio expediente ou não, é que eles apreciam pessoas que se interessam genuinamente por seus trabalhos."

# game/script-a2-hanako.rpy:3325
translate pt_br a2_hanako_equivalent_exchange_841b50b9:

    # "I walk the now-familiar path to Hanako's reading nook, picking out a few titles along the way."
    "Ando pelo agora familiar caminho até o recanto de leitura da Hanako, escolhendo alguns títulos pelo caminho."

# game/script-a2-hanako.rpy:3327
translate pt_br a2_hanako_equivalent_exchange_48dbde7d:

    # "Sometimes I find it hard to discover a book that will interest me among the shelves. An author's name and a two-word title don't mean much in a sea of similar words."
    "Às vezes acho difícil achar algo que me interesse pelas estantes. Um nome de autor e um título de duas palavras não significam muito num mar de palavras semelhantes."

# game/script-a2-hanako.rpy:3329
translate pt_br a2_hanako_equivalent_exchange_0e555f9a:

    # "For that reason, I sometimes re-read books that I read in the past. Better to bet on the favorite than a new runner."
    "Por isso, eu às vezes releio livros que já li no passado. Melhor apostar num favorito do que num competidor novo."

# game/script-a2-hanako.rpy:3331
translate pt_br a2_hanako_equivalent_exchange_40cdad86:

    # "An unfamiliar title from a familiar author peeks out among the spines of its neighbors, so I remove it from the shelf."
    "Um título desconhecido de um autor familiar espreita por entre as lombadas de seus vizinhos, então o removo da estante."

# game/script-a2-hanako.rpy:3333
translate pt_br a2_hanako_equivalent_exchange_323ebc25:

    # "At least I'm not going over old material."
    "Pelo menos não estarei passando por material antigo."

# game/script-a2-hanako.rpy:3338
translate pt_br a2_hanako_equivalent_exchange_3a836703:

    # "As expected, Hanako sits on her beanbag, buried deep in a copy of 'Dance Dance Dance.'"
    "Como o esperado, Hanako está sentada em seu puff, vidrada em sua cópia de “Dance Dance Dance.”"

# game/script-a2-hanako.rpy:3340
translate pt_br a2_hanako_equivalent_exchange_d5ff4c39:

    # hi "Hi Hanako. How's it going?"
    hi "Oi, Hanako. Como vão as coisas?"

# game/script-a2-hanako.rpy:3342
translate pt_br a2_hanako_equivalent_exchange_0e7a2da3:

    # "I fight back the urge to ask why she left class early. If Lilly's suspicions were right, then asking her about that could have the opposite effect."
    "Eu luto contra a vontade de perguntar por que ela deixou a classe mais cedo. Se as suspeitas da Lilly estavam certas, então perguntar sobre isso pode ter o efeito oposto."

# game/script-a2-hanako.rpy:3344
translate pt_br a2_hanako_equivalent_exchange_3d528b66:

    # "Best to leave it for the time being. Sometimes the best way to get an answer from someone is to never ask the question."
    "Melhor deixar isso pra lá por enquanto. Às vezes a melhor forma de se conseguir uma resposta de alguém é nunca perguntando."

# game/script-a2-hanako.rpy:3349
translate pt_br a2_hanako_equivalent_exchange_fbc1a5ee:

    # ha "Hello, H-Hisao. I'm fine."
    ha "Oi, H-Hisao. Bem."

# game/script-a2-hanako.rpy:3351
translate pt_br a2_hanako_equivalent_exchange_1442a777:

    # "Something seems off, and after a couple of seconds, I realize what it is. Hanako's smiling."
    "Algo parece fora do normal, e depois de uns segundos, percebo o que é. A Hanako está sorrindo."

# game/script-a2-hanako.rpy:3353
translate pt_br a2_hanako_equivalent_exchange_ee8d27a8:

    # "She looks as if she's pleased to see me. It's a nice change from the usual, instinctively frightened reaction, and something I hope I can see more of as we get to know each other better."
    "Ela parece feliz em me ver. É uma boa mudança em relação à reação instintivamente assustada costumeira, e algo que eu espero ver mais vezes agora que estamos nos conhecendo melhor."

# game/script-a2-hanako.rpy:3355
translate pt_br a2_hanako_equivalent_exchange_3ebf617c:

    # hi "Good to hear. How's that book? I've heard it's a trip."
    hi "Que bom. Esse livro é bom? Ouvi falar que é a maior viagem."

# game/script-a2-hanako.rpy:3357
translate pt_br a2_hanako_equivalent_exchange_7ce63cc2:

    # ha "I-it's good… I think."
    ha "É-é bom… eu acho."

# game/script-a2-hanako.rpy:3359
translate pt_br a2_hanako_equivalent_exchange_879bd045:

    # ha "I've only j-just started it, so I d-don't really know."
    ha "Eu acabei de c-começar a ler, então ainda n-não sei."

# game/script-a2-hanako.rpy:3361
translate pt_br a2_hanako_equivalent_exchange_2aefd36e:

    # hi "Fair enough. Let me know how it goes; I may borrow it once you're done."
    hi "É justo. Me diga o que achou depois; eu posso querer pegar depois que você terminar."

# game/script-a2-hanako.rpy:3363
translate pt_br a2_hanako_equivalent_exchange_ff70d1cd:

    # ha "S-sure."
    ha "T-tá bom."

# game/script-a2-hanako.rpy:3365
translate pt_br a2_hanako_equivalent_exchange_6e5ab4a7:

    # "There's a good fifteen minutes left in lunch. Not enough to really get into a book, but too much to stand around doing nothing."
    "Ainda restam uns bons quinze minutos do intervalo de almoço. Não é o suficiente para começar uma nova leitura direito, mas é muito para ficar parado sem fazer nada."

# game/script-a2-hanako.rpy:3370
translate pt_br a2_hanako_equivalent_exchange_099755f6:

    # "And Hanako's already returned to her reading, so I doubt I'll get much conversation from her."
    "E Hanako já voltou à sua leitura, então não acho que vou conseguir muita conversa com ela."

# game/script-a2-hanako.rpy:3372
translate pt_br a2_hanako_equivalent_exchange_74bf9165:

    # "Oh well, I'd better make myself comfortable."
    "É isso aí, melhor eu ficar mais confortável."

# game/script-a2-hanako.rpy:3376
translate pt_br a2_hanako_equivalent_exchange_26e24156:

    # "I slouch into a beanbag and crack open my book."
    "Eu me esparramo num puff e abro meu livro."

# game/script-a2-hanako.rpy:3378
translate pt_br a2_hanako_equivalent_exchange_7677bb0b:

    # "The familiar style of the author leaps out at me from the very first line. As the sentences turn into paragraphs, I start to relax a little."
    "O estilo familiar do autor salta aos meus olhos já na primeira linha. À medida que as sentenças se tornam parágrafos, começo a relaxar um pouco."

# game/script-a2-hanako.rpy:3382
translate pt_br a2_hanako_equivalent_exchange_22e4f130:

    # "But no matter how I try, I can't seem to get myself into the atmosphere of the book."
    "Mas não importa o quanto eu tente, pareço não conseguir entrar na atmosfera do livro."

# game/script-a2-hanako.rpy:3384
translate pt_br a2_hanako_equivalent_exchange_255a61dd:

    # "This is partly due to the lack of time, but the more distracting factor is Hanako."
    "Isso acontece parcialmente devido à falta de tempo, mas o fator mais distrativo é a Hanako."

# game/script-a2-hanako.rpy:3392
translate pt_br a2_hanako_equivalent_exchange_640b70b1:

    # "Every ten or so seconds she peers over the top of her book, but when our eyes meet she quickly ducks behind the covers."
    "Mais ou menos a cada dez segundos ela espia por cima do seu livro, mas quando nossos olhos se encontram ela rapidamente se esconde por trás da capa dele."

# game/script-a2-hanako.rpy:3394
translate pt_br a2_hanako_equivalent_exchange_999fbeb1:

    # "I guess she did want to talk about something after all."
    "Acho que ela queria mesmo conversar sobre algo no fim das contas."

# game/script-a2-hanako.rpy:3399
translate pt_br a2_hanako_equivalent_exchange_f8f384f1:

    # hi "What's up? You look like a prairie dog on lookout."
    hi "O que houve? Você está parecendo um lobo à espreita."

# game/script-a2-hanako.rpy:3406
translate pt_br a2_hanako_equivalent_exchange_f630accd:

    # ha "N-… it's nothing."
    ha "N-… não é nada."

# game/script-a2-hanako.rpy:3408
translate pt_br a2_hanako_equivalent_exchange_608f5117:

    # hi "I've told you before, 'nothing' means 'something' when you say it like that."
    hi "Já te disse antes, “nada” significa “algo” quando dito dessa forma."

# game/script-a2-hanako.rpy:3413
translate pt_br a2_hanako_equivalent_exchange_aec32af1:

    # "Hanako squirms a little in her beanbag, hoping that by changing her position she'll find the words she's looking for."
    "Hanako se contorce um pouco no seu puff, esperando que ao trocar sua posição ela possa achar as palavras que procura."

# game/script-a2-hanako.rpy:3418
translate pt_br a2_hanako_equivalent_exchange_792e9b61:

    # ha "I… I was in an accident."
    ha "Eu… eu sofri um acidente."

# game/script-a2-hanako.rpy:3420
translate pt_br a2_hanako_equivalent_exchange_085f70ab:

    # hi "Accident? Just now? Are you all right?"
    hi "Acidente? Agora? Você está bem?"

# game/script-a2-hanako.rpy:3425
translate pt_br a2_hanako_equivalent_exchange_0d38ccce:

    # "Hanako shakes her head, her hair flowing around her shoulders in wisps of amethyst on a background of pale and dark flesh."
    "Hanako balança a cabeça negativamente, seu cabelo esvoaçando por cima de seus ombros como tons de ametista por cima de um fundo de pele pálida e escura."

# game/script-a2-hanako.rpy:3430
translate pt_br a2_hanako_equivalent_exchange_88aaa4a3:

    # ha "N-no. When I was y-younger."
    ha "N-não. Quando eu era mais n-nova."

# game/script-a2-hanako.rpy:3434
translate pt_br a2_hanako_equivalent_exchange_8d4ce2bf:

    # "Realization crashes into me like a semi."
    "A compreensão do assunto me atinge como um trem."

# game/script-a2-hanako.rpy:3436
translate pt_br a2_hanako_equivalent_exchange_38beb042:

    # ha "When I… when I was…"
    ha "Quando eu… quando eu tinha…"

# game/script-a2-hanako.rpy:3438
translate pt_br a2_hanako_equivalent_exchange_e8b16f5b:

    # hi "It's all right Hanako, you don't have to tell me anything if you don't want to…"
    hi "Está tudo bem, Hanako, você não precisa me contar nada se não quiser…"

# game/script-a2-hanako.rpy:3440
translate pt_br a2_hanako_equivalent_exchange_5bc16071:

    # "Again she shakes her head."
    "Ela balança a cabeça negativamente de novo."

# game/script-a2-hanako.rpy:3445
translate pt_br a2_hanako_equivalent_exchange_3b36a0d5:

    # ha "N-no. I want… I have to tell you."
    ha "N-não. Eu quero… eu tenho que te contar."

# game/script-a2-hanako.rpy:3452
translate pt_br a2_hanako_equivalent_exchange_e7a3777b:

    # ha "When I was young… I was in a fire."
    ha "Quando eu era nova… estive em um incêndio."

# game/script-a2-hanako.rpy:3454
translate pt_br a2_hanako_equivalent_exchange_81215d0d:

    # ha "M-my house b-burned down, and I nearly… I nearly didn't make it."
    ha "M-minha casa p-pegou fogo, e eu quase… quase não consegui escapar."

# game/script-a2-hanako.rpy:3460
translate pt_br a2_hanako_equivalent_exchange_0faf065d:

    # ha "A-after that… I was alone…"
    ha "D-depois disso… eu estava sozinha…"

# game/script-a2-hanako.rpy:3468
translate pt_br a2_hanako_equivalent_exchange_fe3d5e06:

    # "Hanako's eyes glisten in the dim light of the library, and I reach out to grasp her hand."
    "Os olhos de Hanako reluzem na luz opaca da livraria, e eu avanço para segurar sua mão."

# game/script-a2-hanako.rpy:3470
translate pt_br a2_hanako_equivalent_exchange_acffb714:

    # hi "It's okay, Hanako. You don't have to keep going."
    hi "Está tudo bem, Hanako. Você não precisa continuar."

# game/script-a2-hanako.rpy:3475
translate pt_br a2_hanako_equivalent_exchange_64fa94c8:

    # ha "B-but… I have to…"
    ha "M-mas… eu preciso…"

# game/script-a2-hanako.rpy:3477
translate pt_br a2_hanako_equivalent_exchange_28ec15f7:

    # hi "Why? What brought this on?"
    hi "Por quê? O que trouxe isso à tona?"

# game/script-a2-hanako.rpy:3482
translate pt_br a2_hanako_equivalent_exchange_6546120e:

    # ha "L-Last night Lilly t-told me about your heart…"
    ha "O-ontem à noite a Lilly m-me contou sobre seu coração…"

# game/script-a2-hanako.rpy:3487
translate pt_br a2_hanako_equivalent_exchange_e266b502:

    # ha "A-and I… I didn't think it was f-fair."
    ha "E-e eu… não achei que isso fosse j-justo."

# game/script-a2-hanako.rpy:3489
translate pt_br a2_hanako_equivalent_exchange_c8114f15:

    # hi "Fair?"
    hi "Justo?"

# game/script-a2-hanako.rpy:3494
translate pt_br a2_hanako_equivalent_exchange_756e589a:

    # ha "T-that I knew about you b-but you didn't know about me…"
    ha "Q-que eu soubesse sobre você m-mas você não soubesse sobre mim…"

# game/script-a2-hanako.rpy:3496
translate pt_br a2_hanako_equivalent_exchange_50d4a94b:

    # "I squeeze Hanako's hand a little."
    "Eu aperto um pouco a mão da Hanako."

# game/script-a2-hanako.rpy:3498
translate pt_br a2_hanako_equivalent_exchange_fb3ba6d5:

    # hi "Don't be silly. But yes, I have a heart condition."
    hi "Não seja boba. Mas sim, eu tenho um problema de coração."

# game/script-a2-hanako.rpy:3500
translate pt_br a2_hanako_equivalent_exchange_40ebfd87:

    # "I lean a little closer to Hanako."
    "Chego um pouco mais perto da Hanako."

# game/script-a2-hanako.rpy:3502
translate pt_br a2_hanako_equivalent_exchange_9bb46ab3:

    # hi "What I didn't tell Lilly is that I had my first attack when a girl confessed to me."
    hi "O que eu não contei à Lilly é que tive meu primeiro ataque quando uma garota se confessou para mim."

# game/script-a2-hanako.rpy:3504
translate pt_br a2_hanako_equivalent_exchange_0502808f:

    # "I smile a little to break the tension."
    "Eu sorrio um pouco para quebrar a tensão."

# game/script-a2-hanako.rpy:3509
translate pt_br a2_hanako_equivalent_exchange_b6cc3c0b:

    # ha "R-really?"
    ha "S-sério?"

# game/script-a2-hanako.rpy:3511
translate pt_br a2_hanako_equivalent_exchange_43ca3443:

    # hi "Really. I haven't heard from her for a while though, so I guess it's all over."
    hi "Sério. Mas já faz um bom tempo que não sei de nada dela, então acho que está tudo acabado."

# game/script-a2-hanako.rpy:3513
translate pt_br a2_hanako_equivalent_exchange_6441e68b:

    # "I know it's all over. There's no other way to interpret what happened the last time I saw her. In some ways, not having heard from her again has helped me move on from that period of my life."
    "Eu sei que está tudo acabado. Não há outra forma de interpretar o que aconteceu da última vez que a vi. Em alguns sentidos, não saber de mais nada dela me ajudou a sair daquele período da minha vida."

# game/script-a2-hanako.rpy:3515
translate pt_br a2_hanako_equivalent_exchange_4cf2653d:

    # hi "So now, we both know a little more about each other. But you don't have to talk about things if you don't want to."
    hi "Então, agora nós dois sabemos um pouco mais um sobre o outro. Mas você não precisa falar sobre algo se não quiser."

# game/script-a2-hanako.rpy:3517
translate pt_br a2_hanako_equivalent_exchange_2426c794:

    # "In fact, I feel a little bad even thinking about that whole incident. I can almost smell the hospital's disinfectant burning the back of my sinuses again."
    "De fato, me sinto um pouco mal só de lembrar daquele incidente todo. Quase posso sentir o cheiro do desinfetante do hospital queimando a parte de trás das minhas narinas de novo."

# game/script-a2-hanako.rpy:3519
translate pt_br a2_hanako_equivalent_exchange_de5bd408:

    # "I imagine Hanako is going through the same thing now."
    "Imagino que a Hanako esteja passando pelo mesmo agora."

# game/script-a2-hanako.rpy:3523
translate pt_br a2_hanako_equivalent_exchange_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:3526
translate pt_br a2_hanako_equivalent_exchange_8c19269f:

    # n "{vspace=60}When I was in the hospital I went to the burn ward once, and only once. I was bored, so I went for a walk through all of the wards."
    n "{vspace=60}Quando eu estava no hospital eu fui ao setor dos queimados uma vez, e apenas uma vez. Eu estava entediado, então fui dar uma volta pelas alas."

# game/script-a2-hanako.rpy:3528
translate pt_br a2_hanako_equivalent_exchange_fdff8193:

    # n "I went through oncology and thought I could take it, but when I got to the burn ward I turned around and went back to my bed."
    n "Eu passeei pelo setor de oncologia e pensei que poderia aguentar, mas quando fui até a ala dos queimados, dei meia volta e voltei para minha cama."

# game/script-a2-hanako.rpy:3530
translate pt_br a2_hanako_equivalent_exchange_784965c1:

    # n "To think that Hanako would have spent months in a place like that, smelling nothing but corrupted skin, strong disinfectant and sterilized air."
    n "Só de pensar que a Hanako teria passado meses num lugar assim, cheirando a nada além de pele queimada, desinfetante forte e ar esterelizado."

# game/script-a2-hanako.rpy:3532
translate pt_br a2_hanako_equivalent_exchange_cf98c88d:

    # n "The really bad cases were kept in isolated pods that no foreign objects could enter. That would have meant no reading."
    n "Os casos realmente graves eram mantidos em cabines isoladas onde nenhum objeto externo podia entrar. Isso significaria sem leitura."

# game/script-a2-hanako.rpy:3534
translate pt_br a2_hanako_equivalent_exchange_8a557bd7:

    # n "{vspace=30}I would have gone insane if I didn't have my books in the hospital."
    n "{vspace=30}Eu teria ficado insano se não tivesse meus livros no hospital."

# game/script-a2-hanako.rpy:3536
translate pt_br a2_hanako_equivalent_exchange_c5eebcd4:

    # n "And she said she was alone…"
    n "E ela disse que estava sozinha…"

# game/script-a2-hanako.rpy:3538
translate pt_br a2_hanako_equivalent_exchange_7afe38dd:

    # n "Did her parents die? I'll have to ask Lilly about it. I can imagine myself saying something dumb unintentionally."
    n "Seus pais morreram? Terei que perguntar à Lilly sobre isso. Consigo me imaginar dizendo algo estúpido sem querer."

# game/script-a2-hanako.rpy:3542
translate pt_br a2_hanako_equivalent_exchange_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-hanako.rpy:3548
translate pt_br a2_hanako_equivalent_exchange_74c2ab5d:

    # ha "T-thank you, Hisao."
    
    ha "O-obrigada, Hisao."

# game/script-a2-hanako.rpy:3553
translate pt_br a2_hanako_equivalent_exchange_469d29e6:

    # ha "I… I haven't told many people about this."
    ha "Eu… eu não contei a muitas pessoas sobre isso."

# game/script-a2-hanako.rpy:3555
translate pt_br a2_hanako_equivalent_exchange_a3366c17:

    # hi "To be honest, I haven't told many people about my… circumstances either."
    hi "Para ser honesto, eu não contei a muita gente sobre minhas… circunstâncias também."

# game/script-a2-hanako.rpy:3560
translate pt_br a2_hanako_equivalent_exchange_7e647897:

    # ha "T-then I won't tell a-anyone either."
    ha "E-então eu não vou contar para n-ninguém também."

# game/script-a2-hanako.rpy:3562
translate pt_br a2_hanako_equivalent_exchange_a5f1a108:

    # hi "Deal."
    hi "Fechado."

# game/script-a2-hanako.rpy:3566
translate pt_br a2_hanako_equivalent_exchange_45004422:

    # "I change my grip on Hanako's hand into a handshake as the warning bells chime through the window."
    "Transformo nossas mãos dadas em um aperto de mão enquanto o sinal do fim do intervalo de almoço é ouvido através da janela."

# game/script-a2-hanako.rpy:3568
translate pt_br a2_hanako_equivalent_exchange_0b3aab3d:

    # hi "Well then, we'd better head back to class then, eh?"
    hi "Bem então, melhor nós voltarmos pra sala, né?"

# game/script-a2-hanako.rpy:3573
translate pt_br a2_hanako_equivalent_exchange_ff70d1cd_1:

    # ha "S-sure."
    ha "S-sim."

translate pt_br strings:

    # game/script-a2-hanako.rpy:1168
    old "What do you think, Hanako?"
    new "O que você acha, Hanako?"

    # game/script-a2-hanako.rpy:1168
    old "I've done enough work for the council already."
    new "Já fiz trabalhos o suficiente para o Conselho."

