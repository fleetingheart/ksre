# game/script-a2-shizune.rpy:12
translate pt_br a2_shizune_message_passing_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:18
translate pt_br a2_shizune_message_passing_91dbeffc:

    # n "{vspace=60}The next morning, I recall what a perfect night last night was. So much so that I can't stop thinking about it."
    n "{vspace=60}Na manhã seguinte, recordo-me do quão perfeita a noite passada foi. Tanto que eu não consigo parar de pensar nisto."

# game/script-a2-shizune.rpy:20
translate pt_br a2_shizune_message_passing_f8ec4968:

    # n "It's probably not the most appropriate time to reminisce, since I have a test first period."
    n "Provavelmente não é a melhor hora para relembrar, já que tenho uma prova no primeiro período."

# game/script-a2-shizune.rpy:22
translate pt_br a2_shizune_message_passing_9f6d1f3d:

    # n "Ah, it's so unfair. How can they do this? They hold a festival that is the culmination of what has to be at least a few weeks' worth of work on a Sunday, and then follow up with exams starting the very next morning?"
    n "Ah, é tão injusto. Como eles podem fazer isso? Fazer um evento que é o ápice do que deve levar no mínimo algumas semanas de trabalho em um domingo, e em seguida provas começando logo na manhã seguinte?"

# game/script-a2-shizune.rpy:24
translate pt_br a2_shizune_message_passing_288c3239:

    # n "It's got to be some kind of sick joke."
    n "Isso deve ser algum tipo de piada doentia."

# game/script-a2-shizune.rpy:26
translate pt_br a2_shizune_message_passing_f42d1960:

    # n "I'm not too worried about it, but I wonder if they really couldn't have held off on this for at least another week."
    n "Eu não estou tão preocupado, mas eu me pergunto se eles realmente não poderiam ter segurado isto por pelo menos mais uma semana."

# game/script-a2-shizune.rpy:28
translate pt_br a2_shizune_message_passing_1f91f161:

    # n "{vspace=60}Well, at least the weather this morning is nice enough that I can study outside before class."
    n "{vspace=60}Bem, pelo menos o tempo esta manhã está bom o suficiente para eu estudar fora antes da aula."

# game/script-a2-shizune.rpy:35
translate pt_br a2_shizune_message_passing_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:39
translate pt_br a2_shizune_message_passing_a8e10ab2:

    # n "{vspace=60}It's a lot more refreshing out here than it would be in the classroom. Not to mention with how quiet it is, I'm starting to think that everyone else will be sleeping in pretty late today."
    n "{vspace=60}Está muito mais refrescante aqui fora do que estaria na sala de aula. Sem contar que, com o quão quieto hoje está, eu estou começando a achar que todo mundo estará dormindo até tarde."

# game/script-a2-shizune.rpy:41
translate pt_br a2_shizune_message_passing_e3c899a0:

    # n "I put down the notes I'm reviewing for a second and stare out at the school grounds, still littered with festival stalls."
    n "Eu largo as anotações que estou revisando por um momento e observo a escola, ainda desarrumada com as barracas do festival."

# game/script-a2-shizune.rpy:43
translate pt_br a2_shizune_message_passing_9194aafc:

    # n "Looking at them now in the daytime, without paper lanterns or crowds of people to draw my attention away from them, I notice something peculiar."
    n "Olhando-as agora a luz do dia, sem lanternas de papel ou multidões que desviam minha atenção, eu percebo algo peculiar."

# game/script-a2-shizune.rpy:45
translate pt_br a2_shizune_message_passing_8bd0e480:

    # n "A lot of the stalls that Shizune, Misha, and I visited last night also happen to be ones that we worked on."
    n "Várias das barracas que Shizune, Misha e eu visitamos na noite passada também são as nas quais nós trabalhamos."

# game/script-a2-shizune.rpy:47
translate pt_br a2_shizune_message_passing_e49a48d7:

    # n "{vspace=30}…"
    n "{vspace=30}…"

# game/script-a2-shizune.rpy:49
translate pt_br a2_shizune_message_passing_af19685d:

    # n "{vspace=30}That's cute. Did Shizune come up with this? It had to be intentional, especially knowing her. Did she hope that I would catch on and see the fruit of our labors?"
    n "{vspace=30}Que bonitinho. Será que foi ideia da Shizune? Tem que ter sido intencional, especialmente conhecendo ela. Será que ela esperava que eu fosse perceber e ver o fruto de nossos trabalhos?"

# game/script-a2-shizune.rpy:59
translate pt_br a2_shizune_message_passing_0d5522a7:

    # "I hear footsteps crunching the grass behind me and turn around. I feel slightly paranoid, but all I find is Shizune standing there with an innocuous look on her face."
    "Eu ouço passos esmagando a grama atrás de mim e me viro. Sinto-me um pouco paranóico, mas tudo que vejo é Shizune parada com um olhar inócuo em sua face."

# game/script-a2-shizune.rpy:66
translate pt_br a2_shizune_message_passing_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:68
translate pt_br a2_shizune_message_passing_8e4a18dc:

    # hi "Good morning."
    hi "Bom dia."

# game/script-a2-shizune.rpy:70
translate pt_br a2_shizune_message_passing_b657b756:

    # "Why do I keep forgetting that she can't hear me?"
    "Por que eu sempre esqueço que ela não pode me ouvir?"

# game/script-a2-shizune.rpy:72
translate pt_br a2_shizune_message_passing_853cc0c6:

    # "It's probably because I've gotten so used to Misha translating for both of us that I haven't actually run into many situations where I was forced to acknowledge Shizune's deafness and the problems that could stem from it."
    "É provavelmente porque eu fiquei tão acostumado com Misha traduzindo para nós dois que eu não cheguei a cair em muitas situações nas quais eu fui forçado a reconhecer a surdez da Shizune e os problemas que poderiam ser causados por isto."

# game/script-a2-shizune.rpy:74
translate pt_br a2_shizune_message_passing_05d13e5b:

    # "I think yesterday was the first."
    "Acho que ontem foi a primeira."

# game/script-a2-shizune.rpy:76
translate pt_br a2_shizune_message_passing_4fa96385:

    # "I give her a wave anyway. I can do at least this much, but I'm not even going to pretend for a minute that I could hold up a conversation with her, considering my ignorance of sign language."
    "Eu acenei para ela, pelo menos. É o mínimo que posso fazer, mas eu não vou fingir nem por um minuto que eu posso sustentar uma conversa com ela, considerando minha ignorância da língua de sinais."

# game/script-a2-shizune.rpy:78
translate pt_br a2_shizune_message_passing_2806dcfa:

    # "Would it be rude to just go back to my notes? I don't really know what else I could do."
    "Seria rude se eu somente voltasse para minhas anotações? Eu não sei bem o que mais eu poderia fazer."

# game/script-a2-shizune.rpy:80
translate pt_br a2_shizune_message_passing_75a17d86:

    # hi "Where's Misha?"
    hi "Onde está Misha?"

# game/script-a2-shizune.rpy:85
translate pt_br a2_shizune_message_passing_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:87
translate pt_br a2_shizune_message_passing_64b2364d:

    # hi "Not just because I can't understand you. You two are always together anyway, so I'm not used to seeing you apart."
    hi "Não apenas porque eu não posso te entender. Vocês duas estão sempre juntas, então não estou acostumado a vê-las separadas."

# game/script-a2-shizune.rpy:89
translate pt_br a2_shizune_message_passing_efe0be43:

    # "I know it's silly but for some reason talking to her makes me feel less awkward."
    "Eu sei que é bobo, mas por alguma razão falar com ela me faz sentir menos estranho."

# game/script-a2-shizune.rpy:100
translate pt_br a2_shizune_message_passing_0f894574:

    # "Surprisingly, she doesn't get mad at all. She starts signing; but it's different than usual. Shizune's hands move more slowly, and the gestures are simpler."
    "Surpreendentemente, ela não fica brava. Ela começa a fazer sinais, mas é diferente do usual. As mãos de Shizune se movem mais lentamente, e os gestos são mais simples."

# game/script-a2-shizune.rpy:102
translate pt_br a2_shizune_message_passing_1361b9fe:

    # "I quickly realize that this isn't sign language at all, but she's still attempting to communicate with me."
    "Rapidamente percebo que isso não é língua de sinais, mas ela ainda está tentando se comunicar comigo."

# game/script-a2-shizune.rpy:104
translate pt_br a2_shizune_message_passing_1fdc3c62:

    # hi "So is this the sign language equivalent of breaking it down into layman's terms?"
    hi "Então essa é a língua de sinais reduzida a termos simples?"

# game/script-a2-shizune.rpy:109
translate pt_br a2_shizune_message_passing_fd352afc:

    # "I'm terrified that if I attempt to gesticulate back, I'd just look like a total dumbass. The look on Shizune's face tells me that she is starting to think that trying to have any kind of back and forth like this is not exactly the best way to accomplish things."
    "Eu temo que se eu tentar gesticular de volta, eu vou parecer um completo idiota. O olhar na cara da Shizune me diz que ela está pensando que ter qualquer tipo de troca dessa forma não é exatamente o melhor jeito de fazer as coisas."

# game/script-a2-shizune.rpy:111
translate pt_br a2_shizune_message_passing_8a2fc558:

    # "There has to be a better way."
    "Deve ter algum jeito melhor."

# game/script-a2-shizune.rpy:113
translate pt_br a2_shizune_message_passing_5df29a5d:

    # "Writing on a pad? Well, I do have paper and a pencil. What else, though?"
    "Escrever em um bloco? Bom, eu tenho um papel e um lápis. O que mais, porém?"

# game/script-a2-shizune.rpy:115
translate pt_br a2_shizune_message_passing_033ae216:

    # "Cell phones? I don't really have much use for mine here, so I barely carry it around, and I don't know if Shizune even has one."
    "Celulares? Eu não uso o meu muito aqui, então eu mal levo ele, e eu nem sei se a Shizune tem um."

# game/script-a2-shizune.rpy:123
translate pt_br a2_shizune_message_passing_8b67e2d6:

    # "She takes the initiative, holding up a finger to ask for a pause before pulling out a pad and pen from her bag and writing a single word on it:"
    "Ela toma a iniciativa, segurando o dedo para pedir uma pausa antes de puxar um bloco e caneta de sua bolsa e escrever uma única palavra nele:"

# game/script-a2-shizune.rpy:130
translate pt_br a2_shizune_message_passing_ef2b123c_2:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:132
translate pt_br a2_shizune_message_passing_7f436bd2:

    # "I stare blankly at her and receive a similar but somehow more intimidating stare in response. She nudges the pad in my direction forcefully, clearly wanting me to reply."
    "Eu a olho fixamente e recebo um olhar similar porém mais intimidante como resposta. Ela cutuca o bloco em minha direção forçadamente, claramente querendo que eu a responda."

# game/script-a2-shizune.rpy:139
translate pt_br a2_shizune_message_passing_180c00ec:

    # "Shizune beams with a disproportionate amount of happiness. She starts twirling her pen triumphantly as she thinks about where to go from here."
    "Shizune sorri com uma felicidade desproporcional. Ela começa a rodopiar sua caneta triunfantemente, já pensando sobre aonde ir daqui."

# game/script-a2-shizune.rpy:141
translate pt_br a2_shizune_message_passing_a3c44b6a:

    # hi "Oh, come on, it's not like we just invented fire."
    hi "Ah, qual é, não é como se tivéssemos acabado de inventar o fogo."

# game/script-a2-shizune.rpy:146
translate pt_br a2_shizune_message_passing_dbde6151:

    # "Shizune pushes up her glasses curtly, as if she had heard me, and then starts writing at a furious pace."
    "Shizune empurra seus óculos secamente, como se ela tivesse me ouvido, e então começa a escrever em um ritmo furioso."

# game/script-a2-shizune.rpy:150
translate pt_br a2_shizune_message_passing_28366303:

    # "I'm confused; am I supposed to take it from her and write 'okay' now?"
    "Estou confuso; devo pegar isto dela e escrever “ok” agora?"

# game/script-a2-shizune.rpy:152
translate pt_br a2_shizune_message_passing_98112932:

    # "This is about the furthest thing I could imagine from a smooth, flowing conversation. It makes me envy the ease with which Misha is able to communicate with Shizune."
    "Isso é a coisa mais distante que eu posso imaginar de uma conversa suave e fluente. Me faz invejar a facilidade com a qual Misha se comunica com Shizune."

# game/script-a2-shizune.rpy:159
translate pt_br a2_shizune_message_passing_552347f1:

    # "I'm pretty sure I can get away with answering simple yes or no questions like this with nods."
    "Tenho certeza que eu posso escapar, respondendo simples questões de sim ou não com acenos."

# game/script-a2-shizune.rpy:166
translate pt_br a2_shizune_message_passing_a494c9b2:

    # "…Is that so?"
    "…É isso mesmo?"

# game/script-a2-shizune.rpy:170
translate pt_br a2_shizune_message_passing_724ccde2:

    # "Before handing that response back to her, though, I remember what I'd noticed earlier, and add:"
    "Antes de devolver a resposta a ela, porém, eu me lembro do que percebi antes, e acrescento:"

# game/script-a2-shizune.rpy:177
translate pt_br a2_shizune_message_passing_4e19594f:

    # "She shakes her head from side to side indignantly."
    "Ela balança a cabeça lado a lado, indignada."

# game/script-a2-shizune.rpy:186
translate pt_br a2_shizune_message_passing_a1792a8c:

    # "I'm sort of touched. Still, I have to wonder why she would go so out of her way, and I ask as much in my response."
    "Estou meio que comovido. Ainda assim, eu tenho que imaginar porque que ela sairia tanto de seu jeito, e eu pergunto isto em minha resposta."

# game/script-a2-shizune.rpy:195
translate pt_br a2_shizune_message_passing_54755ec7:

    # "I want to say that I was depressed for days, but stop. It's true, I was moping quite a bit, and not being too subtle about it half the time, either, so it's possible that she knew. Was everything she did just to cheer me up, then?"
    "Eu quero dizer que eu estava deprimido por dias, mas paro. É verdade, eu estava lastimando um tanto, e não sendo muito sutil sobre isso boa parte do tempo também, então é possível que ela saiba. Será que tudo que ela fez foi pra me animar, então?"

# game/script-a2-shizune.rpy:197
translate pt_br a2_shizune_message_passing_9d5a9627:

    # hi "Thanks."
    hi "Obrigado."

# game/script-a2-shizune.rpy:199
translate pt_br a2_shizune_message_passing_c7a3064d:

    # "I mumble it before I can catch myself, but Shizune doesn't seem to care. I write it down instead, and she nods once, as if unused to it."
    "Eu resmungo sem perceber, mas Shizune não parece ligar. Eu escrevo, então, e ela acena uma vez, como se estivesse desacostumada a isso."

# game/script-a2-shizune.rpy:201
translate pt_br a2_shizune_message_passing_7b1d242e:

    # "The silence between us grows more vast with each passing second, and there's nothing I can do to break it. Having to write everything down on paper kind of destroys any hope of trying to be casual."
    "O silêncio entre nós fica mais vasto com cada segundo que passa, e não há nada que eu possa fazer para quebrá-lo. Ter que escrever tudo em um papel meio que destrói qualquer esperança de tentar ser casual."

# game/script-a2-shizune.rpy:208
translate pt_br a2_shizune_message_passing_5523dee2:

    # "Shizune pushes the pad right in front of my eyes, breaking my concentration. Taking the initiative again, as always."
    "Shizune empurra o bloco na frente de meus olhos, me desconcentrando. Tomando a iniciativa novamente, como sempre."

# game/script-a2-shizune.rpy:213
translate pt_br a2_shizune_message_passing_81adc568:

    # "As she walks into the school building, I can't help feeling a little sad."
    "Enquanto ela caminha ao prédio escolar, eu me sinto um pouco triste."

# game/script-a2-shizune.rpy:215
translate pt_br a2_shizune_message_passing_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:219
translate pt_br a2_shizune_message_passing_0c09c5e5:

    # n "{vspace=60}That felt like the longest twenty minutes of my life, and all because it's so alien to me to have a face-to-face conversation with someone by passing notes to each other that I can't help coming up blank most of the time."
    n "{vspace=60}Estes pareceram ser os vinte minutos mais longos da minha vida, e tudo porque é tão estranho para mim ter uma conversa cara-a-cara com alguém passando anotações um ao outro que eu não consigo responder apropriadamente maior parte do tempo."

# game/script-a2-shizune.rpy:221
translate pt_br a2_shizune_message_passing_3bde1f9f:

    # n "It makes me want to learn sign language."
    n "Me faz querer aprender língua de sinais."

# game/script-a2-shizune.rpy:223
translate pt_br a2_shizune_message_passing_17cc4301:

    # n "That's easier said than done. Although in a school like Yamaku, they might very well have sign language classes. In that case, there would be little reason not to pursue this."
    n "Falar é fácil. Apesar que, em uma escola como Yamaku, é bem provável que eles tenham aula de língua de sinais. Nesse caso, não teria motivo para não correr atrás disso."

# game/script-a2-shizune.rpy:225
translate pt_br a2_shizune_message_passing_278daf1f:

    # n "The only person who I can think to ask, at the moment, is Misha."
    n "A única pessoa que eu penso em perguntar, no momento, é Misha."

# game/script-a2-shizune.rpy:227
translate pt_br a2_shizune_message_passing_e1f004ef:

    # n "How badly do I want to know this? There's two options: wait until after class, or go look for her now."
    n "Será que eu quero muito saber disso? Tem duas opções: esperar até depois da aula, ou procurar por ela agora."

# game/script-a2-shizune.rpy:229
translate pt_br a2_shizune_message_passing_1bb73432:

    # n "I guess I'll go now, but I'm not certain where she is. My best bet would be to start searching for her in the girls' dorm, though. After all, if she wasn't with Shizune, that's probably the only place where she would be."
    n "Acho que vou agora, mas não sei onde ela está. Minha melhor aposta seria procurar por ela no dormitório feminino. Afinal, se ela não estava com Shizune, esse é provavelmente o único lugar onde ela estaria."

# game/script-a2-shizune.rpy:233
translate pt_br a2_shizune_message_passing_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:243
translate pt_br a2_shizune_message_passing_281173e0:

    # n "{vspace=60}A guy casually prowling around the girls' dorm early in the morning is unacceptable, but asking Misha about sign language classes in front of Shizune would be just unthinkable."
    n "{vspace=60}Um homem casualmente perambulando pelo dormitório das garotas de manhã cedo é inaceitável, mas perguntar à Misha sobre aula de língua de sinais na frente da Shizune seria simplesmente impensável."

# game/script-a2-shizune.rpy:245
translate pt_br a2_shizune_message_passing_b1147a07:

    # n "She has to come to school sometime. After all, we're in the same class, so she too has to take this test."
    n "Ela tem que vir à escola uma hora. Afinal de contas, estamos na mesma sala, então ela também tem que vir fazer esta prova."

# game/script-a2-shizune.rpy:247
translate pt_br a2_shizune_message_passing_a2ce23c7:

    # n "If I wait here, I'll be sure to see her sooner or later."
    n "Se eu esperar aqui, com certeza a verei mais cedo ou mais tarde."

# game/script-a2-shizune.rpy:249
translate pt_br a2_shizune_message_passing_2ee46b2b:

    # n "I just hope she doesn't walk past me while I'm flipping through my notes."
    n "Só espero que ela não passe por mim enquanto estou relendo minhas anotações."

# game/script-a2-shizune.rpy:251
translate pt_br a2_shizune_message_passing_1d3a5f46:

    # n "{vspace=60}It turns out to be a pretty long wait. As students file into the school, I wonder if Misha is going to be late."
    n "{vspace=60}Acaba sendo uma espera bem longa. Conforme os estudantes chegam à escola, eu me pergunto se Misha vai se atrasar."

# game/script-a2-shizune.rpy:253
translate pt_br a2_shizune_message_passing_9b185b81:

    # n "Eventually I catch sight of her. While she bounces across the grounds, it hits me that I'd have to be blind to miss her with her incredibly distinctive hair."
    n "Eventualmente eu a vejo. Enquanto ela anda pela escola, eu percebo que teria que ser cego pra não percebê-la, com seu cabelo incrivelmente distinto."

# game/script-a2-shizune.rpy:257
translate pt_br a2_shizune_message_passing_76b2fe88_4:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:264
translate pt_br a2_shizune_message_passing_c44f4be9:

    # mi "Hi, Hicchan~! Good morning~!"
    mi "Olá, Hisaozinho~! Bom dia~!"

# game/script-a2-shizune.rpy:266
translate pt_br a2_shizune_message_passing_699b492a:

    # hi "'Morning."
    hi "Bom dia."

# game/script-a2-shizune.rpy:268
translate pt_br a2_shizune_message_passing_ce523a9e:

    # "I don't have a lot of time left before class starts, so I cut directly to the chase."
    "Eu não tenho muito tempo antes da aula começar, então sou curto e grosso."

# game/script-a2-shizune.rpy:270
translate pt_br a2_shizune_message_passing_b8123627:

    # hi "Hey, can I ask you a question?"
    hi "Ei, posso te fazer uma pergunta?"

# game/script-a2-shizune.rpy:275
translate pt_br a2_shizune_message_passing_5ba755dd:

    # mi "A question? Hm~… Okay, Hicchan~! Sure~ sure~! I have time, but only because I'm late!"
    mi "Uma pergunta? Hm~… Ok, Hisaozinho~! Claro~, claro~! Eu tenho tempo, mas só porque estou atrasada!"

# game/script-a2-shizune.rpy:277
translate pt_br a2_shizune_message_passing_4361f86d:

    # hi "What does that mean?"
    hi "O que isso quer dizer?"

# game/script-a2-shizune.rpy:282
translate pt_br a2_shizune_message_passing_fc7d4033:

    # mi "Haha~. I should have woken up earlier, but I was so tired~… if I had, I would have to study, but since I didn't, it won't hurt~! What is it, Hicchan?"
    mi "Haha~. Eu deveria ter acordado mais cedo, mas eu estava tão cansada~… se eu tivesse, eu teria que estudar, mas já que não acordei, não custa nada~! O que é, Hisaozinho?"

# game/script-a2-shizune.rpy:284
translate pt_br a2_shizune_message_passing_e690168c:

    # hi "Well, there are sign language classes here, right?"
    hi "Bem, tem aulas de língua de sinais aqui, certo?"

# game/script-a2-shizune.rpy:289
translate pt_br a2_shizune_message_passing_75ba6ace:

    # mi "Yup~! They're electives! Why do you want to know, Hicchan?"
    mi "Sim~! Elas são eletivas! Por que você quer saber, Hisaozinho?"

# game/script-a2-shizune.rpy:291
translate pt_br a2_shizune_message_passing_9f808d12:

    # "For some reason that question briefly makes me panic."
    "Por alguma razão essa pergunta brevemente me faz entrar em pânico."

# game/script-a2-shizune.rpy:293
translate pt_br a2_shizune_message_passing_59d4b561:

    # hi "No reason. It sounds interesting, but I guess it's too late to sign up now, right?"
    hi "Não há um motivo. Me parece interessante, mas eu acho que é meio tarde pra me inscrever, certo?"

# game/script-a2-shizune.rpy:295
translate pt_br a2_shizune_message_passing_bdde3da7:

    # "I'm not exactly being too subtle here, but Misha never seems to pick up on things like that anyway, so I'm probably being more cautious than is necessary."
    "Eu não estou sendo muito sutil aqui, mas a Misha nunca parece perceber coisas assim, então estou provavelmente estou sendo mais cauteloso que o necessário."

# game/script-a2-shizune.rpy:300
translate pt_br a2_shizune_message_passing_9c8a481a:

    # mi "Hm~? Ah, well, Hicchan, I've heard there are fewer and fewer students taking sign language every year. So! If you want to, I'm sure they will let you in~!"
    mi "Hm~? Ah, bem, Hisaozinho, eu ouvi dizer que tem menos e menos estudantes pegando essas aulas a cada ano. Então! Se você quiser, tenho certeza que eles vão deixar~!"

# game/script-a2-shizune.rpy:305
translate pt_br a2_shizune_message_passing_85486fda:

    # mi "Are you thinking of learning sign language, Hicchan?"
    mi "Está pensando em aprender língua de sinais, Hisaozinho?"

# game/script-a2-shizune.rpy:307
translate pt_br a2_shizune_message_passing_348ab03f:

    # hi "…Yeah."
    hi "…Sim."

# game/script-a2-shizune.rpy:312
translate pt_br a2_shizune_message_passing_713b9765:

    # mi "If you learned sign language, Hicchan, that would make Shicchan really happy~. If you want, we can go to the teachers' office after school. They'll probably let you in."
    mi "Se você aprender língua de sinais, Hisaozinho, isso faria Shizunezinha muito feliz~. Se você quiser, podemos ir à sala dos professores depois da aula. Eles provavelmente vão deixar você pegar essas aulas."

# game/script-a2-shizune.rpy:314
translate pt_br a2_shizune_message_passing_b4a26cf6:

    # hi "That would be great."
    hi "Isso seria ótimo."

# game/script-a2-shizune.rpy:316
translate pt_br a2_shizune_message_passing_402b5bcb:

    # hi "Don't tell Shizune that I want to learn it, though."
    hi "Todavia, não diga a Shizune que eu quero aprender."

# game/script-a2-shizune.rpy:321
translate pt_br a2_shizune_message_passing_bb0504e6:

    # mi "Why not?"
    mi "Por que não?"

# game/script-a2-shizune.rpy:323
translate pt_br a2_shizune_message_passing_f6a449f7:

    # hi "So it can be a surprise. Besides, it'll look bad if you tell her this morning, and then I find out in the afternoon that I can't take the classes."
    hi "Para ser uma surpresa, aliás, pegaria mal se você falasse a ela essa manhã, e aí de tarde eu descubro que eu não posso pegar as aulas."

# game/script-a2-shizune.rpy:328
translate pt_br a2_shizune_message_passing_14d6edc6:

    # mi "Aw~. You're right, Hicchan. Still, this will be hard~… It's such good news…"
    mi "Aw~. Você está certo, Hisaozinho. Ainda assim, isso vai ser difícil~… É uma notícia tão boa…"

# game/script-a2-shizune.rpy:330
translate pt_br a2_shizune_message_passing_380395ab:

    # hi "I'm in the Student Council, so I might as well try learning it. Even if it's just the basics, it'd be a step up from nothing. Besides, Shizune and I can't keep relaying everything through you as if you were a phone or something, right?"
    hi "Eu estou no Conselho Estudantil, então é bom eu aprender. Mesmo se for só o básico, já seria melhor que nada. Aliás, Shizune e eu não podemos ficar nos falando por você como se você fosse um telefone ou algo do tipo, certo?"

# game/script-a2-shizune.rpy:332
translate pt_br a2_shizune_message_passing_ce617998:

    # "…"
    "…"

# game/script-a2-shizune.rpy:339
translate pt_br a2_shizune_message_passing_e39fcd2d:

    # mi "Wahaha~!"
    mi "Wahaha~!"

# game/script-a2-shizune.rpy:344
translate pt_br a2_shizune_message_passing_54a7b100:

    # mi "You're right, Hicchan~!"
    mi "Você está certo, Hisaozinho~"

# game/script-a2-shizune.rpy:346
translate pt_br a2_shizune_message_passing_ce617998_1:

    # "…"
    "…"

# game/script-a2-shizune.rpy:351
translate pt_br a2_shizune_message_passing_00fb0fea:

    # "The bell rings to signal the start of first period, cutting our conversation short. I guess I'll just ask a teacher after classes are through."
    "O sinal toca para indicar o começo do primeiro período, interrompendo nossa conversa. Acho que eu vou só perguntar a um professor depois que as aulas terminarem."

# game/script-a2-shizune.rpy:353
translate pt_br a2_shizune_message_passing_2fd84c09:

    # "Her reaction was a little strange, but I forget about it as the day goes on."
    "A reação dela foi meio estranha, mas eu me esqueço disso no decorrer do dia."

# game/script-a2-shizune.rpy:369
translate pt_br a2_shizune_talk_to_the_hand_2c507019:

    # "The bell rings and the teacher at the front of the room gestures that classes are over for the day."
    "O sinal toca e a professora na frente da sala gesticula que as aulas estão encerradas por hoje."

# game/script-a2-shizune.rpy:373
translate pt_br a2_shizune_talk_to_the_hand_f2632e7a:

    # "Although getting into this class was surprisingly easy, it's only been a few days and I'm still not used to the experience. The actual signing is easier to pick up than I expected, but most of my classmates are hard of hearing."
    "Apesar de que entrar nessa aula foi surpreendentemente fácil, foram apenas poucos dias e eu ainda não estou acostumado à experiência. Os sinais em si são mais fáceis de entender do que eu esperava, mas a maioria dos meus colegas são difíceis de se ouvir."

# game/script-a2-shizune.rpy:375
translate pt_br a2_shizune_talk_to_the_hand_0c002680:

    # "On top of that, the teacher favors immersion. I haven't heard her speak since I asked if I could take the class. It's an alien concept, and really unnerving."
    "Ainda por cima, a professora favorece imersão. Eu não ouvi ela falar desde que eu perguntei se eu podia pegar a aula. É um conceito estranho, e muito enervante."

# game/script-a2-shizune.rpy:380
translate pt_br a2_shizune_talk_to_the_hand_b1f84c9f:

    # "The moment I step out of the classroom, I hear a familiar laugh explode through the air a short distance to my left."
    "No momento que saio da sala, eu ouço uma risada familiar explodir no ar um pouco à minha esquerda."

# game/script-a2-shizune.rpy:385
translate pt_br a2_shizune_talk_to_the_hand_300b2599:

    # mi "Hi, Hicchan~!"
    mi "Olá, Hisaozinho~!"

# game/script-a2-shizune.rpy:387
translate pt_br a2_shizune_talk_to_the_hand_e934ea59:

    # "Misha's not in my sign language class, so this is the first time I've seen her in this context. I still don't know whether her not being in my class is good or bad."
    "Misha não está na minha aula de língua de sinais, então essa é a primeira vez que a vejo neste contexto. Eu ainda não sei se ela não estar na minha sala é bom ou ruim."

# game/script-a2-shizune.rpy:389
translate pt_br a2_shizune_talk_to_the_hand_8f3cab4c:

    # "It would be more interesting with her in it, but the potential for awkward situations would increase drastically."
    "Provavelmente seria mais interessante com ela, mas o potencial de situações embaraçosas aumentaria drasticamente."

# game/script-a2-shizune.rpy:391
translate pt_br a2_shizune_talk_to_the_hand_ca61152d:

    # hi "Hi."
    hi "Olá."

# game/script-a2-shizune.rpy:396
translate pt_br a2_shizune_talk_to_the_hand_2750d507:

    # mi "It's a surprise to see you here, Hicchan! …Ah, that's right! You're taking sign language, aren't you~? Right~!"
    mi "Que surpresa vê-lo por aqui, Hisaozinho! …Ah, certo! Você pegou as aulas de língua de sinais, não pegou~? Certo~!"

# game/script-a2-shizune.rpy:401
translate pt_br a2_shizune_talk_to_the_hand_753a99dd:

    # mi "What do you think of it so far, Hicchan?"
    mi "O que você está achando das aulas, Hisaozinho?"

# game/script-a2-shizune.rpy:403
translate pt_br a2_shizune_talk_to_the_hand_e34e8301:

    # hi "It's not easy to learn a new language, but I think I'm getting the hang of it. Despite how different it is from other languages, it's still easier than English."
    hi "Não é fácil aprender uma nova língua, mas acho que estou pegando o jeito. Apesar de ser bem diferente de outras línguas, ainda assim é mais fácil que inglês."

# game/script-a2-shizune.rpy:408
translate pt_br a2_shizune_talk_to_the_hand_5476afa9:

    # mi "Haha~! Really, Hicchan?"
    mi "Haha~! Sério, Hisaozinho?"

# game/script-a2-shizune.rpy:413
translate pt_br a2_shizune_talk_to_the_hand_d2bf800b:

    # mi "Hm~… I agree~!"
    mi "Hm~… Concordo~!"

# game/script-a2-shizune.rpy:415
translate pt_br a2_shizune_talk_to_the_hand_60737e58:

    # "I was just joking, but she's apparently totally serious."
    "Eu estava brincando, mas aparentemente ela está falando sério."

# game/script-a2-shizune.rpy:417
translate pt_br a2_shizune_talk_to_the_hand_f7e53f9c:

    # "I wonder how Misha can effortlessly translate things to me while simultaneously having a conversation with Shizune in a different language like she does."
    "Eu me pergunto como Misha pode tão facilmente traduzir coisas para mim enquanto conversa com Shizune em uma língua diferente, ao mesmo tempo."

# game/script-a2-shizune.rpy:419
translate pt_br a2_shizune_talk_to_the_hand_5367ce39:

    # "Until now, I've taken for granted how amazing it is."
    "Até agora, eu admito que isso é incrível."

# game/script-a2-shizune.rpy:421
translate pt_br a2_shizune_talk_to_the_hand_0e9f3bcc:

    # "Someone bumps into my shoulder and apologizes. It's getting kind of crowded here, what with it being the end of the day and all."
    "Alguém tromba com meu ombro e pede desculpas. Está ficando meio lotado aqui, considerando que é o fim do dia e tudo mais."

# game/script-a2-shizune.rpy:423
translate pt_br a2_shizune_talk_to_the_hand_52eb164f:

    # hi "I think we should talk somewhere else instead of the hallway. Let's go to the roof or something."
    hi "Acho que deveríamos falar em outro lugar ao invés do corredor. Vamos para o telhado ou algo do tipo."

# game/script-a2-shizune.rpy:428
translate pt_br a2_shizune_talk_to_the_hand_6a3da49d:

    # mi "Okay~!"
    mi "Okay~!"

# game/script-a2-shizune.rpy:430
translate pt_br a2_shizune_talk_to_the_hand_98a86c84:

    # "I decide to continue talking on the way. It's surprisingly quiet enough to carry on a conversation while doing so."
    "Eu decido continuar falando no caminho. Está surpreendentemente quieto o suficiente para continuar uma conversa."

# game/script-a2-shizune.rpy:440
translate pt_br a2_shizune_talk_to_the_hand_8033e165:

    # hi "It's still taking me some time to get used to having to look at the teacher constantly. I guess I took all those years of simply listening to the lectures while I doodled for granted. It makes taking notes a lot more difficult, too."
    hi "Ainda vou levar um tempo pra acostumar a olhar pra professora constantemente. Eu acho que eu fiquei todos esses anos somente ouvindo às aulas enquanto eu rabiscava num papel. Anotar o conteúdo da aula também fica bem mais difícil."

# game/script-a2-shizune.rpy:442
translate pt_br a2_shizune_talk_to_the_hand_b1a976b7:

    # hi "The introductory class is small, and I'm already behind. I guess I have a lot of stuff to do."
    hi "A aula introdutória é curta, e eu já estou atrás. Acho que tenho muita coisa pra fazer."

# game/script-a2-shizune.rpy:450
translate pt_br a2_shizune_talk_to_the_hand_6fb5e9e5:

    # hi "Yeah, this is much better."
    hi "É, isso é muito melhor."

# game/script-a2-shizune.rpy:452
translate pt_br a2_shizune_talk_to_the_hand_9d095125:

    # "I turn around to look back at Misha and see her staring at me with her hands on her hips and her cheeks puffed outwards."
    "Eu me viro para olhar para Misha e a vejo me olhando com suas mãos nos quadris e suas bochechas inchadas para fora."

# game/script-a2-shizune.rpy:459
translate pt_br a2_shizune_talk_to_the_hand_d5cfe4d2:

    # mi "Hicchan, you're behind? That's not good at all!"
    mi "Hisaozinho, você está para trás? Isso não é nada bom!"

# game/script-a2-shizune.rpy:461
translate pt_br a2_shizune_talk_to_the_hand_af0d20a9:

    # hi "I started the class a week later than everyone else. It's not that bad."
    hi "Eu comecei as aulas uma semana depois de todo mundo. Não é tão ruim assim."

# game/script-a2-shizune.rpy:466
translate pt_br a2_shizune_talk_to_the_hand_3e369f0a:

    # mi "Okay, Hicchan, let's review what you learned, then~! I'll tutor you, okay~?"
    mi "Ok, Hisaozinho, vamos revisar o que você aprendeu, então~! Eu te ensinarei, ok~?"

# game/script-a2-shizune.rpy:468
translate pt_br a2_shizune_talk_to_the_hand_25887334:

    # "This is the first time I've heard 'I'll tutor you' used outside of dirty movies; I'm not nearly as turned on as I'd have expected."
    "Esta é a primeira vez que eu ouço esta frase fora de filmes pervertidos; Não soou como eu esperava."

# game/script-a2-shizune.rpy:470
translate pt_br a2_shizune_talk_to_the_hand_730496fa:

    # hi "I don't know if I need a tutor yet."
    hi "Eu não sei se eu já preciso de um tutor."

# game/script-a2-shizune.rpy:475
translate pt_br a2_shizune_talk_to_the_hand_e643fe3f:

    # mi "Aw…"
    mi "Aw…"

# game/script-a2-shizune.rpy:477
translate pt_br a2_shizune_talk_to_the_hand_a09840c0:

    # "She looks more disappointed than usual. It makes me feel awkward to see her making that kind of face."
    "Ela parece mais desapontada que o usual. Ver ela fazendo esse tipo de cara me faz sentir meio desconfortável."

# game/script-a2-shizune.rpy:482
translate pt_br a2_shizune_talk_to_the_hand_1ba376a3:

    # mi "I want to be a sign language teacher, Hicchan! But~, it would really be great if I could try tutoring someone in it, first. Even if it's for a little while, the experience would be valuable."
    mi "Eu quero ser uma professora de língua de sinais, Hisaozinho! Mas~, seria bem legal se eu pudesse tentar ensinar alguém, antes. Mesmo que por um curto tempo, a experiência seria valiosa."

# game/script-a2-shizune.rpy:484
translate pt_br a2_shizune_talk_to_the_hand_7f9103c6:

    # hi "Ah, well, yeah, that's true."
    hi "Ah, bem, sim, isso é verdade."

# game/script-a2-shizune.rpy:486
translate pt_br a2_shizune_talk_to_the_hand_70fd2256:

    # hi "I didn't know you wanted to be a sign language teacher."
    hi "Eu não sabia que você queria ser uma professora de língua de sinais."

# game/script-a2-shizune.rpy:488
translate pt_br a2_shizune_talk_to_the_hand_c9a51e4e:

    # "It's hard to believe she isn't intentionally trying to make me feel guilty, because she's very good at it."
    "É difícil acreditar que ela não está intencionalmente tentando fazer eu me sentir culpado, porque ela é muito boa nisso."

# game/script-a2-shizune.rpy:490
translate pt_br a2_shizune_talk_to_the_hand_dc137ec5:

    # "Still, it makes sense. She's very good at sign language already from what I've seen, and certainly has the voice for dealing with the hearing impaired. I never saw her as the teaching type, though."
    "Ainda assim, faz sentido. Ela é muito boa em língua de sinais pelo que vi, e certamente tem a voz para lidar com deficientes auditivos. Mas eu nunca vi ela como uma professora."

# game/script-a2-shizune.rpy:495
translate pt_br a2_shizune_talk_to_the_hand_a678fb91:

    # mi "Hahaha~! It's the reason why I wanted to go to this school, Hicchan!"
    mi "Hahaha~! Esse é o motivo pelo qual eu quis vir para essa escola, Hisaozinho!"

# game/script-a2-shizune.rpy:500
translate pt_br a2_shizune_talk_to_the_hand_d514e8b7:

    # mi "It's also really expensive to attend here, you know. Because I want to be a sign language teacher, I have reduced tuition fees. If it wasn't for that, I don't know if I'd be able to keep going here."
    mi "É bem caro estudar aqui, sabe. Eu tenho bolsa de estudos porque eu quero ser uma professora de língua de sinais. Se não fosse por isso, eu não sei se eu seria capaz de continuar aqui."

# game/script-a2-shizune.rpy:502
translate pt_br a2_shizune_talk_to_the_hand_d9b3c93a:

    # hi "I see. It's not that I think you would be bad at tutoring, it's just that I don't know if I need it just yet."
    hi "Entendo. Não é que eu ache que você seria uma má tutora, é que eu não sei se eu preciso disso ainda."

# game/script-a2-shizune.rpy:507
translate pt_br a2_shizune_talk_to_the_hand_146180c1:

    # mi "You're right, Hicchan, you're smart."
    mi "Está certo, Hisaozinho, você é esperto."

# game/script-a2-shizune.rpy:509
translate pt_br a2_shizune_talk_to_the_hand_4f302aab:

    # hi "Well, no, that just makes me sound arrogant."
    hi "Bem, não, isso só me faz soar arrogante."

# game/script-a2-shizune.rpy:511
translate pt_br a2_shizune_talk_to_the_hand_db8822b6:

    # hi "All right, please tutor me."
    hi "Tudo bem, por favor me ensine."

# game/script-a2-shizune.rpy:516
translate pt_br a2_shizune_talk_to_the_hand_03face0a:

    # mi "Ahahaha~! Really? Okay~! Okay okay okay~! Yay~! Thanks, Hicchan~! I'll do my best!"
    mi "Ahahaha~! Sério? Ok~! Ok ok ok~! Yay~! Obrigada, Hisaozinho~! Farei meu melhor!"

# game/script-a2-shizune.rpy:521
translate pt_br a2_shizune_talk_to_the_hand_c59a6d2b:

    # mi "Let's start right now~!"
    mi "Vamos começar agora mesmo~!"

# game/script-a2-shizune.rpy:523
translate pt_br a2_shizune_talk_to_the_hand_0428facd:

    # hi "Too soon."
    hi "Muito cedo."

# game/script-a2-shizune.rpy:528
translate pt_br a2_shizune_talk_to_the_hand_ce617998:

    # "…"
    "…"

# game/script-a2-shizune.rpy:530
translate pt_br a2_shizune_talk_to_the_hand_47c17fe0:

    # mi "I miss Shicchan~…"
    mi "Sinto saudades de Shizunezinha~…"

# game/script-a2-shizune.rpy:532
translate pt_br a2_shizune_talk_to_the_hand_c9c67f1d:

    # hi "Didn't you just see her this morning?"
    hi "Você não a viu esta manhã?"

# game/script-a2-shizune.rpy:537
translate pt_br a2_shizune_talk_to_the_hand_c855a167:

    # mi "But it's hard to talk to her in class, Hicchan! There's no Student Council today, either~."
    mi "Mas é difícil falar com ela na aula, Hisaozinho! E não tem Conselho Estudantil hoje, também~."

# game/script-a2-shizune.rpy:539
translate pt_br a2_shizune_talk_to_the_hand_c5661061:

    # hi "Well, there have been exams all week. I'd be kind of mad if there was still Student Council; I'll be glad when they are over."
    hi "Bom, tivemos prova toda a semana. Eu ficaria meio bravo se ainda tivesse Conselho Estudantil; eu ficarei contente quando acabar."

# game/script-a2-shizune.rpy:544
translate pt_br a2_shizune_talk_to_the_hand_f485a5f7:

    # mi "When it's back, you're not going to skip out, right, Hicchan?"
    mi "Quando voltar, você não vai pular fora, né, Hisaozinho?"

# game/script-a2-shizune.rpy:546
translate pt_br a2_shizune_talk_to_the_hand_d81a542c:

    # hi "Of course. I'm in it, after all."
    hi "Claro que não. Eu estou nele, afinal de contas."

# game/script-a2-shizune.rpy:548
translate pt_br a2_shizune_talk_to_the_hand_bc71df72:

    # hi "Don't worry, I'm not going to just suddenly stop showing up. A promise is a promise."
    hi "Não se preocupe, eu não vou parar de aparecer do nada. Uma promessa é uma promessa."

# game/script-a2-shizune.rpy:550
translate pt_br a2_shizune_talk_to_the_hand_9a95944b:

    # "Misha pauses for a second, not looking very convinced."
    "Misha pausa por um momento, não parecendo muito convencida."

# game/script-a2-shizune.rpy:555
translate pt_br a2_shizune_talk_to_the_hand_4dca721e:

    # mi "Shicchan takes the Student Council very seriously, Hicchan. Now that you've joined, she works harder than before since she wants to make a good impression."
    mi "Shizunezinha leva o Conselho Estudantil muito a sério, Hisaozinho. Agora que você entrou, ela trabalha mais duro que antes já que ela quer dar uma boa impressão."

# game/script-a2-shizune.rpy:560
translate pt_br a2_shizune_talk_to_the_hand_80d9e5ad:

    # mi "Some other people joined, at first, but they stopped coming soon after. Shicchan tried to get more people interested in the Student Council but wasn't successful."
    mi "Outras pessoas entraram, a princípio, mas eles pararam de vir logo após. Shizunezinha tentou achar mais pessoas interessadas no Conselho Estudantil mas não conseguiu."

# game/script-a2-shizune.rpy:565
translate pt_br a2_shizune_talk_to_the_hand_02c4b8e4:

    # mi "Even when someone would join, they'd stop coming eventually. They'd make excuses and just put it off more and more until they stopped coming altogether."
    mi "Mesmo se alguém entrasse, eles parariam de vir eventualmente. Eles dariam desculpas e adiariam mais e mais até que eles parassem de vir de uma vez."

# game/script-a2-shizune.rpy:570
translate pt_br a2_shizune_talk_to_the_hand_31a622df:

    # mi "However… I believe that you really mean it, Hicchan."
    mi "Porém… Eu acredito que você está sendo sincero, Hisaozinho."

# game/script-a2-shizune.rpy:572
translate pt_br a2_shizune_talk_to_the_hand_1f0f7779:

    # "My eyes stay focused on her hands, tilting and moving almost of their own free will, softly signing everything she is saying to herself as she speaks."
    "Meus olhos continuam focados em suas mãos, se inclinando e movendo quase por vontade própria, suavemente sinalizando tudo que ela está dizendo a si mesma enquanto fala."

# game/script-a2-shizune.rpy:577
translate pt_br a2_shizune_talk_to_the_hand_0f52295b:

    # mi "When you said you would join, she was really happy."
    mi "Quando você disse que iria entrar, ela ficou muito feliz."

# game/script-a2-shizune.rpy:582
translate pt_br a2_shizune_talk_to_the_hand_f1f008cb:

    # mi "Shicchan thinks you're interesting, Hicchan. An uninteresting person won't have the drive needed to join. Even if they do, a person that isn't interesting will quit soon after."
    mi "Shizunezinha acha você interessante, Hisaozinho. Uma pessoa desinteressante não teria a energia necessária para entrar. Mesmo se tivessem, uma pessoa que não é interessante sairia logo após."

# game/script-a2-shizune.rpy:584
translate pt_br a2_shizune_talk_to_the_hand_9db8992b:

    # mi "That's what Shicchan said."
    mi "Foi isso que a Shizunezinha disse."

# game/script-a2-shizune.rpy:589
translate pt_br a2_shizune_talk_to_the_hand_2dd72d36:

    # mi "So~! It's my duty to make sure you keep going~!"
    mi "Então~! É meu dever me certificar que você continue~!"

# game/script-a2-shizune.rpy:591
translate pt_br a2_shizune_talk_to_the_hand_dbec42c4:

    # hi "Is that why you want to tutor me? You're kind of sneaky."
    hi "É por isso que você quer ser minha tutora? Você é meio astuta."

# game/script-a2-shizune.rpy:596
translate pt_br a2_shizune_talk_to_the_hand_43105377:

    # mi "Really, Hicchan? That's the first time anyone has said that about me~! Wahahaha~!"
    mi "Sério, Hisaozinho? É a primeira vez que alguém disse isso de mim~! Wahahaha~!"

# game/script-a2-shizune.rpy:598
translate pt_br a2_shizune_talk_to_the_hand_6d76e2e9:

    # "There's no chance that I would avoid student council work now."
    "Não tem mais jeito de escapar do trabalho do conselho de classe agora."

# game/script-a2-shizune.rpy:600
translate pt_br a2_shizune_talk_to_the_hand_9d519120:

    # "Thinking back over the past few days, I've started to realize that the only reason I joined in the first place was because of Shizune; her competitiveness and force of will are alluring."
    "Pensando nos dias passados, eu comecei a perceber que o único motivo que eu entrei em primeiro lugar foi por causa da Shizune; sua competitividade e força de vontade são encantadores."

# game/script-a2-shizune.rpy:602
translate pt_br a2_shizune_talk_to_the_hand_5ac7b856:

    # "I can't tell Misha that, though."
    "Todavia, não posso falar isso à Misha."

# game/script-a2-shizune.rpy:607
translate pt_br a2_shizune_talk_to_the_hand_0b374656:

    # mi "Okay, Hicchan, let's review what you learned in class today~!"
    mi "Ok, Hisaozinho, vamos revisar o que você aprendeu na aula de hoje~!"

# game/script-a2-shizune.rpy:609
translate pt_br a2_shizune_talk_to_the_hand_ea7d507b:

    # hi "You don't even know what I learned in class today."
    hi "Você nem sabe o que eu aprendi na aula hoje."

# game/script-a2-shizune.rpy:614
translate pt_br a2_shizune_talk_to_the_hand_47d43dc9:

    # mi "Hm~, you're right, Hicchan~! Okay, let's start with the basics, then~! I'll just teach you everything from the beginning~!"
    mi "Hm~, você está certo, Hisaozinho~! Ok, vamos começar com o básico, então~! Eu vou te ensinar tudo do começo~!"

# game/script-a2-shizune.rpy:616
translate pt_br a2_shizune_talk_to_the_hand_cd9123d1:

    # hi "You're kidding, right?"
    hi "Cê tá me zoando, né?"

# game/script-a2-shizune.rpy:621
translate pt_br a2_shizune_talk_to_the_hand_b21211fc:

    # mi "Huh~?"
    mi "Hã~?"

# game/script-a2-shizune.rpy:623
translate pt_br a2_shizune_talk_to_the_hand_ae886b73:

    # hi "You're serious? That's like, days of lessons, and we're not even learning on the same level…"
    hi "É sério? Isso é, tipo, dias de lições, e nós não estamos nem aprendendo no mesmo nível…"

# game/script-a2-shizune.rpy:628
translate pt_br a2_shizune_talk_to_the_hand_59aa4b5e:

    # mi "It's like riding a bike, Hicchan~! You never forget the basics! Wahaha~!"
    mi "É como andar de bicicleta, Hisaozinho~! Você nunca esquece o básico! Wahaha~!"

# game/script-a2-shizune.rpy:633
translate pt_br a2_shizune_talk_to_the_hand_34719828:

    # mi "I don't know how to ride a bike, though~…"
    mi "Eu não sei como andar de bicicleta, na verdade~…"

# game/script-a2-shizune.rpy:635
translate pt_br a2_shizune_talk_to_the_hand_9d8a2c49:

    # "Oh no."
    "Ah não."

# game/script-a2-shizune.rpy:640
translate pt_br a2_shizune_talk_to_the_hand_35ab135a:

    # mi "Right, right~. I want to be a teacher one day, so of course I know what I'm doing… Okay~! Okay okay okay~! We're starting~!"
    mi "Certo, certo~. Eu quero ser uma professora um dia, então com certeza eu sei o que estou fazendo… Ok~! Ok ok ok~! Vamos começar~!"

# game/script-a2-shizune.rpy:647
translate pt_br a2_shizune_talk_to_the_hand_a3b008f1:

    # mi "Uh…"
    mi "Uh…"

# game/script-a2-shizune.rpy:652
translate pt_br a2_shizune_talk_to_the_hand_40d58157:

    # mi "…Mmm~…"
    mi "…Hmmm~…"

# game/script-a2-shizune.rpy:657
translate pt_br a2_shizune_talk_to_the_hand_2342e611:

    # mi "Ahahaha~…"
    mi "Ahahaha~…"

# game/script-a2-shizune.rpy:659
translate pt_br a2_shizune_talk_to_the_hand_8575efe5:

    # "She looks like she's trying very hard, so this could be bad. Well, learning a language is vastly different from teaching it, and the first step is usually the hardest part. Honestly, I couldn't do any better."
    "Parece que ela está tentando arduamente, então isto pode ser ruim. Bem, aprender uma língua é muito diferente de ensinar, e o primeiro passo é geralmente o mais difícil. Honestamente, eu não faria melhor."

# game/script-a2-shizune.rpy:661
translate pt_br a2_shizune_talk_to_the_hand_e2cf25f9:

    # "Still…"
    "Mas ainda assim…"

# game/script-a2-shizune.rpy:666
translate pt_br a2_shizune_talk_to_the_hand_5da649f2:

    # mi "Um… Sign language was formally introduced in the 18th century by a Frenchman named… ah… whose name I can't pronounce, and he started the first public school for the deaf in 1755, but the unwritten history of sign language is said to…"
    mi "Um… Língua de sinais foi formalmente introduzida no século XVIII por um francês cujo nome… ah… cujo nome eu não sei pronunciar, e ele fundou a primeira escola pública para surdos em 1755, mas a história da língua de sinais…"

# game/script-a2-shizune.rpy:671
translate pt_br a2_shizune_talk_to_the_hand_c4f05c8e:

    # mi "I don't really know where to start. Sorry~… Well~, what better place to start than the history of sign language? Right~? Right~!"
    mi "Eu não sei muito bem por onde começar. Desculpe~… Bem~, nada melhor que começar pela história da língua de sinais? Certo~? Certo~!"

# game/script-a2-shizune.rpy:676
translate pt_br a2_shizune_talk_to_the_hand_455911f8:

    # mi "No, wait, maybe the alphabet. Okay~, the alphabet it is, then!"
    mi "Não, espere, talvez o alfabeto. Ok~, será o alfabeto, então!"

# game/script-a2-shizune.rpy:683
translate pt_br a2_shizune_talk_to_the_hand_dc6cd0aa:

    # mi "Okay, Hicchan~! This is pretty basic stuff, although some people think that this is all of signing, and forget there are all kinds of specific gestures and words."
    mi "Ok, Hisaozinho~! Isso é bem básico, apesar de que algumas pessoas acham que isso é tudo de sinais, e se esquecem que existem vários tipos de palavras e gestos específicos."

# game/script-a2-shizune.rpy:688
translate pt_br a2_shizune_talk_to_the_hand_e6e0bad6:

    # mi "Although you can't really get anywhere else without the basics! This is A. Do you see it? Now, you try!"
    mi "Apesar de que você não consegue ir a lugar nenhum sem o básico. Isso é o A. Está vendo? Agora, sua vez!"

# game/script-a2-shizune.rpy:690
translate pt_br a2_shizune_talk_to_the_hand_1817a117:

    # hi "I already know this, though."
    hi "Eu já sei isso, na verdade."

# game/script-a2-shizune.rpy:692
translate pt_br a2_shizune_talk_to_the_hand_8a38930a:

    # "I humor her anyway."
    "Eu a entretenho, de qualquer modo."

# game/script-a2-shizune.rpy:697
translate pt_br a2_shizune_talk_to_the_hand_a36c7048:

    # mi "Hahaha! Yeah, that's it!"
    mi "Hahaha! É, é isso aí!"

# game/script-a2-shizune.rpy:702
translate pt_br a2_shizune_talk_to_the_hand_fd2862fb:

    # mi "Now, this is B, and this is C."
    mi "Agora, isso é B, e isso é C."

# game/script-a2-shizune.rpy:704
translate pt_br a2_shizune_talk_to_the_hand_b80df628:

    # "Misha makes one symbol with each hand, without specifying which is which."
    "Misha faz um símbolo com cada mão, sem especificar qual é qual."

# game/script-a2-shizune.rpy:715
translate pt_br a2_shizune_talk_to_the_hand_43066202:

    # mi "And now D, E, F, G, H, I, J, K, L, M, N, O, P, Q, R, S, T, U, VWXY 'n' Z~!"
    mi "E agora D, E, F, G, H, I, J, K, L, M, N, O, P, Q, R, S, T, U, VWXY e Z~!"

# game/script-a2-shizune.rpy:717
translate pt_br a2_shizune_talk_to_the_hand_ad4f94db:

    # "Yeah, this is bad."
    "É, isso é ruim."

# game/script-a2-shizune.rpy:719
translate pt_br a2_shizune_talk_to_the_hand_4fd7a3aa:

    # hi "Do you think Shizune wants to do some student council work today anyway? We could go."
    hi "Você acha que a Shizune quer fazer algum trabalho do conselho estudantil hoje? Nós poderíamos ir."

# game/script-a2-shizune.rpy:724
translate pt_br a2_shizune_talk_to_the_hand_f80a7d54:

    # mi "Of course not, Hicchan~!! Come on, I'll do it again! A, B, C, D, E, F, G, H, I, J, K… Your turn~!"
    mi "Claro que não, Hisaozinho~!! Vamos lá, eu farei de novo! A, B, C, D, E, F, G, H, I, J, K… Sua vez~!"

# game/script-a2-shizune.rpy:726
translate pt_br a2_shizune_talk_to_the_hand_aff046ae:

    # hi "So there's really no student council work that needs doing, or anything like that?"
    hi "Então não tem nenhum trabalho do conselho estudantil por fazer, ou algo do tipo?"

# game/script-a2-shizune.rpy:731
translate pt_br a2_shizune_talk_to_the_hand_58d08d5a:

    # mi "What are you talking about, Hicchan? Come on, sign, sign~!"
    mi "O que você está falando, Hisaozinho? Vamos, faça o sinal, faça o sinal~!"

# game/script-a2-shizune.rpy:733
translate pt_br a2_shizune_talk_to_the_hand_1f92e5eb:

    # hi "Like this?"
    hi "Assim?"

# game/script-a2-shizune.rpy:738
translate pt_br a2_shizune_talk_to_the_hand_b2f2e184:

    # mi "No, like this!"
    mi "Não, assim!"

# game/script-a2-shizune.rpy:740
translate pt_br a2_shizune_talk_to_the_hand_00ecf413:

    # hi "Like…"
    hi "Tipo…"

# game/script-a2-shizune.rpy:748
translate pt_br a2_shizune_talk_to_the_hand_c0b22256:

    # mi "This~!"
    mi "Assim~!"

# game/script-a2-shizune.rpy:750
translate pt_br a2_shizune_talk_to_the_hand_3d4fb1b1:

    # hi "Uh… huh…"
    hi "Ã… hã…"

# game/script-a2-shizune.rpy:755
translate pt_br a2_shizune_talk_to_the_hand_22be7289:

    # mi "I wish Shicchan was here, this would be so much easier with her. Hahaha, that's how sign language is taught most of the time, anyway, with two instructors~! Did you know that, Hicchan?"
    mi "Queria que Shizunezinha estivesse aqui, isso seria muito mais fácil com ela. Hahaha, é assim que a língua de sinais é ensinada maior parte do tempo, de qualquer forma, com dois instrutores~! Você sabia disso, Hisaozinho?"

# game/script-a2-shizune.rpy:757
translate pt_br a2_shizune_talk_to_the_hand_7efcef0d:

    # hi "No."
    hi "Não."

# game/script-a2-shizune.rpy:759
translate pt_br a2_shizune_talk_to_the_hand_b4669a73:

    # "I let my brain run through what this would be like if Shizune were here."
    "Eu deixo meu cérebro se distrair imaginando como isso seria se a Shizune estivesse aqui."

# game/script-a2-shizune.rpy:761
translate pt_br a2_shizune_talk_to_the_hand_ce617998_1:

    # "…"
    "…"

# game/script-a2-shizune.rpy:766
translate pt_br a2_shizune_talk_to_the_hand_8e93eed4:

    # mi "Hicchan~! Are you paying attention?"
    mi "Hisaozinho~! Você está prestando atenção?"

# game/script-a2-shizune.rpy:768
translate pt_br a2_shizune_talk_to_the_hand_142d50b9:

    # hi "Yeah."
    hi "Tô."

# game/script-a2-shizune.rpy:773
translate pt_br a2_shizune_talk_to_the_hand_e0605432:

    # mi "Shicchan says that sign language is different from any other, because you have to think about everything before you say it. That means every word has more weight, Hicchan. Every single one is more important than normal."
    mi "Shizunezinha diz que a língua de sinais é diferente de qualquer outra, porque você tem que pensar sobre tudo antes de dizer. Isso quer dizer que toda palavra tem mais peso, Hisaozinho. Cada palavra é mais importante que o normal."

# game/script-a2-shizune.rpy:778
translate pt_br a2_shizune_talk_to_the_hand_f6c880dd:

    # mi "So~, pay attention, please."
    mi "Então~, preste atenção, por favor."

# game/script-a2-shizune.rpy:783
translate pt_br a2_shizune_talk_to_the_hand_0d1c7fdb:

    # "She continues her basic rundown of the basics of sign language. Eventually she starts talking about stuff I start to recognize."
    "Ela continua a explicar o básico da língua de sinais. Eventualmente ela começa a falar sobre coisas que eu começo a reconhecer."

# game/script-a2-shizune.rpy:785
translate pt_br a2_shizune_talk_to_the_hand_110e28e1:

    # "In the end, I'm impressed. It took a bit of stumbling to get there, but as a teacher, she's pretty good when she's serious."
    "No fim, estou impressionado. Levou alguns tropeços para chegar aqui, mas como professora, ela é muito boa quando está séria."

# game/script-a2-shizune.rpy:793
translate pt_br a2_shizune_talk_to_the_hand_a69c6240:

    # "After awhile I start to notice that it's getting late, so I thank Misha, bid her goodbye, and go back to my dorm."
    "Depois de um tempo eu começo a perceber que está ficando tarde, então eu agradeço Misha, me despeço, e volto ao meu quarto."

# game/script-a2-shizune.rpy:800
translate pt_br a2_shizune_talk_to_the_hand_910b2921:

    # "I learned a lot today."
    "Eu aprendi muito hoje."

# game/script-a2-shizune.rpy:816
translate pt_br a2_shizune_chinese_whispers_43cb5adb:

    # "I'm jolted awake by a thunderous banging sound coming from my door."
    "Sou acordado por sons de batidas violentas vindo da minha porta."

# game/script-a2-shizune.rpy:818
translate pt_br a2_shizune_chinese_whispers_fdf1ae4f:

    # "My first thought is, it could be Shizune. After all, only a deaf person or a jackass would knock that loudly at this hour."
    "Meu primeiro pensamento é, deve ser Shizune. Afinal de contas, só uma pessoa surda ou estúpida bateria na porta tão alto a essa hora."

# game/script-a2-shizune.rpy:820
translate pt_br a2_shizune_chinese_whispers_0cf91355:

    # hi "Who is it?"
    hi "Quem é?"

# game/script-a2-shizune.rpy:822
translate pt_br a2_shizune_chinese_whispers_37c357fe:

    # "Of course, if it's Shizune, she wouldn't be able to hear that or answer it."
    "Claro, se for a Shizune, ela não seria capaz de ouvir ou responder a isto."

# game/script-a2-shizune.rpy:824
translate pt_br a2_shizune_chinese_whispers_d1a5c171:

    # "There's no reply, so I'm kind of pleased. I haven't seen Shizune in a while."
    "Não há resposta, então me sinto feliz. Eu não vejo a Shizune faz um tempo."

# game/script-a2-shizune.rpy:834
translate pt_br a2_shizune_chinese_whispers_62b4673d:

    # "Opening the door, I find Kenji standing out in the hall, his eyes nervously darting from side to side."
    "Abrindo a porta, eu vejo Kenji parado na sala, seus olhos nervosamente se atirando de um lado pro outro."

# game/script-a2-shizune.rpy:836
translate pt_br a2_shizune_chinese_whispers_50684ad3:

    # hi "Oh, it's you."
    hi "Ah, é você."

# game/script-a2-shizune.rpy:841
translate pt_br a2_shizune_chinese_whispers_f4ec0af8:

    # ke "Yeah, it's me. What kind of reaction is that?"
    ke "É, sou eu. Que tipo de reação é essa?"

# game/script-a2-shizune.rpy:843
translate pt_br a2_shizune_chinese_whispers_5bc44b2c:

    # hi "Well, I'd be able to give you a more personalized response if you had answered when I asked who it was."
    hi "Bom, eu daria uma resposta mais personalizada se você tivesse respondido quando eu perguntei quem era."

# game/script-a2-shizune.rpy:848
translate pt_br a2_shizune_chinese_whispers_08ee7198:

    # "Kenji frowns and pushes up his glasses exactly like Shizune."
    "Kenji franze a testa e empurra seus óculos exatamente como a Shizune."

# game/script-a2-shizune.rpy:850
translate pt_br a2_shizune_chinese_whispers_e397122c:

    # ke "Why are you making that weird face?"
    ke "Por que você está fazendo essa cara estranha?"

# game/script-a2-shizune.rpy:852
translate pt_br a2_shizune_chinese_whispers_b6ec4598:

    # "I wonder how he's able to see me making a face now, yet wasn't able to the millions of other times I've reacted to something weird he has said or done. I kind of want to pursue this, but am too tired to actually do it."
    "Eu me pergunto como ele foi capaz de me ver fazendo uma cara agora, apesar de não ser capaz em outras milhões de vezes que eu reagi a algo estranho que ele fez ou disse. Eu meio que quero insistir nisso, mas estou muito cansado para fazê-lo."

# game/script-a2-shizune.rpy:854
translate pt_br a2_shizune_chinese_whispers_7de334c9:

    # hi "Shizune pushes her glasses up just like that. You know, the Student Council president. It's just a little weird."
    hi "Shizune empurra seus óculos bem desse jeito. Você sabe, a presidente do Conselho Estudantil. É meio estranho."

# game/script-a2-shizune.rpy:859
translate pt_br a2_shizune_chinese_whispers_7099a560:

    # ke "What the hell? What do you mean there's this girl who does the same thing? You mean she touches her glasses? I do that, that's my thing."
    ke "O quê? O que você quer dizer com tem uma garota que faz a mesma coisa? Você diz ela toca seus óculos? Eu faço isso, isso é meu."

# game/script-a2-shizune.rpy:861
translate pt_br a2_shizune_chinese_whispers_2c20f3f3:

    # ke "Who is this bitch? Why are bitches all up in my business, stealing what I do?"
    ke "Quem é essa vadia? Por que as vadias estão metidas nos meus assuntos, roubando o que faço?"

# game/script-a2-shizune.rpy:866
translate pt_br a2_shizune_chinese_whispers_574a6e96:

    # "His character flips from anger to fear in the blink of an eye."
    "Seu caráter muda de ira pra medo em um piscar de olhos."

# game/script-a2-shizune.rpy:868
translate pt_br a2_shizune_chinese_whispers_7485d1b1:

    # ke "Is she trying to replace me? Pod people? No, wait, that's an exact copy. Pod women?"
    ke "Ela está tentando me substituir? Usurpar pessoas? Não, espere, essa é uma cópia exata. Mulheres usurpadoras?"

# game/script-a2-shizune.rpy:870
translate pt_br a2_shizune_chinese_whispers_6b3911dc:

    # ke "It's like my two greatest fears combined."
    ke "É tipo meus dois maiores medos combinados."

# game/script-a2-shizune.rpy:875
translate pt_br a2_shizune_chinese_whispers_86b49537:

    # ke "It is!"
    ke "É isso!"

# game/script-a2-shizune.rpy:877
translate pt_br a2_shizune_chinese_whispers_db0c0901:

    # "I can't believe he has a point…"
    "Não acredito que ele tem razão…"

# game/script-a2-shizune.rpy:882
translate pt_br a2_shizune_chinese_whispers_d0dcbfc7:

    # ke "Hey, you going to go into town today?"
    ke "Ei, você vai pra cidade hoje?"

# game/script-a2-shizune.rpy:884
translate pt_br a2_shizune_chinese_whispers_3038084f:

    # hi "Uh, maybe later."
    hi "Uh, talvez depois."

# game/script-a2-shizune.rpy:889
translate pt_br a2_shizune_chinese_whispers_d09d38ef:

    # ke "Okay. Awesome. I have some… stuff I want you to pick up for me at the post office. Some delicate and secret stuff."
    ke "Ok. Maravilha. Eu tenho algumas… coisas que eu quero que você pegue pra mim no correio. Algumas coisas delicadas e secretas."

# game/script-a2-shizune.rpy:891
translate pt_br a2_shizune_chinese_whispers_a826a9e1:

    # "He speaks in a whisper, as if talking about his mail in even a normal tone of voice will jeopardize it."
    "Ele fala sussurrando, como se falar sobre sua correspondência num tom normal fosse pô-la em risco."

# game/script-a2-shizune.rpy:893
translate pt_br a2_shizune_chinese_whispers_868cf4a6:

    # hi "You can have your mail sent directly here, you know."
    hi "Você pode ter sua correspondência enviada diretamente aqui, sabe."

# game/script-a2-shizune.rpy:898
translate pt_br a2_shizune_chinese_whispers_47b6ec2a:

    # ke "No you can't. You can have your mail sent to the school, and then the Student Council picks it up, and then they give it to you. That's not the same as the mail appearing in your hands."
    ke "Não você não pode. Você pode ter sua correspondência enviada para a escola, então o Conselho Estudantil a pega, então eles a dão pra você. Não é a mesma coisa."

# game/script-a2-shizune.rpy:900
translate pt_br a2_shizune_chinese_whispers_d01526d3:

    # ke "I don't trust the Student Council. Many dudes don't get their mail here, you know."
    ke "Eu não confio no Conselho Estudantil. Vários caras não recebem suas correspondências aqui, sabe."

# game/script-a2-shizune.rpy:905
translate pt_br a2_shizune_chinese_whispers_3ef00601:

    # ke "They probably steal it all! They think that just because it's sent to them, they have a license to steal? I can just see them now, elbow deep in mail, fast grabbing all the free swag they can get a hold on. Sickening."
    ke "Eles provavelmente roubam tudo! Eles acham que só porque é enviado pra eles, eles tem permissão para roubar? Eu posso vê-los agora, com as mãos até o cotovelo na correspondência, pegando tudo o que podem. Repugnante."

# game/script-a2-shizune.rpy:907
translate pt_br a2_shizune_chinese_whispers_b205e952:

    # hi "Where can I find this mailman who can conjure mail out of thin air and into your hands?"
    hi "Onde posso achar esse entregador que pode conjurar correspondência do ar em suas mãos?"

# game/script-a2-shizune.rpy:909
translate pt_br a2_shizune_chinese_whispers_117d23e4:

    # ke "I don't know, I bet the Student Council killed him to preserve their monopoly on all the students' shit."
    ke "Eu não sei, acho que o Conselho Estudantil matou ele pra preservar seu monopólio nas merdas dos estudantes."

# game/script-a2-shizune.rpy:911
translate pt_br a2_shizune_chinese_whispers_1b31fc7a:

    # hi "It doesn't work that way."
    hi "As coisas não funcionam assim."

# game/script-a2-shizune.rpy:913
translate pt_br a2_shizune_chinese_whispers_bd03f497:

    # hi "Is that what you wanted, though? Fine, I can pick up your mail for you, but eventually I'm going to collect on all these favors. You already owe me some money."
    hi "Mas é isso o que você quer? Beleza, eu posso pegar sua correspondência pra você, mas eventualmente eu vou cobrar todos esses favores. Você já me deve algum dinheiro."

# game/script-a2-shizune.rpy:918
translate pt_br a2_shizune_chinese_whispers_6cc66624:

    # ke "Thanks for reminding me. I'll pay you back after I get my package."
    ke "Obrigado por me lembrar. Te pagarei depois de pegar meu pacote."

# game/script-a2-shizune.rpy:920
translate pt_br a2_shizune_chinese_whispers_e7169f05:

    # ke "Yeah, my bad, I can't really pay you until then. I'm still broke."
    ke "É, desculpe, eu não posso te pagar até então. Ainda estou duro."

# game/script-a2-shizune.rpy:922
translate pt_br a2_shizune_chinese_whispers_181395c1:

    # hi "Then I'm basically doing it for money, like a job. Why do you need the package first? Is there money in the package?"
    hi "Então eu estou fazendo isto pelo dinheiro, como um trabalho. Mas por que você precisa do pacote primeiro? Tem dinheiro nele?"

# game/script-a2-shizune.rpy:927
translate pt_br a2_shizune_chinese_whispers_cec583aa:

    # ke "Nah."
    ke "Nah."

# game/script-a2-shizune.rpy:929
translate pt_br a2_shizune_chinese_whispers_c790c319:

    # "I am seriously dumbfounded."
    "Estou seriamente pasmo."

# game/script-a2-shizune.rpy:931
translate pt_br a2_shizune_chinese_whispers_16053745:

    # hi "Why can't you get it?"
    hi "Por que você não pode ir pegar?"

# game/script-a2-shizune.rpy:936
translate pt_br a2_shizune_chinese_whispers_c9999502:

    # ke "Because I am going to remodel my room today into a war room."
    ke "Porque vou remodelar meu quarto hoje em um quarto de guerra."

# game/script-a2-shizune.rpy:938
translate pt_br a2_shizune_chinese_whispers_481b81cc:

    # ke "As the days go by, I realize more and more how dangerous feminism is. It really is everywhere, even in places like Iran. You can't tell how far up it goes."
    ke "Conforme os dias passam, eu percebo cada vez mais como o feminismo é perigoso. Ele realmente está em todo lugar, até em lugares como Irã. Você não pode dizer o quão longe ele vai."

# game/script-a2-shizune.rpy:943
translate pt_br a2_shizune_chinese_whispers_2de5d654:

    # ke "When the war begins, if we haven't transcended the concept of nations to fight for our genders, it will be chaos."
    ke "Quando a guerra começar, se nós não tivermos transcendido o conceito de nações pra lutar por nossos sexos, surgirá o caos."

# game/script-a2-shizune.rpy:945
translate pt_br a2_shizune_chinese_whispers_8be2db5e:

    # ke "No one will know who will take what side, and a war against feminism wouldn't just mean World War III, but the end of all life on Earth as we know it."
    ke "Ninguém vai saber quem vai tomar qual lado, e uma guerra contra o feminismo não significaria somente uma Terceira Guerra Mundial, mas o fim de toda a vida na terra como conhecemos."

# game/script-a2-shizune.rpy:947
translate pt_br a2_shizune_chinese_whispers_d886c686:

    # ke "If we lose, all our supple Japanese women will be raped and enslaved by a bunch of sociopathic lesbian supremacists."
    ke "Se perdermos, todas as mulheres japonesas serão estupradas e escravizadas por um bando de lésbicas supremacistas sociopáticas."

# game/script-a2-shizune.rpy:949
translate pt_br a2_shizune_chinese_whispers_f8f5a191:

    # ke "Meanwhile, the handful of men that didn't die in the war will be castrated and forced to repair toilets and build massive monuments commemorating the feminist victory."
    ke "Enquanto isso, os poucos homens que não morreram na guerra serão castrados e forçados a consertar privadas e construir grandes monumentos comemorando a vitória feminista."

# game/script-a2-shizune.rpy:951
translate pt_br a2_shizune_chinese_whispers_620cd863:

    # hi "That's crazy. You're crazy. I think you're overthinking this."
    hi "Isso é loucura. Você é louco. Eu acho que você está pensando demais nisso."

# game/script-a2-shizune.rpy:953
translate pt_br a2_shizune_chinese_whispers_16da0c70:

    # ke "As the days go by, I realize more and more that you are not ballin'."
    ke "Conforme os dias passam, eu percebo cada vez mais que você não é legal."

# game/script-a2-shizune.rpy:955
translate pt_br a2_shizune_chinese_whispers_e7d42b77:

    # hi "We've only talked like four times."
    hi "Nós só nos falamos umas quatro vezes."

# game/script-a2-shizune.rpy:960
translate pt_br a2_shizune_chinese_whispers_179f1467:

    # ke "Oh. Sorry."
    ke "Oh. Desculpe."

# game/script-a2-shizune.rpy:962
translate pt_br a2_shizune_chinese_whispers_0b171c0a:

    # hi "Yeah, whatever, I'll get your package."
    hi "É, tanto faz, vou pegar seu pacote."

# game/script-a2-shizune.rpy:967
translate pt_br a2_shizune_chinese_whispers_8c4739a5:

    # ke "Awesome."
    ke "Ótimo!"

# game/script-a2-shizune.rpy:976
translate pt_br a2_shizune_chinese_whispers_2a6d2c78:

    # "I close the door and jump right back into bed."
    "Eu fecho a porta e pulo de volta pra cama."

# game/script-a2-shizune.rpy:980
translate pt_br a2_shizune_chinese_whispers_18294cec:

    # "The second my head hits the pillow, a painfully loud ringing assaults my ears, and I realize it's my clock. The alarm going off means that right now is the time I'm supposed to wake up in the first place."
    "No segundo que minha cabeça toca o travesseiro, ouço um toque dolorosamente alto, e percebo que é meu relógio. O som do alarme indica que agora é a hora que eu deveria estar acordando."

# game/script-a2-shizune.rpy:982
translate pt_br a2_shizune_chinese_whispers_d4cebc88:

    # "On weekdays, at least."
    "Em dias de semana, pelo menos."

# game/script-a2-shizune.rpy:986
translate pt_br a2_shizune_chinese_whispers_07ccd715:

    # "I pick it up and throw it without looking up. It gets wedged between the bed and the wall, the noise not stopping. In fact, it seems to grow louder."
    "Eu o pego e arremesso sem olhar. Ele fica preso entre a cama e a parede, e o barulho não para. Na verdade, ele parece ficar ainda mais alto."

# game/script-a2-shizune.rpy:990
translate pt_br a2_shizune_chinese_whispers_4b12bfea:

    # "By the time I'm able to pry it out of there I know I'm not going to be able to go back to sleep. The only thing I can think of doing now is going into town and just getting Kenji's stupid package, but it's too early for that."
    "No momento que eu consigo tirar ele dali eu percebo que eu não vou conseguir voltar a dormir. A única coisa que penso em fazer é sair pra cidade e somente pegar o pacote estúpido do Kenji, mas ainda está cedo para isso."

# game/script-a2-shizune.rpy:992
translate pt_br a2_shizune_chinese_whispers_2ec8f192:

    # "After showering, I take my medication. I'm actually very hungry today since I went without dinner yesterday, and before that I had just a very light lunch."
    "Depois de me banhar, tomo meus remédios. Eu estou com bastante fome hoje já que eu não jantei ontem, e antes disso eu tive um almoço bem leve."

# game/script-a2-shizune.rpy:994
translate pt_br a2_shizune_chinese_whispers_22c80257:

    # "I eat the pills, chomping on them like a leg of lamb. They are unbelievably bitter and disgusting."
    "Eu como as pílulas, mastigando-as como uma perna de um cordeiro. Elas são inacreditavelmente amargas e nojentas."

# game/script-a2-shizune.rpy:996
translate pt_br a2_shizune_chinese_whispers_f1df7fe7:

    # "Well, good medicine tastes bad, or something like that. I'm still hungry, and there's still a lot of time to kill, so I decide to go into town and find somewhere to have breakfast."
    "Bem, bons remédios têm gosto ruim, ou algo assim. Ainda estou com fome, e tenho bastante tempo pra matar, então decido ir à cidade e achar algum lugar pra tomar café da manhã."

# game/script-a2-shizune.rpy:998
translate pt_br a2_shizune_chinese_whispers_ca6f4bc3:

    # "I can't remember the last time I ate out. Besides, the weather is nice, so why not?"
    "Não consigo lembrar da última vez que comi fora. Aliás, o tempo está bom, então por que não?"

# game/script-a2-shizune.rpy:1005
translate pt_br a2_shizune_chinese_whispers_2f09bb7b:

    # "The walk into town is longer than I remember, possibly because it's been a while, and probably because I rarely come here alone. There are barely any cars on the road because it's so early in the morning, making it unusually quiet."
    "A caminhada até a cidade é mais longa do que eu me lembro, talvez porque já faz um tempo, e provavelmente porque eu raramente venho aqui sozinho. Quase não tem carros na rua porque ainda é cedo, deixando o ambiente bastante quieto."

# game/script-a2-shizune.rpy:1010
translate pt_br a2_shizune_chinese_whispers_8042cdb5:

    # "The first thing I do is start looking for a place to eat. Immediately I think of the Shanghai, but I want something more substantial than sandwiches or a cake."
    "A primeira coisa que faço é procurar por um lugar para comer. Imediatamente penso no Xangai, mas eu quero algo mais substancial que sanduíches ou um bolo."

# game/script-a2-shizune.rpy:1012
translate pt_br a2_shizune_chinese_whispers_2ba8556b:

    # "Since it's so early, though, I decide to get Kenji's package first."
    "Mas já que ainda está cedo, eu decido pegar o pacote do Kenji primeiro."

# game/script-a2-shizune.rpy:1014
translate pt_br a2_shizune_chinese_whispers_24d8feb6:

    # "Picking it up at the post office doesn't take very long, but the moment I see it, I'm enraged about what a pain in the ass it will be to carry this thing all the way back to the school."
    "Pegá-lo no correio não demora muito, mas no momento que o vejo, fico enfurecido sobre o pé no saco que vai ser levar isso até a escola."

# game/script-a2-shizune.rpy:1027
translate pt_br a2_shizune_chinese_whispers_ec8a14d4:

    # "The box is huge, you need two hands to hold it. Insultingly, it's not even very heavy."
    "A caixa é enorme, você precisa de duas mãos para segurá-la. E nem é tão pesada!"

# game/script-a2-shizune.rpy:1029
translate pt_br a2_shizune_chinese_whispers_62e7a391:

    # "I was thinking of wandering around for a little while, but with this thing in tow, that's going to be a real problem. I guess the Shanghai is my only option now."
    "Eu estava pensando em zanzar por aí por um tempo, mas com esta coisa em mãos, isso vai ser um verdadeiro problema. Acho que o Xangai é a minha única opção agora."

# game/script-a2-shizune.rpy:1040
translate pt_br a2_shizune_chinese_whispers_c37ae111:

    # "Everything else is closed, and the ones that aren't all have about the same menu. That fact also makes me want to throw some more business Yuuko's way."
    "Todo o resto está fechado, e os que não estão têm todos o mesmo menu. Esse fato também me faz querer jogar alguns afazeres no caminho de Yuuko."

# game/script-a2-shizune.rpy:1047
translate pt_br a2_shizune_chinese_whispers_1bcf1113:

    # "Before I can even open the door and enter, someone taps me on the shoulder from behind. I turn around and see Shizune there. Instinctively, I look for Misha, but she doesn't seem to be here."
    "Antes que eu possa abrir a porta e entrar, alguem cutuca meu ombro por trás. Eu me viro e vejo a Shizune ali. Instintivamente, eu procuro por Misha, mas ela não parece estar aqui."

# game/script-a2-shizune.rpy:1052
translate pt_br a2_shizune_chinese_whispers_ece4a6b6:

    # ssh "Good morning."
    ssh "Bom dia."

# game/script-a2-shizune.rpy:1054
translate pt_br a2_shizune_chinese_whispers_f428269f:

    # "Looks like those sign language classes are already starting to pay off. I'm tempted to sign it right back, but then she might think I know a lot more than I actually do."
    "Parece que essas aulas de língua de sinais já estão me recompensando. Estou tentado a sinalizar de volta, mas ela pode pensar que eu sei bem mais do que eu sei de fato."

# game/script-a2-shizune.rpy:1056
translate pt_br a2_shizune_chinese_whispers_f0d36342:

    # "For now, I just give her a wave and open the door. She's probably here for her morning tea and didn't come here just to greet me. It turns out I'm right, as Shizune follows me inside the teahouse."
    "Por ora, só dei um aceno e abri a porta. Ela está provavelmente aqui pelo chá matinal e não veio aqui apenas para me cumprimentar. No fim estou certo, visto que Shizune me segue pra dentro da casa de chá."

# game/script-a2-shizune.rpy:1063
translate pt_br a2_shizune_chinese_whispers_13d7eee9:

    # "It's a total ghost town in here. It's not exactly peak hours, but every other café I passed had at least a few customers."
    "É uma cidade fantasma aqui. Não é exatamente horário de pico, mas todos os outros cafés que eu passei tinham pelo menos alguns poucos fregueses."

# game/script-a2-shizune.rpy:1065
translate pt_br a2_shizune_chinese_whispers_6a1b2777:

    # "Actually, the Shanghai has been fairly empty every time I passed by. How does this place stay in business?"
    "Aliás, o Xangai sempre esteve meio vazio toda vez que eu passava por aqui. Como este lugar ainda está de pé?"

# game/script-a2-shizune.rpy:1070
translate pt_br a2_shizune_chinese_whispers_40bb4093:

    # yu "Hello! Thank you for choosing to patronize our establishment!"
    yu "Olá! Obrigado por ter escolhido nosso estabelecimento!"

# game/script-a2-shizune.rpy:1085
translate pt_br a2_shizune_chinese_whispers_20043695:

    # "Yuuko bows with the force of a falling axe and her head collides with the box in my hands, launching it towards the floor."
    "Yuuko se curva com a força de um machado, e sua cabeça colide com a caixa em minhas mãos, lançando-a ao chão."

# game/script-a2-shizune.rpy:1092
translate pt_br a2_shizune_chinese_whispers_144eb8fa:

    # yu "Oh no, I'm sorry, I'm really sorry, sorry, please forgive me!"
    yu "Oh não, me desculpe, me desculpe mesmo, por favor, me perdoe!"

# game/script-a2-shizune.rpy:1094
translate pt_br a2_shizune_chinese_whispers_f74d683b:

    # hi "It's okay, and you don't have to do that 'Hello, thanks for choosing our shop!' thing since we know you."
    hi "Tudo bem, e você não precisa dizer “Olá, obrigado por escolher nossa loja!” e essas coisas já que nós te conhecemos."

# game/script-a2-shizune.rpy:1099
translate pt_br a2_shizune_chinese_whispers_4f476eb5:

    # yu "But it's part of my job."
    yu "Mas faz parte do meu trabalho."

# game/script-a2-shizune.rpy:1104
translate pt_br a2_shizune_chinese_whispers_2038c6b7:

    # yu "You're here early, what can I get you?"
    yu "Você está aqui cedo, o que posso pegar pra você?"

# game/script-a2-shizune.rpy:1106
translate pt_br a2_shizune_chinese_whispers_8078f022:

    # hi "I just want some coffee for now."
    hi "Por ora eu só quero um café."

# game/script-a2-shizune.rpy:1119
translate pt_br a2_shizune_chinese_whispers_e696af71:

    # "I wonder what Shizune wants. Without Misha, there's no real way to tell, or any way to even ask. I haven't learned about that yet. She's here, so I'm pretty sure that means she wants something too."
    "Eu me pergunto o que a Shizune quer. Sem a Misha por perto, não tem como saber com certeza, e não tem como perguntar. Eu ainda não aprendi isso. Ela está aqui, então eu tenho certeza de que ela quer algo também."

# game/script-a2-shizune.rpy:1121
translate pt_br a2_shizune_chinese_whispers_4c6e28ef:

    # hi "Er, I don't really know what Shizune wants. Does she have a usual?"
    hi "Er, eu não sei o que a Shizune quer. Ela tem um “o de sempre”?"

# game/script-a2-shizune.rpy:1123
translate pt_br a2_shizune_chinese_whispers_6aaf4ee5:

    # hi "Wait, she might want something else, though. Perhaps you should bring us a menu just in case."
    hi "Espere, pode ser que ela queira outra coisa, porém. Talvez você poderia nos trazer um menu, caso precise."

# game/script-a2-shizune.rpy:1125
translate pt_br a2_shizune_chinese_whispers_a9c6f12d:

    # "I look around for one, but can't find anything that looks remotely like a menu."
    "Eu procuro por um, mas não consigo achar nada que se pareça remotamente com um menu."

# game/script-a2-shizune.rpy:1130
translate pt_br a2_shizune_chinese_whispers_691bcfd9:

    # yu "Menus… I'll look for one right now."
    yu "Menus… Procurarei um agora mesmo."

# game/script-a2-shizune.rpy:1132
translate pt_br a2_shizune_chinese_whispers_0f638bea:

    # hi "Huh?"
    hi "Hã?"

# game/script-a2-shizune.rpy:1137
translate pt_br a2_shizune_chinese_whispers_81303457:

    # yu "Um… there are menus. They're just… rare."
    yu "Um… aqui tem menus. Só que eles são… raros."

# game/script-a2-shizune.rpy:1139
translate pt_br a2_shizune_chinese_whispers_945b7462:

    # "It's only a restaurant menu, not a collector's edition."
    "É só um menu de restaurante, não um item de colecionador."

# game/script-a2-shizune.rpy:1144
translate pt_br a2_shizune_chinese_whispers_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1146
translate pt_br a2_shizune_chinese_whispers_86d35800:

    # hi "Weird."
    hi "Estranho."

# game/script-a2-shizune.rpy:1151
translate pt_br a2_shizune_chinese_whispers_3e8507cf:

    # yu "Is that what Shizune is saying?"
    yu "É isso que a Shizune está dizendo?"

# game/script-a2-shizune.rpy:1153
translate pt_br a2_shizune_chinese_whispers_35ef789c:

    # hi "Nah, she can't hear you. It's just weird for a café to make you have to go out of your way to look for a menu."
    hi "Nah, ela não pode te ouvir. Só é meio estranho para um café você ter que sair do caminho para procurar por um menu."

# game/script-a2-shizune.rpy:1158
translate pt_br a2_shizune_chinese_whispers_b819fda3:

    # yu "Weird…?"
    yu "Estranho…?"

# game/script-a2-shizune.rpy:1163
translate pt_br a2_shizune_chinese_whispers_ad5bfad1:

    # yu "Yes… you're right. It's so illogical. There are so many things… Like, why is it called the Shanghai? This is a Western style teahouse… but, the name is Chinese… and the architecture is old-fashioned, but my uniform is so modern and sophisticated…"
    yu "Sim… você está certo. Não faz sentido. Tem tantas coisas… Como, porque aqui é chamado o Xangai? Isso é uma casa de chá de estilo ocidental… mas, o nome é chinês… e a arquitetura é tão antiquada mas meu uniforme é tão moderno e sofisticado…"

# game/script-a2-shizune.rpy:1165
translate pt_br a2_shizune_chinese_whispers_2f390fcb:

    # "She looks like she's about to pass out. If she does she'll probably fall forward and make a mess of everything."
    "Ela parece que está prestes a desmaiar. Se isso acontecer ela provavelmente cairá pra frente e fará uma bagunça em tudo."

# game/script-a2-shizune.rpy:1170
translate pt_br a2_shizune_chinese_whispers_98cb8fdc:

    # yu "I can't work here any more."
    yu "Não posso mais trabalhar aqui."

# game/script-a2-shizune.rpy:1172
translate pt_br a2_shizune_chinese_whispers_5e7691d0:

    # "What a bad place for her circular train of logic to end up."
    "Que lugar ruim para sua lógica terminar."

# game/script-a2-shizune.rpy:1174
translate pt_br a2_shizune_chinese_whispers_668ef6b5:

    # hi "No, come on. That kind of stuff is what sets this place apart; there are a lot of cafés around here, you know. I think it's charming, really. Please don't quit. Business is good here, isn't it?"
    hi "Não, vamos lá. Este tipo de coisa é o que diferencia esse lugar; tem vários cafés por aqui, sabe. Eu acho charmoso, sério. Por favor, não saia. Trabalhar aqui é bom, não é?"

# game/script-a2-shizune.rpy:1179
translate pt_br a2_shizune_chinese_whispers_e21527c2:

    # yu "Not really…"
    yu "Não muito…"

# game/script-a2-shizune.rpy:1181
translate pt_br a2_shizune_chinese_whispers_58a606de:

    # hi "See, I think this is a good job for you. It suits you, you shouldn't quit."
    hi "Veja, eu acho que esse é um bom trabalho pra você. Combina com você, você não deve sair."

# game/script-a2-shizune.rpy:1183
translate pt_br a2_shizune_chinese_whispers_407b6141:

    # "I've never had to defuse this kind of crisis before."
    "Eu nunca tive que amenizar esse tipo de crise antes."

# game/script-a2-shizune.rpy:1187
translate pt_br a2_shizune_chinese_whispers_ea1a84fd:

    # "Eventually, I manage to calm her down, and convince her that I'm sure Shizune just wants what she usually orders here."
    "Eventualmente, eu consigo acalmá-la, e convencê-la que a Shizune quer o que ela geralmente pede aqui."

# game/script-a2-shizune.rpy:1200
translate pt_br a2_shizune_chinese_whispers_fc0919dc:

    # "Yuuko walks away to get our drinks, and by then, Shizune has already picked a table."
    "Yuuko sai para pegar nossas bebidas, e a Shizune já escolheu uma mesa."

# game/script-a2-shizune.rpy:1204
translate pt_br a2_shizune_chinese_whispers_00ae4000:

    # "There are no other customers, and Yuuko isn't the most talkative person, so it's very quiet."
    "Não tem outros fregueses, e a Yuuko não é a pessoa mais falante do mundo, então está bem quieto."

# game/script-a2-shizune.rpy:1206
translate pt_br a2_shizune_chinese_whispers_58b6f1e0:

    # "It doesn't really bother me, but I wish that there was some way we could communicate. There are so few moments when we're alone. Shizune and Misha are almost always together, to the point where sometimes it seems like they are one."
    "Isso não me incomoda, mas eu queria que tivesse algum jeito de nos comunicarmos. São poucos os momentos que estamos sozinhos. Shizune e Misha estão quase sempre juntas, ao ponto que às vezes parecem que são uma só."

# game/script-a2-shizune.rpy:1208
translate pt_br a2_shizune_chinese_whispers_141c6a82:

    # "Now, it's just me and her, and I'm unable to understand her or have her understand me. It's terrible."
    "Agora, sou só eu e ela, e eu sou incapaz de entendê-la ou fazê-la me entender. É terrível."

# game/script-a2-shizune.rpy:1210
translate pt_br a2_shizune_chinese_whispers_69e8b6f0:

    # hi "You don't have your little notepad today? I know it's the weekend and all, but it's not like you to be unprepared."
    hi "Você não trouxe seu bloquinho de notas hoje? Eu sei que é fim de semana e tudo mais, mas é estranho você estar despreparada."

# game/script-a2-shizune.rpy:1212
translate pt_br a2_shizune_chinese_whispers_beb58c29:

    # hi "Well, that's fine. I don't really like using it anyway. Still, it would come in handy now."
    hi "Bem, tudo bem. Eu não gosto de usá-lo, de qualquer forma. Ainda assim, seria bem conveniente agora."

# game/script-a2-shizune.rpy:1217
translate pt_br a2_shizune_chinese_whispers_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1222
translate pt_br a2_shizune_chinese_whispers_0783f6df:

    # shi "… …"
    shi "… …"

# game/script-a2-shizune.rpy:1224
translate pt_br a2_shizune_chinese_whispers_f486adfc:

    # "Shizune starts signing in short bursts punctuated by her stopping to take a sip of tea. It's strange how she doesn't make the slightest attempt to change how she normally acts."
    "Shizune começa a fazer sinais em pequenos estouros pontuados por suas paradas para tomar um pequeno gole de chá. É estranho como ela não tenta mudar o jeito que ela age normalmente."

# game/script-a2-shizune.rpy:1226
translate pt_br a2_shizune_chinese_whispers_96daa63e:

    # "I'm talking to her for the most part because I'm not used to long silences. I briefly wonder if it's the same for her, in a way; however, it seems unlikely. I think it's more that she is the type who doesn't change how she acts for anyone."
    "Eu estou falando com ela a maior parte porque eu não estou acostumado a longos silêncios. Imagino se é o mesmo para ela, de certo modo; contudo, parece improvável. Acho que ela é mais o tipo que não muda o modo que ela age pra ninguém."

# game/script-a2-shizune.rpy:1228
translate pt_br a2_shizune_chinese_whispers_bd3b9735:

    # hi "Hey, it seems like Misha joined the Student Council because of you. That makes two of us, you know. I'm only there because you forced me into it."
    hi "Ei, parece que a Misha entrou no Conselho Estudantil por causa de você. Isso nos fazem dois, sabe. Eu só estou lá porque você me forçou a entrar nele."

# game/script-a2-shizune.rpy:1230
translate pt_br a2_shizune_chinese_whispers_adcc8667:

    # hi "Well, not really forced, I guess. If it wasn't for you, I wouldn't have joined."
    hi "Bem, não exatamente forçou, eu acho. Mas se não fosse por você, eu não teria entrado."

# game/script-a2-shizune.rpy:1232
translate pt_br a2_shizune_chinese_whispers_10e9f26a:

    # "That sounds slightly romantic, and I find myself blushing a little. I feel like such an idiot."
    "Isso soa um pouco romântico, e eu me sinto um pouco envergonhado. Me sinto como um idiota."

# game/script-a2-shizune.rpy:1234
translate pt_br a2_shizune_chinese_whispers_834afab0:

    # hi "Although, I still don't know why you joined. It should have been the first thing I asked, in retrospect, but I'm really curious. I'll have to remember to ask Misha sometime."
    hi "Porém, eu ainda não sei porque você entrou. Deveria ter sido a primeira coisa que eu perguntei, mas estou bem curioso. Eu me lembrarei de perguntar a Misha, qualquer hora."

# game/script-a2-shizune.rpy:1239
translate pt_br a2_shizune_chinese_whispers_ef2b123c_2:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1241
translate pt_br a2_shizune_chinese_whispers_5d7d4f9f:

    # hi "It's nice to talk to you, even if you can't understand me. I wonder if it's the same for you."
    hi "É legal falar com você, mesmo você não podendo me entender. Eu me pergunto se é o mesmo pra você."

# game/script-a2-shizune.rpy:1243
translate pt_br a2_shizune_chinese_whispers_0f23c0ce:

    # hi "That would be really… great."
    hi "Isso seria bem… legal."

# game/script-a2-shizune.rpy:1248
translate pt_br a2_shizune_chinese_whispers_ef2b123c_3:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1250
translate pt_br a2_shizune_chinese_whispers_4e0174cc:

    # hi "I don't think sign language will ever be as natural for me as Misha makes it look, but it's got to be a step up from using pen and paper, right?"
    hi "Não acho que a língua de sinais vai ser tão natural pra mim quanto a Misha faz parecer, mas já vai ser melhor que usar caneta e papel, certo?"

# game/script-a2-shizune.rpy:1255
translate pt_br a2_shizune_chinese_whispers_ef2b123c_4:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1259
translate pt_br a2_shizune_chinese_whispers_9885a81e:

    # "We've both been finished with our drinks for a while, and Shizune's eyes fall upon the box sitting in its own chair by my side."
    "Nós dois já terminamos nossa bebida há um tempo, e os olhos de Shizune caem sobre a caixa repousada em sua cadeira ao meu lado."

# game/script-a2-shizune.rpy:1264
translate pt_br a2_shizune_chinese_whispers_ef2b123c_5:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1266
translate pt_br a2_shizune_chinese_whispers_54517eae:

    # hi "I'm just picking it up for someone, it's not mine."
    hi "Eu só estou pegando-a pra alguém, não é minha."

# game/script-a2-shizune.rpy:1273
translate pt_br a2_shizune_chinese_whispers_d7b6daf5:

    # "Shizune pulls it closer to her, intending to open it, and my heart almost leaps out of my throat. I quickly try to pull it back by wrapping my leg around the leg of the chair."
    "Shizune a puxa pra perto dela, pensando em abrí-la, e meu coração quase salta da garganta. Rapidamente tento puxar de volta, colocando minha perna em volta da cadeira."

# game/script-a2-shizune.rpy:1275
translate pt_br a2_shizune_chinese_whispers_4544d5e4:

    # hi "What the hell, don't open it. You can't just open other people's mail, that's not legal."
    hi "Ei, não abra isso! Você não pode abrir a correspondência das outras pessoas, isso não é legal."

# game/script-a2-shizune.rpy:1280
translate pt_br a2_shizune_chinese_whispers_ef2b123c_6:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1282
translate pt_br a2_shizune_chinese_whispers_9859958a:

    # hi "No!"
    hi "Não!"

# game/script-a2-shizune.rpy:1287
translate pt_br a2_shizune_chinese_whispers_b33ba1f7:

    # shi "…!"
    shi "…!"

# game/script-a2-shizune.rpy:1289
translate pt_br a2_shizune_chinese_whispers_271d0911:

    # "Once she gets going, there is almost no stopping her. Eyes filled with excitement, she looks ready to fight me over this stupid package and I realize just how fast this could turn into a game of tug-of-war."
    "Quando ela começa, não tem quem pare. Seus olhos cheios de entusiasmo, ela parece pronta para lutar por este estúpido pacote e eu percebo o quão rápido isso poderia virar um jogo de cabo-de-guerra."

# game/script-a2-shizune.rpy:1294
translate pt_br a2_shizune_chinese_whispers_8cc3abc0:

    # "I am almost out of my seat now and waving my arms like an air traffic controller, before she finally settles down."
    "Eu estou quase fora do meu assento e balançando meus braços feito um controlador de tráfego aéreo, antes dela finalmente se acalmar."

# game/script-a2-shizune.rpy:1299
translate pt_br a2_shizune_chinese_whispers_46946ec2:

    # "Shizune pouts, not pleased with having her curiosity checked, and gets up to leave."
    "Shizune faz cara feia, insatisfeita por ter sua curiosidade restringida, e se levanta para sair."

# game/script-a2-shizune.rpy:1301
translate pt_br a2_shizune_chinese_whispers_58b5c907:

    # "It's about time to, I guess. We've been here a while. I protectively pick up the box before standing up myself."
    "Acho que já está na hora. Nós estamos aqui faz um tempo. Eu pego a caixa com cuidado antes de me levantar."

# game/script-a2-shizune.rpy:1306
translate pt_br a2_shizune_chinese_whispers_d6cf4016:

    # "Suddenly, she tents her fingers excitedly and pulls out a marker from her pocket, and starts writing on Kenji's box."
    "De repente, ela mexe seu dedo animadamente e tira um marca-texto do seu bolso, e começa a escrever na caixa do Kenji."

# game/script-a2-shizune.rpy:1308
translate pt_br a2_shizune_chinese_whispers_effde555:

    # hi "Hey, what are you doing? I said this isn't mine!"
    hi "Ei, o que você está fazendo? Eu disse que isso não é meu!"

# game/script-a2-shizune.rpy:1310
translate pt_br a2_shizune_chinese_whispers_d5322af5:

    # hi "Hey!"
    hi "Ei!"

# game/script-a2-shizune.rpy:1312
translate pt_br a2_shizune_chinese_whispers_72f7250f:

    # "I can't even see her with it blocking my vision."
    "Eu nem sequer posso vê-la com a caixa bloqueando minha visão."

# game/script-a2-shizune.rpy:1314
translate pt_br a2_shizune_chinese_whispers_b0bc164b:

    # hi "Fine, at least let me put it down first."
    hi "Beleza, pelo menos deixe eu abaixá-la antes."

# game/script-a2-shizune.rpy:1316
translate pt_br a2_shizune_chinese_whispers_789e9b34:

    # "I have to to read whatever she's writing, anyway."
    "Eu tenho que ler seja lá o que ela está escrevendo, de qualquer forma."

# game/script-a2-shizune.rpy:1323
translate pt_br a2_shizune_chinese_whispers_9540b45b:

    # "It doesn't seem like she's finished, though, and Shizune draws a fierce line afterward to signify that there's a catch."
    "Todavia, ela não parece ter terminado, e Shizune desenha uma linha forte depois para indicar que tem uma pegadinha."

# game/script-a2-shizune.rpy:1327
translate pt_br a2_shizune_chinese_whispers_862b88cc:

    # hi "That's stupid, there's a fifty percent chance I'll end up carrying it myself anyway."
    hi "Isso é estúpido, tem uma chance de cinquenta por cento que eu vou acabar carregando eu mesmo, de qualquer modo."

# game/script-a2-shizune.rpy:1329
translate pt_br a2_shizune_chinese_whispers_d3fa4e81:

    # "Actually, I feel pretty stupid myself right now. I just forgot she can't hear me. I stop talking and shake my head."
    "Na verdade, eu me sinto bem estúpido também agora. Eu acabei de esquecer que ela não pode me ouvir. Eu paro de falar e balanço minha cabeça."

# game/script-a2-shizune.rpy:1334
translate pt_br a2_shizune_chinese_whispers_ef2b123c_7:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1339
translate pt_br a2_shizune_chinese_whispers_b33ba1f7_1:

    # shi "…!"
    shi "…!"

# game/script-a2-shizune.rpy:1344
translate pt_br a2_shizune_chinese_whispers_b33ba1f7_2:

    # shi "…!"
    shi "…!"

# game/script-a2-shizune.rpy:1346
translate pt_br a2_shizune_chinese_whispers_e06b7a09:

    # "I can't understand her at all, but she's coming across very forcefully. It's clear that she thinks this is a great idea."
    "Eu não consigo entendê-la, mas claramente ela acha que essa é uma ótima ideia."

# game/script-a2-shizune.rpy:1348
translate pt_br a2_shizune_chinese_whispers_7c0b59a2:

    # "Well, if she drops the box or something, she'll have to carry it. That would make things a lot easier for me, obviously."
    "Bem, se ela deixar a caixa cair ou algo do tipo, ela terá que carregá-la. Isso deixaria as coisas bem mais fáceis pra mim, obviamente."

# game/script-a2-shizune.rpy:1350
translate pt_br a2_shizune_chinese_whispers_e26ca318:

    # "The odds are 50-50, then… they're probably higher than they would be for any other plan of hers. All right, I'll take it."
    "As chances são 50-50, então… elas provavelmente são mais altas do que seriam pra qualquer outro plano dela. Ok, eu topo."

# game/script-a2-shizune.rpy:1355
translate pt_br a2_shizune_chinese_whispers_d4c8e398:

    # "Thinking about it, I'm not sure how we should do this. Then Shizune grabs hold of one end of the box and lifts it up, and I take the side that she isn't holding. Is this even right? It's very uncomfortable to walk like this."
    "Pensando nisso, eu não sei como deveríamos fazer isto. Então Shizune segura um lado da caixa e o levanta, e eu pego o lado que ela não está segurando. Será que tá certo? É bem desconfortável andar assim."

# game/script-a2-shizune.rpy:1360
translate pt_br a2_shizune_chinese_whispers_cd16030b:

    # "We leave the café, and I find myself hoping that the streets are still devoid of people. Yuuko seemed confused as to what we were doing, and I imagine it'll only get worse as more people see us."
    "Nós saímos do café, e eu me vejo torcendo para que as ruas ainda estejam vazias. Yuuko parece estar confusa sobre o que estamos fazendo, e eu imagino que só vá piorar conforme as pessoas nos veem."

# game/script-a2-shizune.rpy:1368
translate pt_br a2_shizune_chinese_whispers_6fab88c3:

    # "Shizune doesn't seem bothered at all while walking with her arm at this unnatural angle; she just grins confidently and periodically makes some kind of weird gesture."
    "Shizune não parece incomodada enquanto anda com seu braço neste ângulo anormal; ela apenas sorri confiante e periodicamente faz algum tipo de gesto estranho."

# game/script-a2-shizune.rpy:1373
translate pt_br a2_shizune_chinese_whispers_3c766f04:

    # "There are people staring at us as time passes, and the usual morning crowd begins to fill the streets."
    "As pessoas nos observam conforme o tempo passa, e a multidão usual da manhã começa a encher as ruas."

# game/script-a2-shizune.rpy:1375
translate pt_br a2_shizune_chinese_whispers_091821c8:

    # "I feel silly, but I'm sure that if I give up, Shizune will take it as a sign of surrender. I can't allow that, because I think I'm doing well so far."
    "Eu me sinto bobo, mas eu tenho certeza que se eu desistir, Shizune tomará isso como um símbolo de rendição. Não posso permitir isso, porque eu tenho certeza que estou indo bem até agora."

# game/script-a2-shizune.rpy:1383
translate pt_br a2_shizune_chinese_whispers_0f98732a:

    # "Initially, I just write Shizune's little hand signals off as her preemptively gloating, but I catch on quickly that she's actually signaling where she wants to go."
    "Inicialmente, eu interpreto os pequenos sinais de Shizune como deleite antecipado, mas rapidamente percebo que ela está sinalizando aonde ela quer ir."

# game/script-a2-shizune.rpy:1385
translate pt_br a2_shizune_chinese_whispers_24c8fb07:

    # "It dawns on me that this isn't a competition. It's not much of a challenge, first of all, and second, it's really more of an exercise in teamwork. It's just that Shizune has made a punishment for failing instead of a reward for doing well."
    "Eu me toco que isso não é uma competição. Não é um grande desafio, primeiramente, e segundo, é mais um exercício de trabalho em equipe. É que a Shizune fez uma punição por falhar do que uma recompensa por ir bem."

# game/script-a2-shizune.rpy:1392
translate pt_br a2_shizune_chinese_whispers_401329c5:

    # "Our fingers touch under the box, and Shizune moves her hand away, almost dropping her side of the box in the process."
    "Nossos dedos se tocam sob a caixa, e Shizune move sua mão, quase deixando cair seu lado da caixa no processo."

# game/script-a2-shizune.rpy:1394
translate pt_br a2_shizune_chinese_whispers_bf15c76a:

    # "Well, that's game over for her."
    "Bem, isso é fim de jogo pra ela."

# game/script-a2-shizune.rpy:1396
translate pt_br a2_shizune_chinese_whispers_7f479ed4:

    # "She doesn't look very happy. Does she think I did it on purpose to make her lose? If she does, she isn't making a big deal out of it. All's fair in love and war."
    "Ela não parece muito contente. Ela acha que eu fiz de propósito para fazê-la perder? Se sim, ela não está fazendo muito disto. Vale tudo no amor e na guerra."

# game/script-a2-shizune.rpy:1401
translate pt_br a2_shizune_chinese_whispers_870e1436:

    # "I feel like I should take it from her and carry it myself, but she pushes me away when I try."
    "Eu sinto que eu devo tirar a caixa dela e carregá-la eu mesmo, mas ela me empurra quando eu tento."

# game/script-a2-shizune.rpy:1405
translate pt_br a2_shizune_chinese_whispers_21bf6da5:

    # "She glares at me as if to tell me off, but she can't. With that box in her hands, she is basically gagged."
    "Ela olha fixamente pra mim como se fosse repreender, mas não pode. Com a caixa em mãos, ela está praticamente amordaçada."

# game/script-a2-shizune.rpy:1413
translate pt_br a2_shizune_chinese_whispers_5190e505:

    # "A sad expression flickers across her face for a second, maybe on realizing that and having to acknowledge that there are some limitations she has to deal with after all."
    "Uma expressão triste surge em sua cara por um segundo, talvez por perceber isto e ter que admitir que tem algumas limitações que ela tem que lidar apesar de tudo."

# game/script-a2-shizune.rpy:1415
translate pt_br a2_shizune_chinese_whispers_d55b0d48:

    # "However, she is still as prideful as ever, even when it's to her detriment. She wouldn't accept letting me allow her to skip out on the consequences of her bet."
    "Ainda assim, ela está tão orgulhosa como sempre, mesmo quando está a seu detrimento. Ela não aceitaria deixar eu permiti-la pular fora das consequências de sua aposta."

# game/script-a2-shizune.rpy:1417
translate pt_br a2_shizune_chinese_whispers_c20eec2e:

    # "Anything is fair during the game, but the results have to be honored to the letter, huh?"
    "Tudo é justo durante o jogo, mas os resultados têm que ser seguidos ao pé da letra, não?"

# game/script-a2-shizune.rpy:1419
translate pt_br a2_shizune_chinese_whispers_4e5231c4:

    # "Shizune is an interesting type of person."
    "Shizune é um tipo de pessoa interessante."

# game/script-a2-shizune.rpy:1424
translate pt_br a2_shizune_chinese_whispers_3e181de6:

    # "The march back to the dorms is uneventful. Shizune passes the trip by shifting the box around occasionally like a giant Rubik's cube. It looks like another game she has invented to amuse herself."
    "A volta aos dormitórios é calma. Shizune passa a viagem girando a caixa ocasionalmente como um cubo mágico gigante. Parece outro jogo que ela inventou para se entreter."

# game/script-a2-shizune.rpy:1426
translate pt_br a2_shizune_chinese_whispers_f0dfa9ce:

    # "It can't be good for whatever's inside, but I don't care enough to stop her."
    "Não deve ser bom para seja lá o que está dentro, mas eu não ligo o suficiente para pará-la."

# game/script-a2-shizune.rpy:1428
translate pt_br a2_shizune_chinese_whispers_a8886688:

    # "Maybe this is how she deals with things, by making everything into a game; it's hard to say for sure, though."
    "Talvez seja assim que ela lide com as coisas, transformando tudo em um jogo; todavia, é difícil ter certeza."

# game/script-a2-shizune.rpy:1430
translate pt_br a2_shizune_chinese_whispers_75aba597:

    # "It seems futile to try to psychoanalyze Shizune. In the short time we've known each other, I've been surprised on a fair number of occasions."
    "Parece fútil tentar analisar a Shizune psicologicamente. No curto período de tempo que nós nos conhecemos, eu fui surpreendido num número razoável de ocasiões."

# game/script-a2-shizune.rpy:1437
translate pt_br a2_shizune_chinese_whispers_2980203a:

    # "I notice Shizune shivering. The wind is picking up, and the school is pretty high up. It makes sense that she would be cold. If I gave her my jacket, though, would she reject it?"
    "Eu percebo Shizune tremendo. Está começando a ventar, e a escola está lá no alto. Faz sentido estar frio. Se eu a desse minha blusa, porém, ela rejeitaria?"

# game/script-a2-shizune.rpy:1444
translate pt_br a2_shizune_chinese_whispers_d9f448fb:

    # "I take off my jacket and drape it across her shoulders before she has a chance to protest. Her shoulders are slim and delicate, so much so that I want to let my hands linger on them."
    "Eu tiro minha blusa e coloco sobre seus ombros antes que ela possa protestar. Seus ombros são finos e delicados, tanto que eu quero deixar minhas mãos sobre eles por um momento."

# game/script-a2-shizune.rpy:1449
translate pt_br a2_shizune_chinese_whispers_ee0d0788:

    # "Shizune flinches when my fingers brush against her, understandably surprised."
    "Shizune recua quando meus dedos tocam nela, compreensivelmente surpresa."

# game/script-a2-shizune.rpy:1451
translate pt_br a2_shizune_chinese_whispers_eab1722c:

    # hi "Sorry."
    hi "Desculpe."

# game/script-a2-shizune.rpy:1456
translate pt_br a2_shizune_chinese_whispers_ef2b123c_8:

    # shi "…"
    shi "…"
    
    

# game/script-a2-shizune.rpy:1461
translate pt_br a2_shizune_chinese_whispers_ef2b123c_9:

    # shi "…"
    shi "…"
    
    

# game/script-a2-shizune.rpy:1463
translate pt_br a2_shizune_chinese_whispers_c9a02be6:

    # "Her fingers dance lightly over the surface of the box, and I think of taking it from her, but I doubt she would let me. Shizune makes a quick gesture with her hands as best she can, pausing a bit afterward as if wanting to say more."
    "Seus dedos dançam levemente sobre a superfície da caixa, e eu penso em tirá-la dela, mas duvido que ela deixaria. Shizune faz um gesto rápido com suas mãos, pausando um pouco depois como se quisesse dizer mais."

# game/script-a2-shizune.rpy:1465
translate pt_br a2_shizune_chinese_whispers_5e268974:

    # "I'm sure that what she means is 'thank you.' I'm glad that I was able to catch it."
    "Eu tenho certeza que o que ela quer dizer é “obrigada.” Estou contente que eu fui capaz de entender."

# game/script-a2-shizune.rpy:1479
translate pt_br a2_shizune_advanced_game_theory_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:1486
translate pt_br a2_shizune_advanced_game_theory_d2997a3f:

    # n "{vspace=60}The sign language teacher says I'm pretty good."
    n "{vspace=60}O professor de língua de sinais diz que sou muito bom."

# game/script-a2-shizune.rpy:1488
translate pt_br a2_shizune_advanced_game_theory_4733eb15:

    # n "I try not to think about it too much, but the truth is I'm poring over it so much lately that it's hard not to keep coming back to it at least a couple times a day. I guess I am picking it up faster than expected, but it's still not enough."
    n "Eu tento não pensar nisso muito, mas a verdade é que estou tão focado nisso que é difícil não voltar a pensar nissso pelo menos algumas vezes no dia. Acho que estou pegando o jeito mais rápido que o esperado, mas ainda não é o suficiente."

# game/script-a2-shizune.rpy:1490
translate pt_br a2_shizune_advanced_game_theory_dad9890e:

    # n "I understand it just fine; understanding it is simple. Well, I have to put my mind to it to read it, but it's easy enough when I do."
    n "Eu consigo entender direito; entender é simples. Bem, eu tenho que me concentrar bastante para ler, mas até que é facil quando eu me concentro."

# game/script-a2-shizune.rpy:1492
translate pt_br a2_shizune_advanced_game_theory_3e3bbd49:

    # n "The signing itself is doable, I just need a little more practice. However, trying to do both at the same time, even at half the speed Misha does it? It's impossible."
    n "Também consigo fazer os sinais em si, só preciso de um pouco mais de prática. Mas tentar fazer ambos ao mesmo tempo, mesmo na metade da velocidade que a Misha faz? Impossível!"

# game/script-a2-shizune.rpy:1494
translate pt_br a2_shizune_advanced_game_theory_5d0b9f8f:

    # n "Where I'm at now is good for my level, but in order to reach a point where I'll be able to really converse with Shizune, I'll need more work."
    n "Aonde eu estou agora é bom para o meu nível, mas pra chegar num ponto onde eu vou conseguir conversar normalmente com Shizune, precisarei trabalhar mais."

# game/script-a2-shizune.rpy:1496
translate pt_br a2_shizune_advanced_game_theory_01a2001e:

    # n "{vspace=30}I'm doing my best to get to that point one step at a time by doing as much studying as I can squeeze in during lunch."
    n "{vspace=30}Estou dando meu melhor pra chegar nesse ponto, estudando o máximo que posso durante o almoço."

# game/script-a2-shizune.rpy:1500
translate pt_br a2_shizune_advanced_game_theory_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:1504
translate pt_br a2_shizune_advanced_game_theory_378acdd4:

    # "I look up from 'Introduction to Japanese Sign Language' to check if Shizune or Misha are around."
    "Eu olho sobre o livro “Introdução à Língua Japonesa de Sinais” para ver se Shizune ou Misha estão ao redor."

# game/script-a2-shizune.rpy:1506
translate pt_br a2_shizune_advanced_game_theory_587bd54a:

    # "Of course, since this is taking up my lunch hour, I've had to avoid them for a few days now. What's more, I'll have to continue doing so if I want to keep Shizune from finding out."
    "Claro, já que isso está tomando meu horário de almoço, eu tive que evitá-las por uns dias. E mais, eu terei que continuar fazendo isso se eu quiser evitar que a Shizune descubra."

# game/script-a2-shizune.rpy:1508
translate pt_br a2_shizune_advanced_game_theory_5c1327e2:

    # "My back to the corner, scanning the area every ten minutes, I feel like some kind of criminal trying to evade capture."
    "Sentado no canto, olhando a área a cada dez minutos, me sinto como um tipo de criminoso tentando evitar ser pego."

# game/script-a2-shizune.rpy:1510
translate pt_br a2_shizune_advanced_game_theory_ce617998:

    # "…"
    "…"

# game/script-a2-shizune.rpy:1516
translate pt_br a2_shizune_advanced_game_theory_44a7ce24:

    # nvl clear
    # n "{vspace=60}Every chance she gets, Misha asks me why I want to hide the fact I'm learning sign language from Shizune."
    nvl clear
    n "{vspace=60}Toda vez que consegue, Misha me pergunta porque eu quero esconder o fato que eu estou aprendendo língua de sinais da Shizune."

# game/script-a2-shizune.rpy:1520
translate pt_br a2_shizune_advanced_game_theory_b6b7e84c:

    # n "Looking back on it, there really wasn't any reason, but now I think I know."
    n "Olhando para trás, não tinha nenhuma razão específica, mas agora eu acho que sei."

# game/script-a2-shizune.rpy:1522
translate pt_br a2_shizune_advanced_game_theory_b0750deb:

    # n "If I want Shizune to be able to treat me as a true equal, sign language is an important step towards that goal."
    n "Se eu quero que a Shizune possa me tratar como um igual, a língua de sinais é um passo importante para isso."

# game/script-a2-shizune.rpy:1524
translate pt_br a2_shizune_advanced_game_theory_eab4dacf:

    # n "If I want to be able to treat Shizune as an equal, then sign language is an important step towards that goal."
    n "Se eu quero ser capaz de tratar a Shizune como uma igual, a língua de sinais é um passo importante para isso."

# game/script-a2-shizune.rpy:1526
translate pt_br a2_shizune_advanced_game_theory_5356577e:

    # n "Another important step is to make sure she doesn't know, so that when we're able to finally speak on equal terms, I'll be fully ready, able to do it right, not like some dilettante."
    n "Outro passo importante é me certificar que ela não sabe, então quando nós formos realmente capazes de nos falar, eu estarei pronto, capaz de fazê-lo corretamente, não como um amador."

# game/script-a2-shizune.rpy:1528
translate pt_br a2_shizune_advanced_game_theory_7337ca16:

    # n "Anything less, I think, would be insulting. She would see it the same way."
    n "Algo menos seria insultante, eu acho. Ela veria da mesma forma."

# game/script-a2-shizune.rpy:1530
translate pt_br a2_shizune_advanced_game_theory_5626da4c:

    # n "{vspace=30}So to me, this is the only option. Especially now that I've decided to be so resolute with it."
    n "{vspace=30}Então pra mim, essa é a única opção. Especialmente agora que eu decidi ser firme nisto."

# game/script-a2-shizune.rpy:1534
translate pt_br a2_shizune_advanced_game_theory_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a2-shizune.rpy:1538
translate pt_br a2_shizune_advanced_game_theory_930e27c8:

    # "Shizune has a huge aura. It's very easy to see her coming, or even to sense her coming. Mostly because Misha's hair lights up any crowd she's in like a beacon, and you can hear her laughing from a mile away."
    "Shizune tem uma grande aura. É fácil vê-la chegando, ou até mesmo sentí-la chegar. Sobretudo porque o cabelo da Misha acende em qualquer multidão que ela está como um farol, e você pode ouví-la rindo de longe."

# game/script-a2-shizune.rpy:1540
translate pt_br a2_shizune_advanced_game_theory_4bd878cf:

    # "Although, even if Misha weren't with her, it would be the same. Her directness and efficiency are core parts of her, so it's no surprise that they come across in the way she walks as well."
    "Todavia, mesmo se a Misha não estivesse com ela, seria o mesmo. Seu jeito direto e eficiente de ser são suas características principais, então não seria surpresa se ele fosse transmitidos no modo que ela anda também."

# game/script-a2-shizune.rpy:1542
translate pt_br a2_shizune_advanced_game_theory_60953e84:

    # "Due to all these factors, I'm able to put away all my things and put on my best casual face long before they see me and head my way."
    "Devido a todos esses fatores, sou capaz de guardar todas as minhas coisas e fazer minha melhor cara casual antes que elas possam me ver e vir a meu caminho."

# game/script-a2-shizune.rpy:1548
translate pt_br a2_shizune_advanced_game_theory_ca61152d:

    # hi "Hi."
    hi "Olá."

# game/script-a2-shizune.rpy:1553
translate pt_br a2_shizune_advanced_game_theory_3d2bf224:

    # ssh "Student Councilll."
    ssh "Conselho Estudantiiil."

# game/script-a2-shizune.rpy:1558
translate pt_br a2_shizune_advanced_game_theory_bdebd484:

    # mi "Student Council~!"
    mi "Conselho Estudantil~!"

# game/script-a2-shizune.rpy:1560
translate pt_br a2_shizune_advanced_game_theory_9d93062f:

    # "'Student Council' was the first thing I asked to learn; it seemed like it would come in handy."
    "“Conselho Estudantil” foi a primeira coisa que eu pedi pra aprender; pareceu que viria a ser conveniente."

# game/script-a2-shizune.rpy:1562
translate pt_br a2_shizune_advanced_game_theory_f74b566b:

    # hi "Yeah, I've been dodging it for a while now, huh?"
    hi "É, eu estive o evitando por um tempinho, não?"

# game/script-a2-shizune.rpy:1568
translate pt_br a2_shizune_advanced_game_theory_f7267e24:

    # mi "Yup~!"
    mi "Yup~!"

# game/script-a2-shizune.rpy:1582
translate pt_br a2_shizune_advanced_game_theory_439519ba:

    # "Shizune sits down in front of me to my right, and Misha to my left. It was a mistake putting myself in the corner; now I'm, well, cornered."
    "Shizune senta à minha frente um pouco à direita, e Misha à minha esquerda. Foi um erro ficar no canto. Agora estou encurralado."

# game/script-a2-shizune.rpy:1587
translate pt_br a2_shizune_advanced_game_theory_1af80203:

    # "In the end, I'm dragged off to the student council room, but I don't mind. I was starting to miss them a bit, anyway."
    "No fim, sou arrastado à sala do conselho estudantil, mas eu não ligo. Estava começando a sentir falta delas, de qualquer modo."

# game/script-a2-shizune.rpy:1589
translate pt_br a2_shizune_advanced_game_theory_d5d9845e:

    # "In some ways this makes it easier: satisfied with having caught me, Shizune doesn't ask me where I've been all this time."
    "Isso facilita um pouco: satisfeita com ter me pego, Shizune não pergunta aonde eu estive este tempo todo."

# game/script-a2-shizune.rpy:1591
translate pt_br a2_shizune_advanced_game_theory_499f3308:

    # "Once I stand before the door, I wonder what could be so important that they're so eager to pull me back in."
    "Uma vez que estou à porta, eu me pergunto o que poderia ser tão importante que elas estão tão ansiosas para me puxarem de volta."

# game/script-a2-shizune.rpy:1596
translate pt_br a2_shizune_advanced_game_theory_b6cc39b9:

    # hi "Games."
    hi "Jogos."

# game/script-a2-shizune.rpy:1600
translate pt_br a2_shizune_advanced_game_theory_6bcef903:

    # "There are more games out than books. This at last explains why every time I come here there are stacks of books piled on every table and occasionally parts of the floor: they need the room to put all these games somewhere."
    "Há mais jogos aqui do que livros. Isto, afinal, explica por que toda vez que eu venho aqui há pilhas de livros empilhados em cada mesa e ocasionalmente em partes do piso: eles precisam do espaço para colocar todos esses jogos em algum lugar."

# game/script-a2-shizune.rpy:1605
translate pt_br a2_shizune_advanced_game_theory_66b999fb:

    # mi "Hahaha~!"
    mi "Hahaha~!"

# game/script-a2-shizune.rpy:1610
translate pt_br a2_shizune_advanced_game_theory_eb1473e5:

    # mi "It's boring playing against each other so much, Hicchan. So, it's your turn, okay? Okay~! It's settled then~!"
    mi "É tedioso jogar contra nós mesmas toda hora, Hisaozinho. Então, é a sua vez, ok? Ok~! Fechou, então~!"

# game/script-a2-shizune.rpy:1612
translate pt_br a2_shizune_advanced_game_theory_a63f7e85:

    # hi "I didn't even say anything!"
    hi "Eu nem disse nada!"

# game/script-a2-shizune.rpy:1628
translate pt_br a2_shizune_advanced_game_theory_ef2b123c:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1633
translate pt_br a2_shizune_advanced_game_theory_cbdf09f8:

    # mi "Hicchan, this is one of the last days we'll be able to take it easy like this for a while. So~, it's especially important that we make the most of it, don't you think?"
    mi "Hisaozinho, este é um dos últimos dias que seremos capazes de pegar leve assim por um tempo. Então~, é importante aproveitarmos a maior parte desse tempo, não acha?"

# game/script-a2-shizune.rpy:1638
translate pt_br a2_shizune_advanced_game_theory_fe171261:

    # mi "Tanabata will be coming up soon, and we'll have to put in a lot of work for that, too."
    mi "Tanabata estará chegando logo, e teremos que começar a trabalhar nisto, também."

# game/script-a2-shizune.rpy:1644
translate pt_br a2_shizune_advanced_game_theory_7fe2e51e:

    # mi "So, for now, play with us~!"
    mi "Então, agora, jogue com a gente~!"

# game/script-a2-shizune.rpy:1646
translate pt_br a2_shizune_advanced_game_theory_e131e3ea:

    # "Come to think of it, it's true. I hadn't even noticed because I've been so wrapped up in wanting to learn sign language. Right on the heels of one festival, a bigger one appears."
    "Pensando bem, é verdade. Eu não havia nem percebido porque eu estive tão concentrado em querer aprender língua de sinais. Logo após o final de um festival, outro maior aparece."

# game/script-a2-shizune.rpy:1648
translate pt_br a2_shizune_advanced_game_theory_ec8f46de:

    # "I wonder if Shizune will try and rope a couple new members in to help with that one as well."
    "Eu me pergunto se a Shizune tentará chamar alguns membros novos para nos ajudar com este também."

# game/script-a2-shizune.rpy:1650
translate pt_br a2_shizune_advanced_game_theory_b13b2718:

    # hi "You're right."
    hi "Você está certa."

# game/script-a2-shizune.rpy:1655
translate pt_br a2_shizune_advanced_game_theory_c519e28d:

    # mi "Hahaha~! Yay~! Hicchan agrees~! Let's celebrate!"
    mi "Hahaha~! Yay~! Hisaozinho concorda~! Vamos celebrar!"

# game/script-a2-shizune.rpy:1660
translate pt_br a2_shizune_advanced_game_theory_66f8512e:

    # ssh "I know, we should play a game."
    ssh "Eu sei, devemos jogar um jogo."

# game/script-a2-shizune.rpy:1665
translate pt_br a2_shizune_advanced_game_theory_5eb4028f:

    # mi "Let's play a game to celebrate, Hicchan~!"
    mi "Vamos jogar um jogo para celebrar, Hisaozinho~!"

# game/script-a2-shizune.rpy:1667
translate pt_br a2_shizune_advanced_game_theory_e7f7460d:

    # hi "I don't know, that kind of thing usually ends badly for me."
    hi "Eu não sei, esse tipo de coisa geralmente termina mal pra mim."

# game/script-a2-shizune.rpy:1672
translate pt_br a2_shizune_advanced_game_theory_199cd058:

    # mi "Hicchan is worried about the stakes~."
    mi "Hisaozinho tá preocupado sobre as apostas~."

# game/script-a2-shizune.rpy:1674
translate pt_br a2_shizune_advanced_game_theory_7ce4ee2a:

    # "Misha makes a very disappointed face. It's hard to tell if she's mocking me, since her expressions are so exaggerated by default. She's an 'all-out' kind of girl."
    "Misha faz uma cara bastante desapontada. É difícil dizer se ela está me zombando, já que suas expressões são bastante exageradas por padrão."

# game/script-a2-shizune.rpy:1676
translate pt_br a2_shizune_advanced_game_theory_2c5a7ec0:

    # "I turn my head to Shizune. Now, this person, she is definitely mocking me."
    "Eu viro minha cabeça pra Shizune. Agora, essa pessoa, ela está definitivamente zombando de mim."

# game/script-a2-shizune.rpy:1678
translate pt_br a2_shizune_advanced_game_theory_3020e2d7:

    # hi "Hey, stop that. But, yes, I'll play with you if you tell me what's at stake first."
    hi "Ei, pare com isso. Mas, sim, jogarei com vocês se me disserem o que está em jogo primeiro."

# game/script-a2-shizune.rpy:1683
translate pt_br a2_shizune_advanced_game_theory_ef2b123c_1:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1688
translate pt_br a2_shizune_advanced_game_theory_16d5803a:

    # mi "How very Japanese, putting the consequences above everything else."
    mi "Quão japonês, colocando as consequências sobre todo o resto."

# game/script-a2-shizune.rpy:1693
translate pt_br a2_shizune_advanced_game_theory_7a1d9f19:

    # mi "Hicchan, have you ever heard of the expression 'missing the forest for the trees?'"
    mi "Hisaozinho, você já ouviu a expressão “não ver a floresta por causa das árvores?”"

# game/script-a2-shizune.rpy:1695
translate pt_br a2_shizune_advanced_game_theory_7efcef0d:

    # hi "No."
    hi "Não."

# game/script-a2-shizune.rpy:1697
translate pt_br a2_shizune_advanced_game_theory_47e3f9fb:

    # "That's a lie. But I have my pride, which is currently feeling wounded."
    "É uma mentira. Mas eu tenho meu orgulho, o qual está sendo ferido."

# game/script-a2-shizune.rpy:1699
translate pt_br a2_shizune_advanced_game_theory_079974d7:

    # hi "Okay, I'll play, but I want to pick the game."
    hi "Ok, eu jogo, mas eu quero escolher o jogo."

# game/script-a2-shizune.rpy:1705
translate pt_br a2_shizune_advanced_game_theory_36afeb57:

    # "Misha nods."
    "Misha acena."

# game/script-a2-shizune.rpy:1707
translate pt_br a2_shizune_advanced_game_theory_6fd7bb3c:

    # hi "Additionally, I pick the punishment if you lose."
    hi "E mais, eu escolho a punição se vocês perderem."

# game/script-a2-shizune.rpy:1712
translate pt_br a2_shizune_advanced_game_theory_113eaa9b:

    # "Shizune makes an X with her arms. That either means 'denied' or that she's about to use her special attack."
    "Shizune faz um X com seus braços. Ou isso quer dizer “negado” ou ela está prestes a usar seu ataque especial."

# game/script-a2-shizune.rpy:1714
translate pt_br a2_shizune_advanced_game_theory_3663f0fd:

    # hi "Aha, now who's afraid of consequences?"
    hi "Aha, agora quem tem medo de consequências?"

# game/script-a2-shizune.rpy:1719
translate pt_br a2_shizune_advanced_game_theory_93b9175a:

    # ssh "How vengeful, still thinking so spitefully about a playful little joke."
    ssh "Que vingativo, ainda pensando tão rancorosamente sobre uma brincadeirinha."

# game/script-a2-shizune.rpy:1724
translate pt_br a2_shizune_advanced_game_theory_68d3b0ea:

    # ssh "If a … bit you, you would probably bite back."
    ssh "Se um … te mordesse, você provavelmente o morderia de volta."

# game/script-a2-shizune.rpy:1726
translate pt_br a2_shizune_advanced_game_theory_1aff0c5c:

    # "Shizune signs a word that I don't quite catch."
    "Shizune sinaliza uma palavra que eu não entendo direito."

# game/script-a2-shizune.rpy:1731
translate pt_br a2_shizune_advanced_game_theory_687e57d8:

    # mi "Hicchan is so vengeful~, even though it was just a playful little joke. If an armadillo bit you, you would probably bite back!"
    mi "Hisaozinho é tão vingativo~, mesmo aquilo tendo sido só uma brincadeirinha. Se um tatu te mordesse, você provavelmente o morderia de volta!"

# game/script-a2-shizune.rpy:1733
translate pt_br a2_shizune_advanced_game_theory_d324d9c4:

    # hi "Armadillo?"
    hi "Tatu?"

# game/script-a2-shizune.rpy:1738
translate pt_br a2_shizune_advanced_game_theory_8c35516d:

    # mi "It's foolish to bite an armadillo back, Hicchan!"
    mi "É tolice morder um tatu, Hisaozinho!"

# game/script-a2-shizune.rpy:1743
translate pt_br a2_shizune_advanced_game_theory_ef2b123c_2:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1748
translate pt_br a2_shizune_advanced_game_theory_6483aa78:

    # mi "But Hicchan would do it anyway, you see~! Hahaha!"
    mi "Mas Hisaozinho o faria ainda assim~! Hahaha!"

# game/script-a2-shizune.rpy:1750
translate pt_br a2_shizune_advanced_game_theory_e1f8a5e6:

    # hi "I see."
    hi "Entendo."

# game/script-a2-shizune.rpy:1755
translate pt_br a2_shizune_advanced_game_theory_abb82823:

    # "Shizune adjusts her glasses with a small flourish of her hand."
    "Shizune ajusta seus óculos com um pequeno floreio em sua mão."

# game/script-a2-shizune.rpy:1760
translate pt_br a2_shizune_advanced_game_theory_ef2b123c_3:

    # shi "…"
    shi "…"

# game/script-a2-shizune.rpy:1765
translate pt_br a2_shizune_advanced_game_theory_3139c78c:

    # mi "Hicchan, we didn't have anything planned at all if you were to win or lose, you just assumed there would be something like that~."
    mi "Hisaozinho, nós não tínhamos nada planejado se você fosse ganhar ou perder, você só deduziu que teria algo do tipo~."

# game/script-a2-shizune.rpy:1767
translate pt_br a2_shizune_advanced_game_theory_36d04ce4:

    # hi "I wonder why."
    hi "Eu me pergunto por quê."

# game/script-a2-shizune.rpy:1772
translate pt_br a2_shizune_advanced_game_theory_9cc320eb:

    # mi "Hm~, me too~! But, oh well~! There isn't. Does that change your mind, Hicchan?"
    mi "Hm~, eu também~! Mas, ah bem~! Não tem. Isso o faz mudar de ideia, Hisaozinho?"

# game/script-a2-shizune.rpy:1774
translate pt_br a2_shizune_advanced_game_theory_57ecc993:

    # hi "Well… yes."
    hi "Bem… sim."

# game/script-a2-shizune.rpy:1779
translate pt_br a2_shizune_advanced_game_theory_dc77c9b5:

    # "Misha windmills her arm at high speed to show her joy. Weird habit. This is the kind of thing you could only see in the student council room, occupied only by three people."
    "Misha balança seu braço em alta velocidade para mostrar sua alegria. Hábito estranho. Esse é o tipo de coisa que você só pode ver na sala do conselho estudantil, ocupada por somente três pessoas."

# game/script-a2-shizune.rpy:1781
translate pt_br a2_shizune_advanced_game_theory_c52294dd:

    # "Anywhere else she would end up socking someone in the face."
    "Em qualquer outro lugar ela acabaria socando a cara de alguém."

# game/script-a2-shizune.rpy:1786
translate pt_br a2_shizune_advanced_game_theory_6729b82b:

    # mi "Yay yay~! Let's start right now~!"
    mi "Yay yay~! Vamos começar agora mesmo~!"

# game/script-a2-shizune.rpy:1788
translate pt_br a2_shizune_advanced_game_theory_dd2b3381:

    # hi "Not just yet."
    hi "Ainda não."

