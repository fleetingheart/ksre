# game/script-a2-emi.rpy:6188
translate pt_br a2_emi_famous_last_words_92ba0fea:

    # hi "Hey, it'll let up soon enough. You can go running then, right?"
    hi "Ei, vai parar de chover daqui a pouco. Você vai poder ir correr então, certo?"

# game/script-a2-emi.rpy:6193
translate pt_br a2_emi_famous_last_words_b71a3875:

    # "Emi snorts, seemingly amused."
    "Emi concorda, visivelmente satisfeita."

# game/script-a2-emi.rpy:6198
translate pt_br a2_emi_famous_last_words_8100f11d:

    # emi "Like I'm not going to run in the rain."
    emi "Como se eu não fosse correr na chuva."

# game/script-a2-emi.rpy:6200
translate pt_br a2_emi_famous_last_words_07a50215:

    # hi "Well you shouldn't! You could catch a cold!"
    hi "Bem, você não deveria! Você pode pegar um resfriado!"

# game/script-a2-emi.rpy:6205
translate pt_br a2_emi_famous_last_words_a3e443a7:

    # "Emi waves her hand airily."
    "Emi acena com a mão no ar."

# game/script-a2-emi.rpy:6207
translate pt_br a2_emi_famous_last_words_0561226c:

    # emi "Ridiculous! I don't get colds."
    emi "Isso é ridículo! Eu não pego resfriados."

# game/script-a2-emi.rpy:6212
translate pt_br a2_emi_famous_last_words_eb5ccf45:

    # emi "My immune system is far too strong for something like that."
    emi "Meu sistema imunológico é muito mais forte que algo assim."

# game/script-a2-emi.rpy:6214
translate pt_br a2_emi_famous_last_words_b7fd02df:

    # "I can't help but laugh."
    "Não posso fazer nada além de rir."

# game/script-a2-emi.rpy:6216
translate pt_br a2_emi_famous_last_words_85d565a3:

    # hi "Well, I'll see you tomorrow then, okay?"
    hi "Bom, te vejo amanhã então, tá bom?"

# game/script-a2-emi.rpy:6221
translate pt_br a2_emi_famous_last_words_b286e85a:

    # emi "Yeah!"
    emi "Sim!"

# game/script-a2-emi.rpy:6226
translate pt_br a2_emi_famous_last_words_3dff13f9:

    # emi "Thanks for coming! Oh, and for carrying the picnic basket!"
    emi "Obrigada por ter vindo! Ah, e por ter carregado o cesto de piquenique!"

# game/script-a2-emi.rpy:6231
translate pt_br a2_emi_famous_last_words_f8e2e460:

    # emi "I'll bring it for lunch tomorrow. We can have our picnic on the roof!"
    emi "Eu vou levar para o almoço amanhã. Nós poderemos ter nosso piquenique no telhado!"

# game/script-a2-emi.rpy:6233
translate pt_br a2_emi_famous_last_words_bf9d18bd:

    # hi "Sounds good to me. See you then!"
    hi "Parece bom para mim. Até mais então!"

# game/script-a2-emi.rpy:6238
translate pt_br a2_emi_famous_last_words_9b3afd52:

    # "Emi grabs the basket from me and shoots through the door."
    "Emi pega o cesto de mim e corre pela porta."

# game/script-a2-emi.rpy:6240
translate pt_br a2_emi_famous_last_words_4b108f56:

    # "Rin gives me a sort of half-nod and ambles inside as well."
    "Rin me dá uma espécie de cumprimento pela metade e entra também."

# game/script-a2-emi.rpy:6242
translate pt_br a2_emi_famous_last_words_ee9dde8b:

    # "Damn, it's wet out here."
    "Caramba, está molhado aqui fora."

# game/script-a2-emi.rpy:6244
translate pt_br a2_emi_famous_last_words_35524d2a:

    # "I need to get back to my room and into some dry clothes."
    "Eu tenho que voltar para o meu quarto e para algumas roupas secas."

# game/script-a2-emi.rpy:6251
translate pt_br a2_emi_famous_last_words_c133bff3:

    # "I'm soon in front of my door, but I am intercepted by the sudden appearance of Kenji, who appears to be carrying a stack of books."
    "Logo estou na frente de minha porta, mas sou interrompido pela aparição súbita do Kenji, que parece estar carregando vários livros."

# game/script-a2-emi.rpy:6256
translate pt_br a2_emi_famous_last_words_01f5a8ee:

    # ke "Hey man, give me a hand, would you?"
    ke "Ei cara, me dá uma mão aí!"

# game/script-a2-emi.rpy:6258
translate pt_br a2_emi_famous_last_words_0f638bea:

    # hi "Huh?"
    hi "Hã?"

# game/script-a2-emi.rpy:6264
translate pt_br a2_emi_famous_last_words_511b1d18:

    # "The books are unceremoniously dumped into my arms as Kenji fumbles with his room key."
    "Os livros são jogados nos meus braços enquanto Kenji mexe na chave do seu quarto."

# game/script-a2-emi.rpy:6269
translate pt_br a2_emi_famous_last_words_3250fc10:

    # ke "Thanks, you're a lifesaver."
    ke "Obrigado, você salvou minha vida."

# game/script-a2-emi.rpy:6271
translate pt_br a2_emi_famous_last_words_79dab7ad:

    # ke "If you weren't around I'd have to keep my door unlocked, and that's just begging for trouble."
    ke "Se você não estivesse por perto eu teria que deixar minha porta aberta, e isso é praticamente pedir por briga."

# game/script-a2-emi.rpy:6276
translate pt_br a2_emi_famous_last_words_40111e99:

    # ke "The perfect opportunity to set up an ambush, or maybe just plant a bomb if they don't want to get their hands too dirty."
    ke "A oportunidade perfeita para montar uma armadilha, ou talvez apenas plantar uma bomba, se elas não quiserem sujar suas mãos."

# game/script-a2-emi.rpy:6278
translate pt_br a2_emi_famous_last_words_936ad778:

    # ke "Probably don't."
    ke "Provavelmente não."

# game/script-a2-emi.rpy:6280
translate pt_br a2_emi_famous_last_words_786d6d03:

    # ke "Afraid they'll break a nail or something if they have to stab me."
    ke "Elas tem medo de quebrar uma unha ou algo assim caso tenham que me esfaquear."

# game/script-a2-emi.rpy:6282
translate pt_br a2_emi_famous_last_words_5a50af32:

    # ke "Women."
    ke "Mulheres."

# game/script-a2-emi.rpy:6284
translate pt_br a2_emi_famous_last_words_5e01faf9:

    # "My mind thinks about digesting the verbal torrent that's just been unleashed, but elects to remain comfortably in the dark."
    "Minha mente pensa em tentar interpretar a corrente verbal que ele acabou de soltar, mas escolhe ficar confortavelmente no escuro."

# game/script-a2-emi.rpy:6286
translate pt_br a2_emi_famous_last_words_3abc1135:

    # hi "Uh… huh."
    hi "A… ham."

# game/script-a2-emi.rpy:6291
translate pt_br a2_emi_famous_last_words_a12e6e19:

    # ke "Anyway, where have you been, man?"
    ke "De qualquer forma, onde você estava, cara?"

# game/script-a2-emi.rpy:6296
translate pt_br a2_emi_famous_last_words_f6868f0c:

    # ke "I could have used some help carrying these back from the library!"
    ke "Você poderia ter me ajudado a carregar esses livros de lá da biblioteca!"

# game/script-a2-emi.rpy:6298
translate pt_br a2_emi_famous_last_words_8dfb95c8:

    # ke "I knocked on your door, but you weren't there."
    ke "Eu bati na sua porta, mas você não estava."

# game/script-a2-emi.rpy:6300
translate pt_br a2_emi_famous_last_words_9b8ec38e:

    # hi "Oh, sorry."
    hi "Oh, desculpe."

# game/script-a2-emi.rpy:6302
translate pt_br a2_emi_famous_last_words_0bb93cbb:

    # "Not really. You appear to think I'm some kind of pack mule."
    "Na verdade não. Você parece achar que sou algum tipo de mula de carga."

# game/script-a2-emi.rpy:6304
translate pt_br a2_emi_famous_last_words_78613848:

    # hi "I was out with Emi and Rin."
    hi "Eu saí com a Emi e a Rin."

# game/script-a2-emi.rpy:6309
translate pt_br a2_emi_famous_last_words_597149c2:

    # "Kenji staggers back in shock."
    "Kenji fica em choque."

# game/script-a2-emi.rpy:6311
translate pt_br a2_emi_famous_last_words_b9f3b241:

    # "It looks like I just shot his dog, if he had a dog."
    "É como se eu tivesse acabado de atirar no seu cachorro, se ele tivesse um cachorro."

# game/script-a2-emi.rpy:6313
translate pt_br a2_emi_famous_last_words_6ddf70bb:

    # ke "The limbless ladies again?"
    ke "De novo com as damas sem membros?"

# game/script-a2-emi.rpy:6318
translate pt_br a2_emi_famous_last_words_d48bed5a:

    # ke "What'd you do this time?"
    ke "O que você fez dessa vez?"

# game/script-a2-emi.rpy:6320
translate pt_br a2_emi_famous_last_words_a6ba33e8:

    # hi "Well, we wound up at the Shanghai—"
    hi "Bom, nós fomos ao Xangai—"

# game/script-a2-emi.rpy:6322
translate pt_br a2_emi_famous_last_words_8f3d8b26:

    # "I'm prevented from continuing by a sudden exclamation of despair."
    "Sou impedido de continuar por uma súbita exclamação de desespero."

# game/script-a2-emi.rpy:6327
translate pt_br a2_emi_famous_last_words_c3c6001d:

    # ke "The Shanghai?"
    ke "O Xangai?"

# game/script-a2-emi.rpy:6329
translate pt_br a2_emi_famous_last_words_f9ed436c:

    # ke "Why the Shanghai?"
    ke "Por que o Xangai?"

# game/script-a2-emi.rpy:6331
translate pt_br a2_emi_famous_last_words_f8a5c9db:

    # ke "No no no no, man, you can't just go to the damn Shanghai!"
    ke "Não não não não cara, você não pode simplesmente ir para a droga do Xangai!"

# game/script-a2-emi.rpy:6333
translate pt_br a2_emi_famous_last_words_75080c59:

    # ke "It's the most dangerous place in the city!"
    ke "É o lugar mais perigoso da cidade!"

# game/script-a2-emi.rpy:6335
translate pt_br a2_emi_famous_last_words_0acdf0fb:

    # ke "A veritable stronghold of their best agents!"
    ke "Uma verdadeira fortaleza das suas melhores agentes!"

# game/script-a2-emi.rpy:6337
translate pt_br a2_emi_famous_last_words_1cb6164d:

    # ke "I know! I've met them!"
    ke "Eu sei! Eu as conheci!"

# game/script-a2-emi.rpy:6339
translate pt_br a2_emi_famous_last_words_842b4ea6:

    # ke "They'll stop at nothing to lull you into a false sense of security, and then BAM!"
    ke "Elas não vão parar por nada, vão te enganar com uma falsa sensação de segurança, e então BAM!"

# game/script-a2-emi.rpy:6344
translate pt_br a2_emi_famous_last_words_d6b352d6:

    # "He hits his door for emphasis."
    "Ele bate na porta pra dar ênfase."

# game/script-a2-emi.rpy:6346
translate pt_br a2_emi_famous_last_words_46bc6065:

    # ke "Wallet's gone. Bus pass? Gone. Identity? Fuckin' {b}gone{/b}, man!"
    ke "A carteira sumiu. Passagem de ônibus? Sumiu. Identidade? Merda, {b}sumiu{/b}, cara!"

# game/script-a2-emi.rpy:6351
translate pt_br a2_emi_famous_last_words_33e9708b:

    # ke "Promise me you won't go there again!"
    ke "Me promete que você não vai voltar lá de novo!"

# game/script-a2-emi.rpy:6353
translate pt_br a2_emi_famous_last_words_1d5349ef:

    # "He seems so vehemently opposed to the idea of the Shanghai that I'm willing to lie a little in order to get to my room."
    "Ele parece estar se opondo à ideia do Xangai tão veementemente que eu até mentiria um pouco para poder voltar pro meu quarto."

# game/script-a2-emi.rpy:6355
translate pt_br a2_emi_famous_last_words_babcb504:

    # hi "Sure, I won't go there again."
    hi "Prometo, não irei voltar lá de novo."

# game/script-a2-emi.rpy:6357
translate pt_br a2_emi_famous_last_words_0a011a80:

    # "Or at least, I won't ever tell you I've gone there again."
    "Ou ao menos, eu não irei falar a você que eu voltei lá."

# game/script-a2-emi.rpy:6359
translate pt_br a2_emi_famous_last_words_5d1407d1:

    # "This seems to mollify my bespectacled companion."
    "Isso parece tranquilizar meu companheiro."

# game/script-a2-emi.rpy:6364
translate pt_br a2_emi_famous_last_words_5645daa4:

    # ke "Good, good."
    ke "Muito bom, muito bom."

# game/script-a2-emi.rpy:6369
translate pt_br a2_emi_famous_last_words_fe10349b:

    # ke "Sorry to come on so strong, but I know the danger there too well to let you just wander into the lion's den again."
    ke "Desculpa ter falado assim, mas eu conheço o perigo que há lá bem demais pra simplesmente te deixar entrar na cova do leão novamente."

# game/script-a2-emi.rpy:6371
translate pt_br a2_emi_famous_last_words_2e330485:

    # ke "You got out of there alive once, but twice is pushing it."
    ke "Você saiu vivo de lá uma vez, mas duas já é querer demais."

# game/script-a2-emi.rpy:6373
translate pt_br a2_emi_famous_last_words_1d3e49b6:

    # hi "Yeah, well I need to get changed and uh, do homework. So… I'll see you later."
    hi "É, bom, eu preciso trocar de roupa e er, fazer o dever de casa. Então…te vejo depois."

# game/script-a2-emi.rpy:6378
translate pt_br a2_emi_famous_last_words_1e477de6:

    # ke "Huh?"
    ke "Hã?"

# game/script-a2-emi.rpy:6383
translate pt_br a2_emi_famous_last_words_e1781ee8:

    # ke "Oh, sure. Whatever."
    ke "Ah, certo. Que seja."

# game/script-a2-emi.rpy:6385
translate pt_br a2_emi_famous_last_words_17c011b0:

    # "I suddenly remember that I'm still holding his books."
    "Eu subitamente lembro que ainda estou segurando os livros dele."

# game/script-a2-emi.rpy:6387
translate pt_br a2_emi_famous_last_words_9b37b247:

    # hi "You'd better take these."
    hi "Melhor você pegar esses livros."

# game/script-a2-emi.rpy:6389
translate pt_br a2_emi_famous_last_words_a378284c:

    # "I catch a glimpse of one of titles, something about cryptography."
    "Entendo uma parte de um dos títulos, algo sobre criptografia."

# game/script-a2-emi.rpy:6391
translate pt_br a2_emi_famous_last_words_8fd2ae2e:

    # "What a weirdo."
    "Que cara estranho."

# game/script-a2-emi.rpy:6398
translate pt_br a2_emi_famous_last_words_476fb2b0:

    # "Kenji grabs his precious cargo from me and disappears through his doorway."
    "Kenji pega sua carga preciosa de mim e desaparece para o seu quarto."

# game/script-a2-emi.rpy:6406
translate pt_br a2_emi_famous_last_words_8ceca8a3:

    # "I open my own door and walk in, grateful to get out of my soaking wet clothes."
    "Eu abro a minha porta e entro, agradecido de poder trocar minhas roupas molhadas."

# game/script-a2-emi.rpy:6408
translate pt_br a2_emi_famous_last_words_b300bdfd:

    # "The rain outside picks up, and I find myself hoping that Emi's not out running in this weather. She seemed so adamant about doing the run alone, I can't help but wonder if her leg's still bothering her."
    "Lá fora a chuva retorna, e eu me vejo esperando que a Emi não tenha saído para correr neste clima. Ela parecia tão certa em correr sozinha, não posso fazer nada além de me perguntar se a perna dela ainda está a importunando."

# game/script-a2-emi.rpy:6410
translate pt_br a2_emi_famous_last_words_8673179e:

    # "I try to remember whether or not I've seen her limping at all today, but I can't. Guess I was too caught up in enjoying the day, even if it did rain on us."
    "Eu tento lembrar se eu vi ou não ela mancando hoje mas não consigo. Acho que eu estava muito ocupado aproveitando o dia, mesmo tendo chovido bastante."

# game/script-a2-emi.rpy:6412
translate pt_br a2_emi_famous_last_words_7d701ea2:

    # "And as I think back over the events of today, I keep finding myself focusing on my running partner."
    "E quando eu volto a pensar no que aconteceu hoje, continuo me focando na minha parceira de corrida."

# game/script-a2-emi.rpy:6414
translate pt_br a2_emi_famous_last_words_a6f6f723:

    # "Her complete refusal to allow the rain to spoil her plans was incredibly cute."
    "A refusa completa dela de deixar a chuva atrapalhar seus planos foi incrivelmente fofa."

# game/script-a2-emi.rpy:6416
translate pt_br a2_emi_famous_last_words_d723f38f:

    # "But there was something else there, too."
    "Mas tinha algo a mais, também."

# game/script-a2-emi.rpy:6418
translate pt_br a2_emi_famous_last_words_b99e582a:

    # "Sort of an unflappable attitude when it comes to enjoying the day as it comes."
    "Algo como uma atitude insistente quando se refere a aproveitar o dia o quanto possível."

# game/script-a2-emi.rpy:6420
translate pt_br a2_emi_famous_last_words_6c8e1918:

    # "I really like that quality."
    "Eu realmente gosto desta qualidade."

# game/script-a2-emi.rpy:6422
translate pt_br a2_emi_famous_last_words_276db480:

    # "Maybe I need to do a little of that myself."
    "Talvez eu mesmo precise de um pouco disso."

# game/script-a2-emi.rpy:6443
translate pt_br a2_emi_tracking_absences_8c329500:

    # "The sound of my alarm brings me out of a dream involving pirates and some other stuff I can't really remember."
    "O som do alarme me acorda de um sonho envolvendo piratas e alguma outra coisa que não consigo lembrar."

# game/script-a2-emi.rpy:6452
translate pt_br a2_emi_tracking_absences_87761859:

    # "I'm a little bleary-eyed, and it feels like it takes me longer than usual to get dressed and down to the track."
    "Eu estou com os olhos um pouco cansados, e parece que demora mais que o normal para me vestir e descer para a pista."

# game/script-a2-emi.rpy:6454
translate pt_br a2_emi_tracking_absences_9c185493:

    # "A glance at my watch reveals that I was right, and I am in fact running a little late."
    "Uma olhada no meu relógio revela que eu estava certo, e estou realmente atrasado."

# game/script-a2-emi.rpy:6456
translate pt_br a2_emi_tracking_absences_c1b1cc52:

    # "The thing is…"
    "O problema é…"

# game/script-a2-emi.rpy:6458
translate pt_br a2_emi_tracking_absences_10f46017:

    # "There's no Emi."
    "Não tem Emi aqui."

# game/script-a2-emi.rpy:6460
translate pt_br a2_emi_tracking_absences_997d0c2a:

    # "That's odd. She should be here."
    "Isso é estranho. Ela deveria estar aqui."

# game/script-a2-emi.rpy:6462
translate pt_br a2_emi_tracking_absences_67dec535:

    # "She definitely should be here."
    "Definitivamente ela deveria estar aqui."

# game/script-a2-emi.rpy:6464
translate pt_br a2_emi_tracking_absences_f487f26f:

    # "I mean, I was {b}late{/b}."
    "Quero dizer, eu estava {b}atrasado{/b}."

# game/script-a2-emi.rpy:6466
translate pt_br a2_emi_tracking_absences_63d693fd:

    # "I guess I wasn't the only one who had trouble getting up this morning."
    "Acho que não fui o único que teve problemas para acordar esta manhã."

# game/script-a2-emi.rpy:6468
translate pt_br a2_emi_tracking_absences_9e0a6ca9:

    # "The thought crosses my mind that it never quite stopped raining yesterday. Did she go running anyway?"
    "Me recai o pensamento de que não parou de chover ontem. Será que ela foi correr mesmo assim?"

# game/script-a2-emi.rpy:6471
translate pt_br a2_emi_tracking_absences_8199c4b2:

    # "It seems likely. Emi's a lot of things, but cautious isn't one of them. She probably figured the rain wouldn't stop, and that's why she was so adamant about running alone."
    "Parece provável. A Emi é um monte de coisas, mas cautelosa não é uma delas. Ela provavelmente percebeu que não pararia de chover, e é por isso que ela estava tão certa em correr sozinha."

# game/script-a2-emi.rpy:6473
translate pt_br a2_emi_tracking_absences_4359bea0:

    # "Still, I would have gladly run with her, even if it was in the rain."
    "Mesmo assim, eu correria junto dela com prazer, mesmo que fosse na chuva."

# game/script-a2-emi.rpy:6475
translate pt_br a2_emi_tracking_absences_aea2716b:

    # "Heck, if anything I would have been able to convince her to come in once it got really bad. That would be why she didn't want me along, of course."
    "Caramba, ao menos eu poderia ter convencido ela a se abrigar quando começasse a ficar ruim. Por isso ela não me queria por perto, claro."

# game/script-a2-emi.rpy:6477
translate pt_br a2_emi_tracking_absences_c6285978:

    # "I should have offered to run with her."
    "Eu deveria ter me oferecido para correr com ela."

# game/script-a2-emi.rpy:6479
translate pt_br a2_emi_tracking_absences_ec6bff48:

    # "Then I could have talked her out of the idea, or at the least known that she was okay. What if she got struck by lightning or something?"
    "Daí eu poderia fazê-la mudar de ideia, ou ao menos saberia que ela estava bem. E se ela fosse atingida por um raio ou algo assim?"

# game/script-a2-emi.rpy:6481
translate pt_br a2_emi_tracking_absences_b2fa9faa:

    # "I'd never forgive myself."
    "Eu nunca me perdoaria."

# game/script-a2-emi.rpy:6483
translate pt_br a2_emi_tracking_absences_ce617998:

    # "…"
    "…"

# game/script-a2-emi.rpy:6485
translate pt_br a2_emi_tracking_absences_3f7f65f7:

    # "Okay, that's probably a little stupid."
    "Ok, isso é provavelmente um pouco estúpido."

# game/script-a2-emi.rpy:6487
translate pt_br a2_emi_tracking_absences_37676b44:

    # "Emi's a resourceful girl. I doubt even she'd stay out in a thunderstorm."
    "Emi é uma garota esperta. Eu duvido que ela fosse ficar no meio de uma tempestade."

# game/script-a2-emi.rpy:6489
translate pt_br a2_emi_tracking_absences_4f112735:

    # "I trust her judgment on that matter, at least."
    "Eu acredito no julgamento dela nesse assunto, ao menos."

# game/script-a2-emi.rpy:6491
translate pt_br a2_emi_tracking_absences_0fbdd48d:

    # "Even so, I can't help wanting to know where she is."
    "Mesmo assim, não consigo ficar sem querer saber aonde ela está."

# game/script-a2-emi.rpy:6493
translate pt_br a2_emi_tracking_absences_456a0a58:

    # "…Well, nothing for it. I'd better stretch and run, and hope that Emi shows up with a grin and an excuse."
    "…Bom, não que seja por isso. É melhor eu me alongar e correr, e esperar que a Emi apareça com um sorriso e uma desculpa."

# game/script-a2-emi.rpy:6501
translate pt_br a2_emi_tracking_absences_1be7b618:

    # "On my cool down lap, I am forced to admit that Emi isn't showing up."
    "Na minha volta, sou forçado a admitir que a Emi não vai aparecer."

# game/script-a2-emi.rpy:6503
translate pt_br a2_emi_tracking_absences_d73a041c:

    # "Furthermore, I have no idea where she is. Anxiety gnaws at me while at the same time I wonder just why I'm so worried over her."
    "Além do mais, não tenho ideia de onde ela está. A ansiedade me perturba enquanto ao mesmo tempo eu me pergunto porque estou tão preocupado com ela."

# game/script-a2-emi.rpy:6505
translate pt_br a2_emi_tracking_absences_955bea6f:

    # "The run helped to take my mind off it for a little while, but now that I'm finished I'm back to worrying."
    "A corrida me ajudou a esquecer isso um pouco, mas agora que acabei, estou voltando a me preocupar."

# game/script-a2-emi.rpy:6509
translate pt_br a2_emi_tracking_absences_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:6513
translate pt_br a2_emi_tracking_absences_04eab752:

    # n "{vspace=60}It was weird not having her here."
    n "{vspace=60}Foi estranho não ter ela por aqui."

# game/script-a2-emi.rpy:6515
translate pt_br a2_emi_tracking_absences_1e05035b:

    # n "Downright unnerving."
    n "Extremamente inquietante."

# game/script-a2-emi.rpy:6517
translate pt_br a2_emi_tracking_absences_64feca4b:

    # n "It suddenly dawns on me that I've been running to hang out with Emi as much as I've been running to stay healthy - probably more to be with Emi, now that I think of it."
    n "Subitamente me ocorre que eu estive correndo pra estar junto da Emi tanto quanto eu estive correndo pra me manter saudável - provavelmente mais pra estar com a Emi, agora que parei pra pensar."

# game/script-a2-emi.rpy:6519
translate pt_br a2_emi_tracking_absences_a734c3cf:

    # n "It's one of those things that are completely obvious yet somehow, I never realized it."
    n "É uma dessas coisas que são completamente óbvias e mesmo assim, eu nunca percebi."

# game/script-a2-emi.rpy:6521
translate pt_br a2_emi_tracking_absences_184c7b83:

    # n "She really is someone I enjoy being with."
    n "Ela é realmente alguém quem eu gosto de estar junto."

# game/script-a2-emi.rpy:6523
translate pt_br a2_emi_tracking_absences_3d681119:

    # n "As revelations go, it's hardly world-shaking."
    n "Quanto à revelação, é dificilmente algo surpreendente."

# game/script-a2-emi.rpy:6525
translate pt_br a2_emi_tracking_absences_d1733ad7:

    # n "All the same, I find myself feeling slightly shocked."
    n "Ao mesmo tempo, eu me vejo levemente chocado."

# game/script-a2-emi.rpy:6527
translate pt_br a2_emi_tracking_absences_1084fb4f:

    # n "When did this happen?"
    n "Quando isso aconteceu?"

# game/script-a2-emi.rpy:6529
translate pt_br a2_emi_tracking_absences_9e086cbe:

    # n "Well, no time to think about this - though I want to ponder this new development, I have a greater desire to find out what's happened to Emi."
    n "Bom, não há tempo para pensar nisso - apesar de que eu quero me envolver nisso, eu tenho um desejo maior de saber o que aconteceu com a Emi."

# game/script-a2-emi.rpy:6531
translate pt_br a2_emi_tracking_absences_c96bc927:

    # n "I'll ask the nurse when I stop in to see him."
    n "Vou perguntar ao enfermeiro quando eu parar para vê-lo."

# game/script-a2-emi.rpy:6536
translate pt_br a2_emi_tracking_absences_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:6544
translate pt_br a2_emi_tracking_absences_0740aedb:

    # nk "Well, you seem to be in good shape, Hisao."
    nk "Bom, você parece estar em forma, Hisao."

# game/script-a2-emi.rpy:6546
translate pt_br a2_emi_tracking_absences_352b7d96:

    # hi "That's good to hear."
    hi "É bom ouvir isso."

# game/script-a2-emi.rpy:6548
translate pt_br a2_emi_tracking_absences_07c37885:

    # "I replace my shirt and stand to leave, as usual."
    "Eu troco minha camisa e me levanto para sair, como sempre."

# game/script-a2-emi.rpy:6550
translate pt_br a2_emi_tracking_absences_b2c0930a:

    # "Except instead of leaving, I ask a question."
    "Exceto que em vez de sair, eu faço uma pergunta."

# game/script-a2-emi.rpy:6552
translate pt_br a2_emi_tracking_absences_1ebe115c:

    # hi "Hey, where's Emi? She didn't show up this morning."
    hi "Ei, cadê a Emi? Ela não apareceu de manhã."

# game/script-a2-emi.rpy:6554
translate pt_br a2_emi_tracking_absences_d92cf5ac:

    # hi "Is she okay?"
    hi "Ela está bem?"

# game/script-a2-emi.rpy:6559
translate pt_br a2_emi_tracking_absences_9b60457e:

    # "While I try valiantly to conceal the anxiety in my voice, the nurse's expression suggests that I've failed miserably."
    "Enquanto eu tento valentemente esconder a ansiedade na minha voz, a expressão do enfermeiro sugere que falhei miseravelmente."

# game/script-a2-emi.rpy:6561
translate pt_br a2_emi_tracking_absences_1fa74ca3:

    # nk "You mean she didn't tell you?"
    nk "Quer dizer que ela não te disse?"

# game/script-a2-emi.rpy:6563
translate pt_br a2_emi_tracking_absences_05fc082f:

    # nk "She's sick in bed."
    nk "Ela está doente e de cama."

# game/script-a2-emi.rpy:6565
translate pt_br a2_emi_tracking_absences_8eaa0ce8:

    # hi "What? Sick?"
    hi "Quê? Doente?"

# game/script-a2-emi.rpy:6570
translate pt_br a2_emi_tracking_absences_81fd2592:

    # "The nurse shrugs."
    "O enfermeiro suspira."

# game/script-a2-emi.rpy:6572
translate pt_br a2_emi_tracking_absences_18afe979:

    # nk "Yeah, she came to my office early this morning with a fever."
    nk "Sim, ela veio a minha sala de manhã com febre."

# game/script-a2-emi.rpy:6574
translate pt_br a2_emi_tracking_absences_a70f24e8:

    # nk "To be honest I'm surprised she made it here."
    nk "Pra falar a verdade, eu fiquei surpreso que ela conseguiu chegar até aqui."

# game/script-a2-emi.rpy:6579
translate pt_br a2_emi_tracking_absences_47b8268e:

    # nk "She was burning up when she arrived."
    nk "Ela estava queimando quando chegou."

# game/script-a2-emi.rpy:6581
translate pt_br a2_emi_tracking_absences_6bd1f5da:

    # nk "I believe she'd planned to let you know, but she asked me to tell you - oh shoot!"
    nk "Eu creio que ela planejou para que você soubesse, mas ela me pediu para contar a você - ah caramba!"

# game/script-a2-emi.rpy:6588
translate pt_br a2_emi_tracking_absences_fe3a7981:

    # "The nurse gives me a sheepish smile that seems at least partially sincere."
    "O enfermeiro sorri intimidado e parece ao menos parcialmente sincero."

# game/script-a2-emi.rpy:6590
translate pt_br a2_emi_tracking_absences_4a77e825:

    # nk "I told her I'd stop by the track to let you know in case she forgot to. Sorry about that."
    nk "Eu disse a ela que iria até a pista para contar a você caso ela esquecesse. Desculpe por isso."

# game/script-a2-emi.rpy:6597
translate pt_br a2_emi_tracking_absences_ea8d0b15:

    # nk "But we don't need to tell Emi I forgot, right?"
    nk "Mas não precisamos falar para a Emi que eu esqueci, certo?"

# game/script-a2-emi.rpy:6599
translate pt_br a2_emi_tracking_absences_2e3f0e3b:

    # "I return the nurse's smile with a devious one of my own."
    "Eu sorrio de volta pro enfermeiro com um sorriso diabólico."

# game/script-a2-emi.rpy:6601
translate pt_br a2_emi_tracking_absences_7f627108:

    # hi "Oh, of course not."
    hi "Ah, claro que não."

# game/script-a2-emi.rpy:6603
translate pt_br a2_emi_tracking_absences_c9acba56:

    # hi "This is fine blackmail material."
    hi "Isso é um material perfeito para chantagem."

# game/script-a2-emi.rpy:6605
translate pt_br a2_emi_tracking_absences_5f082e72:

    # hi "I'll save it for whenever I need a favor from you."
    hi "Vou lembrar para quando eu precisar de um favor seu."

# game/script-a2-emi.rpy:6610
translate pt_br a2_emi_tracking_absences_1a26db20:

    # "The nurse laughs."
    "O enfermeiro ri."

# game/script-a2-emi.rpy:6612
translate pt_br a2_emi_tracking_absences_075d56eb:

    # nk "Well, I guess I deserve that."
    nk "Bem, eu acho que mereci isso."

# game/script-a2-emi.rpy:6614
translate pt_br a2_emi_tracking_absences_e841eca9:

    # nk "But you know, I've got tons of blackmail on you that you're not even aware of."
    nk "Mas, sabe, eu tenho várias formas de te chantagear que você não faz nem ideia."

# game/script-a2-emi.rpy:6619
translate pt_br a2_emi_tracking_absences_ebcee4b4:

    # nk "So don't push your luck, okay?"
    nk "Então não confie tanto na sua sorte, ok?"

# game/script-a2-emi.rpy:6621
translate pt_br a2_emi_tracking_absences_f5b925d0:

    # "My expression earns another laugh from the nurse."
    "Minha expressão causa outra risada no enfermeiro."

# game/script-a2-emi.rpy:6626
translate pt_br a2_emi_tracking_absences_0ae5c739:

    # nk "I'm just kidding, Hisao."
    nk "Eu estou brincando, Hisao."

# game/script-a2-emi.rpy:6631
translate pt_br a2_emi_tracking_absences_a010bbf7:

    # nk "But seriously - don't tell Emi I forgot, okay?"
    nk "Mas falando sério - não fale para a Emi que eu esqueci, certo?"

# game/script-a2-emi.rpy:6633
translate pt_br a2_emi_tracking_absences_39cb7134:

    # hi "Your secret is safe with me."
    hi "Seu segredo está seguro comigo."

# game/script-a2-emi.rpy:6638
translate pt_br a2_emi_tracking_absences_e3ab67c4:

    # nk "Oh good. Now go on, get out of here."
    nk "Ah bem. Agora vá, saia daqui."

# game/script-a2-emi.rpy:6640
translate pt_br a2_emi_tracking_absences_a8ffb7fc:

    # hi "Wait, I've got one more question."
    hi "Espera, tenho mais uma pergunta."

# game/script-a2-emi.rpy:6645
translate pt_br a2_emi_tracking_absences_eae343b0:

    # nk "Shoot."
    nk "Diga."

# game/script-a2-emi.rpy:6647
translate pt_br a2_emi_tracking_absences_ddc1e56e:

    # hi "Is she going to be okay?"
    hi "Ela vai ficar bem?"

# game/script-a2-emi.rpy:6652
translate pt_br a2_emi_tracking_absences_c43a427b:

    # nk "Oh yeah, definitely."
    nk "Ah sim, definitivamente."

# game/script-a2-emi.rpy:6657
translate pt_br a2_emi_tracking_absences_d259a064:

    # nk "Her fever was high, but it was already starting to go down by the time she came by my office."
    nk "A febre dela estava alta, mas estava começando a diminuir quando ela veio à minha sala."

# game/script-a2-emi.rpy:6659
translate pt_br a2_emi_tracking_absences_87a92e49:

    # nk "I'll probably check up on her again at lunch to be sure, but I expect she'll be up and about by the evening no matter what I tell her."
    nk "Vou provavelmente checá-la de novo na hora do almoço, para ter certeza, mas creio que ela estará acordada de noite não importa o que eu diga a ela."

# game/script-a2-emi.rpy:6661
translate pt_br a2_emi_tracking_absences_ad5afd39:

    # hi "Hmm, maybe I should visit her after class."
    hi "Hum, talvez eu deva visitá-la após a aula."

# game/script-a2-emi.rpy:6663
translate pt_br a2_emi_tracking_absences_02426b0a:

    # "It takes me a second to realize I've spoken aloud."
    "Levo um segundo para perceber que falei alto."

# game/script-a2-emi.rpy:6668
translate pt_br a2_emi_tracking_absences_8beb2df1:

    # "The nurse raises an eyebrow and gives me a searching glance for a moment."
    "O enfermeiro levanta uma sobrancelha e me examina com o olhar por um momento."

# game/script-a2-emi.rpy:6670
translate pt_br a2_emi_tracking_absences_04ea4e98:

    # nk "Hmm…"
    nk "Hmm…"

# game/script-a2-emi.rpy:6675
translate pt_br a2_emi_tracking_absences_d511b71b:

    # nk "Well, it might not be a bad idea."
    nk "Bom, pode não ser uma má ideia."

# game/script-a2-emi.rpy:6677
translate pt_br a2_emi_tracking_absences_69d04c07:

    # nk "You could let me know if she'd taken a turn for the worse, I guess."
    nk "Você poderia me avisar se ela ficar pior, eu acho."

# game/script-a2-emi.rpy:6682
translate pt_br a2_emi_tracking_absences_3b08ee9e:

    # nk "But no funny business, you got it? I know what meds you're on, after all."
    nk "Mas nada de se engraçar com ela, viu? Eu sei quais remédios você está tomando."

# game/script-a2-emi.rpy:6684
translate pt_br a2_emi_tracking_absences_7dc53cf4:

    # "I think that's a threat against my life, but I'm not sure."
    "Eu acho que é uma ameaça à minha vida, mas não tenho certeza."

# game/script-a2-emi.rpy:6691
translate pt_br a2_emi_tracking_absences_7582a255:

    # "Either way, I assure the nurse that my intentions are chaste and exit the office."
    "De qualquer forma, eu convenço o enfermeiro que minhas intenções são puras e saio da sala."

# game/script-a2-emi.rpy:6693
translate pt_br a2_emi_tracking_absences_915d80df:

    # "Interesting that the nurse sees me as some sort of potential suitor to Emi."
    "Interessante que o enfermeiro me vê como um futuro pretendente para a Emi."

# game/script-a2-emi.rpy:6695
translate pt_br a2_emi_tracking_absences_1892afec:

    # "Even more interesting is how pleased that makes me feel."
    "Muito mais interessante é como isso me deixa satisfeito."

# game/script-a2-emi.rpy:6697
translate pt_br a2_emi_tracking_absences_9a837167:

    # "I need a shower."
    "Preciso de um banho."

# game/script-a2-emi.rpy:6704
translate pt_br a2_emi_tracking_absences_df421f90:

    # "The lunch bell rings, and I find myself disinclined to make my way up to the roof."
    "A campainha do almoço toca, e eu me sinto sem vontade de subir até o telhado."

# game/script-a2-emi.rpy:6706
translate pt_br a2_emi_tracking_absences_ed560ab1:

    # "After all, I'm betting Rin knows where Emi is, and if that's the case then I doubt she'd bother going up there."
    "Além do mais, aposto que a Rin sabe onde a Emi está, e se é esse o caso, eu duvido que ela esteja lá em cima."

# game/script-a2-emi.rpy:6708
translate pt_br a2_emi_tracking_absences_3686ca7b:

    # "More to the point, I doubt we'd have any sort of scintillating conversation if she did. Chances are she'd prefer to be alone up there anyway, so I don't accidentally ruin her train of thought or something."
    "Mais além, eu duvido que teríamos algum tipo de conversa brilhante se ela estivesse. Ela preferiria estar sozinha lá, para eu não arruinar a sua linha de raciocínio ou algo assim."

# game/script-a2-emi.rpy:6710
translate pt_br a2_emi_tracking_absences_55fef60b:

    # "Unfortunately, I don't really feel like heading to the cafeteria either."
    "Infelizmente, não estou com vontade de ir ao refeitório também."

# game/script-a2-emi.rpy:6712
translate pt_br a2_emi_tracking_absences_390f848e:

    # "Guess I'll go to the library instead."
    "Acho que vou à biblioteca então."

# game/script-a2-emi.rpy:6714
translate pt_br a2_emi_tracking_absences_b84e60b6:

    # "I need a new book to read anyway, having finished my other one yesterday before bed. Maybe I can find more by the same author."
    "Preciso de um novo livro pra ler de qualquer jeito, já que acabei meu outro ontem antes de dormir. Talvez eu possa achar mais pelo mesmo autor."

# game/script-a2-emi.rpy:6721
translate pt_br a2_emi_tracking_absences_29a00a49:

    # "I love libraries."
    "Eu amo bibliotecas."

# game/script-a2-emi.rpy:6723
translate pt_br a2_emi_tracking_absences_2bd03b20:

    # "They smell like dust and paper and ink."
    "Elas cheiram à poeira e papel e tinta."

# game/script-a2-emi.rpy:6725
translate pt_br a2_emi_tracking_absences_1ade6424:

    # "All these stories and facts and opinions crowded together in one place makes the air come alive with potential."
    "Todas essas histórias e fatos e opiniões reunidas em um só lugar dão um ar de potencial."

# game/script-a2-emi.rpy:6727
translate pt_br a2_emi_tracking_absences_9128fa24:

    # "I'm not sure how to navigate Yamaku's library yet, having mostly stuck to books I brought with me, so I search for the librarian to ask for help."
    "Ainda não sei como navegar na biblioteca da Yamaku, já que a maioria dos livros que li foram os que eu trouxe comigo, então eu procuro a bibliotecária pra me ajudar."

# game/script-a2-emi.rpy:6729
translate pt_br a2_emi_tracking_absences_ce617998_1:

    # "…"
    "…"

# game/script-a2-emi.rpy:6731
translate pt_br a2_emi_tracking_absences_0c5b0f47:

    # "Hmm. I suppose she's not arou—{w=0.5}{nw}"
    "Hum. Eu presumo que ela não esteja por per—{w=0.5}{nw}"

# game/script-a2-emi.rpy:6741
translate pt_br a2_emi_tracking_absences_57c2d882:

    # yu "…can't believe it."
    yu "…não acredito nisso."

# game/script-a2-emi.rpy:6743
translate pt_br a2_emi_tracking_absences_a8f69565:

    # "Yuuko, looking rather distracted, suddenly emerges from one of the aisles."
    "Yuuko, parecendo meio que distraída, subitamente aparece de uma das alas."

# game/script-a2-emi.rpy:6745
translate pt_br a2_emi_tracking_absences_7aba37c7:

    # hi "Er, excuse me."
    hi "Er, com licença."

# game/script-a2-emi.rpy:6750
translate pt_br a2_emi_tracking_absences_72b89b86:

    # yu "Oh, can I help you?"
    yu "Oh, posso lhe ajudar?"

# game/script-a2-emi.rpy:6752
translate pt_br a2_emi_tracking_absences_80748a53:

    # hi "Actually, I was looking for a book…"
    hi "Na verdade, eu estava procurando por um livro…"

# game/script-a2-emi.rpy:6757
translate pt_br a2_emi_tracking_absences_fe62e514:

    # yu "So am I!"
    yu "Eu também estou!"

# game/script-a2-emi.rpy:6762
translate pt_br a2_emi_tracking_absences_38d67974:

    # yu "'Advanced Cryptography.' We just got it in, and now it's gone missing."
    yu "“Criptografia Avançada.” Nós o adquirimos há pouco tempo, e agora desapareceu."

# game/script-a2-emi.rpy:6767
translate pt_br a2_emi_tracking_absences_b52f457c:

    # yu "I really, really wanted to read that one!"
    yu "Eu realmente, realmente queria ler esse!"

# game/script-a2-emi.rpy:6769
translate pt_br a2_emi_tracking_absences_1b51c966:

    # hi "Cryptography?"
    hi "Criptografia?"

# game/script-a2-emi.rpy:6774
translate pt_br a2_emi_tracking_absences_3c681e3f:

    # yu "Yeah, my… er, that is…"
    yu "Sim, o meu… er, é…"

# game/script-a2-emi.rpy:6776
translate pt_br a2_emi_tracking_absences_2190bcee:

    # yu "This guy I knew. Know. Um."
    yu "Um cara que eu conheci. Conheço. Hum."
    

# game/script-a2-emi.rpy:6778
translate pt_br a2_emi_tracking_absences_74cc7acc:

    # yu "Not sure how to describe it…"
    yu "Não sei como descrever…"

# game/script-a2-emi.rpy:6780
translate pt_br a2_emi_tracking_absences_6363a0d2:

    # hi "Skip to the end."
    hi "Pule para o fim."

# game/script-a2-emi.rpy:6785
translate pt_br a2_emi_tracking_absences_19570e66:

    # yu "He got me interested in cryptography only now the book's gone, and I think it's been stolen!"
    yu "Ele me fez ficar interessada em criptografia e agora o livro sumiu, e eu acho que foi roubado!"

# game/script-a2-emi.rpy:6787
translate pt_br a2_emi_tracking_absences_5e58b3d0:

    # hi "Sounds pretty terrible."
    hi "Parece bastante terrível."

# game/script-a2-emi.rpy:6792
translate pt_br a2_emi_tracking_absences_c7077b46:

    # yu "Yeah, especially because now I have to search the whole library for it!"
    yu "É, especialmente porque agora eu vou ter que procurar toda a biblioteca por ele!"

# game/script-a2-emi.rpy:6794
translate pt_br a2_emi_tracking_absences_145179bc:

    # yu "Even though it's probably not even here!"
    yu "Mesmo que provavelmente ele nem esteja aqui!"

# game/script-a2-emi.rpy:6796
translate pt_br a2_emi_tracking_absences_5c2bcfcf:

    # hi "You seem… busy."
    hi "Você parece… ocupada."

# game/script-a2-emi.rpy:6801
translate pt_br a2_emi_tracking_absences_acf61eb8:

    # yu "A little."
    yu "Um pouco."

# game/script-a2-emi.rpy:6806
translate pt_br a2_emi_tracking_absences_214fb7dc:

    # "She dashes off down another aisle, and I resign myself to finding my own damn book."
    "Ela corre para a outra ala, e eu volto a me preocupar em achar meu próprio livro."

# game/script-a2-emi.rpy:6808
translate pt_br a2_emi_tracking_absences_5fd5b846:

    # "Hmm, plenty of choices."
    "Hum, bastante escolhas."

# game/script-a2-emi.rpy:6815
translate pt_br a2_emi_tracking_absences_2983a0a0:

    # "Oh come on, how did I get lost?"
    "Ah fala sério, como eu me perdi!"

# game/script-a2-emi.rpy:6817
translate pt_br a2_emi_tracking_absences_409b1c88:

    # "These aren't even printed books! They're all in Braille."
    "Esses livros não são nem impressos? Estão todos em Braille."

# game/script-a2-emi.rpy:6819
translate pt_br a2_emi_tracking_absences_b3c16a0c:

    # "I guess that makes sense in a school like this, but honestly, it's a little annoying."
    "Eu suponho que faz sentido ser assim em uma escola desse tipo, mas honestamente, é um pouco entediante."

# game/script-a2-emi.rpy:6821
translate pt_br a2_emi_tracking_absences_20686807:

    # li "I'm sorry, is someone there?"
    li "Desculpe, tem alguém aí?"

# game/script-a2-emi.rpy:6823
translate pt_br a2_emi_tracking_absences_c903c136:

    # "A lilting voice drifts out from behind one of the cubicles set up for research."
    "Uma voz cantarolante vem de trás de um dos cubículos reservados para pesquisa."

# game/script-a2-emi.rpy:6828
translate pt_br a2_emi_tracking_absences_f61c93f1:

    # "As I approach, I see that Lilly's been reading a book while I've been stomping about the aisles."
    "Enquanto me aproximo, vejo que a Lilly estava lendo um livro enquanto eu estava resmungando sobre as alas."

# game/script-a2-emi.rpy:6830
translate pt_br a2_emi_tracking_absences_9734ad8b:

    # hi "Oh no, I should be apologizing. I didn't mean to make so much noise."
    hi "Ah não, eu que deveria me desculpar, não quis fazer tanto barulho."

# game/script-a2-emi.rpy:6835
translate pt_br a2_emi_tracking_absences_ee96a5fb:

    # li "My, is that you Hisao?"
    li "Oh, é você Hisao?"

# game/script-a2-emi.rpy:6840
translate pt_br a2_emi_tracking_absences_861ff926:

    # li "I've not heard from you in quite some time."
    li "Não tive notícias suas por um tempo."

# game/script-a2-emi.rpy:6845
translate pt_br a2_emi_tracking_absences_2216716b:

    # li "I was beginning to think you'd forgotten all about me."
    li "Eu estava começando a achar que você havia me esquecido totalmente."

# game/script-a2-emi.rpy:6847
translate pt_br a2_emi_tracking_absences_5ef97bdf:

    # hi "Er, sorry."
    hi "Er, desculpe."

# game/script-a2-emi.rpy:6854
translate pt_br a2_emi_tracking_absences_ab7ee3c5:

    # "Lilly laughs in that refined manner of hers and shakes her head."
    "Lilly ri de uma maneira refinada e acena."

# game/script-a2-emi.rpy:6859
translate pt_br a2_emi_tracking_absences_e2b9cdf6:

    # li "I'm only teasing you, Hisao."
    li "Estou apenas brincando com você, Hisao."

# game/script-a2-emi.rpy:6861
translate pt_br a2_emi_tracking_absences_254943e9:

    # li "From what I hear, you've been busy."
    li "Pelo que eu ouvi, você esteve ocupado."

# game/script-a2-emi.rpy:6866
translate pt_br a2_emi_tracking_absences_9edde637:

    # li "Morning runs with Emi Ibarazaki {b}and{/b} lunch on the rooftop, if I'm not mistaken."
    li "Corridas matinais com Emi Ibarazaki {b}e{/b} almoço no telhado, se eu não me engano."

# game/script-a2-emi.rpy:6868
translate pt_br a2_emi_tracking_absences_f2186f54:

    # hi "Heh, yeah."
    hi "Heh, sim."

# game/script-a2-emi.rpy:6870
translate pt_br a2_emi_tracking_absences_1ccf0d23:

    # hi "Guess word gets around pretty quickly."
    hi "Parece que as notícias se espalham bem rápido."

# game/script-a2-emi.rpy:6875
translate pt_br a2_emi_tracking_absences_79872182:

    # li "That and I can't coax poor Hanako on the roof any more."
    li "Além disso, também não posso mais bajular a pobre da Hanako no telhado."

# game/script-a2-emi.rpy:6880
translate pt_br a2_emi_tracking_absences_5c8eaf50:

    # li "You three are always up there, claiming the spot for yourselves."
    li "Vocês três sempre estão lá em cima, pegando o lugar para vocês."

# game/script-a2-emi.rpy:6882
translate pt_br a2_emi_tracking_absences_a03d44fb:

    # "She chides me gently, though it's pretty clear she's just teasing me again."
    "Ela me repreende gentilmente, porém é bem claro que ela está me provocando novamente."

# game/script-a2-emi.rpy:6884
translate pt_br a2_emi_tracking_absences_dd9a351e:

    # "Still, I feel an odd need to apologize."
    "Mesmo assim, sinto uma necessidade estranha de pedir desculpas."

# game/script-a2-emi.rpy:6886
translate pt_br a2_emi_tracking_absences_86d11e92:

    # hi "Sorry, we could eat lunch somewhere else if it's a real problem—"
    hi "Desculpe, nós podemos almoçar em outro lugar se é um problema grande—"

# game/script-a2-emi.rpy:6891
translate pt_br a2_emi_tracking_absences_20c574f8:

    # li "Oh no, I wouldn't worry about it."
    li "Ah não, não precisa se preocupar."

# game/script-a2-emi.rpy:6896
translate pt_br a2_emi_tracking_absences_cf4a7ae3:

    # li "Hanako and I have other things to do at lunch, too."
    li "Hanako e eu temos outras coisas para fazer no almoço também."

# game/script-a2-emi.rpy:6898
translate pt_br a2_emi_tracking_absences_55102577:

    # li "Such as read in the library, as you can see."
    li "Tipo ler na biblioteca, como você pode ver."

# game/script-a2-emi.rpy:6900
translate pt_br a2_emi_tracking_absences_aac70433:

    # hi "Oh, Hanako's here too? I didn't see her."
    hi "Oh, a Hanako está aqui também? Eu não a vi."

# game/script-a2-emi.rpy:6905
translate pt_br a2_emi_tracking_absences_790a59df:

    # "Lilly smiles, a bit enigmatically."
    "Lilly sorri, um pouco enigmática."

# game/script-a2-emi.rpy:6907
translate pt_br a2_emi_tracking_absences_840e0786:

    # li "Oh, she's around somewhere."
    li "Oh, ela está em algum lugar por perto."

# game/script-a2-emi.rpy:6912
translate pt_br a2_emi_tracking_absences_4b1abe40:

    # li "But I'm surprised, Hisao. You're in here, instead of up there."
    li "Mas eu estou surpresa, Hisao. Você está aqui, ao invés de lá em cima."

# game/script-a2-emi.rpy:6914
translate pt_br a2_emi_tracking_absences_4966e2b9:

    # li "What brings you to the library?"
    li "O que te traz à biblioteca?"

# game/script-a2-emi.rpy:6916
translate pt_br a2_emi_tracking_absences_ea964981:

    # hi "Well, Emi's ill, so there's no lunch on the rooftop to keep me occupied…"
    hi "Bem, a Emi está doente, então não tem o almoço no telhado para me ocupar."

# game/script-a2-emi.rpy:6921
translate pt_br a2_emi_tracking_absences_4b4dde96:

    # "Lilly raises an eyebrow at my statement before giving another chuckle."
    
    "Lilly levanta uma das sobrancelhas quando digo isso, e logo dá uma risada."

# game/script-a2-emi.rpy:6923
translate pt_br a2_emi_tracking_absences_0c398c48:

    # li "My, poor Rin must feel left out."
    li "A pobre Rin deve se sentir excluída."

# game/script-a2-emi.rpy:6925
translate pt_br a2_emi_tracking_absences_44f83214:

    # hi "It's not like that!"
    hi "As coisas não são assim!"

# game/script-a2-emi.rpy:6930
translate pt_br a2_emi_tracking_absences_a88dfec8:

    # li "Ah, but I'm sure it isn't. Emi tends to be the life of whatever group she's in."
    li "Ah, mas eu tenho certeza que não são. A Emi costuma ser o centro de qualquer grupo em que ela esteja."

# game/script-a2-emi.rpy:6935
translate pt_br a2_emi_tracking_absences_ba30994b:

    # li "It's a shame to hear she's fallen ill. Will she be okay?"
    li "É uma pena saber que ela ficou doente. Ela vai ficar bem?"

# game/script-a2-emi.rpy:6937
translate pt_br a2_emi_tracking_absences_953baf9d:

    # "Somehow I get the feeling that Lilly's just inquiring out of politeness, but I respond anyway."
    "De alguma forma eu sinto que a Lilly está perguntando apenas por educação, mas respondo assim mesmo."

# game/script-a2-emi.rpy:6939
translate pt_br a2_emi_tracking_absences_9df6f907:

    # hi "The nurse thinks so. I'm going to swing by and see how she's doing after school myself."
    hi "O enfermeiro acha que sim. Eu vou passar por lá e ver como ela está depois das aulas."

# game/script-a2-emi.rpy:6944
translate pt_br a2_emi_tracking_absences_2b162d95:

    # "Another raised eyebrow."
    "Outra sobrancelha levantada."

# game/script-a2-emi.rpy:6946
translate pt_br a2_emi_tracking_absences_d1180ed1:

    # li "My, what a noble gentleman you are, Hisao."
    li "Nossa, que nobre cavalheiro você é, Hisao."

# game/script-a2-emi.rpy:6948
translate pt_br a2_emi_tracking_absences_ecd291d9:

    # hi "It's nothing, really. Just checking up on my friend, after all."
    hi "Não é nada, sério. Apenas dando uma checada em minha amiga."

# game/script-a2-emi.rpy:6953
translate pt_br a2_emi_tracking_absences_0ef9b922:

    # li "Ah, so it's just friends, is it? How disappointing."
    li "Ah, então são apenas amigos? Que desapontante."

# game/script-a2-emi.rpy:6955
translate pt_br a2_emi_tracking_absences_f82f1332:

    # "I blush, glad that Lilly can't see it."
    "Eu fico vermelho, mas feliz pela Lilly não poder me ver."

# game/script-a2-emi.rpy:6960
translate pt_br a2_emi_tracking_absences_c83497e7:

    # "But somehow she knows that I've been flustered by her comment anyway, and laughs."
    "Mas de algum jeito ela sabe que eu fiquei envergonhado com o seu comentário."

# game/script-a2-emi.rpy:6962
translate pt_br a2_emi_tracking_absences_e7fbe940:

    # li "I'm sorry, Hisao. I'm teasing you again."
    li "Desculpe Hisao, estou te chateando de novo."

# game/script-a2-emi.rpy:6967
translate pt_br a2_emi_tracking_absences_2426cede:

    # li "Please do tell Emi that I hope she feels better, won't you?"
    li "Por favor diga à Emi que eu desejo melhoras, pode ser?"

# game/script-a2-emi.rpy:6969
translate pt_br a2_emi_tracking_absences_5caa6f31:

    # "A glance at my watch reveals that I'm very nearly out of time to find my book."
    "Uma olhada no meu relógio mostra que estou quase sem tempo para achar meu livro."

# game/script-a2-emi.rpy:6971
translate pt_br a2_emi_tracking_absences_2f6a93ba:

    # hi "Of course."
    hi "É claro."

# game/script-a2-emi.rpy:6973
translate pt_br a2_emi_tracking_absences_9f2ea3d6:

    # hi "Hey, I've got to find a book before lunch is over, so I'd better get moving."
    hi "Ei, tenho que achar um livro antes do intervalo acabar, então tenho que ir."

# game/script-a2-emi.rpy:6975
translate pt_br a2_emi_tracking_absences_181ad1e9:

    # hi "See you later."
    hi "Te vejo depois."

# game/script-a2-emi.rpy:6977
translate pt_br a2_emi_tracking_absences_e39af9f2:

    # "That was probably not the best phrase to use."
    "Essa provavelmente não foi a melhor frase a ser usada."

# game/script-a2-emi.rpy:6979
translate pt_br a2_emi_tracking_absences_daa84b9a:

    # "Lilly, however, takes my gaffe in stride."
    "Porém, Lilly responde minha gafe andando."

# game/script-a2-emi.rpy:6986
translate pt_br a2_emi_tracking_absences_161766b4:

    # li "Until we meet again, Hisao."
    li "Até a próxima, Hisao."

# game/script-a2-emi.rpy:6991
translate pt_br a2_emi_tracking_absences_6a7a17bd:

    # "I never do find the book I was looking for, but I walk out with something else instead."
    "Eu não acho o livro que estava procurando, mas saio com outra coisa no lugar dele."

# game/script-a2-emi.rpy:6993
translate pt_br a2_emi_tracking_absences_e734cb30:

    # "My stomach growls slightly, letting me know that I should have had something for lunch."
    "Meu estômago ronca um pouco, me lembrando que eu deveria ter almoçado."

# game/script-a2-emi.rpy:6995
translate pt_br a2_emi_tracking_absences_2521d867:

    # "Oh well."
    "Que coisa."

# game/script-a2-emi.rpy:6997
translate pt_br a2_emi_tracking_absences_50276528:

    # "I'll grab something before I visit Emi later."
    "Vou pegar algo para comer antes de visitar a Emi."

# game/script-a2-emi.rpy:7010
translate pt_br a2_emi_dropping_by_ef7cb43f:

    # "It seems as if time has decided to slow down for the express purpose of annoying the hell out of me."
    "Parece que o tempo decidiu desacelerar apenas pelo propósito de me irritar."

# game/script-a2-emi.rpy:7012
translate pt_br a2_emi_dropping_by_b74e32a6:

    # "Class feels like it drags on for ages."
    "Parece que a aula dura séculos."

# game/script-a2-emi.rpy:7014
translate pt_br a2_emi_dropping_by_398a54ff:

    # "I suspect that my being consumed with worry probably has something to do with it."
    "Suspeito que o fato de eu estar extremamente preocupado tem algo a ver com isso."

# game/script-a2-emi.rpy:7018
translate pt_br a2_emi_dropping_by_a8c92e8e:

    # "Blessedly the bell rings and I dash out of class, drawing a few raised eyebrows, I'm sure."
    "Milagrosamente o sinal toca e eu corro para fora, chamando a atenção de alguns olhares. Tenho certeza."

# game/script-a2-emi.rpy:7023
translate pt_br a2_emi_dropping_by_3eb0adc0:

    # "I have spent the majority of the day fretting as unobtrusively as I could."
    "Passei a maioria do dia me inquietando o mais discretamente que pude."

# game/script-a2-emi.rpy:7025
translate pt_br a2_emi_dropping_by_ed35cd16:

    # "Even though the nurse thinks that Emi is perfectly okay, I want to see for myself."
    "Mesmo que o enfermeiro pense que a Emi esteja perfeitamente bem, quero ver com meus próprios olhos."

# game/script-a2-emi.rpy:7032
translate pt_br a2_emi_dropping_by_9c39e3ee:

    # "It doesn't take long to get to the girls' dormitory and make my way to Emi's room."
    "Não demoro muito para chegar ao dormitório feminino e ir até o quarto da Emi."

# game/script-a2-emi.rpy:7034
translate pt_br a2_emi_dropping_by_3133b83c:

    # "Standing outside her door, I suddenly pause. What if she's resting?"
    "Do lado de fora do quarto, eu paro subitamente. E se ela estiver descansando?"

# game/script-a2-emi.rpy:7036
translate pt_br a2_emi_dropping_by_f8eb2ddc:

    # "I'd hate to wake her up, especially if she's still feeling ill."
    "Eu odiaria ter que acordar ela, especialmente se ela ainda estiver se sentindo doente."

# game/script-a2-emi.rpy:7038
translate pt_br a2_emi_dropping_by_26b18f5d:

    # "Then again, if she sleeps all day then it could throw off her sleeping schedule."
    "De novo, se ela dormir o dia todo então isso poderia descontrolar seu relógio biológico."

# game/script-a2-emi.rpy:7040
translate pt_br a2_emi_dropping_by_98b34ac8:

    # "But rest is important if you're ill, isn't it?"
    "Mas descanso é importante se você está se sentindo doente, não é?"

# game/script-a2-emi.rpy:7042
translate pt_br a2_emi_dropping_by_f63d809f:

    # "I can't decide what to do, so I settle for standing outside the door looking like an idiot."
    "Não consigo decidir o que fazer, então continuo do lado de fora do quarto como um idiota."

# game/script-a2-emi.rpy:7044
translate pt_br a2_emi_dropping_by_c29722e7:

    # "Then I hear Emi's voice from behind the door."
    "Então ouço a voz da Emi do outro lado."

# game/script-a2-emi.rpy:7046
translate pt_br a2_emi_dropping_by_0e6ed5f9:

    # emi "Thanks for your concern, but I really am okay."
    emi "Obrigado pela preocupação, mas estou bem."

# game/script-a2-emi.rpy:7048
translate pt_br a2_emi_dropping_by_3cb4c53d:

    # "Is she talking to me?"
    "Ela está falando comigo?"

# game/script-a2-emi.rpy:7050
translate pt_br a2_emi_dropping_by_79c8422f:

    # emi "I'll see you at practice tomorrow!"
    emi "Te vejo no treino amanhã!"

# game/script-a2-emi.rpy:7052
translate pt_br a2_emi_dropping_by_606b9053:

    # "Guess not."
    "Acho que não."

# game/script-a2-emi.rpy:7054
translate pt_br a2_emi_dropping_by_a7ace483:

    # "Still, clearly she's not asleep, so I can knock without worry."
    "Novamente, ela claramente está acordada, então posso bater sem me preocupar."

# game/script-a2-emi.rpy:7056
translate pt_br a2_emi_dropping_by_fb9fe023:

    # "So why this clenched feeling in my gut? I wasn't nervous about dropping by the other day, so why today?"
    "Então por que esse frio na barriga? Eu não estava nervoso no outro dia que vim aqui, então por que estou hoje?"

# game/script-a2-emi.rpy:7058
translate pt_br a2_emi_dropping_by_85b08c1b:

    # "Granted, I still haven't really had time to figure out this newfound interest in Emi's well-being."
    "Para falar a verdade, ainda não tive tempo para descobrir porquê estou tão interessado no bem estar da Emi ultimamente."

# game/script-a2-emi.rpy:7060
translate pt_br a2_emi_dropping_by_74c6244d:

    # "I don't have a lot of experience in the matter, of course, but certainly this seems to go beyond feelings of mere friendship."
    "Não tenho muita experiência no assunto, é claro, mas isso com certeza vai além de uma mera amizade."

# game/script-a2-emi.rpy:7062
translate pt_br a2_emi_dropping_by_18574878:

    # "But could I take that step? Could I even bring myself to risk what I have right now?"
    "Mas será que eu poderia dar este passo? Será que eu teria coragem de arriscar o que eu tenho agora?"

# game/script-a2-emi.rpy:7064
translate pt_br a2_emi_dropping_by_dd164a57:

    # "I mean it's enough to be friends with her, isn't it?"
    "Digo, é suficiente ser amigo dela, não é?"

# game/script-a2-emi.rpy:7066
translate pt_br a2_emi_dropping_by_3ac405e6:

    # "Either way, shouldn't I just open the door and see how she's doing? That's why I came here… right?"
    "De qualquer jeito, por que eu simplesmente não abro a porta e vejo como ela está? Foi pra isso que eu vim aqui… não foi?"

# game/script-a2-emi.rpy:7070
translate pt_br a2_emi_dropping_by_17461f2e:

    # "What if she's not dressed yet?"
    "E se ela não estiver vestida?"

# game/script-a2-emi.rpy:7076
translate pt_br a2_emi_dropping_by_c2e69b55:

    # "The image that flashes through my mind causes my heart to skip a beat, literally."
    "A imagem que passa pela minha mente faz meu coração acelerar, literalmente."

# game/script-a2-emi.rpy:7080
translate pt_br a2_emi_dropping_by_a3304c70:

    # "I should probably not ever think those thoughts again. Not if I want to avoid a heart attack."
    "Eu nem deveria pensar essas coisas de novo. A menos que eu queira ter um ataque do coração."

# game/script-a2-emi.rpy:7082
translate pt_br a2_emi_dropping_by_38a7b25c:

    # "I suddenly realize I'm still standing in the hallway looking like an idiot."
    "Subitamente percebo que ainda estou parado no corredor parecendo um idiota."

# game/script-a2-emi.rpy:7086
translate pt_br a2_emi_dropping_by_3e6c1bf5:

    # "Emi still seems to be in the middle of a conversation, but I knock anyway. Hopefully she won't mind the interruption."
    "Emi parece estar ainda no meio de uma conversa, mas eu a chamo assim mesmo. Espero que ela não ligue para a interrupção."

# game/script-a2-emi.rpy:7088
translate pt_br a2_emi_dropping_by_a4478a9f:

    # emi "You worry too mu— Come in! The door's unlocked."
    emi "Você se preocupa mui— Pode entrar! A porta está aberta."

# game/script-a2-emi.rpy:7090
translate pt_br a2_emi_dropping_by_42ed4737:

    # "So it is. I open the door and step in, which is about where my thought process comes to a grinding halt."
    "Então é isso. Eu abro a porta e entro, e é quando os meus pensamentos param."

# game/script-a2-emi.rpy:7100
translate pt_br a2_emi_dropping_by_7bdc66a4:

    # "Emi is sitting up in bed, her hair tousled from a day spent asleep. I think this is the first time I've seen her without those familiar beads in her hair."
    "Emi está sentada na cama, seu cabelo desarrumado por ter passado um dia dormindo. Acho que essa é a primeira vez que eu a vi sem seus broches no cabelo."

# game/script-a2-emi.rpy:7102
translate pt_br a2_emi_dropping_by_469ba94f:

    # "Her gym shirt and bloomers, obviously hastily pulled on before I came in, are creased and folded from less than proper storage."
    "Sua camisa de educação física e shorts, obviamente vestidos com pressa antes de eu entrar, estão marcados pela falta de cuidados."

# game/script-a2-emi.rpy:7109
translate pt_br a2_emi_dropping_by_67fc11bd:

    # "Her legs lay bare on the sheets."
    "Suas pernas estão desnudas no lençol."

# game/script-a2-emi.rpy:7111
translate pt_br a2_emi_dropping_by_c271b4cc:

    # "I've never seen Emi without prosthetics before. Yet here she is, slender legs terminating in stumps just below her knees."
    "Eu nunca havia visto a Emi sem as próteses antes. Mas aqui está ela, pernas franzinas terminando abaixo de seus joelhos."

# game/script-a2-emi.rpy:7113
translate pt_br a2_emi_dropping_by_bee8152e:

    # "But as odd as the sight is, I find myself more captivated by everything north of the waist."
    "Mas por mais estranha que seja essa vista, eu me vejo mais cativado por tudo acima de sua cintura."

# game/script-a2-emi.rpy:7121
translate pt_br a2_emi_dropping_by_f530fd8a:

    # "It seems that Emi had finished her conversation with whoever was on the phone with her, and is now watching my reaction closely out of her one open eye as she wipes sleep from the other."
    "Parece que a Emi terminou de conversar com quem estava no celular com ela, e está olhando minha reação com apenas um olho, enquanto esfrega o outro."

# game/script-a2-emi.rpy:7123
translate pt_br a2_emi_dropping_by_be99b68f:

    # "Her expression, far from being embarrassed, is rather one of a surprisingly wide yawn. One perhaps appropriate from such a small mouth."
    "Sua expressão, longe de estar envergonhada, está mais para um grande bocejo. Um apropriado para uma boca tão pequena."

# game/script-a2-emi.rpy:7125
translate pt_br a2_emi_dropping_by_da31bc0c:

    # "A grin that for a brief moment seems almost flirtatious tugs at the corner of her mouth as she takes the sight of me in."
    "Um sorriso que por um breve momento parece um convite romântico se forma no canto de sua boca enquanto ela me olha."

# game/script-a2-emi.rpy:7127
translate pt_br a2_emi_dropping_by_de2476bd:

    # "I can do nothing but remain in a state fluctuating between fear, confusion, and not a little bit of lust."
    "Não posso fazer nada além de ficar entre medo, confusão e um pouco de desejo."

# game/script-a2-emi.rpy:7129
translate pt_br a2_emi_dropping_by_aacf539d:

    # "Emi hastily sweeps her hair out of her eyes, fixing it back into place before addressing me."
    "Emi forçosamente tira seu cabelo da frente dos olhos, colocando-o no lugar antes de falar comigo."

# game/script-a2-emi.rpy:7135
translate pt_br a2_emi_dropping_by_4f30954e:

    # emi "You seem a bit caught off guard, Hisao."
    emi "Você parece que foi pego com a guarda baixa, Hisao."

# game/script-a2-emi.rpy:7137
translate pt_br a2_emi_dropping_by_b68611b4:

    # "A wave of laughter erupts from her, and I find myself grinning and rubbing the back of my head ruefully."
    "Uma onda de riso emana dela, e eu fico rindo e coçando minha cabeça com vergonha."

# game/script-a2-emi.rpy:7139
translate pt_br a2_emi_dropping_by_76651ca1:

    # hi "Sorry, I've just…"
    hi "Desculpe, é que eu…"

# game/script-a2-emi.rpy:7141
translate pt_br a2_emi_dropping_by_64e32e14:

    # "Never seen someone so disheveled look so attractive."
    "Nunca vi alguém tão desarrumada parecer tão atrativa."

# game/script-a2-emi.rpy:7143
translate pt_br a2_emi_dropping_by_ec333982:

    # "Never seen you without your legs on."
    "Nunca havia te visto sem as suas pernas."

# game/script-a2-emi.rpy:7145
translate pt_br a2_emi_dropping_by_23421273:

    # "Never seen you look so…"
    "Nunca havia te visto estar tão…"

# game/script-a2-emi.rpy:7147
translate pt_br a2_emi_dropping_by_4f48a656:

    # hi "Um, sorry."
    hi "Hum, desculpa."

# game/script-a2-emi.rpy:7152
translate pt_br a2_emi_dropping_by_72f5f4ad:

    # "Emi giggles again and moves to sit up a little straighter."
    "Emi sorri de novo e ajeita sua postura."

# game/script-a2-emi.rpy:7154
translate pt_br a2_emi_dropping_by_687d353a:

    # "I'm caught up in the movements of her shirt, very nearly losing myself."
    "Eu quase me perco observando os movimentos da sua camisa."

# game/script-a2-emi.rpy:7159
translate pt_br a2_emi_dropping_by_ca737fe5:

    # emi "I was wondering what your reaction would be."
    emi "Estava imaginando qual seria sua reação."

# game/script-a2-emi.rpy:7164
translate pt_br a2_emi_dropping_by_48fadb88:

    # emi "The nurse called and told me you were going to drop by, you see."
    emi "O enfermeiro me chamou e me disse que você apareceria."

# game/script-a2-emi.rpy:7169
translate pt_br a2_emi_dropping_by_a810b9a7:

    # emi "And I know you haven't seen me… well, you know."
    emi "E eu sei que você ainda não havia me visto… bom, você sabe."

# game/script-a2-emi.rpy:7174
translate pt_br a2_emi_dropping_by_00a072a3:

    # emi "Without legs."
    emi "Sem as pernas."

# game/script-a2-emi.rpy:7176
translate pt_br a2_emi_dropping_by_022d760b:

    # "I respond in a tone of casual surprise."
    "Respondo em um tom casual de surpresa."

# game/script-a2-emi.rpy:7178
translate pt_br a2_emi_dropping_by_d00e69fb:

    # hi "Oh, you don't have them on? I didn't notice."
    hi "Ah, você não está com elas? Não percebi."

# game/script-a2-emi.rpy:7180
translate pt_br a2_emi_dropping_by_2a6c5559:

    # "This is almost the truth. I very nearly didn't."
    "Isso é praticamente verdade. Eu quase não percebi mesmo."

# game/script-a2-emi.rpy:7182
translate pt_br a2_emi_dropping_by_f941e843:

    # "I'm not trying to be suave or anything, mind you. Somehow I think Emi would get offended by that."
    "Não estou tentando ser suave ou algo assim, entenda. De algum jeito eu acho que a Emi se sentiria ofendida ao ouvir isso."

# game/script-a2-emi.rpy:7189
translate pt_br a2_emi_dropping_by_a3e992a8:

    # "Instead, she sticks her tongue out at me and chucks a pillow at my head."
    "Ao invés disso, ela mostra a língua para mim e me atira um travesseiro."

# game/script-a2-emi.rpy:7191
translate pt_br a2_emi_dropping_by_da07edab:

    # emi "Ass."
    emi "Cuzão."

# game/script-a2-emi.rpy:7193
translate pt_br a2_emi_dropping_by_932daf6b:

    # "I deftly catch the pillow and take careful aim before throwing."
    "Eu rapidamente pego o travesseiro e miro bem antes de jogar."

# game/script-a2-emi.rpy:7204
translate pt_br a2_emi_dropping_by_c6a5a43f:

    # "Emi laughs and rolls to one side, dodging my shot, the shifting of her shirt distracting me enough so that the next thrown pillow hits me right between the eyes."
    "Emi ri e rola de lado, desviando do meu ataque, com o movimento da sua camisa me distraindo o suficiente para que o próximo travesseiro me acerte bem na cara."

# game/script-a2-emi.rpy:7208
translate pt_br a2_emi_dropping_by_75415527:

    # hi "Oof!" with hpunch
    hi "Oof!" with hpunch

# game/script-a2-emi.rpy:7210
translate pt_br a2_emi_dropping_by_f053e5f5:

    # "I retaliate, of course."
    "Claro que eu retribuo."

# game/script-a2-emi.rpy:7212
translate pt_br a2_emi_dropping_by_bd4fa3a4:

    # "And once I've retaliated twice, well, a war was bound to break out sooner or later."
    "E quando eu retribuo duas vezes, bem, uma guerra de travesseiros iria acontecer mais cedo ou mais tarde."

# game/script-a2-emi.rpy:7214
translate pt_br a2_emi_dropping_by_832ae5b3:

    # "And really, when Emi appears to have far better aim than me, well…"
    "Porém, quando a Emi parece ter uma mira muito melhor que a minha, bem…"

# game/script-a2-emi.rpy:7216
translate pt_br a2_emi_dropping_by_5875d971:

    # "It was just a matter of time before I'd have to resort to a suicidal charge."
    "Era só uma questão de tempo até eu tentar um ataque suicida."

# game/script-a2-emi.rpy:7227
translate pt_br a2_emi_dropping_by_b0d74d7c:

    # hi "Gotcha!"
    hi "Te peguei!"

# game/script-a2-emi.rpy:7232
translate pt_br a2_emi_dropping_by_5c74aadc:

    # emi "Eep!"
    emi "Eep!"

# game/script-a2-emi.rpy:7267
translate pt_br a2_emi_dropping_by_07072cc3:

    # "And once the charge was accomplished, well, of course I'd have to wrestle the pillows away from her."
    "E quando o ataque fosse completado, bem, claro que eu teria que tirar os travesseiros dela."

# game/script-a2-emi.rpy:7269
translate pt_br a2_emi_dropping_by_ee374098:

    # "And with that kind of struggle, of course we'd wind up in this sort of position."
    "E com toda essa resistência, claro que terminaríamos nessa posição."

# game/script-a2-emi.rpy:7280
translate pt_br a2_emi_dropping_by_755636cf:

    # "And so I find myself staring down at her from my position atop her."
    "E então percebo que estou em cima dela a admirando."

# game/script-a2-emi.rpy:7282
translate pt_br a2_emi_dropping_by_66702d6f:

    # "She's grinning, eyes sparkling with amusement, maybe a little sweaty now from our tussle."
    "Ela está sorrindo, com os olhos brilhando de ânimo, e um pouco suada da nossa brincadeira."

# game/script-a2-emi.rpy:7284
translate pt_br a2_emi_dropping_by_05323cc8:

    # "Her chest is heaving up and down, sucking in air."
    "Seu peito sobe e desce, aspirando ar."

# game/script-a2-emi.rpy:7286
translate pt_br a2_emi_dropping_by_ecd4247f:

    # "The small bit of my brain that is not currently enraptured by the sight and the smell of her observes that she must still be ill, because her stamina's not what it should be."
    "A pequena parte do meu cérebro que não está extasiada com a visão e o cheiro dela observa que ela ainda deve estar doente, porque sua resistência não é a mesma."

# game/script-a2-emi.rpy:7288
translate pt_br a2_emi_dropping_by_2d909687:

    # "We stay that way for a while."
    "Nós ficamos assim por um tempo."

# game/script-a2-emi.rpy:7290
translate pt_br a2_emi_dropping_by_8cee9218:

    # "I'm not sure how long, because everything seems to go fuzzy. Everything that isn't her, anyway."
    "Eu não sei quanto, porque tudo parecia distorcido. Tudo exceto ela, de qualquer forma."

# game/script-a2-emi.rpy:7292
translate pt_br a2_emi_dropping_by_5e7e078d:

    # "Her eyes meet mine, and deep inside them I almost catch a glimpse of… what, fear? Longing?"
    "Os olhos dela encontram os meus, e profundo dentro deles eu tenho um vislumbre de… quê, medo? Saudade?"

# game/script-a2-emi.rpy:7294
translate pt_br a2_emi_dropping_by_12bdd339:

    # "Hope?"
    "Esperança?"

# game/script-a2-emi.rpy:7296
translate pt_br a2_emi_dropping_by_4932c45f:

    # hi "Emi…?"
    hi "Emi…?"

# game/script-a2-emi.rpy:7303
translate pt_br a2_emi_dropping_by_a725250c:

    # "A cough suddenly convulses her, and I'm almost stumbling in my haste to get off, to apologize for everything."
    "Uma tosse repentina a convulsiona, e estou quase tropeçando na minha pressa de sair para me desculpar por tudo."

# game/script-a2-emi.rpy:7307
translate pt_br a2_emi_dropping_by_aedd61b5:

    # hi "Sorry, I shouldn't have…"
    hi "Desculpa, eu não deveria…"

# game/script-a2-emi.rpy:7312
translate pt_br a2_emi_dropping_by_3dd87fd4:

    # emi "It's fine, it's fine."
    emi "Tudo bem, tudo bem."

# game/script-a2-emi.rpy:7314
translate pt_br a2_emi_dropping_by_3ae69760:

    # "She gives me a reassuring pat on the shoulder."
    "Ela me dá um tapinha tranquilizador no ombro."

# game/script-a2-emi.rpy:7319
translate pt_br a2_emi_dropping_by_d73512f3:

    # emi "So… what brings you here?"
    emi "Então… o que te traz aqui?"

# game/script-a2-emi.rpy:7321
translate pt_br a2_emi_dropping_by_f2d9fe58:

    # "She's still breathing hard, and that causes her voice to shake slightly."
    "Ela ainda respira com dificuldade, e isso faz sua voz tremer ligeiramente."

# game/script-a2-emi.rpy:7323
translate pt_br a2_emi_dropping_by_82595690:

    # hi "Well, before I was so rudely assaulted by pillows, I came to see how you were doing."
    hi "Bem, antes de eu ser tão rudemente agredido por travesseiros, eu vim para ver como você estava."

# game/script-a2-emi.rpy:7340
translate pt_br a2_emi_dropping_by_48ee4bb9:

    # "This earns me another shove, and I very nearly fall off her bed."
    "Isso me faz ganhar outro empurrão, e quase cair na cama."

# game/script-a2-emi.rpy:7345
translate pt_br a2_emi_dropping_by_2a2f4794:

    # "Emi's eyes sparkle again, and I wonder how I never noticed how attractive they are before."
    "Os olhos da Emi brilham novamente, e eu me pergunto como nunca tinha percebido o quão atraentes eles são."

# game/script-a2-emi.rpy:7350
translate pt_br a2_emi_dropping_by_2cfb1de9:

    # emi "Consumed with worry, were you?"
    emi "Consumido pela preocupação, certo?"

# game/script-a2-emi.rpy:7352
translate pt_br a2_emi_dropping_by_b985fd9e:

    # "Her tone is mocking, haughty. Teasing."
    "Seu tom de voz é zombador, arrogante. Provocante."

# game/script-a2-emi.rpy:7354
translate pt_br a2_emi_dropping_by_c137796b:

    # "She throws her arm across her forehead dramatically, grin still apparent from underneath."
    "Ela dramaticamente joga um braço em direção a testa, seu sorriso ainda é evidente embaixo dele."

# game/script-a2-emi.rpy:7359
translate pt_br a2_emi_dropping_by_660c5a88:

    # emi "Couldn't bear the thought of me laying deathly ill?"
    emi "Não podia suportar a ideia de mim deitada gravemente doente?"

# game/script-a2-emi.rpy:7361
translate pt_br a2_emi_dropping_by_dd7dace3:

    # "As we both recover from our brief wrestling match, Emi appears to fall back on teasing me."
    "Quando nós dois nos recuperamos de nossa pequena luta livre, Emi parece cair para trás me provocando."

# game/script-a2-emi.rpy:7363
translate pt_br a2_emi_dropping_by_ebec6404:

    # hi "Well, I wouldn't say consumed with worry, but after you didn't show up this morning like a total wuss…"
    hi "Bem, eu não diria consumido pela preocupação, mas depois de você não aparecer esta manhã como uma total covarde…"

# game/script-a2-emi.rpy:7368
translate pt_br a2_emi_dropping_by_1d7bc5fa:

    # "Emi pouts, crossing her arms petulantly and sticking her lower lip out."
    "Emi faz beicinho, cruzando os braços com petulância e colocando o lábio inferior para fora."

# game/script-a2-emi.rpy:7370
translate pt_br a2_emi_dropping_by_1cc1bd9a:

    # emi "It's not my fault."
    emi "Não é culpa minha."

# game/script-a2-emi.rpy:7372
translate pt_br a2_emi_dropping_by_f408f7df:

    # emi "Nurse wouldn't allow it."
    emi "O enfermeiro não permitiria isso."

# game/script-a2-emi.rpy:7374
translate pt_br a2_emi_dropping_by_d2f42122:

    # hi "Sure he wouldn't. I completely believe you."
    hi "Claro que ele não permitiria. Eu acredito completamente em você."

# game/script-a2-emi.rpy:7376
translate pt_br a2_emi_dropping_by_de7084b1:

    # "Emi sticks her tongue out again."
    "Emi coloca a língua para fora novamente."

# game/script-a2-emi.rpy:7378
translate pt_br a2_emi_dropping_by_14a1acc7:

    # emi "You're such a jerk, Hisao."
    emi "Você é um idiota, Hisao."

# game/script-a2-emi.rpy:7380
translate pt_br a2_emi_dropping_by_c4d6eced:

    # hi "So how was your day then, eh? Did you enjoy slacking off?"
    hi "Então como foi o seu dia, hein? Você aproveitou faltar?"

# game/script-a2-emi.rpy:7385
translate pt_br a2_emi_dropping_by_c641e61b:

    # emi "Not really, the phone woke me up pretty early on."
    emi "Na verdade não, o telefone me acordou bem cedo."

# game/script-a2-emi.rpy:7387
translate pt_br a2_emi_dropping_by_ac2d8ba8:

    # hi "The phone?"
    hi "O telefone?"

# game/script-a2-emi.rpy:7389
translate pt_br a2_emi_dropping_by_ce28f319:

    # emi "Yeah, the captain of the team called to make sure I was doing okay."
    emi "Sim, o capitão da equipe me ligou para ter certeza de que eu estava indo bem."

# game/script-a2-emi.rpy:7391
translate pt_br a2_emi_dropping_by_141b3331:

    # emi "Also to let me know it was okay to skip practice."
    emi "Também para me deixar sabendo que estava tudo bem pular a prática."

# game/script-a2-emi.rpy:7393
translate pt_br a2_emi_dropping_by_212a70b5:

    # "Good, at least she wasn't alone all day. Someone checked up on her."
    "Bom, pelo menos ela não ficou sozinha o dia todo. Alguém a checou."

# game/script-a2-emi.rpy:7395
translate pt_br a2_emi_dropping_by_56069f9d:

    # "Although I can't help but think that it should have been me."
    "Embora não possa ajudar, penso que deveria ter sido eu."

# game/script-a2-emi.rpy:7397
translate pt_br a2_emi_dropping_by_54aa636c:

    # hi "Oh, that's good."
    hi "Oh, isso é bom."

# game/script-a2-emi.rpy:7399
translate pt_br a2_emi_dropping_by_f80aef76:

    # hi "He really keeps an eye on you, huh?"
    hi "Ele realmente mantém um olho em você, hein?"

# game/script-a2-emi.rpy:7404
translate pt_br a2_emi_dropping_by_18357699:

    # "Emi shrugs."
    "Emi dá de ombros."

# game/script-a2-emi.rpy:7406
translate pt_br a2_emi_dropping_by_7ba4d731:

    # emi "It's his job."
    emi "É o trabalho dele."

# game/script-a2-emi.rpy:7408
translate pt_br a2_emi_dropping_by_696d22ee:

    # emi "Part of being the captain means you know where your team members are when they're not in school."
    emi "Parte de ser um capitão significa você saber onde os membros da sua equipe estão quando eles não estão na escola."

# game/script-a2-emi.rpy:7410
translate pt_br a2_emi_dropping_by_dcfbe713:

    # emi "Still, I guess it was nice of him to call, huh?"
    emi "Ainda assim, eu acho que foi legal da parte dele em ligar, não?"

# game/script-a2-emi.rpy:7412
translate pt_br a2_emi_dropping_by_f017c3ce:

    # hi "Yep. Sure was."
    hi "Sim. Com certeza foi."

# game/script-a2-emi.rpy:7414
translate pt_br a2_emi_dropping_by_7b08d651:

    # "Emi yawns and shimmies down into a more comfortable position."
    "Emi boceja e se retorce para ficar em uma posição mais confortável."

# game/script-a2-emi.rpy:7419
translate pt_br a2_emi_dropping_by_5b5aa4f4:

    # emi "So how was your day?"
    emi "Então, como foi seu dia?"

# game/script-a2-emi.rpy:7421
translate pt_br a2_emi_dropping_by_5887a7ef:

    # hi "Kind of uneventful, you know?"
    hi "Meio monótono, sabe?"

# game/script-a2-emi.rpy:7423
translate pt_br a2_emi_dropping_by_66f235b5:

    # hi "I went ahead and ran by myself, and talked with the nurse about how you were doing…"
    hi " Fui na frente correr por mim mesmo, e falei com o enfermeiro para ver como você estava indo…"

# game/script-a2-emi.rpy:7430
translate pt_br a2_emi_dropping_by_5b83f0ef:

    # "I meander through the day's events, none of which are particularly engrossing."
    "Pensando através dos eventos do dia, nenhum deles foi particulamente cativante."

# game/script-a2-emi.rpy:7432
translate pt_br a2_emi_dropping_by_17329eaa:

    # "That's when I'm distracted by an arm finding its way across my waist."
    "Quando sou distraído por um braço encontrando seu caminho em torno da minha cintura."

# game/script-a2-emi.rpy:7434
translate pt_br a2_emi_dropping_by_cbfd9c53:

    # "It seems that Emi fell asleep while I was talking so I draw her blanket to cover us."
    "Parece que a Emi adormeceu enquanto eu estava falando, então eu pego seu cobertor para nos cobrir."

# game/script-a2-emi.rpy:7441
translate pt_br a2_emi_dropping_by_3d6efdcb:

    # "She's rolled over on to her side, and now one leg is thrown over my legs, effectively trapping me."
    "Ela rolou para o lado dela, e agora uma perna é lançada sobre as minhas pernas, efetivamente me prendendo."

# game/script-a2-emi.rpy:7443
translate pt_br a2_emi_dropping_by_20a67d9a:

    # hi "Hey."
    hi "Ei."

# game/script-a2-emi.rpy:7445
translate pt_br a2_emi_dropping_by_747bc777:

    # "It seems a shame to wake her, but I have things to do."
    "Parece uma pena acordá-la, mas eu tenho coisas para fazer."

# game/script-a2-emi.rpy:7449
translate pt_br a2_emi_dropping_by_de921d83:

    # "I gently shake her, but in response she only tightens her arm's grip on me and sighs a little."
    "Eu a balanço gentilmente, mas em resposta ela só aperta mais forte com suas mãos em mim e suspira um pouco."

# game/script-a2-emi.rpy:7451
translate pt_br a2_emi_dropping_by_425d6471:

    # "My resistance to this position crumbles rather quickly."
    "Minha resistência a esta posição desmorona rapidamente."

# game/script-a2-emi.rpy:7453
translate pt_br a2_emi_dropping_by_3832a633:

    # "The feeling of her body breathing steadily is both calming and incredibly stimulating at the same time."
    "A sensação do seu corpo respirando de forma constante é tranquilizante e incrivelmente estimulante ao mesmo tempo."

# game/script-a2-emi.rpy:7455
translate pt_br a2_emi_dropping_by_a887bfd1:

    # "My breathing cannot decide if it wants to relax or speed up."
    "Minha respiração não pode decidir se quer relaxar ou acelerar."

# game/script-a2-emi.rpy:7457
translate pt_br a2_emi_dropping_by_0d158b40:

    # "Relaxation wins, and I find myself putting an arm around Emi."
    "O relaxamento ganha, e eu me vejo colocando um braço em torno da Emi."

# game/script-a2-emi.rpy:7462
translate pt_br a2_emi_dropping_by_e3c94eb3:

    # hi "I think I'm in love."
    hi "Acho que estou apaixonado."

# game/script-a2-emi.rpy:7464
translate pt_br a2_emi_dropping_by_b7b9e9ee:

    # "The words slip out and hang in the air unnoticed."
    "As palavras escorregam para fora e planam no ar despercebidas."

# game/script-a2-emi.rpy:7466
translate pt_br a2_emi_dropping_by_5fd52044:

    # "At least I hope they've gone unnoticed."
    "Pelo menos eu espero que elas tenham passado despercebidas."

# game/script-a2-emi.rpy:7471
translate pt_br a2_emi_dropping_by_0681d79e:

    # "Emi whimpers weakly through her dream, and her grip suddenly tightens again."
    "Emi choraminga fracamente através do seu sonho, e sua mão de repente aperta novamente."

# game/script-a2-emi.rpy:7473
translate pt_br a2_emi_dropping_by_0d0b2460:

    # "For the first time since I've known her, I see tears running down Emi's face."
    "Pela primeira vez desde que eu a conheço, vejo lágrimas escorrendo pelo rosto da Emi."

# game/script-a2-emi.rpy:7475
translate pt_br a2_emi_dropping_by_93dd11d0:

    # "It feels like my heart is about to break."
    "Eu sinto que meu coração está prestes a quebrar."

# game/script-a2-emi.rpy:7477
translate pt_br a2_emi_dropping_by_17bdcb30:

    # "I instinctively tighten my own grip and stroke her hair in what I hope is a soothing manner."
    "Eu instintivamente estico meu braço e acaricio seus cabelos em o que espero ser uma forma suave."

# game/script-a2-emi.rpy:7479
translate pt_br a2_emi_dropping_by_1b01371e:

    # "Words of comfort, meaningless in this situation, spring to mind."
    "Palavras de conforto, sem sentido nessa situação, vêm à mente."

# game/script-a2-emi.rpy:7481
translate pt_br a2_emi_dropping_by_0e158b35:

    # "Maybe I should wake her. Are you supposed to wake people having nightmares?"
    "Talvez eu devesse acordá-la. Você deveria acordar pessoas tendo pesadelos?"

# game/script-a2-emi.rpy:7483
translate pt_br a2_emi_dropping_by_7f74854a:

    # "I can't for the life of me remember."
    "Pela minha própria vida, eu juro que não me lembro."

# game/script-a2-emi.rpy:7485
translate pt_br a2_emi_dropping_by_e9883e49:

    # "The decision is taken from me as Emi suddenly jerks awake with a cry."
    "A decisão foge de mim assim que de repente a Emi acorda bruscamente com um grito."

# game/script-a2-emi.rpy:7490
translate pt_br a2_emi_dropping_by_21a67a0f:

    # emi "Dad!"
    emi "Pai!"

# game/script-a2-emi.rpy:7492
translate pt_br a2_emi_dropping_by_c218ccde:

    # "This is… more than I think I want to hear without her knowing. I quickly sit upright and gently shake her shoulder to stir her."
    "Isso é… mais do que eu acho querer ouvir sem que ela soubesse. Eu rapidamente sento direito e agito suavemente seus ombros para acordá-la."

# game/script-a2-emi.rpy:7497
translate pt_br a2_emi_dropping_by_4b3de8b2:

    # hi "Hey, you okay?"
    hi "Ei, você está bem?"

# game/script-a2-emi.rpy:7499
translate pt_br a2_emi_dropping_by_c1a18342:

    # "What a silly question."
    "Que pergunta boba."

# game/script-a2-emi.rpy:7504
translate pt_br a2_emi_dropping_by_20863c68:

    # emi "Huh? What?"
    emi "Hã? O quê?"

# game/script-a2-emi.rpy:7509
translate pt_br a2_emi_dropping_by_a18df911:

    # emi "Hisao?"
    emi "Hisao?"

# game/script-a2-emi.rpy:7511
translate pt_br a2_emi_dropping_by_83625526:

    # "She shakes her head as if to clear it and quickly wipes her eyes."
    "Ela balança a cabeça como se fosse limpá-la e rapidamente enxuga os olhos."

# game/script-a2-emi.rpy:7513
translate pt_br a2_emi_dropping_by_61382e86:

    # hi "You had a nightmare. I think."
    hi "Você teve um pesadelo. Eu acho."

# game/script-a2-emi.rpy:7518
translate pt_br a2_emi_dropping_by_ff04155e:

    # "Emi shudders again and glances up at me a little cautiously, as if unsure whether or not she's actually up."
    "Emi estremece novamente e olha para mim com um pouco de receio, como se não soubesse se realmente estivesse acordada ou não."

# game/script-a2-emi.rpy:7520
translate pt_br a2_emi_dropping_by_4b84c74d:

    # emi "Y-yeah, I guess so."
    emi "S-sim, eu acho que sim."

# game/script-a2-emi.rpy:7522
translate pt_br a2_emi_dropping_by_3f4a33df:

    # hi "You wanna talk about it?"
    hi "Quer falar sobre isso?"

# game/script-a2-emi.rpy:7524
translate pt_br a2_emi_dropping_by_19972527:

    # emi "Hmm?"
    emi "Hmm?"

# game/script-a2-emi.rpy:7526
translate pt_br a2_emi_dropping_by_d9326b4f:

    # "A speedy internal debate seems to be going on in her head, which resolves itself with a shrug."
    "Um rápido debate interno parece ocorrer na sua cabeça, o qual se resolve com um encolher de ombros."

# game/script-a2-emi.rpy:7531
translate pt_br a2_emi_dropping_by_9dedb4a6:

    # emi "Nah, I don't really remember much of it."
    emi "Nah, eu realmente não me lembro muito disso."

# game/script-a2-emi.rpy:7533
translate pt_br a2_emi_dropping_by_ef6f08ad:

    # "I'm pretty sure she's lying to me, but somehow I don't think I should press the issue."
    "Eu tenho certeza que ela está mentindo para mim, mas de alguma forma eu não acho que deva insistir no assunto."

# game/script-a2-emi.rpy:7538
translate pt_br a2_emi_dropping_by_0ce28ae2:

    # "Emi shudders again and turns toward me, looking a little sheepish."
    "Emi estremece novamente e se vira para mim, parecendo um pouco envergonhada."

# game/script-a2-emi.rpy:7540
translate pt_br a2_emi_dropping_by_ec47b8ac:

    # emi "Sorry for falling asleep on you like that."
    emi "Desculpe por adormecer em você assim."

# game/script-a2-emi.rpy:7542
translate pt_br a2_emi_dropping_by_b47e375f:

    # "I keep my voice as soothing as I can."
    "Eu mantenho a minha voz tão suave quanto posso."

# game/script-a2-emi.rpy:7544
translate pt_br a2_emi_dropping_by_69393502:

    # hi "Hey, don't worry about it. You've been ill."
    hi "Ei, não se preocupe com isso. Você tem estado doente."

# game/script-a2-emi.rpy:7546
translate pt_br a2_emi_dropping_by_58e8e0b4:

    # emi "Yeah, I guess that cold medicine's just made me a little drowsy."
    emi "Sim, eu acho que os medicamentos para o meu resfriado me deixaram meio sonolenta."

# game/script-a2-emi.rpy:7548
translate pt_br a2_emi_dropping_by_92de4009:

    # hi "I guess so."
    hi "Eu acho que sim."

# game/script-a2-emi.rpy:7550
translate pt_br a2_emi_dropping_by_d2290dc9:

    # "Emi does not strike me as the sort of person who'd fall asleep at the drop of a hat."
    "Emi não me parece o tipo de pessoa que iria cair no sono em um piscar de olhos."

# game/script-a2-emi.rpy:7552
translate pt_br a2_emi_dropping_by_a8271bf0:

    # "Rin, maybe. But Emi's far too energetic."
    "Rin, talvez. Mas a Emi é muito enérgica."

# game/script-a2-emi.rpy:7557
translate pt_br a2_emi_dropping_by_06f18373:

    # "Emi gives a half-smile at my response, and then just like that she's back to her old self."
    "Emi dá um meio sorriso em resposta, e em seguida volta ao seu antigo eu."

# game/script-a2-emi.rpy:7562
translate pt_br a2_emi_dropping_by_0d805659:

    # emi "Well, prepare yourself for tomorrow morning Hisao!"
    emi "Bem, prepare-se para amanhã de manhã Hisao!"

# game/script-a2-emi.rpy:7567
translate pt_br a2_emi_dropping_by_3829ca07:

    # emi "We'll have to go twice as hard to make up for today!"
    emi "Nós vamos ter que dar duas vezes mais duro para compensar hoje!"

# game/script-a2-emi.rpy:7569
translate pt_br a2_emi_dropping_by_b3d7bc56:

    # hi "But I went running this morning!"
    hi "Mas eu fui correr esta manhã!"

# game/script-a2-emi.rpy:7574
translate pt_br a2_emi_dropping_by_11c4476e:

    # emi "No excuse!"
    emi "Sem desculpas!"

# game/script-a2-emi.rpy:7576
translate pt_br a2_emi_dropping_by_4bf91997:

    # hi "Oh fine, I'll be ready for you!"
    hi "Oh tudo bem, eu vou estar pronto para você!"

# game/script-a2-emi.rpy:7581
translate pt_br a2_emi_dropping_by_aa9844f1:

    # "Emi nods, satisfied."
    "Emi acena com a cabeça, satisfeita."

# game/script-a2-emi.rpy:7583
translate pt_br a2_emi_dropping_by_481d5cf5:

    # emi "Good."
    emi "Bom."

# game/script-a2-emi.rpy:7585
translate pt_br a2_emi_dropping_by_aec6ec4f:

    # "I take this as my cue to exit."
    "Eu tomo isso como minha deixa para sair."

# game/script-a2-emi.rpy:7587
translate pt_br a2_emi_dropping_by_eeee8aa0:

    # hi "Well, I'd better get going. Especially if I want to get enough sleep for tomorrow."
    hi "Bem, é melhor eu ir. Especialmente se eu quiser dormir o suficiente para amanhã."

# game/script-a2-emi.rpy:7592
translate pt_br a2_emi_dropping_by_4d40ead6:

    # "I hop off the bed and head for the door."
    "Eu pulo para fora da cama e me direciono a porta."

# game/script-a2-emi.rpy:7597
translate pt_br a2_emi_dropping_by_a39497ad:

    # emi "Hey, Hisao…"
    emi "Ei, Hisao…"

# game/script-a2-emi.rpy:7599
translate pt_br a2_emi_dropping_by_34d1d59d:

    # hi "Hmm?"
    hi "Hmm?"

# game/script-a2-emi.rpy:7601
translate pt_br a2_emi_dropping_by_00cf1d24:

    # "I pivot neatly on my heel and face Emi."
    "Giro completamente sobre meu calcanhar e me viro para a Emi."

# game/script-a2-emi.rpy:7606
translate pt_br a2_emi_dropping_by_b6fcb4bc:

    # "She opens her mouth to say something, and then in another first, I see her falter slightly."
    "Ela abre a boca para dizer alguma coisa, e em seguida em vez de dizer, eu a vejo hesitar um pouco."

# game/script-a2-emi.rpy:7608
translate pt_br a2_emi_dropping_by_c8ab8658:

    # "She closes her mouth and opens it again."
    "Ela fecha a boca e a abre novamente."

# game/script-a2-emi.rpy:7613
translate pt_br a2_emi_dropping_by_e49af0b9:

    # emi "…Thanks."
    emi "… Obrigada."

# game/script-a2-emi.rpy:7615
translate pt_br a2_emi_dropping_by_fb780ae8:

    # emi "For dropping by, I mean."
    emi "Pela visita, eu quero dizer."

# game/script-a2-emi.rpy:7617
translate pt_br a2_emi_dropping_by_6344dfa0:

    # emi "You're kind of the first visitor I've ever had who wasn't Rin."
    emi "Você é meio que o primeiro visitante que eu já tive que sem ser a Rin."

# game/script-a2-emi.rpy:7619
translate pt_br a2_emi_dropping_by_13b2d47a:

    # "Now that's surprising. I would figure that Emi'd have people dropping by all the time."
    "Isso sim é supreendente. Eu imaginaria que a Emi teria pessoas a visitando o tempo todo."

# game/script-a2-emi.rpy:7621
translate pt_br a2_emi_dropping_by_ede4a31a:

    # "She's certainly popular enough, or so I thought. Always talking to people in the hallways."
    "Ela é certamente popular o suficiente, ou era o que pensava. Sempre conversando com as pessoas nos corredores."

# game/script-a2-emi.rpy:7626
translate pt_br a2_emi_dropping_by_630f8aae:

    # "Emi hesitates again."
    "Emi hesita novamente."

# game/script-a2-emi.rpy:7628
translate pt_br a2_emi_dropping_by_4f57fdca:

    # emi "And thanks for staying around after I… well."
    emi "E obrigado por ficar perto depois que eu… bem."

# game/script-a2-emi.rpy:7633
translate pt_br a2_emi_dropping_by_972601e9:

    # "A look of pain flits across her face."
    "Um olhar de dor passa rapidamente em seu rosto."

# game/script-a2-emi.rpy:7635
translate pt_br a2_emi_dropping_by_a662fcab:

    # emi "You know."
    emi "Você sabe."

# game/script-a2-emi.rpy:7640
translate pt_br a2_emi_dropping_by_ccec68ab:

    # emi "It helped."
    emi "Isso ajudou."

# game/script-a2-emi.rpy:7645
translate pt_br a2_emi_dropping_by_83ed0d12:

    # "She brightens back up and waves cheerily at me."
    "Ela se anima novamente e se despede alegremente de mim."

# game/script-a2-emi.rpy:7647
translate pt_br a2_emi_dropping_by_f7f342fd:

    # emi "See you tomorrow!"
    emi "Até amanhã!"

# game/script-a2-emi.rpy:7649
translate pt_br a2_emi_dropping_by_0dbc8435:

    # hi "Yeah, see you later."
    hi "Sim, vejo você mais tarde."

# game/script-a2-emi.rpy:7651
translate pt_br a2_emi_dropping_by_b215cc7c:

    # "I'm just about to exit the door when something makes me turn around again."
    "Estou prestes a sair pela porta quando algo me faz virar-se de novo."

# game/script-a2-emi.rpy:7653
translate pt_br a2_emi_dropping_by_7312930a:

    # hi "Hey, Emi."
    hi "Ei, Emi."

# game/script-a2-emi.rpy:7658
translate pt_br a2_emi_dropping_by_19972527_1:

    # emi "Hmm?"
    emi "Hmm?"

# game/script-a2-emi.rpy:7660
translate pt_br a2_emi_dropping_by_d37878cf:

    # hi "Anytime you need to talk, let me know, okay?"
    hi "Qualquer hora que você precisar conversar, me avise, tá bem?"

# game/script-a2-emi.rpy:7665
translate pt_br a2_emi_dropping_by_3ef41a6f:

    # "Emi seems taken aback by this offer."
    "Emi parece surpreendida por esta oferta."

# game/script-a2-emi.rpy:7670
translate pt_br a2_emi_dropping_by_be2f29bd:

    # "Her grin gets even wider."
    "Seu sorriso fica ainda maior."

# game/script-a2-emi.rpy:7672
translate pt_br a2_emi_dropping_by_65344442:

    # emi "Sure thing, Hisao."
    emi "Claro que sim, Hisao."

# game/script-a2-emi.rpy:7677
translate pt_br a2_emi_dropping_by_5af7dcf0:

    # emi "See you in the morning!"
    emi "Vejo você pela manhã!"

# game/script-a2-emi.rpy:7682
translate pt_br a2_emi_dropping_by_b9e91565:

    # "I exit Emi's room with my head in a whirl."
    "Eu saio do quarto da Emi com a minha cabeça em um turbilhão."

# game/script-a2-emi.rpy:7684
translate pt_br a2_emi_dropping_by_06455ca0:

    # "Should I have even left?"
    "Eu devia mesmo ter saído?"

# game/script-a2-emi.rpy:7686
translate pt_br a2_emi_dropping_by_3e3dda2b:

    # "Was she really okay?"
    "Ela estava realmente bem?"

# game/script-a2-emi.rpy:7688
translate pt_br a2_emi_dropping_by_f44a8fc1:

    # "I want to turn around and march back down the hallway, open the door and tell her…"
    "Eu quero dar meia volta e marchar de volta pelo corredor, abrir a porta e dizer a ela…"

# game/script-a2-emi.rpy:7692
translate pt_br a2_emi_dropping_by_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:7696
translate pt_br a2_emi_dropping_by_841527aa:

    # n "{vspace=60}Tell her I love her, tell her I think she's beautiful, tell her that I'll be there when she needs me."
    n "{vspace=60}Dizer a ela que eu a amo, dizer a ela que eu a acho linda, dizer a ela que eu vou estar lá quando ela precisar de mim."

# game/script-a2-emi.rpy:7698
translate pt_br a2_emi_dropping_by_7a809be3:

    # n "I want to stay with her, to hold her close as she falls back to sleep."
    n "Eu quero ficar com ela, para abraçá-la enquanto ela cai de volta no sono."

# game/script-a2-emi.rpy:7700
translate pt_br a2_emi_dropping_by_6879110b:

    # n "How many nights has she woken up like that?"
    n "Quantas noites ela tem acordado assim?"

# game/script-a2-emi.rpy:7702
translate pt_br a2_emi_dropping_by_38920d78:

    # n "Only to find that nobody's there."
    n "Apenas para descobrir que ninguém estava lá."

# game/script-a2-emi.rpy:7704
translate pt_br a2_emi_dropping_by_53d16df2:

    # n "I want to be that person she can be with when that happens."
    n "Eu quero ser a pessoa que ela pode estar quando isso acontece."

# game/script-a2-emi.rpy:7706
translate pt_br a2_emi_dropping_by_94309e21:

    # n "It's a silly thought, I know."
    n "É um pensamento bobo, eu sei."

# game/script-a2-emi.rpy:7708
translate pt_br a2_emi_dropping_by_ff796171:

    # n "We don't know each other that well, do we?"
    n "Nós não nos conhecemos tão bem, não é?"

# game/script-a2-emi.rpy:7710
translate pt_br a2_emi_dropping_by_48ca31f9:

    # n "The whole idea, while exhilarating, also makes me feel worry."
    n "A ideia toda, enquanto emocionante, também me faz sentir preocupado."

# game/script-a2-emi.rpy:7712
translate pt_br a2_emi_dropping_by_6b27b717:

    # n "Worry, perhaps, that I'd overstep my bounds."
    n "Preocupado, talvez, que tenha passado meus limites."

# game/script-a2-emi.rpy:7714
translate pt_br a2_emi_dropping_by_491db9bc:

    # n "And now to add to my troubles, it seems as if Emi herself already has an interest in someone else."
    n "E agora para adicionar aos meus problemas, parece que a Emi já esta interessada em outra pessoa."

# game/script-a2-emi.rpy:7716
translate pt_br a2_emi_dropping_by_337ed761:

    # nvl clear
    # n "{vspace=180}This track captain of hers who seems so interested in her well-being."
    nvl clear
    n "{vspace=180}Este capitão dela que parece tão interessado em seu bem-estar."

# game/script-a2-emi.rpy:7720
translate pt_br a2_emi_dropping_by_da79a3c9:

    # n "True, I've only seen the two of them together a few times, but that doesn't change the fact that they seem better suited to one another."
    n "É verdade, eu só vi os dois juntos algumas vezes, mas isso não muda o fato de que eles parecem mais adequados um para o outro."

# game/script-a2-emi.rpy:7722
translate pt_br a2_emi_dropping_by_372e8aa4:

    # n "There's really nothing to be done about that."
    n "Não há realmente nada a ser feito sobre isso."

# game/script-a2-emi.rpy:7724
translate pt_br a2_emi_dropping_by_d7596770:

    # n "I need to take my mind off of this whole situation."
    n "Eu preciso parar de pensar em toda essa situação."

# game/script-a2-emi.rpy:7728
translate pt_br a2_emi_dropping_by_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:7732
translate pt_br a2_emi_dropping_by_ff4cbdea:

    # "I've got homework to do."
    "Eu tenho dever de casa para fazer."

# game/script-a2-emi.rpy:7734
translate pt_br a2_emi_dropping_by_4c9cc1da:

    # "Maybe that will distract me."
    "Talvez isso me distraia."

# game/script-a2-emi.rpy:7752
translate pt_br a2_emi_the_first_morning_after_06c9ea85:

    # "A night of restlessness has left me feeling fairly groggy this morning."
    "Uma noite de inquietação fez eu me sentir bastante grogue esta manhã."

# game/script-a2-emi.rpy:7756
translate pt_br a2_emi_the_first_morning_after_121d5b92:

    # "The events of the previous day keep intruding upon my mind."
    "Os acontecimentos do dia anterior continuam invadindo minha mente."

# game/script-a2-emi.rpy:7758
translate pt_br a2_emi_the_first_morning_after_be702d91:

    # "The memory of how Emi felt against me."
    "A memória de como a Emi se sentia contra mim."

# game/script-a2-emi.rpy:7760
translate pt_br a2_emi_the_first_morning_after_b0bdae75:

    # "The memory of our wrestling match."
    "A memória da nossa luta livre."

# game/script-a2-emi.rpy:7762
translate pt_br a2_emi_the_first_morning_after_f2a466b7:

    # "And most bothersome, the memory of her nightmare."
    "E o mais incômodo, a memória do seu pesadelo."

# game/script-a2-emi.rpy:7764
translate pt_br a2_emi_the_first_morning_after_2996566d:

    # "She was in so much pain."
    "Ela estava com tanta dor."

# game/script-a2-emi.rpy:7766
translate pt_br a2_emi_the_first_morning_after_04db8264:

    # "I can't stop wondering what it must be like for her to wake up with nobody there."
    "Eu não consigo parar de me perguntar como deve ser para ela acordar sem ninguém lá."

# game/script-a2-emi.rpy:7774
translate pt_br a2_emi_the_first_morning_after_657182bf:

    # "The shower shocks me awake with hot water. Awake, but still worried."
    "O chuveiro me desperta com um golpe de água quente. Acordado, mas ainda preocupado."

# game/script-a2-emi.rpy:7781
translate pt_br a2_emi_the_first_morning_after_85c0a972:

    # nvl clear
    # n "{vspace=30}What will happen today?"
    nvl clear
    n "{vspace=30}O que vai acontecer hoje?"

# game/script-a2-emi.rpy:7785
translate pt_br a2_emi_the_first_morning_after_2dd34a53:

    # n "Will things just go back to normal?"
    n "Será que as coisas vão voltar ao normal?"

# game/script-a2-emi.rpy:7787
translate pt_br a2_emi_the_first_morning_after_aec40269:

    # n "End of the episode, back to the status quo?"
    n "Fim do episódio, de volta ao normal?"

# game/script-a2-emi.rpy:7789
translate pt_br a2_emi_the_first_morning_after_98ec3b16:

    # n "There was a connection yesterday. Something that nearly pushed us past the boundaries of normal friendship."
    n "Havia uma conexão ontem. Algo que quase nos empurrou para além dos limites de uma amizade normal."

# game/script-a2-emi.rpy:7791
translate pt_br a2_emi_the_first_morning_after_9b86fe37:

    # n "Would that have been so bad?"
    n "Teria sido assim tão ruim?"

# game/script-a2-emi.rpy:7793
translate pt_br a2_emi_the_first_morning_after_5dd6681b:

    # n "My mind goes back to the look in Emi's eyes after our pillowfight. It almost seemed like she was daring me to go on."
    n "Minha mente volta para quando olhei nos olhos da Emi depois da nossa luta de travesseiros. Era quase como se ele estivesse me desafiando a ir em frente."

# game/script-a2-emi.rpy:7795
translate pt_br a2_emi_the_first_morning_after_c5c9d4a5:

    # n "Almost."
    n "Quase."

# game/script-a2-emi.rpy:7797
translate pt_br a2_emi_the_first_morning_after_51372aa3:

    # n "But I can't know for sure."
    n "Mas eu não posso saber com certeza."

# game/script-a2-emi.rpy:7799
translate pt_br a2_emi_the_first_morning_after_d833d4ec:

    # n "Anyway, the track captain's probably first in her affections."
    n "De qualquer forma, o capitão da equipe é provavelmente o primeiro em sua afeição."

# game/script-a2-emi.rpy:7801
translate pt_br a2_emi_the_first_morning_after_d0ea5122:

    # n "But even as I say that, my mind is already snorting derisively. I'm just looking for an excuse. A reason for everything to go wrong."
    n "Mas mesmo quando eu digo isso, minha mente já está bufando desdenhosamente. Eu estou apenas procurando uma desculpa. Um motivo para tudo dar errado."

# game/script-a2-emi.rpy:7803
translate pt_br a2_emi_the_first_morning_after_8033b3d4:

    # n "A reason to not try."
    n "Um motivo para não tentar."

# game/script-a2-emi.rpy:7805
translate pt_br a2_emi_the_first_morning_after_76debfb8:

    # nvl clear
    # n "{vspace=120}It's not as if I've even seen the two of them together outside of track practice."
    nvl clear
    n "{vspace=120}Não é como se eu mesmo tenha visto os dois juntos fora da pista de treino."

# game/script-a2-emi.rpy:7809
translate pt_br a2_emi_the_first_morning_after_188e73c1:

    # n "And clearly he's never visited. Emi said as much herself. If they were close, surely he'd visit."
    n "E claramente ele nunca a visitou. Emi disse isso ela mesma. Se eles fossem proximos, certamente ele iria visitá-la."

# game/script-a2-emi.rpy:7811
translate pt_br a2_emi_the_first_morning_after_31d6c62c:

    # n "I'm such a wuss."
    n "Eu sou tão covarde."

# game/script-a2-emi.rpy:7813
translate pt_br a2_emi_the_first_morning_after_7fadfb5b:

    # n "I ought to just go for it anyway, damn the consequences."
    n "Eu deveria só fazer isso de uma vez, danem-se as consequências."

# game/script-a2-emi.rpy:7815
translate pt_br a2_emi_the_first_morning_after_1c6315db:

    # n "That's what Emi would do, I think. Hell, I {b}know{/b} that's what she'd do."
    n "Isso é o que a Emi faria, eu acho. Que diabos, eu {b}sei{/b} que isso é o que ela faria."

# game/script-a2-emi.rpy:7817
translate pt_br a2_emi_the_first_morning_after_09179b1a:

    # n "Which is partially why I'm convinced there's no interest on her end. She hasn't acted either."
    n "É por isso que estou parcialmente convecido que não há interesse por parte dela. Ela sequer agiu."

# game/script-a2-emi.rpy:7819
translate pt_br a2_emi_the_first_morning_after_db627a2e:

    # n "Maybe because of this track captain. It's possible she's got a bit of an unrequited crush thing going on."
    n "Talvez por causa do capitão da equipe. É possivel que ela tenha uma pequena paixão não-correspondida."

# game/script-a2-emi.rpy:7821
translate pt_br a2_emi_the_first_morning_after_ad5d1819:

    # nvl clear
    # n "{vspace=180}But who would be able to clarify their relationship?"
    nvl clear
    n "{vspace=180}Mas quem seria capaz de esclarecer o relacionamento deles?"

# game/script-a2-emi.rpy:7825
translate pt_br a2_emi_the_first_morning_after_a49cbcba:

    # n "It sure as hell can't be Emi. She'd probably just laugh and ask why I wanted to know… and I'm not ready to answer that yet."
    n "É certo que pode ser a Emi. Ela provavelmente só iria rir e perguntar porquê eu queria saber… e não estou pronto para responder isso ainda."

# game/script-a2-emi.rpy:7827
translate pt_br a2_emi_the_first_morning_after_baf5f781:

    # n "Rin… Rin would probably just give me some cryptic answer or something. And then with my luck, she'd just ask Emi, who would ask me why I wanted to know, and I've already covered that problem."
    n "Rin… Rin iria provavelmente só me dar uma resposta enigmática ou algo assim. E então com a minha sorte, ela perguntaria à Emi, que iria perguntar a mim o porquê de eu querer saber, e eu já cobri esse problema."

# game/script-a2-emi.rpy:7829
translate pt_br a2_emi_the_first_morning_after_e1ae3ba5:

    # n "I wonder…"
    n "Eu me pergunto…"

# game/script-a2-emi.rpy:7831
translate pt_br a2_emi_the_first_morning_after_d94c114c:

    # nvl clear
    # n "{vspace=150}Could I get away with asking the nurse? He seems pretty protective of Emi. I'm sure he'd know if something was up…"
    nvl clear
    n "{vspace=150}Eu poderia arranjar uma forma de perguntar ao enfermeiro? Ele parece cuidar bastante da Emi. Tenho certeza que ele saberia se algo estivesse acontecendo."

# game/script-a2-emi.rpy:7835
translate pt_br a2_emi_the_first_morning_after_481a6a27:

    # n "And he owes me for not letting Emi know he forgot to tell me about her being ill, so he'll keep quiet."
    n "E ele me deve por não ter deixado a Emi saber que ele esqueceu de me contar sobre ela estar doente, então ele vai ficar quieto."

# game/script-a2-emi.rpy:7837
translate pt_br a2_emi_the_first_morning_after_d5ce5d8f:

    # n "What if he asks me why I want to know, though?"
    n "Mesmo assim, e se ele me perguntar porquê eu quero saber?"

# game/script-a2-emi.rpy:7839
translate pt_br a2_emi_the_first_morning_after_32591f86:

    # n "I can shake him off. Just say I'm curious as a friend. He'll buy that, won't he?"
    n "Eu posso enrolá-lo. Basta dizer que eu sou curioso como amigo. Ele vai acreditar nisso, não é?"

# game/script-a2-emi.rpy:7841
translate pt_br a2_emi_the_first_morning_after_a685f116:

    # n "Of course!"
    n "Claro!"

# game/script-a2-emi.rpy:7843
translate pt_br a2_emi_the_first_morning_after_9f1bffba:

    # n "That's settled, then."
    n "Está resolvido, então."

# game/script-a2-emi.rpy:7845
translate pt_br a2_emi_the_first_morning_after_7098156e:

    # n "After the run, I'll talk to him while Emi's waiting outside the office."
    n "Após a corrida, eu vou falar com ele enquanto a Emi espera fora do consultório."

# game/script-a2-emi.rpy:7849
translate pt_br a2_emi_the_first_morning_after_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:7858
translate pt_br a2_emi_the_first_morning_after_4d486ea3:

    # n "{vspace=120}There's no sign of Emi when I arrive at the track. Is she still too ill?"
    n "{vspace=120}Não há nenhum sinal da Emi quando eu chego na pista. Ela ainda está muito doente?"

# game/script-a2-emi.rpy:7860
translate pt_br a2_emi_the_first_morning_after_959e5ffe:

    # n "I decide to give her ten minutes."
    n "Eu decido dar-lhe dez minutos."

# game/script-a2-emi.rpy:7862
translate pt_br a2_emi_the_first_morning_after_7e6afbd6:

    # n "I'm a little early, and she was ill yesterday, so if she takes a while to show up it shouldn't be surprising."
    n "Eu estou um pouco adiantado, e ela estava doente ontem, por isso, se ela levar um tempo para aparecer, não deve ser surpreendente."

# game/script-a2-emi.rpy:7864
translate pt_br a2_emi_the_first_morning_after_ab68624b:

    # n "Still, I'd hate to just waste my time, so I occupy myself by stretching and pacing back and forth anxiously."
    n "Ainda assim, eu odiaria apenas perder meu tempo, então eu me ocupo me alongando e andando para trás e para a frente, ansioso."

# game/script-a2-emi.rpy:7866
translate pt_br a2_emi_the_first_morning_after_bfcb5e98:

    # n "What if I went too far yesterday?"
    n "E se eu fui longe demais ontem?"

# game/script-a2-emi.rpy:7868
translate pt_br a2_emi_the_first_morning_after_b25ea60b:

    # n "What if she doesn't come because she's embarrassed?"
    n "E se ela não vem porque ela está envergonhada?"

# game/script-a2-emi.rpy:7870
translate pt_br a2_emi_the_first_morning_after_fab85d57:

    # n "What if…"
    n "E se…"

# game/script-a2-emi.rpy:7875
translate pt_br a2_emi_the_first_morning_after_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:7884
translate pt_br a2_emi_the_first_morning_after_3fb6275e:

    # emi "You're early again, Hisao!"
    emi "Você chegou cedo novamente, Hisao!"

# game/script-a2-emi.rpy:7889
translate pt_br a2_emi_the_first_morning_after_3e7ff356:

    # emi "I'm impressed!"
    emi "Estou impressionada!"

# game/script-a2-emi.rpy:7891
translate pt_br a2_emi_the_first_morning_after_41d98294:

    # "Just like that, I feel some of the tension leaving my body."
    "Só assim, sinto um pouco da tensão deixando meu corpo."

# game/script-a2-emi.rpy:7893
translate pt_br a2_emi_the_first_morning_after_c5d25ae0:

    # "Emi seems to be bright and cheerful as usual, with no sign that she even was ill the other day, much less had a less-than-restful sleep."
    "Emi parece estar animada e alegre como de costume, sem nenhum sinal de que ela estava doente no outro dia, muito menos que teve um sono nada repousante."

# game/script-a2-emi.rpy:7895
translate pt_br a2_emi_the_first_morning_after_1b46bbbc:

    # "Still, I have to ask."
    "Ainda assim, eu tenho que perguntar."

# game/script-a2-emi.rpy:7897
translate pt_br a2_emi_the_first_morning_after_7a9d21da:

    # hi "Sleep well last night?"
    hi "Dormiu bem na noite passada?"

# game/script-a2-emi.rpy:7901
translate pt_br a2_emi_the_first_morning_after_4b5ca971:

    # "It's just a throwaway question. Small talk."
    "É apenas uma pergunta descartável. Conversa fiada."

# game/script-a2-emi.rpy:7903
translate pt_br a2_emi_the_first_morning_after_86ab043d:

    # "The sort of thing people ask someone they bump into in the café while getting their morning coffee."
    "O tipo de coisa que as pessoas perguntam a alguém que topam na refeitório enquanto tomam seu café da manhã."

# game/script-a2-emi.rpy:7905
translate pt_br a2_emi_the_first_morning_after_b0eb03c2:

    # "But not for us. At least, not for me."
    "Mas não para nós. Pelo menos, não para mim."

# game/script-a2-emi.rpy:7907
translate pt_br a2_emi_the_first_morning_after_b230b862:

    # "I don't know if Emi realizes that I'm actually concerned about how well she slept last night, but the question does give her pause."
    "Eu não sei se a Emi percebeu que estou realmente preocupado com o quão bem ela dormiu na noite passada, mas a questão não lhe dá tempo."

# game/script-a2-emi.rpy:7912
translate pt_br a2_emi_the_first_morning_after_8674f693:

    # "After a short moment of what seems like her genuinely pondering this, she nods."
    "Depois de um breve momento no qual ela parece estar genuinamente pensando nisso, ela balança a cabeça."

# game/script-a2-emi.rpy:7917
translate pt_br a2_emi_the_first_morning_after_a51bbd10:

    # emi "Yep! Sure did!"
    emi "Sim! Eu tive!"

# game/script-a2-emi.rpy:7919
translate pt_br a2_emi_the_first_morning_after_69e77971:

    # "Was it because of me?"
    "Foi por minha causa?"

# game/script-a2-emi.rpy:7921
translate pt_br a2_emi_the_first_morning_after_2928f9d3:

    # "Did I actually help?"
    "Eu realmente ajudei?"

# game/script-a2-emi.rpy:7923
translate pt_br a2_emi_the_first_morning_after_0371afc3:

    # "Or are you just saying that to get me to stop asking questions?"
    "Ou você está apenas dizendo isso para me fazer parar de fazer perguntas?"

# game/script-a2-emi.rpy:7925
translate pt_br a2_emi_the_first_morning_after_a9e9c2b9:

    # hi "Good to hear."
    hi "É bom ouvir isso."

# game/script-a2-emi.rpy:7930
translate pt_br a2_emi_the_first_morning_after_14483e75:

    # "Emi grins and begins warming up."
    "Emi sorri e começa a aquecer."

# game/script-a2-emi.rpy:7935
translate pt_br a2_emi_the_first_morning_after_6bb65f85:

    # emi "So, ready to begin?"
    emi "Então, pronto para começar?"

# game/script-a2-emi.rpy:7937
translate pt_br a2_emi_the_first_morning_after_3c0303f3:

    # hi "Pfft, am I ready? Of course I'm ready! I was born ready!"
    hi "Pfft, estou pronto? É claro que eu estou pronto! Eu nasci pronto!"

# game/script-a2-emi.rpy:7942
translate pt_br a2_emi_the_first_morning_after_7e92ac70:

    # "Emi laughs at my bravado, and we take off running."
    "Emi ri ao me gabar, e começamos a correr."

# game/script-a2-emi.rpy:7947
translate pt_br a2_emi_the_first_morning_after_7802c46e:

    # "I keep a steady pace the whole time, breathing steadily."
    "Eu mantenho um ritmo estável o tempo todo, respirando de forma constante."

# game/script-a2-emi.rpy:7952
translate pt_br a2_emi_the_first_morning_after_95b7b89f:

    # "I still feel dead at the end, but at least I don't gasp like a fish out of water now."
    "Eu ainda me sinto morto no final, mas pelo menos eu não ofego como um peixe fora d'água agora."

# game/script-a2-emi.rpy:7962
translate pt_br a2_emi_the_first_morning_after_994a54dd:

    # "Emi is positively beaming after the run today."
    "Emi está positivamente radiante após a corrida de hoje."

# game/script-a2-emi.rpy:7964
translate pt_br a2_emi_the_first_morning_after_ea7cbf15:

    # emi "Nice job, Hisao! You're improving!"
    emi "Bom trabalho, Hisao! Você está melhorando!"

# game/script-a2-emi.rpy:7969
translate pt_br a2_emi_the_first_morning_after_14870a8d:

    # emi "You'll be half as fast as me in no time!"
    emi "Você terá metade da minha velocidade em pouco tempo!"

# game/script-a2-emi.rpy:7971
translate pt_br a2_emi_the_first_morning_after_ac9d510e:

    # "This last line is delivered with a teasing grin that I've grown all too used to."
    "Esta última linha é dita com um sorriso provocante que eu me acostumei a usar também."

# game/script-a2-emi.rpy:7973
translate pt_br a2_emi_the_first_morning_after_07d40820:

    # hi "Oh, how exciting."
    hi "Oh, que emocionante."

# game/script-a2-emi.rpy:7984
translate pt_br a2_emi_the_first_morning_after_562d3bc4:

    # "Emi begins to run her sprints while I take a cool-down lap."
    "Emi começa a correr suas sprints enquanto eu faço uma volta para resfrescar."

# game/script-a2-emi.rpy:7986
translate pt_br a2_emi_the_first_morning_after_6d032046:

    # "She's really pushing herself today."
    "Ela está realmente se esforçando hoje."

# game/script-a2-emi.rpy:7995
translate pt_br a2_emi_the_first_morning_after_44c0b47e:

    # "By the time I'm done with my lap, she's laying across one of the bleachers, looking exhausted."
    "No momento em que eu termino minha volta, ela está deitada em frente a uma das arquibancadas, parecendo exausta."

# game/script-a2-emi.rpy:7997
translate pt_br a2_emi_the_first_morning_after_7ffd0a2f:

    # hi "Goodness, not pushing it a little too much today, are you?"
    hi "Puxa, não esta exigindo demais hoje, certo?"

# game/script-a2-emi.rpy:7999
translate pt_br a2_emi_the_first_morning_after_8402747c:

    # hi "You did just have a cold, you'll recall."
    hi "Você recém teve um resfriado, deve se lembrar."

# game/script-a2-emi.rpy:8004
translate pt_br a2_emi_the_first_morning_after_17742603:

    # "Emi gives an annoyed snort and sits up."
    "Emi dá uma bufada irritada e se senta."

# game/script-a2-emi.rpy:8006
translate pt_br a2_emi_the_first_morning_after_6c60b568:

    # emi "Bah! I'm just trying to make up for lost time, that's all."
    emi "Bah! Eu estou tentando compensar o tempo perdido, só isso."

# game/script-a2-emi.rpy:8011
translate pt_br a2_emi_the_first_morning_after_22333fd8:

    # emi "I went twice as hard today, you know."
    emi "Eu me esforcei o dobro hoje, você sabe."

# game/script-a2-emi.rpy:8016
translate pt_br a2_emi_the_first_morning_after_b55284e6:

    # emi "A good run always gets the kinks out, you know."
    emi "Uma boa corrida sempre ajuda com os desconfortos, sabe."

# game/script-a2-emi.rpy:8021
translate pt_br a2_emi_the_first_morning_after_9d76e97a:

    # emi "Clears the mind, too."
    emi "Limpa a mente, também."

# game/script-a2-emi.rpy:8023
translate pt_br a2_emi_the_first_morning_after_f9075882:

    # hi "Oh?"
    hi "Oh?"

# game/script-a2-emi.rpy:8028
translate pt_br a2_emi_the_first_morning_after_6ec5217f:

    # "Emi nods vigorously."
    "Emi acena com a cabeça vigorosamente."

# game/script-a2-emi.rpy:8033
translate pt_br a2_emi_the_first_morning_after_86af1619:

    # emi "Yep! It's a great outlet for that sort of thing."
    emi "Sim! É uma ótima saída para esse tipo de coisa."

# game/script-a2-emi.rpy:8035
translate pt_br a2_emi_the_first_morning_after_99cccf62:

    # "She does not explain further, and I don't ask."
    "Ela não explica mais adiante, e eu não pergunto."

# game/script-a2-emi.rpy:8037
translate pt_br a2_emi_the_first_morning_after_4897b1d8:

    # "I suspect I know the real reason she went so hard today."
    "Eu suspeito que sei a verdadeira razão dela ter se esforçado tanto hoje."

# game/script-a2-emi.rpy:8039
translate pt_br a2_emi_the_first_morning_after_b14126fa:

    # "Being sick had nothing to do with it. Something's bothering her."
    "Estar doente não tem nada a ver com isso. Alguma coisa está a incomodando."

# game/script-a2-emi.rpy:8041
translate pt_br a2_emi_the_first_morning_after_a5bfef6f:

    # "Maybe the nightmare. Maybe something else."
    "Talvez o pesadelo. Talvez algo mais."

# game/script-a2-emi.rpy:8043
translate pt_br a2_emi_the_first_morning_after_c973726d:

    # "But it's not my place to pry."
    "Mas não é meu dever bisbilhotar."

# game/script-a2-emi.rpy:8045
translate pt_br a2_emi_the_first_morning_after_fef62c52:

    # "She'd tell me if she wanted me to know."
    "Ela iria me dizer se quisesse que eu soubesse."

# game/script-a2-emi.rpy:8047
translate pt_br a2_emi_the_first_morning_after_603631d7:

    # hi "I'm sure that comes in handy."
    hi "Tenho certeza de que isso virá a calhar."

# game/script-a2-emi.rpy:8052
translate pt_br a2_emi_the_first_morning_after_456da2cc:

    # emi "You have no idea."
    emi "Você não tem ideia."

# game/script-a2-emi.rpy:8054
translate pt_br a2_emi_the_first_morning_after_c9caf9ff:

    # "The sincerity in her voice confirms my suspicion."
    "A sinceridade em sua voz confirma minha suspeita."

# game/script-a2-emi.rpy:8056
translate pt_br a2_emi_the_first_morning_after_4314f904:

    # "The only problem is…"
    "O único problema é…"

# game/script-a2-emi.rpy:8058
translate pt_br a2_emi_the_first_morning_after_df3d253f:

    # "Even though I know she'd tell me if she wanted me to know, I still want to know."
    "Mesmo que eu saiba que ela me contaria se quisesse, eu ainda quero saber."

# game/script-a2-emi.rpy:8060
translate pt_br a2_emi_the_first_morning_after_5288d787:

    # hi "Something on your mind, then?"
    hi "Então, alguma coisa em sua mente?"

# game/script-a2-emi.rpy:8062
translate pt_br a2_emi_the_first_morning_after_822d4258:

    # "Emi doesn't seem surprised by my question."
    "Emi não pareceu surpresa com minha pergunta."

# game/script-a2-emi.rpy:8067
translate pt_br a2_emi_the_first_morning_after_5a5581e5:

    # "Instead, she shrugs."
    "Em vez disso, ela dá de ombros."

# game/script-a2-emi.rpy:8072
translate pt_br a2_emi_the_first_morning_after_afc5700f:

    # emi "Nah, it's nothing worth getting worried about."
    emi "Nah, não é nada que valha a pena ficar preocupado."

# game/script-a2-emi.rpy:8074
translate pt_br a2_emi_the_first_morning_after_20db812c:

    # "She seems as if she's trying to convince herself as much as she's convincing me."
    "Ela parece estar tentando convencer a sí mesma mais do que a mim."

# game/script-a2-emi.rpy:8076
translate pt_br a2_emi_the_first_morning_after_6775c31f:

    # "I open my mouth to ask if yesterday is responsible for her current state of mind, but think better of it."
    "Eu abro minha boca para perguntar se ontem foi o responsável pelo seu estado atual de espírto, mas pensando melhor."

# game/script-a2-emi.rpy:8078
translate pt_br a2_emi_the_first_morning_after_73e9cd77:

    # "Too much risk of her taking the question the wrong way."
    "Há um grande risco dela levar essa pergunta para o lado errado."

# game/script-a2-emi.rpy:8080
translate pt_br a2_emi_the_first_morning_after_673197a9:

    # "Besides, I'm not even sure myself what to think about yesterday."
    "Além disso, eu mesmo não tenho certeza do que pensar sobre ontem."

# game/script-a2-emi.rpy:8082
translate pt_br a2_emi_the_first_morning_after_0f0d6003:

    # "Really I can only get about as far as how it felt to have Emi sleeping next to me before my brain shuts down."
    "Na verdade eu só posso chegar até como me senti ao ter a Emi dormindo perto de mim antes do meu cérebro desligar."

# game/script-a2-emi.rpy:8084
translate pt_br a2_emi_the_first_morning_after_7e066615:

    # "Having her before me now, covered in sweat and looking wryly at me, she's making it difficult to think."
    "Tê-la diante de mim agora, coberta de suor e olhando ironicamente para mim, ela está fazendo ficar difícil pensar."

# game/script-a2-emi.rpy:8086
translate pt_br a2_emi_the_first_morning_after_2a5381ea:

    # hi "Yeah, I hear you."
    hi "Sim, eu entendo."

# game/script-a2-emi.rpy:8091
translate pt_br a2_emi_the_first_morning_after_83cf391c:

    # emi "We'd better hurry to see the nurse. We're running short on time."
    emi "Melhor nos apressarmos para ver o enfermeiro. Estamos com pouco tempo."

# game/script-a2-emi.rpy:8093
translate pt_br a2_emi_the_first_morning_after_27d97058:

    # hi "Aren't we always?"
    hi "Não estamos sempre?"

# game/script-a2-emi.rpy:8098
translate pt_br a2_emi_the_first_morning_after_7e0e22f5:

    # "Emi laughs at this, a dry chuckle that seems most un-Emi-like."
    
    "Emi ri disso, uma risada seca que parece muito imprópria dela."

# game/script-a2-emi.rpy:8103
translate pt_br a2_emi_the_first_morning_after_392c39aa:

    # emi "Too true."
    
    emi "É verdade também."

# game/script-a2-emi.rpy:8105
translate pt_br a2_emi_the_first_morning_after_c0fe8064:

    # "For a brief moment, she looks old, worn down by some old hurt."
    "Por um breve momento, ela parece velha, desgastada por alguma velha mágoa."

# game/script-a2-emi.rpy:8107
translate pt_br a2_emi_the_first_morning_after_cce4c4c8:

    # "But just like yesterday I can almost see her shouldering the burden and straightening up slightly."
    "Mas assim como ontem eu quase posso vê-la assumindo o fardo e endireitando-se ligeiramente."

# game/script-a2-emi.rpy:8109
translate pt_br a2_emi_the_first_morning_after_13a1fed1:

    # "And then she's back to being Emi again."
    "E então ela volta a ser a Emi novamente."

# game/script-a2-emi.rpy:8114
translate pt_br a2_emi_the_first_morning_after_703d23af:

    # emi "Come on then Hisao. Race ya!"
    emi "Vamos Hisao. Uma corrida!"

# game/script-a2-emi.rpy:8125
translate pt_br a2_emi_the_first_morning_after_c54a1fcb:

    # "With a sudden smile, she darts off."
    "Com um sorriso repentino, ela se lança."

# game/script-a2-emi.rpy:8127
translate pt_br a2_emi_the_first_morning_after_208ff265:

    # hi "Hey! No fair!"
    hi "Ei! Não é justo!"

# game/script-a2-emi.rpy:8129
translate pt_br a2_emi_the_first_morning_after_6308e785:

    # "I take off after her, knowing I won't catch her but not caring."
    "Eu me vou atrás dela, sabendo que eu não irei alcança-la, mas sem me importar."

# game/script-a2-emi.rpy:8131
translate pt_br a2_emi_the_first_morning_after_8482ac2f:

    # "Even if there's no chance of catching her, I'll still run after her."
    "Mesmo que não exista chance de alcançá-la, ainda vou correr atrás dela."

# game/script-a2-emi.rpy:8139
translate pt_br a2_emi_the_first_morning_after_b3dffac6:

    # "Emi's waiting for me at the door as I arrive."
    "Emi estava me esperando na porta quando eu cheguei."

# game/script-a2-emi.rpy:8144
translate pt_br a2_emi_the_first_morning_after_d258c77e:

    # emi "Well well, look who's finally shown up!"
    emi "Ora ora, olha quem finalmente apareceu!"

# game/script-a2-emi.rpy:8146
translate pt_br a2_emi_the_first_morning_after_a22c5637:

    # hi "Yeah, yeah."
    hi "Sim, sim."

# game/script-a2-emi.rpy:8148
translate pt_br a2_emi_the_first_morning_after_9d575024:

    # hi "Enjoy your victory while you can."
    hi "Aproveite a sua vitória, enquanto pode."

# game/script-a2-emi.rpy:8153
translate pt_br a2_emi_the_first_morning_after_d980a954:

    # "Emi grins as the nurse pokes his head out of the door."
    "Emi sorri enquanto o enfermeiro põe a cabeça para fora da porta."

# game/script-a2-emi.rpy:8163
translate pt_br a2_emi_the_first_morning_after_6fdaaec6:

    # nk "Well, there you are."
    nk "Bem, aí está você."

# game/script-a2-emi.rpy:8165
translate pt_br a2_emi_the_first_morning_after_15a6b644:

    # nk "Come on in, Hisao."
    nk "Venha, Hisao."

# game/script-a2-emi.rpy:8173
translate pt_br a2_emi_the_first_morning_after_f536660a:

    # "In what has become a familiar routine by now, he checks my blood pressure and my heart rate."
    "No que se tornou uma rotina familiar agora, ele verifica a minha pressão arterial e o meu rítmo cardíaco."

# game/script-a2-emi.rpy:8178
translate pt_br a2_emi_the_first_morning_after_36dc2ca4:

    # nk "A bit fast today, isn't it?"
    nk "Um pouco rápido hoje, não é?"

# game/script-a2-emi.rpy:8180
translate pt_br a2_emi_the_first_morning_after_3f888388:

    # hi "Yeah, I kind of raced Emi here."
    hi "Sim, tive uma espécie de corrida com a Emi até aqui."

# game/script-a2-emi.rpy:8185
translate pt_br a2_emi_the_first_morning_after_1a26db20:

    # "The nurse laughs."
    "O enfermeiro ri."

# game/script-a2-emi.rpy:8187
translate pt_br a2_emi_the_first_morning_after_2ae6a59f:

    # nk "That's never a good idea!"
    nk "Isso nunca é uma boa idéia!"

# game/script-a2-emi.rpy:8192
translate pt_br a2_emi_the_first_morning_after_3f35ef74:

    # "He leans in to whisper to me in a conspiratory manner."
    "Ele se inclina para sussurrar para mim de uma maneira conspiratória."

# game/script-a2-emi.rpy:8197
translate pt_br a2_emi_the_first_morning_after_e05c2104:

    # nk "I don't know if you've heard… but Emi's a bit of a track star."
    nk "Eu não sei se você já ouviu… mas a Emi é meio que uma estrela da pista."

# game/script-a2-emi.rpy:8202
translate pt_br a2_emi_the_first_morning_after_ca9e7dff:

    # "I reel back in mock surprise."
    "Eu vou para trás, fingindo surpresa."

# game/script-a2-emi.rpy:8204
translate pt_br a2_emi_the_first_morning_after_934c4941:

    # hi "Really? She never mentioned it before!"
    hi "Mesmo? Ela nunca mencionou isso antes!"

# game/script-a2-emi.rpy:8209
translate pt_br a2_emi_the_first_morning_after_075c1eec:

    # "The two of us share a laugh."
    "Nós dois compartilhamos uma risada."

# game/script-a2-emi.rpy:8214
translate pt_br a2_emi_the_first_morning_after_e8791c08:

    # nk "Did she do okay today?"
    nk "Ela fez tudo certo hoje?"

# game/script-a2-emi.rpy:8216
translate pt_br a2_emi_the_first_morning_after_5b90672e:

    # nk "Cold seemed to bother her?"
    nk "O frio parecia incomodá-la?"

# game/script-a2-emi.rpy:8218
translate pt_br a2_emi_the_first_morning_after_3196a269:

    # hi "Why don't you ask her?"
    hi "Por que você não pergunta a ela?"

# game/script-a2-emi.rpy:8223
translate pt_br a2_emi_the_first_morning_after_f3efb64d:

    # "He rolls his eyes in exasperation."
    "Ele revira os olhos em gesto de incômodo."

# game/script-a2-emi.rpy:8225
translate pt_br a2_emi_the_first_morning_after_e93df9df:

    # nk "Of course I'm going to ask her too, but she'll tell me that she didn't have any problems, regardless of whether or not she did."
    nk "É claro que eu vou perguntar a ela também, mas ela vai me dizer que ela não tem nenhum problema, independentemente de haver ou não."

# game/script-a2-emi.rpy:8230
translate pt_br a2_emi_the_first_morning_after_ac02ab17:

    # nk "So I'm asking you, because you're her friend and would probably tell me if she had trouble today."
    nk "Então estou perguntando a você, porque você é amigo dela e provavelmente iria me dizer se ela teve problemas."

# game/script-a2-emi.rpy:8232
translate pt_br a2_emi_the_first_morning_after_994d96b3:

    # "When he puts it that way, it makes a lot more sense."
    "Quando ele coloca isso dessa forma, faz muito mais sentido."

# game/script-a2-emi.rpy:8234
translate pt_br a2_emi_the_first_morning_after_db558086:

    # hi "She seemed pretty good today, if a little more tired than usual."
    hi "Ela parecia muito bem hoje, só um pouco mais cansada do que de costume."

# game/script-a2-emi.rpy:8236
translate pt_br a2_emi_the_first_morning_after_5335c353:

    # hi "She was already feeling better when I dropped by yesterday, so I'm not that surprised."
    hi "Ela já estava se sentindo melhor quando eu fui visitá-la ontem, então eu não estou tão surpreso."

# game/script-a2-emi.rpy:8241
translate pt_br a2_emi_the_first_morning_after_df15a765:

    # "The nurse nods, though I notice he tenses slightly when I mention yesterday's visit."
    "O enfermeiro acena com a cabeça, embora eu perceba que ele fica ligeiramente tenso quando menciono a visita de ontem."

# game/script-a2-emi.rpy:8243
translate pt_br a2_emi_the_first_morning_after_3fcd7ee8:

    # nk "Well, that's good to hear."
    nk "Bem, é bom ouvir isso."

# game/script-a2-emi.rpy:8245
translate pt_br a2_emi_the_first_morning_after_1581f3ce:

    # nk "I figured it was just a 24-hour thing. Emi tends to recover quickly from colds and the like."
    nk "Achei que era só uma coisa de 24 horas. Emi tende a se recuperar rapidamente de resfriados e afins."

# game/script-a2-emi.rpy:8247
translate pt_br a2_emi_the_first_morning_after_bbd2932d:

    # hi "Hey, speaking of Emi…"
    hi "Ei, falando de Emi…"

# game/script-a2-emi.rpy:8249
translate pt_br a2_emi_the_first_morning_after_26326fe3:

    # hi "Are she and the track captain…? Well, you know."
    hi "Ela e o capitão da equipe são…? Bem, você sabe."

# game/script-a2-emi.rpy:8254
translate pt_br a2_emi_the_first_morning_after_29519868:

    # "A look of suspicion crosses his face."
    "Um olhar de suspeita cruza seu rosto."

# game/script-a2-emi.rpy:8256
translate pt_br a2_emi_the_first_morning_after_a79a8ca8:

    # nk "Why do you ask?"
    nk "Por que você pergunta?"

# game/script-a2-emi.rpy:8258
translate pt_br a2_emi_the_first_morning_after_da01a3dd:

    # hi "Well, it's just that they seem kind of close, and I was just curious, you know?"
    hi "Bem, é só que eles parecem próximos, e eu estava apenas curioso, sabe?"

# game/script-a2-emi.rpy:8260
translate pt_br a2_emi_the_first_morning_after_13c9d9c9:

    # hi "And I'd never ask her, because that would be kind of embarrassing."
    hi "E eu nunca perguntaria a ela, porque isso seria meio constrangedor."

# game/script-a2-emi.rpy:8262
translate pt_br a2_emi_the_first_morning_after_ca29d7af:

    # "So far, so good. Now to really sell it."
    "Até aqui tudo bem. Agora para convencê-lo totalmente."

# game/script-a2-emi.rpy:8264
translate pt_br a2_emi_the_first_morning_after_f980b75e:

    # hi "Besides, I think they'd make a cute couple."
    hi "Além disso, eu acho que eles fazem um belo casal."

# game/script-a2-emi.rpy:8269
translate pt_br a2_emi_the_first_morning_after_1a26db20_1:

    # "The nurse laughs."
    "O enfermeiro ri."

# game/script-a2-emi.rpy:8271
translate pt_br a2_emi_the_first_morning_after_32d5ab5c:

    # nk "Well, I don't suppose you're the first to think that."
    nk "Bem, eu não acho que você é o primeiro a pensar nisso."

# game/script-a2-emi.rpy:8273
translate pt_br a2_emi_the_first_morning_after_eca39a2f:

    # nk "But I think I can say with some certainty that the two of them will never do anything like that."
    nk "Mas eu acho que posso dizer com alguma certeza que os dois nunca farão algo do tipo."

# game/script-a2-emi.rpy:8275
translate pt_br a2_emi_the_first_morning_after_b870d7e4:

    # hi "Certainty?"
    hi "Certeza?"

# game/script-a2-emi.rpy:8280
translate pt_br a2_emi_the_first_morning_after_cdd7cf29:

    # nk "Yep."
    nk "Sim."

# game/script-a2-emi.rpy:8285
translate pt_br a2_emi_the_first_morning_after_e5c18736:

    # nk "Not that I could tell you, of course. Confidentiality and all that."
    nk "Não que eu possa lhe dizer, é claro. Confidencialidade e tudo isso."

# game/script-a2-emi.rpy:8287
translate pt_br a2_emi_the_first_morning_after_acf16eb4:

    # hi "Yeah right, you just like holding a secret over my head."
    hi "Sim certo, você apenas gosta de manter um segredo sobre a minha cabeça."

# game/script-a2-emi.rpy:8292
translate pt_br a2_emi_the_first_morning_after_d693f796:

    # nk "That too."
    nk "Isso também."

# game/script-a2-emi.rpy:8297
translate pt_br a2_emi_the_first_morning_after_52c9136e:

    # nk "Right. Get out of here. I'm a busy man, you know."
    nk "Certo. Saia daqui. Eu sou um homem ocupado, sabe."

# game/script-a2-emi.rpy:8305
translate pt_br a2_emi_the_first_morning_after_492d4fed:

    # "I roll my eyes at his last statement and head out the door, motioning to Emi to go in."
    "Eu reviro meus olhos para última declaração e ponho a cabeça para fora da porta, fazendo sinal para a Emi entrar."

# game/script-a2-emi.rpy:8315
translate pt_br a2_emi_the_first_morning_after_37df3339:

    # "The whole time, I'm trying to keep from doing a celebratory dance."
    "O tempo todo, eu tento evitar fazer uma dança comemorativa."

# game/script-a2-emi.rpy:8319
translate pt_br a2_emi_the_first_morning_after_a7994c62:

    # centered "The two of them will never do anything like that."
    centered "Os dois nunca farão nada disso."

# game/script-a2-emi.rpy:8321
translate pt_br a2_emi_the_first_morning_after_d9ef2e95:

    # "That's precisely the sort of thing I wanted to hear."
    "Isso é precisamente o tipo de coisa que eu queria ouvir."

# game/script-a2-emi.rpy:8323
translate pt_br a2_emi_the_first_morning_after_99d006a1:

    # "I'm half-tempted to make some sort of a move on Emi right now, but I think the nurse would probably disapprove."
    "Eu estou meio tentado a fazer alguma jogada com a Emi agora mesmo, mas acho que o enfermeiro provavelmente desaprovaria."

# game/script-a2-emi.rpy:8325
translate pt_br a2_emi_the_first_morning_after_62ad3107:

    # "Besides, I still don't know exactly how Emi feels about me."
    "Além disso, eu ainda não sei exatamente como a Emi se sente sobre mim."

# game/script-a2-emi.rpy:8327
translate pt_br a2_emi_the_first_morning_after_15dd6b0e:

    # "I mean it's obvious that she cares about me as a friend, but something more than that? I can't be certain."
    "Quero dizer, é óbvio que ela se preocupa comigo como um amigo, mas algo mais do que isso? Eu não posso ter certeza."

# game/script-a2-emi.rpy:8329
translate pt_br a2_emi_the_first_morning_after_b3408729:

    # "Even so, I can't help but feel hopeful. I just need to figure out a good time to tell Emi exactly how I feel."
    "Mesmo assim, eu não posso ajudar, mas me sinto esperançoso. Eu só preciso descobrir um bom momento para dizer à Emi exatamente como me sinto."

# game/script-a2-emi.rpy:8331
translate pt_br a2_emi_the_first_morning_after_e2685367:

    # "That puzzle should keep me occupied for the rest of the day, at least."
    "Esse quebra-cabeça deve manter-me ocupado o resto do dia, pelo menos."

# game/script-a2-emi.rpy:8347
translate pt_br a2_emi_the_real_beginning_6e340a55:

    # "The rooftop is completely deserted."
    "A cobertura esta completamente deserta."

# game/script-a2-emi.rpy:8349
translate pt_br a2_emi_the_real_beginning_f13dba25:

    # "Normally I could count on Rin to be up here before me, but she's strangely absent."
    "Normalmente eu poderia contar com a Rin para estar aqui em cima diante de mim, mas ela está estranhamente ausente."

# game/script-a2-emi.rpy:8351
translate pt_br a2_emi_the_real_beginning_8288ee4f:

    # "I wonder if she decided to accompany Emi to the cafeteria for once. That seems pretty unlikely, but it's all I can think of right now."
    "Eu me pergunto se ela decidiu acompanhar a Emi para o refeitório dessa vez. Isso parece bastante improvável, mas é tudo o que posso pensar agora."

# game/script-a2-emi.rpy:8353
translate pt_br a2_emi_the_real_beginning_0321709c:

    # "Part of me wants to go look for Rin, but a far larger part of me is too pleased with the way the sun feels on my skin to care."
    "Parte de mim quer ir ver a Rin, mas uma parte bem maior de mim esta muito satisfeita com a forma que sinto o sol na pele para se importar."

# game/script-a2-emi.rpy:8355
translate pt_br a2_emi_the_real_beginning_9a806d57:

    # "I pick idly at my lunch while I wait for Emi and Rin to show up."
    "Eu manuseio preguiçosamente meu almoço, enquanto espero a Emi e a Rin aparecerem."

# game/script-a2-emi.rpy:8357
translate pt_br a2_emi_the_real_beginning_baa07966:

    # "It does not take long for me to hear the sounds of someone coming up the stairs."
    "Não demorou muito para eu ouvir os sons de alguém subindo as escadas."

# game/script-a2-emi.rpy:8362
translate pt_br a2_emi_the_real_beginning_e0c4a103:

    # "I wait until the door begins to open before talking."
    "Eu espero até que a porta comece a se abrir antes de falar."

# game/script-a2-emi.rpy:8364
translate pt_br a2_emi_the_real_beginning_aebe48ce:

    # hi "Took you long enough."
    hi "Demoraram bastante tempo."

# game/script-a2-emi.rpy:8366
translate pt_br a2_emi_the_real_beginning_a140c53a:

    # hi "Keeping me waiting for you, honestly."
    hi "Me fazendo esperar por vocês, honestamente."

# game/script-a2-emi.rpy:8368
translate pt_br a2_emi_the_real_beginning_495af350:

    # hi "The two of you are…"
    hi "Vocês duas são…"

# game/script-a2-emi.rpy:8370
translate pt_br a2_emi_the_real_beginning_0f638bea:

    # hi "Huh?"
    hi "Hein?"

# game/script-a2-emi.rpy:8372
translate pt_br a2_emi_the_real_beginning_152ecc61:

    # "Well that's odd."
    "Bem, isso é estranho."

# game/script-a2-emi.rpy:8377
translate pt_br a2_emi_the_real_beginning_6cf48b0c:

    # "The only person standing in the doorway is Emi, who looks mildly confused."
    "A única pessoa parada na porta é a Emi, que parece levemente confusa."

# game/script-a2-emi.rpy:8379
translate pt_br a2_emi_the_real_beginning_d2f3f913:

    # emi "What do you mean, 'huh?'"
    emi "O que quer dizer, “hein?”"

# game/script-a2-emi.rpy:8384
translate pt_br a2_emi_the_real_beginning_dde4ed1b:

    # emi "It's me! You know, Emi! We run in the mornings."
    emi "Sou eu! Você sabe, Emi! Corremos nas manhãs."

# game/script-a2-emi.rpy:8386
translate pt_br a2_emi_the_real_beginning_081904b4:

    # "She grins, and I feel my heart jump slightly in my chest at the sight."
    "Ela sorri, e eu sinto meio coração saltar ligeiramente do meu peito com a visão."

# game/script-a2-emi.rpy:8388
translate pt_br a2_emi_the_real_beginning_594d3d53:

    # hi "Yes, I knew that. I'm just confused…"
    hi "Sim, eu sabia disso. Eu estou apenas confuso…"

# game/script-a2-emi.rpy:8390
translate pt_br a2_emi_the_real_beginning_17e7e47d:

    # hi "…Where's Rin?"
    hi "… Onde está a Rin?"

# game/script-a2-emi.rpy:8395
translate pt_br a2_emi_the_real_beginning_db0d141e:

    # "Emi's grin is replaced by a rather guilty-looking expression."
    "O sorriso da Emi é substituída por uma profunda expressão de culpa."

# game/script-a2-emi.rpy:8397
translate pt_br a2_emi_the_real_beginning_45f3b15b:

    # emi "Yeah, about that…"
    emi "Sim, sobre isso…"

# game/script-a2-emi.rpy:8399
translate pt_br a2_emi_the_real_beginning_98cb7fac:

    # emi "I kind of… sort of…"
    emi "Eu meio que… de algum modo…"

# game/script-a2-emi.rpy:8404
translate pt_br a2_emi_the_real_beginning_5b028538:

    # emi "Gavehermycold."
    emi "Passeimeuresfriadopraela."

# game/script-a2-emi.rpy:8409
translate pt_br a2_emi_the_real_beginning_69dad350:

    # hi "Oh dear."
    hi "Oh céus."

# game/script-a2-emi.rpy:8411
translate pt_br a2_emi_the_real_beginning_4ac4806e:

    # hi "Am I at risk too?"
    hi "Estou em risco também?"

# game/script-a2-emi.rpy:8413
translate pt_br a2_emi_the_real_beginning_687436d6:

    # "It would make sense, after all. Emi and I were in close contact the other day…"
    "Faria sentido, afinal. Emi e eu estávamos em estreito contato no outro dia…"

# game/script-a2-emi.rpy:8415
translate pt_br a2_emi_the_real_beginning_ab6ea233:

    # "So what did she and Rin do that got her ill?"
    "Então o que ela e a Rin fizeram para a Rin ter pego o resfriado dela?"

# game/script-a2-emi.rpy:8417
translate pt_br a2_emi_the_real_beginning_ce617998:

    # "…"
    "…"

# game/script-a2-emi.rpy:8419
translate pt_br a2_emi_the_real_beginning_e01c9f1c:

    # "Steady on, old lad. Don't go down that road."
    "Calma aí, rapaz. Não vá por esse caminho."

# game/script-a2-emi.rpy:8421
translate pt_br a2_emi_the_real_beginning_2c495eb8:

    # "Rin's just probably got a worse immune system than me."
    "Rin provavelmente só tem um sistema imunológico pior que o meu."

# game/script-a2-emi.rpy:8426
translate pt_br a2_emi_the_real_beginning_0f68be6f:

    # "Emi seems shocked by my comment, like she hadn't considered that before."
    "Emi parece surpresa com meu comentário, como se ela não tivesse considerado isso antes."

# game/script-a2-emi.rpy:8428
translate pt_br a2_emi_the_real_beginning_d927d398:

    # emi "I hope not!"
    emi "Espero que não!"

# game/script-a2-emi.rpy:8433
translate pt_br a2_emi_the_real_beginning_9223fbb0:

    # emi "I'll feel terrible if you get ill because of me, Hisao!"
    emi "Vou me sentir terrível se você ficar doente por minha causa, Hisao!"

# game/script-a2-emi.rpy:8435
translate pt_br a2_emi_the_real_beginning_34037d29:

    # hi "Oh man, I think I feel a fever coming on…"
    hi "Oh céus, eu acho que sinto a febre chegando."

# game/script-a2-emi.rpy:8440
translate pt_br a2_emi_the_real_beginning_7842db96:

    # "Emi looks horrified, and then quickly shifts into a more angry expression."
    "Emi olha horrorizada, e em seguida muda rapidamente para uma expressão mais irritada."

# game/script-a2-emi.rpy:8442
translate pt_br a2_emi_the_real_beginning_625a31b5:

    # emi "Hisao!"
    emi "Hisao!"

# game/script-a2-emi.rpy:8444
translate pt_br a2_emi_the_real_beginning_20e58e1d:

    # emi "You stop getting sick this instant!"
    emi "Pare de ficar doente neste instante!"

# game/script-a2-emi.rpy:8449
translate pt_br a2_emi_the_real_beginning_a3cf10e3:

    # emi "I won't have it!"
    emi "Eu não te permito!"

# game/script-a2-emi.rpy:8454
translate pt_br a2_emi_the_real_beginning_0678d4b7:

    # "Impulsively she seizes me by the collar."
    "Impulsivamente ela me agarra pelo colarinho."

# game/script-a2-emi.rpy:8456
translate pt_br a2_emi_the_real_beginning_613565fb:

    # emi "Are you listening to me, Hisao's immune system?"
    emi "Está me ouvindo, sistema imunológico do Hisao?"

# game/script-a2-emi.rpy:8461
translate pt_br a2_emi_the_real_beginning_d6bd6732:

    # emi "Get your ass in gear!"
    emi "Mova sua bunda e vá marchar!"

# game/script-a2-emi.rpy:8463
translate pt_br a2_emi_the_real_beginning_313d9758:

    # "I give a smart salute."
    "Eu dou uma saudação adequada."

# game/script-a2-emi.rpy:8465
translate pt_br a2_emi_the_real_beginning_988af9d3:

    # hi "Duly noted, ma'am."
    hi "Devidamente anotado, senhora."

# game/script-a2-emi.rpy:8470
translate pt_br a2_emi_the_real_beginning_d9b7b111:

    # "Emi steps back and nods, satisfied."
    "Emi caminha para trás e acena com a cabeça, satisfeita."

# game/script-a2-emi.rpy:8475
translate pt_br a2_emi_the_real_beginning_481d5cf5:

    # emi "Good."
    emi "Bom."

# game/script-a2-emi.rpy:8480
translate pt_br a2_emi_the_real_beginning_b02e5b6b:

    # emi "You are not allowed to miss any of our morning runs, after all."
    emi "Você não tem permissão para perder nenhuma das nossas corridas da manhã, afinal."

# game/script-a2-emi.rpy:8482
translate pt_br a2_emi_the_real_beginning_3c858fde:

    # hi "But you missed a morning run!"
    hi "Mas você perdeu uma corrida matinal!"

# game/script-a2-emi.rpy:8487
translate pt_br a2_emi_the_real_beginning_52214dcd:

    # "Emi crosses her arms and looks at me haughtily."
    "Emi cruza os braços e olha para mim com ar de superioridade."

# game/script-a2-emi.rpy:8489
translate pt_br a2_emi_the_real_beginning_13e22dbc:

    # emi "Yes, but that's a special case. It was me, and not you."
    emi "Sim, mas esse é um caso especial. Era eu, e não você."

# game/script-a2-emi.rpy:8491
translate pt_br a2_emi_the_real_beginning_e9014558:

    # hi "That's not an explanation at all."
    hi "Isso não é uma explicação de verdade."

# game/script-a2-emi.rpy:8496
translate pt_br a2_emi_the_real_beginning_40e49f4e:

    # "Emi looks flabbergasted."
    "Emi olha espantada."

# game/script-a2-emi.rpy:8498
translate pt_br a2_emi_the_real_beginning_445e5b0b:

    # emi "You're kidding, right?"
    emi "Está brincando, né?"

# game/script-a2-emi.rpy:8503
translate pt_br a2_emi_the_real_beginning_e3b26804:

    # emi "That explanation makes perfect sense!"
    emi "Esta explicação faz todo o sentido!"

# game/script-a2-emi.rpy:8505
translate pt_br a2_emi_the_real_beginning_ce4883ee:

    # hi "No it doesn't! It's a blatant double standard!"
    hi "Não, não tem! É um padrão duplo evidente!"

# game/script-a2-emi.rpy:8510
translate pt_br a2_emi_the_real_beginning_51cc3965:

    # emi "I don't see what that has to do with anything."
    emi "Eu não vejo o que isso tem a ver com algo."

# game/script-a2-emi.rpy:8512
translate pt_br a2_emi_the_real_beginning_b7e9e3ae:

    # hi "Oh, fine."
    hi "Oh, tudo bem."

# game/script-a2-emi.rpy:8517
translate pt_br a2_emi_the_real_beginning_dfde6cfd:

    # "Emi seems pleased by her victory."
    "Emi parece satisfeita pela sua vitória."

# game/script-a2-emi.rpy:8519
translate pt_br a2_emi_the_real_beginning_61e3ab34:

    # hi "Anyway, is Rin going to be okay? She's not terribly ill, right?"
    hi "De qualquer forma, a Rin vai ficar bem? Ela não está terrivelmente doente, certo?"

# game/script-a2-emi.rpy:8524
translate pt_br a2_emi_the_real_beginning_4a72a162:

    # "Emi shakes her head."
    "Emi balança a cabeça."

# game/script-a2-emi.rpy:8526
translate pt_br a2_emi_the_real_beginning_aaa41775:

    # emi "Nope! She'll be fine."
    emi "Não! Ela vai ficar bem."

# game/script-a2-emi.rpy:8531
translate pt_br a2_emi_the_real_beginning_57cde403:

    # emi "I got her some cold medicine that should help her."
    emi "Eu a consegui alguns remédios para resfriado que devem ajudá-la."

# game/script-a2-emi.rpy:8536
translate pt_br a2_emi_the_real_beginning_c37b266f:

    # emi "Although I probably should have made sure she didn't try to take them all at once…"
    emi "Embora eu provavelmente deveria ter me assegurado de que ela não tentasse tomar todos de uma vez."

# game/script-a2-emi.rpy:8541
translate pt_br a2_emi_the_real_beginning_a071b32c:

    # emi "She's done it before, you know."
    emi "Ela já fez isso antes, sabe."

# game/script-a2-emi.rpy:8543
translate pt_br a2_emi_the_real_beginning_ac073ff6:

    # "Somehow, I don't find this all that surprising."
    "De alguma forma, eu não acho isso tudo tão surpreendente."

# game/script-a2-emi.rpy:8545
translate pt_br a2_emi_the_real_beginning_24e238ce:

    # "I doubt Rin is one to pay attention to maximum dosages and such."
    "Duvido que a Rin esteja prestando atenção a dosagem máxima e tal."

# game/script-a2-emi.rpy:8547
translate pt_br a2_emi_the_real_beginning_7052ca65:

    # hi "You should probably check in on her later, then. Just to make sure."
    hi "Você provavelmente deve ir vê-la mais tarde, então. Só para ter certeza."

# game/script-a2-emi.rpy:8552
translate pt_br a2_emi_the_real_beginning_18357699:

    # "Emi shrugs."
    "Emi dá de ombros."

# game/script-a2-emi.rpy:8554
translate pt_br a2_emi_the_real_beginning_b12e3623:

    # emi "I'll stop by after practice. She'll be fine until then."
    emi "Eu vou visitá-la depois do treino. Ela vai ficar bem até lá."

# game/script-a2-emi.rpy:8556
translate pt_br a2_emi_the_real_beginning_e0c633f9:

    # "I nod, figuring that line of conversation is over."
    "Concordo balançando a cabeça, imaginando que esta linha de conversa acabou."

# game/script-a2-emi.rpy:8558
translate pt_br a2_emi_the_real_beginning_e9a5408a:

    # "The only problem is, I don't know what else to talk about."
    "O único problema é, eu não sei mais sobre o que falar."

# game/script-a2-emi.rpy:8560
translate pt_br a2_emi_the_real_beginning_c85221a4:

    # hi "So…"
    hi "Então…"

# game/script-a2-emi.rpy:8562
translate pt_br a2_emi_the_real_beginning_5571e34b:

    # hi "You got any more track meets coming up?"
    hi "Você tem mais alguma competição de atletismo chegando?"

# game/script-a2-emi.rpy:8564
translate pt_br a2_emi_the_real_beginning_76b2fe88:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:8568
translate pt_br a2_emi_the_real_beginning_c30402f9:

    # n "{vspace=240}This is a terribly roundabout way of trying to see if she's free on the weekend."
    n "{vspace=240}Esta é uma terrivel maneira de ver indiretamente se ela está livre no fim de semana."

# game/script-a2-emi.rpy:8570
translate pt_br a2_emi_the_real_beginning_1c09e001:

    # n "If she's free, then maybe I can ask her on a date or something."
    n "Se ela está livre, então talvez eu possa chamá-la para um encontro ou algo assim."

# game/script-a2-emi.rpy:8572
translate pt_br a2_emi_the_real_beginning_118492ef:

    # n "Well, assuming I can get myself to actually form the words."
    n "Bem, assumindo que eu consiga realmente formar as palavras."

# game/script-a2-emi.rpy:8574
translate pt_br a2_emi_the_real_beginning_76b2fe88_1:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:8581
translate pt_br a2_emi_the_real_beginning_4a72a162_1:

    # "Emi shakes her head."
    "Emi balança a cabeça."

# game/script-a2-emi.rpy:8586
translate pt_br a2_emi_the_real_beginning_bca31bf0:

    # emi "Nah, not for another couple weeks, I think. The season's winding down."
    emi "Nah, não por mais algumas semanas, eu acho. A temporada está terminada."

# game/script-a2-emi.rpy:8588
translate pt_br a2_emi_the_real_beginning_a13fdbb3:

    # "Oh yeah. I came in right in the middle of things, didn't I?"
    "Oh sim. Eu vim bem no meio de tudo, não é?"

# game/script-a2-emi.rpy:8590
translate pt_br a2_emi_the_real_beginning_fff3d03f:

    # "Does that mean exams are coming up soon? I should probably look into that."
    "Será que isso significa que as provas vão chegar em breve? Eu provavelmente deveria ver isso."

# game/script-a2-emi.rpy:8592
translate pt_br a2_emi_the_real_beginning_cbfa9324:

    # hi "What do you do on weekends if there's not a meet?"
    hi "O que você faz nos fins de semana se não houver uma competição?"

# game/script-a2-emi.rpy:8597
translate pt_br a2_emi_the_real_beginning_835bf36c:

    # "An eyebrow goes up, and Emi gets a teasing look on her face."
    "Uma sobrancelha sobe, e Emi fica com um olhar provocante no rosto."

# game/script-a2-emi.rpy:8599
translate pt_br a2_emi_the_real_beginning_a0a2897f:

    # emi "You're awfully inquisitive today, aren't you?"
    emi "Você está muito curioso hoje, não é?"

# game/script-a2-emi.rpy:8601
translate pt_br a2_emi_the_real_beginning_5f2fc6dd:

    # "I shrug and hope it looks casual."
    "Eu dou de ombros e espero que pareça casual."

# game/script-a2-emi.rpy:8603
translate pt_br a2_emi_the_real_beginning_65f35b77:

    # hi "Just making conversation."
    hi "Eu só estou tentando ter uma conversa."

# game/script-a2-emi.rpy:8605
translate pt_br a2_emi_the_real_beginning_720225d8:

    # hi "I don't know what it's like to be a track star, after all."
    hi "Eu não sei como é ser uma estrela de atletismo, afinal."

# game/script-a2-emi.rpy:8610
translate pt_br a2_emi_the_real_beginning_3e53c3a2:

    # emi "Pfft, flattery."
    emi "Pfft, bajulador."

# game/script-a2-emi.rpy:8612
translate pt_br a2_emi_the_real_beginning_383667f0:

    # "She waves a hand idly."
    "Ela acena com a mão preguiçosamente."

# game/script-a2-emi.rpy:8617
translate pt_br a2_emi_the_real_beginning_6ac4e003:

    # emi "I'm not actually that good, you know."
    emi "Eu não sou realmente tão boa, sabe."

# game/script-a2-emi.rpy:8622
translate pt_br a2_emi_the_real_beginning_f87f5aa8:

    # emi "You just so happened to see me on a good day, is all."
    emi "Só aconteceu de você me ver em um dia bom, é tudo."

# game/script-a2-emi.rpy:8624
translate pt_br a2_emi_the_real_beginning_421081cc:

    # hi "You liar."
    hi "Sua mentirosa."

# game/script-a2-emi.rpy:8631
translate pt_br a2_emi_the_real_beginning_93580cbd:

    # emi "Heh, yeah."
    emi "Heh, sim."

# game/script-a2-emi.rpy:8633
translate pt_br a2_emi_the_real_beginning_34bc13f2:

    # emi "But humility is the sign of a good athlete."
    emi "Mas a humildade é o sinal de um bom atleta."

# game/script-a2-emi.rpy:8638
translate pt_br a2_emi_the_real_beginning_505348ef:

    # emi "At least that's what my dad used to say."
    emi "Pelo menos é isso que o meu pai costumava dizer."

# game/script-a2-emi.rpy:8640
translate pt_br a2_emi_the_real_beginning_64306ac3:

    # "She shrugs and tries unsuccessfully to hide the rather troubled expression her face has taken on."
    "Ela encolhe os ombros e tenta, sem sucesso, esconder a expressão de preocupação que seu rosto assumiu."

# game/script-a2-emi.rpy:8642
translate pt_br a2_emi_the_real_beginning_3c29bccb:

    # hi "Hey, what's up? You seem bothered by something."
    hi "Ei, o que houve? Você parece incomodada por alguma coisa."

# game/script-a2-emi.rpy:8644
translate pt_br a2_emi_the_real_beginning_e4ffef01:

    # "Emi starts to deny it, then sighs in defeat."
    "Emi começa a negar, depois suspira derrotada."

# game/script-a2-emi.rpy:8646
translate pt_br a2_emi_the_real_beginning_689edcd1:

    # "I wonder if she's too tired from being sick to get herself to deny it like usual."
    "Eu me pergunto se ela está cansada demais de estar doente para obrigar-se a negar, como de costume."

# game/script-a2-emi.rpy:8648
translate pt_br a2_emi_the_real_beginning_6c2cbdc0:

    # "Or if she actually just trusts me enough at this point to open up."
    "Ou se ela realmente só confia em mim o suficiente, a ponto de abrir."

# game/script-a2-emi.rpy:8655
translate pt_br a2_emi_the_real_beginning_224f6158:

    # emi "Well, you remember last night?"
    emi "Bem, você se lembra da noite passada?"

# game/script-a2-emi.rpy:8657
translate pt_br a2_emi_the_real_beginning_7eca3316:

    # "Do I ever. I settle for nodding, however."
    "Como eu não poderia. Decido acenar com a cabeça, de qualquer forma."

# game/script-a2-emi.rpy:8662
translate pt_br a2_emi_the_real_beginning_3de01983:

    # emi "That's not the first time that's happened to me."
    emi "Essa não é a primeira vez que isso aconteceu comigo."

# game/script-a2-emi.rpy:8664
translate pt_br a2_emi_the_real_beginning_bb0aa483:

    # emi "Actually, I get them kind of…"
    emi "Na verdade, isso me acontece…"

# game/script-a2-emi.rpy:8666
translate pt_br a2_emi_the_real_beginning_970a5952:

    # "She pauses, as if it's suddenly occurred to her what she's doing."
    "Ela faz uma pausa, como se de repente percebesse o que ela está fazendo."

# game/script-a2-emi.rpy:8668
translate pt_br a2_emi_the_real_beginning_f8b2a211:

    # "It's almost like she's breaking some sort of personal rule, here."
    "É quase como se ela estivesse quebrando algum tipo de regra pessoal aqui."

# game/script-a2-emi.rpy:8670
translate pt_br a2_emi_the_real_beginning_fdcf526c:

    # "But she starts up again, choosing her words carefully."
    "Mas ela começa novamente, escolhendo as palavras com cuidado."

# game/script-a2-emi.rpy:8672
translate pt_br a2_emi_the_real_beginning_392dbd4a:

    # emi "Well, not often, but…"
    emi "Bem, não muitas vezes, mas…"

# game/script-a2-emi.rpy:8677
translate pt_br a2_emi_the_real_beginning_918c16a5:

    # emi "On occasion."
    emi "Em ocasião."

# game/script-a2-emi.rpy:8679
translate pt_br a2_emi_the_real_beginning_f0048e4e:

    # emi "It's just been one of those weeks where that's what happens."
    emi "Tem sido uma daquelas semanas em que isso acontece."

# game/script-a2-emi.rpy:8684
translate pt_br a2_emi_the_real_beginning_17a4af8c:

    # "A sigh escapes her, and she looks terribly frustrated."
    "Um suspiro escapa, e ela parece terrivelmente frustrada."

# game/script-a2-emi.rpy:8689
translate pt_br a2_emi_the_real_beginning_60cdedc7:

    # "I reach over and give her a hug, which unlike last time doesn't seem to shock her."
    "Me aproximo e lhe dou um abraço, que ao contrário da última vez não parece chocá-la."

# game/script-a2-emi.rpy:8691
translate pt_br a2_emi_the_real_beginning_ce0cc822:

    # "Instead, she seems to relax as my arms wrap around her."
    "Em vez disso, ela parece relaxar como meus braços a envolvendo."

# game/script-a2-emi.rpy:8693
translate pt_br a2_emi_the_real_beginning_2d909687:

    # "We stay that way for a while."
    "Permanecemos assim por um tempo."

# game/script-a2-emi.rpy:8695
translate pt_br a2_emi_the_real_beginning_a8a74faf:

    # hi "Hey, you know I was serious last night."
    hi "Ei, você sabe que eu estava falando sério ontem à noite."

# game/script-a2-emi.rpy:8697
translate pt_br a2_emi_the_real_beginning_a59dcbb0:

    # hi "You really can talk to me if stuff like this is bothering you. It's always difficult to do this sort of thing solo, you know?"
    hi "Você realmente pode falar comigo se esse tipo de coisa estiver a incomodando. É sempre difícil enfrentar esse tipo de coisa sozinha, sabe?"

# game/script-a2-emi.rpy:8702
translate pt_br a2_emi_the_real_beginning_42f3d54b:

    # "Emi smiles and breaks the embrace, but stays leaning on my shoulder."
    "Emi sorri e quebra o abraço, mas permanece apoiada no meu ombro."

# game/script-a2-emi.rpy:8704
translate pt_br a2_emi_the_real_beginning_eca1f13a:

    # emi "Thanks, Hisao."
    emi "Obrigada, Hisao."

# game/script-a2-emi.rpy:8709
translate pt_br a2_emi_the_real_beginning_6d58e409:

    # emi "I'll be fine, I think."
    emi "Eu vou ficar bem, acho."

# game/script-a2-emi.rpy:8711
translate pt_br a2_emi_the_real_beginning_7b15c247:

    # "I can already see her reassembling herself, getting ready to bottle it all up again."
    "Já posso vê-la se recuperando, pronta para engarrafar tudo de novo."

# game/script-a2-emi.rpy:8713
translate pt_br a2_emi_the_real_beginning_a332e480:

    # "Guess that topic's closed, now."
    "Acho que esse tópico está fechado agora."

# game/script-a2-emi.rpy:8715
translate pt_br a2_emi_the_real_beginning_0f92ac4c:

    # hi "So hey, given any more thought to that career survey?"
    hi "Então, refletiu sobre o questionário de orientação profissional?"

# game/script-a2-emi.rpy:8720
translate pt_br a2_emi_the_real_beginning_4b13de8d:

    # emi "Can't say I have."
    emi "Não posso dizer que sim."

# game/script-a2-emi.rpy:8725
translate pt_br a2_emi_the_real_beginning_bc1ff5a6:

    # emi "I don't tend to plan very far ahead, you know."
    emi "Eu não tendo a planejar muito à frente, sabe."

# game/script-a2-emi.rpy:8727
translate pt_br a2_emi_the_real_beginning_e7189cb1:

    # emi "Although I suppose I could at least start looking into college, huh?"
    emi "Embora eu suponha que eu poderia, pelo menos, começar a olhar para a faculdade, não?"

# game/script-a2-emi.rpy:8729
translate pt_br a2_emi_the_real_beginning_8619f2c6:

    # "I shrug."
    "Eu dou de ombros."

# game/script-a2-emi.rpy:8731
translate pt_br a2_emi_the_real_beginning_2e7845e3:

    # hi "I suppose, unless you were serious about that pirate thing."
    hi "Eu suponho, a menos que você falasse sério sobre essa coisa de pirata."

# game/script-a2-emi.rpy:8733
translate pt_br a2_emi_the_real_beginning_69f40f36:

    # hi "Last I checked, pirates didn't have much need for universities."
    hi "A última vez que verifiquei, os piratas não tem muita necessidade de universidades."

# game/script-a2-emi.rpy:8735
translate pt_br a2_emi_the_real_beginning_b93d8c8c:

    # hi "Unless there's like, a pirate university out there somewhere."
    hi "A menos que haja, tipo, uma universidade pirata lá fora em algum lugar."

# game/script-a2-emi.rpy:8740
translate pt_br a2_emi_the_real_beginning_3673e1bc:

    # "Emi giggles and starts to look a little like her old self, but there's a new element to her expression."
    "Emi dá uma risadinha e começa a olhar um pouco como seu antigo eu, mas há um novo elemento em sua expressão."

# game/script-a2-emi.rpy:8742
translate pt_br a2_emi_the_real_beginning_3496f456:

    # "Impish. That's how I'd describe it."
    "Maliciosa. É assim como eu descreveria."

# game/script-a2-emi.rpy:8744
translate pt_br a2_emi_the_real_beginning_3002ae83:

    # "Emi looks impish, looking up at me with her head nestled into my shoulder."
    "Emi parece maliciosa, olhando para mim com a cabeça situada no meu ombro."

# game/script-a2-emi.rpy:8749
translate pt_br a2_emi_the_real_beginning_a0577eed:

    # emi "Would you come with me if I ran off to be a pirate?"
    emi "Você viria comigo se eu decidisse ser uma pirata?"

# game/script-a2-emi.rpy:8751
translate pt_br a2_emi_the_real_beginning_07cd2414:

    # hi "Of course I would!"
    hi "Claro que sim!"

# game/script-a2-emi.rpy:8753
translate pt_br a2_emi_the_real_beginning_455005ae:

    # hi "Who in their right mind would pass up the opportunity to be pirates with you?"
    hi "Quem no seu perfeito juízo iria deixar passar a oportunidade de ser um pirata com você?"

# game/script-a2-emi.rpy:8758
translate pt_br a2_emi_the_real_beginning_13e5ae4a:

    # emi "Well, when you put it that way, I'm not sure."
    emi "Bem, quando você coloca dessa forma, eu não tenho certeza."

# game/script-a2-emi.rpy:8763
translate pt_br a2_emi_the_real_beginning_5b24fe21:

    # "She giggles again."
    "Ela ri novamente."

# game/script-a2-emi.rpy:8765
translate pt_br a2_emi_the_real_beginning_7bdfbbe9:

    # "I notice that my heart seems to have sped up. It's probably due to Emi's proximity to me."
    "Eu noto que o meu coração parece ter acelerado. É provavelmente devido à proximidade da Emi."

# game/script-a2-emi.rpy:8767
translate pt_br a2_emi_the_real_beginning_cf6745b2:

    # "That hint of strawberries, again."
    "Esse toque de morangos, de novo."

# game/script-a2-emi.rpy:8769
translate pt_br a2_emi_the_real_beginning_d341cbff:

    # "I can't help but grin as I gaze down at her."
    "Eu não posso deixar de sorrir quando olho para ela."

# game/script-a2-emi.rpy:8771
translate pt_br a2_emi_the_real_beginning_e1bc3de8:

    # "She's happy again."
    "Ela está feliz novamente."

# game/script-a2-emi.rpy:8776
translate pt_br a2_emi_the_real_beginning_963cdfac:

    # emi "Hey, Hisao."
    emi "Ei, Hisao."

# game/script-a2-emi.rpy:8778
translate pt_br a2_emi_the_real_beginning_34d1d59d:

    # hi "Hmm?"
    hi "Hmm?"

# game/script-a2-emi.rpy:8783
translate pt_br a2_emi_the_real_beginning_ad59654f:

    # emi "If you're going to kiss me, you should probably do it soon. I think the lunch bell is about to ring."
    emi "Se você vai me beijar, você provavelmente deve ir logo. Eu acho que o sinal do almoço está prestes a tocar."

# game/script-a2-emi.rpy:8787
translate pt_br a2_emi_the_real_beginning_97e5273b:

    # "My thoughts grind to a sudden halt."
    "Meus pensamentos são pressionados a uma parada súbita."

# game/script-a2-emi.rpy:8789
translate pt_br a2_emi_the_real_beginning_9a6f8888:

    # "I'm pretty sure my mouth is hanging open in shock."
    "Tenho certeza de que a minha boca está entreaberta em estado de choque."

# game/script-a2-emi.rpy:8791
translate pt_br a2_emi_the_real_beginning_249eac34:

    # "All I can manage is a strangled 'Huh?'"
    "Tudo o que posso dizer é um sufocado “Quê?”"

# game/script-a2-emi.rpy:8796
translate pt_br a2_emi_the_real_beginning_9238e6fc:

    # "This amuses Emi even more."
    "Isso diverte a Emi ainda mais."

# game/script-a2-emi.rpy:8801
translate pt_br a2_emi_the_real_beginning_e5fa778c:

    # emi "You were thinking about it, weren't you?"
    emi "Você estava pensando sobre isso, não estava?"

# game/script-a2-emi.rpy:8803
translate pt_br a2_emi_the_real_beginning_55c427db:

    # "She sits up, bringing her face level with mine."
    "Ela se endireita, trazendo o seu rosto a mesma altura que o meu."

# game/script-a2-emi.rpy:8808
translate pt_br a2_emi_the_real_beginning_ddb4ebba:

    # emi "I'd probably enjoy it, you know?"
    emi "Eu provavelmente apreciaria, sabe?"

# game/script-a2-emi.rpy:8813
translate pt_br a2_emi_the_real_beginning_4e42e3f8:

    # emi "You're a really…"
    emi "Você é realmente um…"

# game/script-a2-emi.rpy:8818
translate pt_br a2_emi_the_real_beginning_418e89a9:

    # emi "…Well."
    emi "…Bem."

# game/script-a2-emi.rpy:8820
translate pt_br a2_emi_the_real_beginning_054a530f:

    # "She briefly composes herself, looking like she's about to say something important."
    "Ela compõe-se brevemente, parecendo que está prestes a dizer algo importante."

# game/script-a2-emi.rpy:8825
translate pt_br a2_emi_the_real_beginning_98512793:

    # emi "If you hadn't figured it out by now, I think I've developed a bit of a crush on you."
    emi "Se ainda não percebeu, eu acho que desenvolvi uma pequena queda por você."

# game/script-a2-emi.rpy:8830
translate pt_br a2_emi_the_real_beginning_6bb86586:

    # emi "You're going to have to do something about that."
    emi "Vai ter que fazer algo a respeito disso."

# game/script-a2-emi.rpy:8832
translate pt_br a2_emi_the_real_beginning_0cfa493e:

    # "This time her grin short circuits several important thought processes."
    "Desta vez, seu sorriso provoca curtos-circuitos em vários processos importantes do meu cérebro."

# game/script-a2-emi.rpy:8834
translate pt_br a2_emi_the_real_beginning_ec9f2809:

    # "At some point I turned toward her, and at another point her arms moved to around my neck."
    "Em algum momento eu me virei para ela, e em outro instante seus braços moveram-se ao redor do meu pescoço."

# game/script-a2-emi.rpy:8836
translate pt_br a2_emi_the_real_beginning_c8ff836c:

    # "At yet another, my arms wrapped around her waist."
    "Em outro ainda, meus braços se agararram em volta de sua cintura."

# game/script-a2-emi.rpy:8838
translate pt_br a2_emi_the_real_beginning_c5adc0aa:

    # "I'll be damned if I could tell precisely when that happened."
    "Eu estaria mentindo se pudesse dizer precisamente quando isso aconteceu."

# game/script-a2-emi.rpy:8840
translate pt_br a2_emi_the_real_beginning_9e2dd8e7:

    # "Because at the moment, there's only a voice in the back of my head yelling at me to kiss her."
    "Porque no momento, há apenas uma voz no fundo da minha cabeça gritando comigo para beijá-la."

# game/script-a2-emi.rpy:8842
translate pt_br a2_emi_the_real_beginning_5d0ea276:

    # "I look into Emi's eyes."
    "Eu olho nos olhos da Emi."

# game/script-a2-emi.rpy:8844
translate pt_br a2_emi_the_real_beginning_993bef03:

    # "There it is."
    "Aqui está."

# game/script-a2-emi.rpy:8846
translate pt_br a2_emi_the_real_beginning_98562970:

    # "The thing I saw yesterday on the bed. It's there again."
    "O que eu vi ontem na cama. Está lá novamente."

# game/script-a2-emi.rpy:8848
translate pt_br a2_emi_the_real_beginning_984cb1f2:

    # "It suddenly strikes me that she's worried that I'll reject her."
    "De repente, me parece que ela está preocupada em se eu vou rejeitá-la."

# game/script-a2-emi.rpy:8852
translate pt_br a2_emi_the_real_beginning_47dac5af:

    # "What a silly worry for her to have."
    "Que preocupação tola para ela ter."

# game/script-a2-emi.rpy:8867
translate pt_br a2_emi_the_real_beginning_76b2fe88_2:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:8870
translate pt_br a2_emi_the_real_beginning_046f7ee3:

    # n "{vspace=120}Her lips taste faintly of strawberries."
    n "{vspace=120}Seus lábios tem um leve sabor de morangos."

# game/script-a2-emi.rpy:8872
translate pt_br a2_emi_the_real_beginning_213544e2:

    # n "She leans into the kiss, and her arms tighten around the back of my head, making sure that I don't pull away."
    n "Ela se inclina, e aperta os braços em torno do meu pescoço, certificando-se de que eu não vá me afastar."

# game/script-a2-emi.rpy:8874
translate pt_br a2_emi_the_real_beginning_4e41d44e:

    # n "Not that there was any danger of that."
    n "Não que houvesse qualquer perigo disso."

# game/script-a2-emi.rpy:8876
translate pt_br a2_emi_the_real_beginning_7451043b:

    # n "There's a churning feeling in my gut."
    n "Há um sentimento de agitação nas minhas entranhas."

# game/script-a2-emi.rpy:8878
translate pt_br a2_emi_the_real_beginning_a4b33ca9:

    # n "The world falls away."
    n "O mundo desmorona."

# game/script-a2-emi.rpy:8880
translate pt_br a2_emi_the_real_beginning_969c8008:

    # n "There's just me, and her, and this bench."
    n "Somos só apenas eu, ela, e este banco."

# game/script-a2-emi.rpy:8882
translate pt_br a2_emi_the_real_beginning_8b59709b:

    # n "My arms tighten, drawing her waist closer, entranced by the feel of her."
    n "Meus braços apertam, trazendo sua cintura mais perto, encantado por sentí-la."

# game/script-a2-emi.rpy:8884
translate pt_br a2_emi_the_real_beginning_fd6b90bf:

    # n "I inhale her scent, my mind trying desperately to memorize everything about how she tastes, how she smells, how she feels."
    
    n "Eu inalo seu aroma, a minha mente tentando desesperadamente memorizar tudo sobre ela, seu gosto, como ela cheira, como ela se sente."

# game/script-a2-emi.rpy:8889
translate pt_br a2_emi_the_real_beginning_76b2fe88_3:

    # nvl clear
    nvl clear

# game/script-a2-emi.rpy:8900
translate pt_br a2_emi_the_real_beginning_656d65f8:

    # "The ringing of the bell snaps us both back to reality, and we break the kiss."
    "O toque do sinal nos leva de volta à realidade, e nós quebramos o beijo."

# game/script-a2-emi.rpy:8902
translate pt_br a2_emi_the_real_beginning_19e5aa47:

    # "Emi's cheeks are slightly flushed, and she seems to be catching her breath. In her defense, so am I."
    "As bochechas da Emi estão ligeiramente coradas, e ela parece estar recuperando o fôlego. Em sua defesa, eu também estou."

# game/script-a2-emi.rpy:8904
translate pt_br a2_emi_the_real_beginning_53718fa5:

    # "We stand there for a few moments, trying to wrap our heads around what we've just done."
    "Ficamos ali por alguns instantes, nossas cabeças tentando entender o que acabamos de fazer."

# game/script-a2-emi.rpy:8906
translate pt_br a2_emi_the_real_beginning_69e6ad1a:

    # "Emi is the first to break the silence."
    "Emi é a primeira a quebrar o silêncio."

# game/script-a2-emi.rpy:8912
translate pt_br a2_emi_the_real_beginning_c91b29de:

    # emi "So…"
    emi "Então…"

# game/script-a2-emi.rpy:8917
translate pt_br a2_emi_the_real_beginning_f8a6e88c:

    # emi "…Wanna grab dinner after I'm done with practice?"
    emi "…Você quer comer alguma coisa depois que eu terminar o treino?"

# game/script-a2-emi.rpy:8919
translate pt_br a2_emi_the_real_beginning_f4eea275:

    # hi "What a coincidence."
    hi "Que coincidência."

# game/script-a2-emi.rpy:8921
translate pt_br a2_emi_the_real_beginning_40962c5f:

    # hi "I was about to ask you the same thing."
    
    hi "Eu estava prestes a perguntar a mesma coisa."

# game/script-a2-emi.rpy:8923
translate pt_br a2_emi_the_real_beginning_58b78ce4:

    # "Well, actually I suppose it was going to be some kind of proper date on the weekend or something. But the thought was there, I think."
    
    "Bem, na verdade eu achava que ia ser algum tipo de data adequada no fim de semana ou algo assim. Mas o pensamento estava lá, eu acho."

# game/script-a2-emi.rpy:8927
translate pt_br a2_emi_the_real_beginning_16c298bf:

    # "Emi gives me a playful shove."
    "Emi me dá um empurrão brincalhão."

# game/script-a2-emi.rpy:8932
translate pt_br a2_emi_the_real_beginning_363354e0:

    # emi "Yeah right."
    emi "Tá bem, certo."

# game/script-a2-emi.rpy:8937
translate pt_br a2_emi_the_real_beginning_43220c8d:

    # emi "You were still in shock from how incredibly awesome I am at kissing."
    emi "Você ainda estava em estado de choque do quão incrivelmente boa eu sou beijando."

# game/script-a2-emi.rpy:8939
translate pt_br a2_emi_the_real_beginning_88c72d98:

    # "We begin to head down the stairs back to our respective classrooms."
    "Começamos a descer as escadas de volta para nossas respectivas salas de aula."

# game/script-a2-emi.rpy:8947
translate pt_br a2_emi_the_real_beginning_02a54b10:

    # hi "Hey, I didn't see you talking immediately afterwards either."
    hi "Ei, eu também não vi você falando imediatamente depois."

# game/script-a2-emi.rpy:8952
translate pt_br a2_emi_the_real_beginning_bb9a36c7:

    # emi "That I didn't."
    
    emi "Verdade."

# game/script-a2-emi.rpy:8957
translate pt_br a2_emi_the_real_beginning_ac33b63d:

    # emi "See you after practice, Hisao."
    emi "Vejo você depois do treino, Hisao."

# game/script-a2-emi.rpy:8965
translate pt_br a2_emi_the_real_beginning_2b33c9de:

    # "She leans in quickly and gives me a quick kiss in the middle of the hallway, sending me into another brief state of mental freefall."
    "Ela se inclina rapidamente e me dá um beijo rápido no meio do corredor, enviando-me em outro breve estado de queda livre mental."

# game/script-a2-emi.rpy:8970
translate pt_br a2_emi_the_real_beginning_03ab9b36:

    # "As I head into my classroom, a giggling Misha greets me."
    
    "Enquanto me dirijo à minha sala, uma risonha Misha me cumprimenta."

# game/script-a2-emi.rpy:8975
translate pt_br a2_emi_the_real_beginning_29e08af9:

    # mi "Why Hicchan, you romantic, you~!"
    mi "Ora ora Hisaozinho, seu romântico~!"

# game/script-a2-emi.rpy:8977
translate pt_br a2_emi_the_real_beginning_da258309:

    # mi "Did you confess on the rooftop? Did you~?"
    mi "Você se confessou na cobertura? Confessou~?"

# game/script-a2-emi.rpy:8979
translate pt_br a2_emi_the_real_beginning_f818e814:

    # hi "Er, actually I think it was the other way around."
    hi "Er, na verdade eu acho que foi o contrário."

# game/script-a2-emi.rpy:8984
translate pt_br a2_emi_the_real_beginning_32a9e29d:

    # "This sends Misha into a fresh fit of laughter."
    "Isso envia a Misha um novo ataque de risos."

# game/script-a2-emi.rpy:8989
translate pt_br a2_emi_the_real_beginning_c45572a6:

    # mi "Young love is so unpredictable, isn't it~?"
    mi "O amor jovem é tão imprevisível, não é~?"

# game/script-a2-emi.rpy:8991
translate pt_br a2_emi_the_real_beginning_c64708e2:

    # "This being Misha, I suppose I should have expected her to tease me over this."
    "Sendo a Misha, eu suponho que deveria ter esperado que ela me provocasse por isso."

# game/script-a2-emi.rpy:8993
translate pt_br a2_emi_the_real_beginning_82ae3054:

    # hi "I guess…"
    hi "Eu acho…"

# game/script-a2-emi.rpy:8998
translate pt_br a2_emi_the_real_beginning_4a007376:

    # "Before I can really respond, Mutou's entered the room and Misha skips off to her seat, giggling all the while."
    "Antes que eu possa realmente responder, Mutou entra na sala e a Misha salta para seu assento, rindo o tempo todo."

# game/script-a2-emi.rpy:9000
translate pt_br a2_emi_the_real_beginning_3800286d:

    # "I suspect that I'll get a lot of that sort of conversation now, especially seeing as how Emi kissed me right in the middle of the hall."
    "Eu suspeito que eu vou ter um monte de conversas desse tipo agora, especialmente levando em conta como a Emi me beijou no meio do salão."

# game/script-a2-emi.rpy:9002
translate pt_br a2_emi_the_real_beginning_b90f4089:

    # "But somehow, I don't care about that."
    "Mas de alguma forma, eu não me importo com isso."

# game/script-a2-emi.rpy:9007
translate pt_br a2_emi_the_real_beginning_5de3dbed:

    # "For the first time since arriving here, my heart feels light."
    "Pela primeira vez desde que cheguei aqui, meu coração se sente leve."

# game/script-a2-emi.rpy:9015
translate pt_br a2ec1o1_74623df0:

    # hi "Hey, I'll run with you."
    hi "Ei, eu vou correr com você."

# game/script-a2-emi.rpy:9017
translate pt_br a2ec1o1_68af942e:

    # hi "I might as well, right?"
    hi "Eu posso também, certo?"

# game/script-a2-emi.rpy:9022
translate pt_br a2ec1o1_54271c6d:

    # "Emi shakes her head emphatically."
    "Emi sacode a cabeça enfaticamente."

# game/script-a2-emi.rpy:9024
translate pt_br a2ec1o1_a659f4c0:

    # emi "No you won't, Hisao. Rest is critical for you, remember?"
    emi "Não, você não pode, Hisao. Descansar é criticamente importante pra você, lembra?"

# game/script-a2-emi.rpy:9026
translate pt_br a2ec1o1_468f56f4:

    # emi "I won't allow you to push yourself too hard."
    emi "Não vou te deixar se esforçar tanto."

# game/script-a2-emi.rpy:9028
translate pt_br a2ec1o1_74e43e5b:

    # "I guess she's better at giving advice than taking it."
    "Eu acho que ela é melhor dando um conselho do que seguindo um."

# game/script-a2-emi.rpy:9030
translate pt_br a2ec1o1_ed8f73af:

    # hi "Whatever you say, Emi."
    hi "Como quiser, Emi."

# game/script-a2-emi.rpy:9032
translate pt_br a2ec1o1_39e12092:

    # "I think it's probably best not to press the issue."
    "Eu acho que o melhor é não insistir no assunto."

# game/script-a2-emi.rpy:9037
translate pt_br a2ec1o2_f0a64c37:

    # "Come to think of it, she looks like she'd rather be alone right now."
    "Parando para pensar, parece que ela estaria melhor sozinha agora."

# game/script-a2-emi.rpy:9039
translate pt_br a2ec1o2_b0a5e746:

    # "I decide to keep my offer to myself."
    "Eu decido guardar minha oferta para mim."

translate pt_br strings:

    # game/script-a2-emi.rpy:5044
    old "Dear Hisao,\n\nHow are you? I hope you are well and happy at your new school. Everyone here misses you. Almost all of our second-year class got put together in class 3-1 for the final year, so we are pretty comfortable right from the beginning of the year. I'm sure you would've been assigned to this class as well."
    new "Querido Hisao,\n\nComo vai você? Eu espero que você esteja bem e feliz em sua nova escola.Todos aqui sentem saudades de você. Quase toda a nossa classe do segundo ano ficou junta na sala 3-1 para o ano final, então estamos bastante confortáveis desde o início do ano. Eu tenho certeza que você também seria dessa classe."

    # game/script-a2-emi.rpy:5046
    old "The mood among the third-years seems to be very anxious about the final exams, even though they are so far away. The teachers are badgering us about it all the time - even old Mr. Tachibana who is, by the way, our homeroom teacher this year. Would you believe it? I was sure that he'd retire after our second year, but here he is, nagging everyone about studying for exams.{vspace=30}"
    new "O clima entre os alunos do terceiro ano é de ansiedade para as provas finais, mesmo que eles estejam tão longe. Os professores estão nos alertando sobre isso o tempo todo - até o velho Sr.Tachibana que é, por falar nisso, nosso orientador. Você consegue acreditar nisso? eu achei que ele se aposentaria após nosso segundo ano, mas aqui está ele, pegando no pé de todo mundo pra estudar para as provas.{vspace=30}"

    # game/script-a2-emi.rpy:5048
    old "I think things like that are the main reason why the mood among the third-years is so nervous. I must admit that I'm somehow losing confidence in myself as well, even though I've always fared reasonably well in exams.{vspace=150}"
    new "Eu acho que coisas assim são a causa do clima entre os alunos do terceiro ano ser tão nervoso. Tenho que admitir que estou perdendo confiança em mim mesma também, mesmo que eu sempre tenha ido bem em provas.{vspace=150}"

    # game/script-a2-emi.rpy:5050
    old "It's so weird to think we are already seniors, isn't it? Time has really flown past. I wonder where it went. The new first-years seem so young and somehow really innocent. I keep wondering if I was like them in my first year. I've been feeling nostalgic like this for the whole first trimester.{vspace=90}"
    new "É estranho pensar que já somos veteranos, o tempo passou tão rápido. Me pergunto pra onde ele foi. Os novos alunos do primeiro ano parecem tão jovens e de algum jeito realmente inocentes. Eu fico me perguntando se eu era assim no meu primeiro ano. Me senti nostálgica assim por todo o primeiro trimestre.{vspace=90}"

    # game/script-a2-emi.rpy:5052
    old "There are other things I want to say. I'm writing to you because I felt that there are things I should've said after the incident back in winter. I really regret that I wasn't able to say them in person, and I have no excuse for it…{vspace=150}"
    new "Tem outras coisas que eu quero dizer. Estou escrevendo pra você porque eu senti que há coisas que eu deveria ter dito depois do incidente no inverno. Eu lamento não poder ter dito em pessoa, e não tenho desculpa por isso… {vspace=150}"

    # game/script-a2-emi.rpy:5987
    old "What?"
    new "Que?"

    # game/script-a2-emi.rpy:5987
    old "Huh?"
    new "Huh?"

    # game/script-a2-emi.rpy:6154
    old "Still, I feel like I should at least offer to run with her…"
    new "Mesmo assim, eu sinto que deveria ao menos me oferecer para correr com ela."

    # game/script-a2-emi.rpy:6154
    old "Offer to run with Emi."
    new "Se oferecer pra correr com a Emi."

    # game/script-a2-emi.rpy:6154
    old "Keep quiet."
    new  "Ficar quieto."


