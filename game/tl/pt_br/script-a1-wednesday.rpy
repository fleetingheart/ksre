    # game/script-a1-wednesday.rpy:212
    old "What to do…"
    new "O que fazer…"

    # game/script-a1-wednesday.rpy:212
    old "Read my book."
    new "Ler meu livro."

    # game/script-a1-wednesday.rpy:212
    old "Go talk with Hanako."
    new  "Ir falar com a Hanako."

    # game/script-a1-wednesday.rpy:212
