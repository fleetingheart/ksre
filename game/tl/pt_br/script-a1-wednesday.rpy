# game/script-a1-wednesday.rpy:374
translate pt_br a1_wednesday_short_sharp_shock_b1238c83:

    # "I wouldn't call that great, but I let it slide this one time."
    "Eu não diria que isso é ótimo, mas vou deixar isso passar mais uma vez."

# game/script-a1-wednesday.rpy:382
